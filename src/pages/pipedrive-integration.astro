---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const crm = "Pipedrive";
const slug = "pipedrive-integration";

const seo = {
  title: `LimeCall + Pipedrive Integration | LimeCall`,
  description: `Connect LimeCall callback software to Pipedrive in 5 minutes. Auto-create Persons and Deals, log calls to deal timelines, and update stages on call outcome.`,
  canonical: `https://www.limecall.com/pipedrive-integration/`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall integrate with Pipedrive?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall connects to Pipedrive via a native OAuth integration. Once authorised from your LimeCall dashboard, every callback automatically creates or updates a Person and Deal in Pipedrive, and logs a Call Activity in the deal timeline — no Zapier or code required.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall create Pipedrive Persons and Deals automatically?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. When a visitor requests a callback, LimeCall searches Pipedrive for a matching Person by phone number or email. If no match is found, LimeCall creates a new Person and an associated Deal in your chosen pipeline and stage. If the Person already exists, LimeCall logs the activity against the existing record.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall update the Pipedrive deal stage based on call outcome?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. You can configure LimeCall to map call outcomes — such as "Demo booked", "Not interested", or "Follow-up required" — to Pipedrive deal stage changes. This means your pipeline progresses automatically based on real call results without any manual rep input.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall sync contact data bidirectionally with Pipedrive?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall supports bidirectional sync with Pipedrive. Contact updates in Pipedrive — such as a rep adding an email address or updating a phone number — are reflected in LimeCall routing rules automatically. This ensures the right rep always handles the right contact.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall trigger Pipedrive automations?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Because LimeCall creates and updates Pipedrive records in real time, any Pipedrive automation triggered by Person creation, Deal stage change, or Activity creation will fire automatically. Use call outcomes to send automated emails, assign follow-up activities, or notify teammates via Pipedrive.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which LimeCall plan includes the Pipedrive integration?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Pipedrive integration is available on the LimeCall Pro plan, which includes 500 calls per month, custom integrations, and API access. You can start a free trial to test the integration with your own Pipedrive account before committing to a paid plan.',
      },
    },
  ],
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Connect LimeCall with Pipedrive',
  description: 'Step-by-step guide to integrating LimeCall with Pipedrive for automated Person and Deal creation, call logging, and pipeline stage updates.',
  totalTime: 'PT5M',
  step: [
    {
      '@type': 'HowToStep',
      name: 'Connect via OAuth',
      text: 'Go to LimeCall → Integrations → Pipedrive. Click "Connect" and authorise with your Pipedrive credentials. Takes under 2 minutes with no developer needed.',
      position: 1,
    },
    {
      '@type': 'HowToStep',
      name: 'Map fields and pipelines',
      text: 'Choose which Pipedrive pipeline and stage new Deals land in. Map LimeCall fields to Pipedrive custom fields and configure call-outcome-to-stage rules.',
      position: 2,
    },
    {
      '@type': 'HowToStep',
      name: 'Go live',
      text: 'Enable the integration and make a test callback. Your Person, Deal, and Activity will appear in Pipedrive within seconds. You\'re ready.',
      position: 3,
    },
  ],
};

const stats = [
  { value: "28s", label: "Average callback speed" },
  { value: "5 min", label: "Setup time — no developer" },
  { value: "64%", label: "Of deals lost to slow lead follow-up" },
  { value: "500", label: "Calls/mo on Pro plan" },
];

const features = [
  {
    title: "Auto-create Person + Deal on callback",
    desc: "Every callback from a new visitor automatically creates a Pipedrive Person and an associated Deal in your pipeline — with phone number, name, traffic source, and the page they called from.",
  },
  {
    title: "Log call as Activity in deal timeline",
    desc: "After each call, LimeCall logs a completed Call Activity against the Pipedrive Deal with duration, outcome, agent name, and a direct link to the call recording.",
  },
  {
    title: "Update deal stage on call outcome",
    desc: "Map LimeCall call dispositions to Pipedrive deal stage changes. A 'Demo booked' call can automatically advance the deal to your 'Demo Scheduled' stage without any rep action.",
  },
  {
    title: "Sync contact data bidirectionally",
    desc: "Contact updates in Pipedrive flow back to LimeCall routing rules automatically. When a rep updates a phone number or reassigns a contact, LimeCall adjusts routing to match.",
  },
  {
    title: "Trigger Pipedrive automations from LimeCall call results",
    desc: "LimeCall call outcomes fire Pipedrive automations in real time — send follow-up emails, create tasks, move deals, or Slack-notify teammates based on exactly what happened on the call.",
  },
  {
    title: "Report attribution: which Pipedrive source drives fastest callbacks",
    desc: "Correlate LimeCall's callback speed data with Pipedrive's Lead Source field to discover which acquisition channels produce the fastest, highest-converting phone conversations.",
  },
];

const useCases = [
  {
    role: "Sales Reps",
    title: "Full deal context before the call begins",
    desc: "LimeCall surfaces the Pipedrive Person and Deal the moment a callback is initiated. Reps see open deals, previous activities, and custom field data before they say a word.",
  },
  {
    role: "Marketing",
    title: "Trace which campaigns drive the most callbacks",
    desc: "UTM parameters and traffic source data captured by LimeCall sync to Pipedrive's Lead Source and custom fields. Marketing can attribute phone conversions to specific campaigns with full precision.",
  },
  {
    role: "Operations",
    title: "Automated deal progression on every call",
    desc: "Call outcomes update deal stages and fire Pipedrive automations automatically — eliminating the admin overhead of manually moving deals through the pipeline after every sales call.",
  },
  {
    role: "Reporting",
    title: "Speed-to-lead by Pipedrive source",
    desc: "Build Pipedrive reports that cross-reference LimeCall callback time with Lead Source to quantify how response speed varies by channel and which sources close fastest.",
  },
];

const comparisonRows = [
  { feature: "Auto-create Person + Deal", limecall: true, manual: false, others: "Partial" },
  { feature: "Log call Activity in deal timeline", limecall: true, manual: false, others: false },
  { feature: "Update deal stage on call outcome", limecall: true, manual: false, others: false },
  { feature: "Bidirectional contact sync", limecall: true, manual: false, others: false },
  { feature: "Trigger Pipedrive automations", limecall: true, manual: false, others: false },
  { feature: "5-minute OAuth setup", limecall: true, manual: "N/A", others: false },
  { feature: "Attribution reporting by source", limecall: true, manual: false, others: "Partial" },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={howToSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Integrations', url: 'https://www.limecall.com/integrations/' },
        { name: crm, url: seo.canonical },
      ]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Official Integration · 5-minute setup · No developers
      </div>
      <h1 class="mt-5 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall + <span class="text-lime-400">Pipedrive</span>:<br class="hidden sm:block" />
        Callback Software That Syncs Every Call to Your Pipeline
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Connect LimeCall to Pipedrive in 5 minutes. Auto-create Persons and Deals, log every callback in your deal timeline, and advance pipeline stages based on real call outcomes.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/get-started/" class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Connect Pipedrive Free →
        </a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          Watch Demo
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Data flow diagram -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">How data flows from your website into Pipedrive</h2>
      <p class="mb-12 text-center text-dark-400 text-sm max-w-2xl mx-auto">
        From the first click on your LimeCall widget to a logged Deal Activity in Pipedrive — fully automatic, zero manual steps.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-0">
        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">1</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Website visitor</h3>
          <p class="mt-1 text-xs text-dark-400">Clicks LimeCall widget and requests a callback</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">2</div>
          <h3 class="mt-3 text-sm font-semibold text-white">LimeCall callback</h3>
          <p class="mt-1 text-xs text-dark-400">Connects visitor to your rep in 28 seconds</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">3</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Call recorded</h3>
          <p class="mt-1 text-xs text-dark-400">Duration, outcome, and recording captured</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <!-- Step 4 -->
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">4</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Synced to Pipedrive</h3>
          <p class="mt-1 text-xs text-dark-400">Person + Deal created, Activity logged in timeline</p>
        </div>
      </div>

      <!-- Setup steps -->
      <div class="mt-14 grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 1</div>
          <h3 class="mb-2 font-semibold text-white">Connect via OAuth</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Go to LimeCall → Integrations → Pipedrive. Click "Connect" and authorise with your Pipedrive credentials. Takes under 2 minutes with no developer needed.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 2</div>
          <h3 class="mb-2 font-semibold text-white">Map fields and pipelines</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Choose which Pipedrive pipeline and stage new Deals land in. Map LimeCall fields to Pipedrive custom fields and configure call-outcome-to-stage rules.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 3</div>
          <h3 class="mb-2 font-semibold text-white">Go live</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Enable the integration and make a test callback. Your Person, Deal, and Activity will appear in Pipedrive within seconds. You're ready.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Everything the LimeCall + Pipedrive integration does</h2>
      <p class="mb-10 text-center text-dark-400 text-sm">Six capabilities that keep your pipeline accurate and your reps focused on selling.</p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f, i) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 hover:border-lime-500/30 transition">
            <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-lg bg-lime-500/15 text-sm font-extrabold text-lime-400">{i + 1}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Who uses LimeCall + Pipedrive and how</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-2 inline-block rounded-full bg-lime-500/15 px-3 py-1 text-xs font-bold text-lime-400">{uc.role}</div>
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">LimeCall + Pipedrive vs the alternatives</h2>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="py-4 px-5 text-left font-semibold text-dark-300">Feature</th>
              <th class="py-4 px-5 text-center font-semibold text-lime-400">LimeCall + Pipedrive</th>
              <th class="py-4 px-5 text-center font-semibold text-dark-400">Manual logging</th>
              <th class="py-4 px-5 text-center font-semibold text-dark-400">Other callback tools</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800/50 ${i % 2 === 0 ? 'bg-dark-950/40' : 'bg-dark-900/20'}`}>
                <td class="py-3 px-5 text-dark-300">{row.feature}</td>
                <td class="py-3 px-5 text-center">
                  {row.limecall === true
                    ? <span class="text-lime-400 font-bold">Yes</span>
                    : <span class="text-dark-500">{row.limecall}</span>}
                </td>
                <td class="py-3 px-5 text-center">
                  {row.manual === false
                    ? <span class="text-dark-600">No</span>
                    : <span class="text-dark-400">{row.manual}</span>}
                </td>
                <td class="py-3 px-5 text-center">
                  {row.others === false
                    ? <span class="text-dark-600">No</span>
                    : <span class="text-dark-400">{row.others}</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 group">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between">
              {item.name}
              <span class="ml-4 text-lime-400 text-xl leading-none group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to connect LimeCall with Pipedrive?</h2>
      <p class="mt-4 text-dark-400">5-minute setup · No developers · Free trial included</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/get-started/" class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free →
        </a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-10 py-4 font-bold text-white hover:border-lime-500/40 transition">
          Book a Demo
        </a>
      </div>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="More CRM Integrations" links={[
        { href: '/salesforce-integration/', title: 'LimeCall + Salesforce', desc: 'Auto-create Leads and log Activities in Salesforce.' },
        { href: '/zoho-crm-integration/', title: 'LimeCall + Zoho CRM', desc: 'Sync callbacks to Zoho Leads, Contacts, and Deals.' },
        { href: '/limecall-for-hubspot/', title: 'LimeCall + HubSpot', desc: 'Log every call in HubSpot automatically.' },
        { href: '/integrations/', title: 'All Integrations', desc: 'See every tool LimeCall connects with.' },
        { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'Why responding in 28 seconds wins more deals.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple plans that include CRM integrations.' },
      ]} />
    </div>
  </div>
</Base>
