---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const competitor = "CallPage";

const seo = {
  title: `Best CallPage Alternative in 2026 — LimeCall | LimeCall`,
  description: `Looking for a CallPage alternative? LimeCall is a feature-rich callback platform with SMS, WhatsApp, virtual numbers, and lead distribution — perfect for any SME. Try free, no credit card.`,
  canonical: `https://www.limecall.com/alternative-to-callpage/`,
};

const features = [
  { feature: "Instant Callback (28 sec)", limecall: true, competitor: true },
  { feature: "Click-to-Call Widget", limecall: true, competitor: true },
  { feature: "Lead Distribution", limecall: true, competitor: false },
  { feature: "SMS & WhatsApp", limecall: true, competitor: false },
  { feature: "Virtual Phone Numbers (40+ countries)", limecall: true, competitor: false },
  { feature: "CRM Integrations", limecall: true, competitor: true },
  { feature: "Call Recording", limecall: true, competitor: true },
  { feature: "Free Plan (no credit card)", limecall: true, competitor: false },
  { feature: "Shared SMS Inbox", limecall: true, competitor: false },
  { feature: "Speed-to-Lead Automation", limecall: true, competitor: false },
  { feature: "Omni-channel Sales Approach", limecall: true, competitor: false },
];

const reasons = [
  { title: "Everything CallPage does — and more", desc: "LimeCall offers all of CallPage's core callback functionality, plus SMS, WhatsApp, virtual numbers, lead distribution, and a shared team inbox." },
  { title: "Perfect fit for SMEs", desc: "LimeCall is purpose-built for small and medium businesses. Simple setup, transparent pricing, and dedicated support to help you grow." },
  { title: "Omni-channel sales approach", desc: "Phone, SMS, WhatsApp — all in one platform. Reach leads on the channel they prefer and increase conversion rates across the board." },
  { title: "Free to start, no commitment", desc: "LimeCall has a free plan with 30 calls/month and no credit card required. Start today with zero risk." },
  { title: "Lead distribution built-in", desc: "Automatically route inbound leads to the right sales rep based on availability, skills, or round-robin. CallPage doesn't offer this." },
  { title: "Virtual numbers in 40+ countries", desc: "Build local presence globally with LimeCall virtual phone numbers. Perfect for international businesses that want a local touch." },
];

const testimonialHighlights = [
  { stat: "28 sec", label: "Average connection time" },
  { stat: "300%", label: "Increase in site conversions" },
  { stat: "40+", label: "Countries with virtual numbers" },
  { stat: "5 min", label: "Widget setup time" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Why should I choose LimeCall over CallPage?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall offers everything CallPage provides — instant callbacks, a click-to-call widget, CRM integrations, and call recording — plus SMS, WhatsApp, virtual numbers, and lead distribution. It\'s a more complete omni-channel solution, especially for SMEs.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is LimeCall free to try?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall has a free plan with 30 calls per month, no credit card required. You can upgrade anytime as your needs grow.',
      },
    },
    {
      '@type': 'Question',
      name: 'How quickly does LimeCall connect calls?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall connects website visitors with your sales team in under 28 seconds — ensuring no lead goes cold.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall work with my CRM?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall integrates with popular CRMs and tools including HubSpot, Salesforce, Pipedrive, Zapier, and more.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I use LimeCall for SMS as well as calls?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall supports SMS, WhatsApp, and phone callbacks — all from one platform. CallPage only offers callback functionality.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `Best CallPage Alternative`, url: seo.canonical }]} />
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        #1 CallPage Alternative
      </div>
      <h1 class="mt-2 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        The Best <span class="text-lime-400">CallPage Alternative</span><br class="hidden sm:block" /> for Growing Teams
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300">
        LimeCall is a feature-rich alternative to CallPage — the perfect fit for any SME. An omni-channel callback solution with SMS, WhatsApp, virtual numbers, and lead distribution. Try free with zero commitment.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">
          Try LimeCall Free →
        </a>
        <a href="/limecall-vs-callpage/" class="rounded-xl border border-dark-700 px-8 py-3.5 text-sm font-semibold text-white hover:border-lime-500/50 transition">
          See Full Comparison
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime</p>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-8">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {testimonialHighlights.map(item => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{item.stat}</div>
            <div class="mt-1 text-xs text-dark-400">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">LimeCall vs CallPage — Feature by Feature</h2>
      <p class="mb-8 text-center text-sm text-dark-400">See exactly what you gain by switching to LimeCall.</p>
      <div class="overflow-hidden rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-6 py-4 text-left font-semibold text-dark-300">Feature</th>
              <th class="px-6 py-4 text-center font-bold text-lime-400">LimeCall</th>
              <th class="px-6 py-4 text-center font-semibold text-dark-400">{competitor}</th>
            </tr>
          </thead>
          <tbody>
            {features.map((row, i) => (
              <tr class:list={["border-b border-dark-800/50", i % 2 === 0 ? "bg-dark-950" : "bg-dark-900/40"]}>
                <td class="px-6 py-3.5 text-dark-300">{row.feature}</td>
                <td class="px-6 py-3.5 text-center">
                  {row.limecall
                    ? <span class="text-lime-400 text-base">✓</span>
                    : <span class="text-dark-600 text-base">✗</span>}
                </td>
                <td class="px-6 py-3.5 text-center">
                  {row.competitor
                    ? <span class="text-dark-300 text-base">✓</span>
                    : <span class="text-dark-600 text-base">✗</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Why LimeCall -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Why LimeCall is the Best CallPage Alternative</h2>
      <p class="mb-10 text-center text-sm text-dark-400">More features, better value, and an omni-channel approach that CallPage simply can't match.</p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {reasons.map(r => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{r.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Switch from CallPage to LimeCall today</h2>
      <p class="mt-4 text-dark-400">Join thousands of SMEs who chose LimeCall as their CallPage alternative. Free plan available — no credit card, no commitment.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free — No Credit Card →
      </a>
      <p class="mt-4 text-xs text-dark-500">30-day money-back guarantee · Cancel anytime</p>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <CrossLinks heading="Explore LimeCall" links={[
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      { href: '/limecall-vs-callpage/', title: 'LimeCall vs CallPage', desc: 'Full feature-by-feature comparison.' },
      { href: '/features/', title: 'Features', desc: 'Everything LimeCall does.' },
      { href: '/customers/', title: 'Customers', desc: 'See who uses LimeCall.' },
    ]} />
  </div>
</Base>
