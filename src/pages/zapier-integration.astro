---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const slug = "zapier-integration";

const seo = {
  title: `LimeCall Zapier Integration | Connect 5,000+ Apps`,
  description: `Use LimeCall's Zapier integration to send call data to any of 5,000+ apps — Slack, Sheets, HubSpot, Trello, and more. No code required.`,
  canonical: `${site.url}/zapier-integration/`,
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'LimeCall Zapier Integration',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Free trial available',
  },
  description: "Use LimeCall's Zapier integration to send call data to any of 5,000+ apps — Slack, Sheets, HubSpot, Trello, and more. No code required.",
  url: `${site.url}/zapier-integration/`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is there a native LimeCall integration or only Zapier?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall offers both native integrations and Zapier. Native integrations — including Salesforce, Pipedrive, HubSpot, and ActiveCampaign — provide deeper, bidirectional sync and are available on Pro plans. The Zapier integration covers the remaining 5,000+ apps in the Zapier library and is ideal for teams that need flexible, no-code connectivity to tools without a native integration.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which LimeCall trigger events are available in Zapier?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall provides the following Zapier triggers: Call Started, Call Completed, Call Missed, Callback Requested, Demo Booked, and Follow-Up Requested. Each trigger fires in real time and passes a rich payload of caller data to your Zap.',
      },
    },
    {
      '@type': 'Question',
      name: 'What data fields does LimeCall send in a Zapier trigger payload?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Each LimeCall Zapier trigger includes: caller name, phone number, email (if provided via widget), call duration, call outcome, agent name, source page URL, UTM parameters (source, medium, campaign, term, content), timestamp, recording URL, and any custom fields collected via the LimeCall widget form.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I use LimeCall as a Zapier action as well as a trigger?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall supports both Zapier triggers and actions. As an action, you can use Zapier to initiate a LimeCall callback — for example, triggering an outbound callback when a new lead is created in your CRM. This allows you to build automated call workflows from any app in Zapier.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does the Zapier integration work in real time?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall Zapier triggers fire in real time using webhooks, not polling. As soon as a call ends or a missed call is logged, Zapier receives the data and your Zap executes immediately — there is no polling delay.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which Zapier plan do I need to use LimeCall triggers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The LimeCall Zapier integration works on all Zapier plans including the free tier, subject to Zapier task limits. For real-time webhook triggers, a Zapier Starter plan or above is recommended. On the LimeCall side, Zapier integration is available on Pro plans and above.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I set up the LimeCall Zapier integration?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Go to zapier.com and search for LimeCall. Click "Connect LimeCall" and authenticate via OAuth using your LimeCall credentials. Select your trigger event, map the data fields to your target app, and activate the Zap. The full setup takes under 10 minutes with no code required.',
      },
    },
  ],
};

const stats = [
  { value: "5,000+", label: "Apps in the Zapier library" },
  { value: "Real-time", label: "Webhook-based triggers" },
  { value: "0", label: "Lines of code required" },
  { value: "6", label: "LimeCall trigger events" },
];

const features = [
  {
    title: "Trigger Zaps on any call event",
    desc: "Fire Zaps on Call Started, Call Completed, Call Missed, Callback Requested, Demo Booked, or Follow-Up Requested. Each trigger carries the full caller data payload so downstream apps get everything they need.",
  },
  {
    title: "Send caller data to any app",
    desc: "Route caller name, phone, email, UTM parameters, call duration, agent name, source URL, and custom field data to any of the 5,000+ apps in Zapier — no API knowledge needed.",
  },
  {
    title: "Create tasks in project management tools",
    desc: "Automatically create follow-up tasks in Asana, Trello, Monday.com, or ClickUp when a call ends with a follow-up outcome. Tasks are pre-filled with caller details and call notes.",
  },
  {
    title: "Post Slack alerts on new callback requests",
    desc: "Send instant Slack messages to your sales channel whenever a new callback is requested. Include caller name, phone number, source page, and UTM campaign so reps know exactly who is waiting.",
  },
  {
    title: "Log calls to Google Sheets for reporting",
    desc: "Every completed call appends a new row to a Google Sheet with all call metadata. Build custom reporting dashboards in Sheets, Data Studio, or Looker without touching your CRM.",
  },
  {
    title: "Create HubSpot contacts automatically",
    desc: "When a new caller's phone number doesn't exist in HubSpot, Zapier creates a new contact with all available fields pre-populated — name, phone, email, lead source, and UTM parameters.",
  },
];

const popularZaps = [
  {
    trigger: "New callback request",
    action: "Slack message",
    app: "Slack",
    desc: "Notify your sales team channel the moment a visitor requests a callback — with their name, number, and the page they called from.",
  },
  {
    trigger: "Call completed",
    action: "Google Sheets row",
    app: "Google Sheets",
    desc: "Log every completed call to a master reporting Sheet. Track call volume, duration, agent performance, and conversion rates over time.",
  },
  {
    trigger: "Call missed",
    action: "Trello card",
    app: "Trello",
    desc: "Create a Trello card in your 'Missed Calls' board for every unanswered call. Assign it to a rep and add caller details in the card description.",
  },
  {
    trigger: "New callback lead",
    action: "HubSpot contact",
    app: "HubSpot",
    desc: "Create a new HubSpot contact from every unique caller with phone, email, UTM source, and the page they requested a callback from.",
  },
  {
    trigger: "Demo booked",
    action: "Asana task",
    app: "Asana",
    desc: "When a call outcome is 'Demo Booked', create an Asana prep task assigned to the relevant rep with call notes and the scheduled demo date.",
  },
  {
    trigger: "Call completed",
    action: "Airtable record",
    app: "Airtable",
    desc: "Build a real-time call log in Airtable. Link calls to campaigns, filter by outcome, and visualise conversion rates with Airtable views.",
  },
];

const useCases = [
  {
    role: "Sales teams",
    title: "Real-time Slack alerts keep reps in the loop",
    desc: "Post a Slack message to your team channel every time a callback is requested or missed. Reps can claim follow-ups directly from Slack without logging into LimeCall or their CRM.",
  },
  {
    role: "Operations",
    title: "Build a call log in Google Sheets without a BI tool",
    desc: "Every call appends a row to Google Sheets. Ops teams get a live call register they can pivot, filter, and share — no CRM login, no data export, no waiting.",
  },
  {
    role: "Marketing",
    title: "Attribute phone conversions to campaigns in any tool",
    desc: "LimeCall captures UTM parameters on every call. Zap that data to your analytics tool, ad platform, or reporting database to close the loop on which campaigns drive phone conversions.",
  },
  {
    role: "Support teams",
    title: "Auto-create support tickets on missed calls",
    desc: "Missed calls create tickets in Zendesk, Freshdesk, or Intercom automatically. Caller details pre-fill the ticket so support agents can respond without asking for information again.",
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={softwareSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Integrations', url: `${site.url}/integrations/` },
        { name: 'Zapier Integration', url: seo.canonical },
      ]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Zapier Integration · 5,000+ apps · No code required
      </div>
      <h1 class="mt-5 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall + <span class="text-lime-400">Zapier</span>:<br class="hidden sm:block" />
        Connect Your Calls to 5,000+ Apps
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Use LimeCall's Zapier integration to send call data to Slack, Google Sheets, HubSpot, Trello, and thousands more — all in real time, without writing a single line of code.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/get-started/" class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Connect via Zapier Free →
        </a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          Watch Demo
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">How the LimeCall Zapier integration works</h2>
      <p class="mb-12 text-center text-dark-400 text-sm max-w-2xl mx-auto">
        A call happens in LimeCall, a webhook fires to Zapier, and your chosen app receives the data — all within seconds.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-0">
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">1</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Call event fires</h3>
          <p class="mt-1 text-xs text-dark-400">Callback requested, completed, or missed on LimeCall</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">2</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Webhook sent to Zapier</h3>
          <p class="mt-1 text-xs text-dark-400">Full caller data payload delivered in real time</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">3</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Zap executes</h3>
          <p class="mt-1 text-xs text-dark-400">Fields mapped and action triggered in target app</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">4</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Your app updated</h3>
          <p class="mt-1 text-xs text-dark-400">Slack notified, Sheet row added, CRM contact created</p>
        </div>
      </div>

      <!-- Setup steps -->
      <div class="mt-14 grid gap-6 sm:grid-cols-4">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 1</div>
          <h3 class="mb-2 font-semibold text-white">Connect via Zapier OAuth</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Search for LimeCall in Zapier and click Connect. Authorise with your LimeCall credentials in under 2 minutes.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 2</div>
          <h3 class="mb-2 font-semibold text-white">Choose trigger event</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Select from Call Started, Completed, Missed, Callback Requested, Demo Booked, or Follow-Up Requested.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 3</div>
          <h3 class="mb-2 font-semibold text-white">Map fields</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Drag caller data fields — name, phone, UTMs, outcome, duration — to the corresponding fields in your target app.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 4</div>
          <h3 class="mb-2 font-semibold text-white">Activate your Zap</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Turn on the Zap and make a test call. Your downstream app receives the data within seconds. Done.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">What you can do with LimeCall + Zapier</h2>
      <p class="mb-10 text-center text-dark-400 text-sm">Six use cases that teams build in their first week.</p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f, i) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 hover:border-lime-500/30 transition">
            <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-lg bg-lime-500/15 text-sm font-extrabold text-lime-400">{i + 1}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular Zaps -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Popular LimeCall Zaps</h2>
      <p class="mb-10 text-center text-dark-400 text-sm">Ready-to-use workflow templates to get you started in minutes.</p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {popularZaps.map(zap => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-5 hover:border-lime-500/30 transition">
            <div class="mb-2 flex items-center gap-2">
              <span class="rounded-full bg-lime-500/15 px-2.5 py-0.5 text-xs font-bold text-lime-400">{zap.app}</span>
            </div>
            <div class="mb-1 text-xs text-dark-500 font-medium uppercase tracking-wider">
              {zap.trigger} → {zap.action}
            </div>
            <p class="text-sm text-dark-400 leading-relaxed">{zap.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Who uses LimeCall + Zapier and how</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-2 inline-block rounded-full bg-lime-500/15 px-3 py-1 text-xs font-bold text-lime-400">{uc.role}</div>
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 group">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between">
              {item.name}
              <span class="ml-4 text-lime-400 text-xl leading-none group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to connect LimeCall to your stack via Zapier?</h2>
      <p class="mt-4 text-dark-400">5-minute setup · 5,000+ apps · No code required</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/get-started/" class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free →
        </a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-10 py-4 font-bold text-white hover:border-lime-500/40 transition">
          Book a Demo
        </a>
      </div>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="More Integrations" links={[
        { href: '/salesforce-integration/', title: 'LimeCall + Salesforce', desc: 'Auto-create Leads and log Activities in Salesforce.' },
        { href: '/activecampaign-integration/', title: 'LimeCall + ActiveCampaign', desc: 'Trigger nurture sequences from call outcomes.' },
        { href: '/lead-routing-software/', title: 'Lead Routing Software', desc: 'Route inbound calls to the right rep instantly.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple plans that include Zapier connectivity.' },
      ]} />
    </div>
  </div>
</Base>
