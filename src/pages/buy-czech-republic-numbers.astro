---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const country = "Czech Republic";
const code = "+420";
const flag = "🇨🇿";

const seo = {
  title: `Czech Republic Virtual Phone Numbers (+420) | LimeCall`,
  description: `Get a Czech Republic virtual phone number (+420) instantly. No hardware needed. Route calls, enable callbacks, and grow your Czech business with LimeCall.`,
  canonical: `https://www.limecall.com/buy-czech-republic-numbers/`,
};

const features = [
  { title: "Instant Setup", desc: "Get your Czech Republic virtual number in minutes. No hardware, no SIM card, no contracts." },
  { title: "Smart Call Routing", desc: "Route incoming calls to any device or team member — mobile, desktop, or desk phone." },
  { title: "Call Recording", desc: "Record and review every call for quality assurance and compliance." },
  { title: "Callback Automation", desc: "Let website visitors request instant callbacks from your Czech-based or global team." },
  { title: "SMS & WhatsApp", desc: "Send and receive SMS messages on your Czech Republic virtual number." },
  { title: "Analytics Dashboard", desc: "Full call analytics, reporting, and conversion tracking in one dashboard." },
];

const stats = [
  { value: "Instant", label: "Activation" },
  { value: "2", label: "Prague Area Code" },
  { value: "+420", label: "CZ Country Code" },
  { value: "99.9%", label: "Uptime SLA" },
];

const countryFacts = [
  { title: "Country Code +420", desc: "The Czech Republic uses country code +420. Prague local numbers start with area code 2, appearing internationally as +420 2 XX XX XX XX. Other cities have their own area codes (Brno: 5, Ostrava: 69)." },
  { title: "Local Presence Builds Trust", desc: "Czech business culture values local presence. Calling from a Czech number (+420) shows commitment to the market and significantly increases answer rates compared to foreign numbers." },
  { title: "EU GDPR Applies", desc: "As an EU member state, the Czech Republic is fully subject to GDPR. Call data and recordings must be handled in compliance with EU data protection law — LimeCall provides the tools to stay compliant." },
];

const comparisonRows = [
  { aspect: "Setup Time", virtual: "Under 5 minutes", sim: "Days + in-country registration" },
  { aspect: "Monthly Cost", virtual: "From $4/mo", sim: "CZK 400–1200/mo plan" },
  { aspect: "Works Internationally", virtual: "Yes — route from anywhere", sim: "Roaming charges apply" },
  { aspect: "Prague Area Code (2)", virtual: "Yes, available", sim: "Depends on SIM region" },
  { aspect: "EU GDPR Tools", virtual: "Full compliance controls", sim: "Carrier dependent" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I get a Czech Republic phone number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sign up for LimeCall, select Czech Republic, choose your preferred area code (Prague: 2, Brno: 5, Ostrava: 69), and your number activates instantly. No SIM card or Czech residency required.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the Czech Republic country code?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Czech Republic country code is +420. A Czech landline number looks like +420 2 XX XX XX XX (Prague), while mobile numbers look like +420 7XX XXX XXX.',
      },
    },
    {
      '@type': 'Question',
      name: 'What are Czech area codes?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Key Czech area codes include: Prague (2), Brno (5), Ostrava (69), Plzen (37), Liberec (48), and Hradec Kralove (49). LimeCall offers virtual numbers for the major Czech cities.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I use a Czech virtual number for business?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. A Czech Republic virtual number from LimeCall is fully suitable for business use — you can make and receive calls, set up IVR menus, record calls, and automate callbacks, all from a local +420 number.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is a Czech virtual number EU GDPR compliant?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall provides GDPR-compliant infrastructure. As the Czech Republic is an EU member state, all call data and recordings are handled in accordance with EU GDPR requirements.',
      },
    },
  ],
};

const faqs = [
  {
    q: `What is a Czech Republic virtual phone number?`,
    a: `A Czech Republic virtual phone number (${code}) is a telephone number that isn't tied to a physical phone line or SIM card. It routes calls over the internet to any device — mobile, laptop, or desk phone — anywhere in the world. Your customers in the Czech Republic dial a local number, and the call reaches you wherever you are.`,
  },
  {
    q: `Do I need to be in the Czech Republic to get a Czech virtual number?`,
    a: `No. Anyone can get a Czech Republic virtual phone number from anywhere in the world. LimeCall gives you a local ${code} number that Czech customers can call at local rates, while your team answers from any country.`,
  },
  {
    q: `What types of Czech Republic virtual numbers are available?`,
    a: `LimeCall offers local Czech Republic numbers with city-specific area codes (Prague, Brno, Ostrava, Plzen, etc.) as well as national numbers. Choose the number type that best fits your business needs.`,
  },
  {
    q: "How long does setup take?",
    a: "Setup takes under 5 minutes. Sign up, choose your Czech Republic number, and you're ready to receive calls immediately — no waiting for hardware or SIM activation.",
  },
  {
    q: "Can I use a Czech virtual number for callbacks?",
    a: "Yes — LimeCall's callback automation lets website visitors request a call and your team calls them back within 28 seconds using your Czech Republic virtual number. This dramatically improves lead conversion rates.",
  },
  {
    q: `Are Czech Republic virtual numbers compliant with CTU regulations?`,
    a: `LimeCall's Czech Republic virtual numbers are provisioned through licensed telecom partners and comply with Czech Telecommunication Office (CTU) guidelines. All numbers are legitimate, registered numbers suitable for business use.`,
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `${country} Virtual Number`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a <span class="text-lime-400">{country} Virtual Phone Number</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Local {country} number ({code}) that works anywhere. Instant setup, no hardware. Route calls, automate callbacks, and close more deals.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your {country} Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <p class="text-2xl font-extrabold text-lime-400">{s.value}</p>
            <p class="mt-1 text-xs text-dark-400 uppercase tracking-wide">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Everything included with your {country} number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Virtual vs SIM Comparison -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Virtual CZ Number vs Czech SIM Card</h2>
      <p class="mb-10 text-center text-sm text-dark-400">Why a virtual number beats a physical SIM for most businesses</p>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-6 py-4 text-left font-semibold text-dark-300">Feature</th>
              <th class="px-6 py-4 text-left font-semibold text-lime-400">Virtual Number (LimeCall)</th>
              <th class="px-6 py-4 text-left font-semibold text-dark-400">Czech SIM Card</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800 ${i % 2 === 0 ? 'bg-dark-900/20' : ''}`}>
                <td class="px-6 py-4 font-medium text-white">{row.aspect}</td>
                <td class="px-6 py-4 text-dark-300">{row.virtual}</td>
                <td class="px-6 py-4 text-dark-500">{row.sim}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Country Facts -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Czech Republic Telecom & Business Facts</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {countryFacts.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 text-sm font-bold text-lime-400 uppercase tracking-wide">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ with JSON-LD -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {item.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your {country} number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall virtual numbers to connect with customers globally.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/incoming-numbers/', title: 'Incoming Numbers', desc: 'DID numbers for inbound calls.' },
        { href: '/virtual-business-numbers/', title: 'Business Numbers', desc: 'Professional virtual numbers for teams.' },
        { href: '/buy-slovakia-numbers/', title: 'Slovakia Numbers', desc: 'Get a Slovak virtual phone number.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
