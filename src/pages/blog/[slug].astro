---
import posts from '../../data/posts.json';

export async function getStaticPaths() {
  return posts
    .filter((post) => !post.slug.includes('/'))
    .map((post) => ({
      params: { slug: post.slug },
      props: { slug: post.slug },
    }));
}

const { slug } = Astro.props;
return Astro.redirect(`/post/${slug}/`, 301);
---
