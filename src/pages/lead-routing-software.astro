---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Lead Routing Software — Route Every Lead Instantly | LimeCall`,
  description: `LimeCall lead routing software connects website visitors to the right sales rep in seconds. 80% faster response, 3x higher contact rate. 5-min setup, free trial.`,
  canonical: `https://www.limecall.com/lead-routing-software/`,
};

const stats = [
  { value: "80%", label: "Faster lead response" },
  { value: "3x", label: "Higher contact rate" },
  { value: "100%", label: "Lead coverage" },
  { value: "5 min", label: "Setup time" },
];

const features = [
  { title: "Rules-Based Routing", desc: "Route leads based on location, lead source, form data, or any custom criteria. The right rep gets every lead." },
  { title: "Round-Robin Distribution", desc: "Distribute leads evenly across your sales team. Fair allocation with automatic failover if a rep is unavailable." },
  { title: "Skills-Based Routing", desc: "Match leads to reps based on expertise, language, product knowledge, or territory for better conversion rates." },
  { title: "Availability Routing", desc: "Route only to available reps. If a rep is busy or offline, the lead goes to the next available team member." },
  { title: "Instant Callback Trigger", desc: "When a lead is captured, LimeCall triggers an instant callback — connecting the lead to the right rep in under 28 seconds. This works in tandem with <a href=\"/automatic-lead-distribution/\" class=\"text-lime-400 hover:underline\">automatic lead distribution</a> to ensure no lead waits." },
  { title: "Routing Analytics", desc: "Track how leads are routed, which reps get the most leads, and how routing rules affect conversion rates." },
];

const useCases = [
  { title: "Multi-Rep Sales Teams", desc: "Distribute inbound leads fairly and instantly across your entire sales team. No leads fall through the cracks, no rep is overloaded." },
  { title: "Territory-Based Sales", desc: "Route leads automatically to the rep who owns that geographic region. Protect territories and improve close rates." },
  { title: "Product Specialists", desc: "Ensure leads interested in specific products or plans always reach the rep with the right expertise to close them." },
  { title: "Enterprise Sales Development", desc: "Route marketing-qualified leads to the correct SDR or AE based on company size, industry, or deal value." },
];

const steps = [
  { n: "1", title: "Set your routing rules", desc: "Define who gets which leads based on territory, product, source, or any custom field. No coding required." },
  { n: "2", title: "Lead arrives", desc: "A visitor submits a form, clicks to call, or requests a callback on your website. LimeCall captures them instantly." },
  { n: "3", title: "Routed and connected", desc: "LimeCall applies your routing rules and connects the lead to the right rep in seconds — before the lead goes cold. This is the core of your <a href=\"/speed-to-lead/\" class=\"text-lime-400 hover:underline\">speed-to-lead advantage</a>." },
];

const comparisonRows = [
  { criterion: "Lead response speed", automated: "Seconds", manual: "Minutes to hours" },
  { criterion: "Routing accuracy", automated: "Rules-enforced 100%", manual: "Human error prone" },
  { criterion: "Lead coverage", automated: "24/7 automatic", manual: "Business hours only" },
  { criterion: "Rep satisfaction", automated: "Fair, transparent", manual: "Perceived favoritism" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is lead routing software?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Lead routing software automatically directs inbound leads — from forms, calls, or chat — to the most appropriate sales rep based on rules you define. Rules can include territory, product interest, company size, language, availability, or any other custom criteria. LimeCall\'s lead routing software also triggers an instant callback so the lead is connected by phone within seconds of expressing interest.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does round-robin routing work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Round-robin routing distributes leads evenly across a team in sequence — rep 1 gets the first lead, rep 2 gets the second, rep 3 gets the third, and so on. When the sequence reaches the last rep, it starts again from rep 1. LimeCall\'s round-robin includes automatic failover: if a rep is unavailable, the lead skips to the next available rep so no lead ever goes uncontacted.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can leads be routed by territory or geography?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall\'s lead routing software supports territory-based routing using the lead\'s IP address, form data (e.g., state or country field), or phone area code. You define the territories and assign reps to each. When a lead arrives from a specific region, it is automatically sent to the rep who owns that territory.',
      },
    },
    {
      '@type': 'Question',
      name: 'What integrations does LimeCall lead routing support?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall integrates with Salesforce, HubSpot, Pipedrive, Zoho CRM, Marketo, and many other platforms natively, plus hundreds more via Zapier. Lead routing rules can be triggered by CRM data, form submissions, or website events, and routed leads are automatically created or updated in your CRM with full contact and source details. Learn about the full <a href="/limecall-for-hubspot/" class="text-lime-400 hover:underline">LimeCall for HubSpot</a> integration.',
      },
    },
    {
      '@type': 'Question',
      name: 'How fast is automated lead routing with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall routes and connects leads in under 28 seconds on average. The moment a lead is captured — via form, widget, or click-to-call — LimeCall evaluates your routing rules, identifies the best available rep, and dials both the lead and the rep simultaneously. Research shows that responding to a lead within 5 minutes makes you 100x more likely to connect than responding after 30 minutes.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Lead Routing Software", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Lead Routing Software
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Route Every Lead to the <span class="text-lime-400">Right Rep, Instantly</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Stop losing leads to slow routing. LimeCall's lead routing software connects website visitors to the right sales rep in seconds, automatically — based on your custom rules. Essential for <a href="/b2b-lead-generation/" class="text-lime-400 hover:text-lime-300 underline">B2B lead generation</a> and <a href="/inbound-lead-generation/" class="text-lime-400 hover:text-lime-300 underline">inbound lead generation</a> teams.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-b border-dark-800 bg-dark-900/30 py-10">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <p class="text-3xl font-extrabold text-lime-400">{s.value}</p>
            <p class="mt-1 text-sm text-dark-400">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Smart lead routing, every time</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Use cases</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 font-semibold text-white">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How lead routing works</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Automated routing vs manual assignment</h2>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900/80">
              <th class="px-5 py-3 text-left font-semibold text-dark-300">Criterion</th>
              <th class="px-5 py-3 text-left font-semibold text-lime-400">Automated (LimeCall)</th>
              <th class="px-5 py-3 text-left font-semibold text-dark-400">Manual assignment</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800 ${i % 2 === 0 ? 'bg-dark-900/40' : ''}`}>
                <td class="px-5 py-3 text-dark-300">{row.criterion}</td>
                <td class="px-5 py-3 text-white font-medium">{row.automated}</td>
                <td class="px-5 py-3 text-dark-400">{row.manual}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(faq => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/50 p-5 open:pb-4">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between gap-4">
              {faq.name}
              <span class="shrink-0 text-lime-400 text-lg">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Never route a lead to the wrong rep again</h2>
      <p class="mt-4 text-dark-400">Set up LimeCall's lead routing in 5 minutes. Start connecting leads to the right reps instantly.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/instant-lead-routing/', title: 'Instant Lead Routing', desc: 'Route leads in real time.' },
        { href: '/automatic-lead-distribution/', title: 'Auto Lead Distribution', desc: 'Automatically distribute leads.' },
        { href: '/lead-distribution/', title: 'Lead Distribution', desc: 'Full lead distribution feature.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
