---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Local Phone Numbers for Business | LimeCall`,
  description: `Get local phone numbers for your business in 50+ countries. Build local presence, increase answer rates, and connect with customers using familiar local area codes.`,
  canonical: `https://www.limecall.com/local-numbers/`,
};

const benefits = [
  { title: "Increase Answer Rates", desc: "Calls from local numbers are answered up to 4x more often than calls from unknown or international numbers." },
  { title: "Build Local Trust", desc: "A local number signals to customers that you have a presence in their market — building immediate credibility." },
  { title: "50+ Countries", desc: "Get local numbers in over 50 countries. Expand globally while maintaining a local feel in every market." },
  { title: "Instant Activation", desc: "Numbers activate immediately after signup. No contracts, no hardware, no waiting for SIM cards." },
  { title: "One Dashboard", desc: "Manage all your local numbers from a single LimeCall dashboard — calls, SMS, analytics, and routing." },
  { title: "Full Call Features", desc: "Every local number includes call routing, recording, callback automation, and SMS — all included." },
];

const stats = [
  { value: "40+", label: "Countries Available" },
  { value: "Instant", label: "Activation" },
  { value: "68%", label: "More Likely to Answer Local Calls" },
  { value: "No Hardware", label: "Required" },
];

const countries = [
  { name: "United States", code: "+1", href: "/buy-usa-numbers/", flag: "🇺🇸" },
  { name: "United Kingdom", code: "+44", href: "/get-uk-virtual-phone-number/", flag: "🇬🇧" },
  { name: "Germany", code: "+49", href: "/buy-germany-numbers/", flag: "🇩🇪" },
  { name: "France (Paris)", code: "+33", href: "/paris-virtual-phone-numbers/", flag: "🇫🇷" },
  { name: "Australia", code: "+61", href: "/get-australia-virtual-phone-number/", flag: "🇦🇺" },
  { name: "Canada", code: "+1", href: "/virtual-phone-number-canada/", flag: "🇨🇦" },
  { name: "India", code: "+91", href: "/india-virtual-phone-number/", flag: "🇮🇳" },
  { name: "Singapore", code: "+65", href: "/singapore-virtual-phone-number/", flag: "🇸🇬" },
];

const comparisonRows = [
  {
    aspect: "Trust Factor",
    local: "High — customers recognise their area code",
    tollFree: "Medium — professional but impersonal",
    intl: "Low — often blocked or ignored",
  },
  {
    aspect: "Call Answer Rates",
    local: "Up to 4x higher than unknown numbers",
    tollFree: "Good for inbound — familiar to consumers",
    intl: "Poor — many people do not answer foreign numbers",
  },
  {
    aspect: "Cost to Caller",
    local: "Local rate or included in plan",
    tollFree: "Free for the caller",
    intl: "International rates — discourages calls",
  },
  {
    aspect: "Best For",
    local: "Local market presence, SMB, field sales",
    tollFree: "National brands, support lines, US/CA enterprise",
    intl: "Internal use or markets without virtual options",
  },
  {
    aspect: "Setup Speed",
    local: "Instant with LimeCall",
    tollFree: "Instant with LimeCall",
    intl: "Depends on carrier and country",
  },
];

const howItWorks = [
  { step: "1", title: "Choose Country & Area Code", desc: "Browse 40+ countries and select the city or area code that matches your target market. Preview available numbers before confirming." },
  { step: "2", title: "Number Provisioned Instantly", desc: "Your local number activates the moment you complete signup. No waiting for hardware, SIM cards, or carrier approval." },
  { step: "3", title: "Calls Forward to Any Phone Worldwide", desc: "Incoming calls to your local number route to your mobile, desktop app, or any phone number — anywhere in the world." },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is a local phone number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A local phone number is a telephone number with an area code specific to a city or region — for example, 212 for New York or 020 for London. When you call from a local number, recipients see a familiar area code rather than an unknown or international number, which significantly increases answer rates.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why do businesses use local phone numbers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Businesses use local numbers to build trust and increase answer rates in specific markets. Research shows calls from local numbers are answered up to 4x more often than calls from unknown or international numbers. Local numbers also convey a physical presence in a market without requiring an actual office.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I get a local number in another country?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sign up for LimeCall, browse the available countries (40+), choose your preferred country and area code, and your local number activates instantly. No local address, SIM card, or in-country presence is required.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I have local numbers in multiple cities?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall lets you provision local numbers in multiple cities and countries from a single account. You can manage all numbers, routing rules, and analytics from one dashboard.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do local virtual numbers work for SMS?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall local virtual numbers support two-way SMS in supported countries. You can send and receive text messages using your local number from the LimeCall web app or mobile app.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Local Numbers", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Virtual Local Numbers
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Local Phone Numbers for <span class="text-lime-400">Your Business</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Get a local number in any city or country. Build trust with local customers, increase answer rates, and manage everything from one platform.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get a Local Number →
        </a>
        <a href="/virtual-numbers/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          Browse All Countries
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <p class="text-2xl font-extrabold text-lime-400">{s.value}</p>
            <p class="mt-1 text-xs text-dark-400 uppercase tracking-wide">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Why get a local phone number?</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map(b => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{b.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {howItWorks.map(h => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{h.step}</div>
            <h3 class="mb-2 font-semibold text-white">{h.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{h.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular Countries -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Popular local number countries</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {countries.map(c => (
          <a href={c.href} class="group flex items-center gap-3 rounded-xl border border-dark-800 bg-dark-900/50 p-4 transition-colors hover:border-lime-500/50">
            <span class="text-2xl">{c.flag}</span>
            <div>
              <p class="font-medium text-white group-hover:text-lime-400 transition text-sm">{c.name}</p>
              <p class="text-xs text-dark-500">{c.code}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/virtual-numbers/" class="text-sm font-medium text-lime-400 hover:text-lime-300 transition">
          View all 50+ countries →
        </a>
      </div>
    </div>
  </section>

  <!-- Comparison: Local vs Toll-Free vs International -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Local vs Toll-Free vs International Number</h2>
      <p class="mb-10 text-center text-sm text-dark-400">Choose the right number type for your use case</p>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-5 py-4 text-left font-semibold text-dark-300">Factor</th>
              <th class="px-5 py-4 text-left font-semibold text-lime-400">Local Number</th>
              <th class="px-5 py-4 text-left font-semibold text-dark-300">Toll-Free Number</th>
              <th class="px-5 py-4 text-left font-semibold text-dark-400">International Number</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800 ${i % 2 === 0 ? 'bg-dark-900/20' : ''}`}>
                <td class="px-5 py-4 font-medium text-white">{row.aspect}</td>
                <td class="px-5 py-4 text-dark-300">{row.local}</td>
                <td class="px-5 py-4 text-dark-400">{row.tollFree}</td>
                <td class="px-5 py-4 text-dark-500">{row.intl}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ with JSON-LD -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {item.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Get your local number today</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall local numbers to build trust and close more deals.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/incoming-numbers/', title: 'Incoming Numbers', desc: 'DID numbers for inbound calls.' },
        { href: '/toll-free-numbers/', title: 'Toll-Free Numbers', desc: 'Free for callers, professional for you.' },
        { href: '/virtual-business-numbers/', title: 'Business Numbers', desc: 'Professional virtual numbers for teams.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
