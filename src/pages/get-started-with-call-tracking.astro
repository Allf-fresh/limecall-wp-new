---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Get Started with Call Tracking — 5-Minute Setup | LimeCall',
  description: 'Set up call tracking in 5 minutes with no developer needed. 40% lower cost-per-lead, 100% call attribution. Copy, paste, and start tracking calls today.',
  canonical: `${site.url}/get-started-with-call-tracking/`,
};

const stats = [
  { value: '5 min', label: 'Setup Time', sub: 'Copy one script tag and call tracking is live' },
  { value: '40%', label: 'Lower Cost-Per-Lead', sub: 'by cutting spend on channels that don\'t drive calls' },
  { value: '100%', label: 'Call Attribution', sub: 'every call traced to its source channel' },
  { value: '0', label: 'Code Required', sub: 'paste-and-go setup, no developer needed' },
];

const features = [
  {
    icon: '📋',
    name: 'Copy-Paste Widget',
    description: 'Install LimeCall call tracking with one line of JavaScript. Paste it into your site header and attribution data starts flowing immediately.',
  },
  {
    icon: '🏷️',
    name: 'Auto-Attribution',
    description: 'LimeCall automatically captures UTM parameters, referring URLs, and keyword data for every call. See which source, medium, and campaign drove each conversation.',
  },
  {
    icon: '🔗',
    name: 'CRM Sync on Day 1',
    description: 'Call data syncs to HubSpot, Salesforce, Pipedrive, or Zoho automatically from the moment you go live. No manual setup required.',
  },
  {
    icon: '📊',
    name: 'Live Analytics Dashboard',
    description: 'A real-time dashboard shows call volume by channel, keyword, and campaign. Spot your best performers and cut spend on what isn\'t working.',
  },
  {
    icon: '📣',
    name: 'Google Ads Connection',
    description: 'Connect to Google Ads and import call conversions directly into your campaigns. Optimise bidding based on calls-to-close, not just clicks.',
  },
  {
    icon: '🎁',
    name: 'First Call Free',
    description: 'Start with LimeCall\'s free plan — no credit card, no time limit. Track your first calls and see the attribution data before committing to a paid plan.',
  },
];

const useCases = [
  {
    icon: '💰',
    title: 'PPC Attribution',
    description: 'Know exactly which Google or Meta ad keyword drives phone calls — not just clicks. Optimise bids toward calls that actually convert into customers.',
  },
  {
    icon: '🔍',
    title: 'SEO Call Tracking',
    description: 'See which organic landing pages drive the most calls. Use this data to prioritise SEO investment on pages that generate revenue, not just traffic.',
  },
  {
    icon: '🧪',
    title: 'Landing Page Testing',
    description: 'A/B test landing pages and measure the impact on call volume and quality — not just form conversion. Get a complete conversion picture.',
  },
  {
    icon: '🎓',
    title: 'Sales Call Coaching',
    description: 'Record and review calls to coach reps on handling objections, qualifying leads, and closing deals. Turn every call into a learning opportunity.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Sign Up & Get Your Script',
    description: 'Create a free LimeCall account and copy your unique tracking script from the dashboard. No credit card required.',
  },
  {
    number: '02',
    title: 'Paste onto Your Website',
    description: 'Paste the script into your website\'s header — in Google Tag Manager, your CMS, or directly in your HTML. Call tracking is live instantly.',
  },
  {
    number: '03',
    title: 'Watch Attribution Flow In',
    description: 'As calls come in, your dashboard fills with source, keyword, and campaign data. Connect to your CRM and Google Ads to complete the loop.',
  },
];

const faqs = [
  {
    question: 'How do I get started with call tracking?',
    answer: 'Sign up for a free LimeCall account, copy your tracking snippet from the dashboard, and paste it into your website header or Google Tag Manager. Call tracking starts working immediately — no developer, no waiting, no complex configuration.',
  },
  {
    question: 'Do I need a developer to set up call tracking?',
    answer: 'No. LimeCall call tracking is installed with a single copy-paste snippet — the same way you would add Google Analytics or a Facebook pixel. If you use Google Tag Manager, you can deploy it in under 2 minutes without touching your site code at all.',
  },
  {
    question: 'What do I need to get started with call tracking?',
    answer: 'All you need is a website and a LimeCall account (free to start). If you want attribution from Google Ads, you\'ll need a Google Ads account connected to LimeCall. For CRM sync, you\'ll need a supported CRM like HubSpot, Salesforce, Pipedrive, or Zoho.',
  },
  {
    question: 'How long does call tracking setup take?',
    answer: 'For basic call tracking, setup takes under 5 minutes — sign up, copy snippet, paste onto site. If you\'re also connecting Google Ads and a CRM, allow 15–20 minutes for the full configuration. Most customers are tracking calls and seeing attribution data within the same day they sign up.',
  },
  {
    question: 'Is call tracking free to try?',
    answer: 'Yes. LimeCall\'s free plan lets you start tracking calls immediately at no cost, with no time limit and no credit card required. The free plan includes 30 calls per month and basic attribution. Paid plans start at $29/month for higher volumes and advanced features.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqJsonLd} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Get Started with Call Tracking', url: `${site.url}/get-started-with-call-tracking/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        Call Tracking Setup
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Set Up Call Tracking in 5 Minutes.<br />
        <span class="text-lime-400">No Developer Needed.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        One copy-paste snippet gives you complete call attribution — which ads, keywords, and pages drive your phone calls. Start for free, see results the same day.
      </p>

      <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-900 px-5 py-3 font-mono text-sm text-lime-400">
        {'<script src="https://cdn.limecall.com/widget.js" data-id="YOUR_ID"></script>'}
      </div>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Tracking Free
        </a>
        <a
          href="/call-tracking"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          Learn About Call Tracking
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Free plan available · No credit card · Tracks calls in under 5 minutes</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/60 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-center">
        {stats.map((s) => (
          <div class="p-4">
            <div class="text-4xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-2 text-sm font-bold text-white">{s.label}</div>
            <div class="mt-1 text-xs text-dark-500">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Everything Included in<br />
          <span class="text-lime-400">Your Free Call Tracking Setup</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          LimeCall gives you attribution, analytics, CRM sync, and more — all from the moment you paste in the script.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{f.name}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          What You Can Do with<br />
          <span class="text-lime-400">Call Tracking Data</span>
        </h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {useCases.map((uc) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-3">{uc.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Up and Running in<br />
          <span class="text-lime-400">3 Steps</span>
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="relative flex flex-col rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="text-4xl font-extrabold text-lime-500/20 mb-4 leading-none">{step.number}</div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Know What's Driving Your Calls.<br />
        <span class="text-lime-400">Start Tracking Free Today.</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        One script tag gives you full call attribution. Free to start — no credit card, no developer, no waiting.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free — No Card Needed
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          View Pricing
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">Free plan: 30 calls/month · Paid from $29/month · Cancel anytime</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="Explore More Call Tracking Resources"
        links={[
          { href: '/call-tracking', title: 'Call Tracking Overview', desc: 'Everything you need to know about call tracking.' },
          { href: '/features', title: 'All Features', desc: 'Explore the full LimeCall feature set.' },
          { href: '/pricing', title: 'Pricing', desc: 'Free plan available. Paid from $29/month.' },
          { href: '/how-it-works', title: 'How It Works', desc: 'A complete walkthrough of the LimeCall platform.' },
        ]}
      />
    </div>
  </section>
</Base>
