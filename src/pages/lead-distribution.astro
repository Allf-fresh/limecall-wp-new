---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Lead Distribution — Route Leads to the Right Rep | LimeCall`,
  description: `Qualify and distribute your leads automatically with LimeCall. Route incoming calls and leads to the right agent faster and increase conversions.`,
  canonical: `https://www.limecall.com/lead-distribution/`,
};

const features = [
  { title: "Automatic Distribution", desc: "Leads are distributed to the right rep the moment they arrive — no manual work, no delays." },
  { title: "Multi-Channel Lead Intake", desc: "Receive leads from calls, forms, SMS, and web widgets. All leads flow into one distribution engine." },
  { title: "Custom Routing Rules", desc: "Define exactly how leads are distributed — by territory, skill, availability, product, or any custom criteria." },
  { title: "Real-Time Rep Availability", desc: "LimeCall checks rep availability before routing. Leads always go to someone ready to respond." },
  { title: "Overflow Handling", desc: "When all reps are busy, leads queue or overflow to the next available team member. No lead is ever lost." },
  { title: "Distribution Reporting", desc: "Full visibility into lead distribution metrics — volume by rep, response times, acceptance rates, and conversion." },
];

const steps = [
  { n: "1", title: "Lead arrives", desc: "A new lead is captured from your website, phone, or any channel connected to LimeCall." },
  { n: "2", title: "Qualifying & matching", desc: "LimeCall qualifies the lead and matches it to the best available rep using your routing rules." },
  { n: "3", title: "Distributed instantly", desc: "The lead is assigned and the rep is notified — or directly connected via callback — within seconds." },
];

const stats = [
  { value: "391%", label: "More conversions, <1 min response" },
  { value: "<1s", label: "Distribution decision time" },
  { value: "3x", label: "Higher rep contact rate" },
  { value: "100%", label: "Lead coverage, no drops" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is lead distribution?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Lead distribution is the process of assigning inbound leads to the appropriate sales rep or team as soon as they arrive. Automated lead distribution software like LimeCall evaluates each lead against configurable rules — territory, skills, availability — and routes it instantly, without any manual intervention.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is round-robin different from skills-based routing?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Round-robin distribution rotates leads equally across all available reps regardless of their skills or specialization. Skills-based routing matches each lead to the rep most qualified to handle it — for example, routing enterprise leads to senior reps and SMB leads to junior reps. LimeCall supports both methods and lets you combine them.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can leads be distributed by territory or geography?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall supports territory-based distribution using the lead\'s phone area code, IP geolocation, or CRM field data. You can define geographic territories and ensure each lead is always routed to the rep responsible for that region.',
      },
    },
    {
      '@type': 'Question',
      name: 'What CRMs does LimeCall sync with for lead distribution?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall integrates natively with Salesforce, HubSpot, Pipedrive, Zoho CRM, and many others. Every distributed lead is automatically logged in your CRM with routing details, response time, and call outcome. Zapier integration extends support to hundreds of additional tools.',
      },
    },
    {
      '@type': 'Question',
      name: 'What happens to overflow leads when all reps are busy?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall has configurable overflow rules. When all reps are busy, leads can be queued with a wait-time estimate, routed to a backup team or after-hours number, sent an automated SMS acknowledgement, or scheduled for a callback at the next available slot. No lead is ever simply dropped.',
      },
    },
  ],
};

const comparisonRows = [
  { label: "Assignment speed", automated: "< 1 second", manual: "Minutes to hours" },
  { label: "Available 24/7", automated: "Yes", manual: "No" },
  { label: "Skill-based matching", automated: "Yes", manual: "Inconsistent" },
  { label: "Overflow handling", automated: "Automatic failover", manual: "Leads dropped" },
  { label: "Attribution tracking", automated: "Full CRM sync", manual: "Often lost" },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Lead Distribution", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Lead Distribution Platform
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Lead Distribution That <span class="text-lime-400">Increases Conversions</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Route every inbound lead to the right sales rep automatically. LimeCall's lead distribution platform qualifies, routes, and connects leads faster than any manual process.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Lead distribution features</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How lead distribution works</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison: automated vs manual -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Automated distribution vs. manual assignment</h2>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900/80">
              <th class="px-5 py-4 text-left font-semibold text-dark-300"></th>
              <th class="px-5 py-4 text-center font-semibold text-lime-400">LimeCall Automated</th>
              <th class="px-5 py-4 text-center font-semibold text-dark-300">Manual Assignment</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800 ${i % 2 === 0 ? 'bg-dark-900/40' : 'bg-dark-900/20'}`}>
                <td class="px-5 py-4 font-medium text-dark-300">{row.label}</td>
                <td class="px-5 py-4 text-center font-semibold text-lime-400">{row.automated}</td>
                <td class="px-5 py-4 text-center text-dark-400">{row.manual}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(q => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {q.name}
              <span class="ml-4 shrink-0 text-lime-400 transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{q.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Start distributing leads smarter</h2>
      <p class="mt-4 text-dark-400">LimeCall's lead distribution is included in Starter and Pro plans. Start your free trial today.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/automatic-lead-distribution/', title: 'Automatic Distribution', desc: 'Automated lead assignment.' },
        { href: '/instant-lead-routing/', title: 'Instant Lead Routing', desc: 'Route leads in real time.' },
        { href: '/lead-distribution-guide/', title: 'Distribution Guide', desc: 'Complete guide to lead distribution.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
