---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Cart Abandonment Recovery Callback Software | LimeCall',
  description: 'LimeCall recovers abandoned carts with instant callbacks, connecting e-commerce stores with buyers in 28 seconds. Shopify & WooCommerce ready. Free trial.',
  canonical: 'https://www.limecall.com/ecommerce/',
};

const stats = [
  { value: '70%', label: 'Average e-commerce cart abandonment rate' },
  { value: '28s', label: 'Shopper connected to your sales team' },
  { value: '3×', label: 'Higher order value on callback-closed sales' },
  { value: '372%', label: 'Average increase in qualified leads' },
];

const features = [
  { icon: '🛒', title: 'Cart Abandonment Recovery', desc: 'Trigger callbacks automatically when a shopper exits with items in their cart — reach them before they buy elsewhere.' },
  { icon: '⚡', title: '28-Second Connection', desc: 'From callback request to live conversation in under 28 seconds. High-intent buyers don\'t wait around — neither should you.' },
  { icon: '🏪', title: 'Product Page Widgets', desc: 'Add callback widgets on high-value product pages. Hesitant buyers get their questions answered instantly and convert.' },
  { icon: '📦', title: 'Order Tracking Callbacks', desc: 'Let customers request order update callbacks instead of waiting in chat queues — reduce support tickets and churn.' },
  { icon: '🔌', title: 'Shopify & WooCommerce Integration', desc: 'Native 5-minute setup for Shopify and WooCommerce. No developers needed — install, configure, go live.' },
  { icon: '💬', title: 'WhatsApp Click-to-Chat', desc: 'Offer WhatsApp as an alternative to calls. Shoppers who prefer messaging get instant responses on the channel they trust.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall help e-commerce stores reduce cart abandonment?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "LimeCall places a callback widget on cart and checkout pages. When a shopper shows exit intent or has been inactive, the widget prompts them to request a callback. Your sales team is connected within 28 seconds to answer questions, offer assistance, and close the sale — before the shopper buys from a competitor. For high-value carts, this real-time intervention is the difference between a lost sale and a conversion.",
      },
    },
    {
      '@type': 'Question',
      name: 'What triggers the callback widget for e-commerce shoppers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall widgets can be triggered by multiple behaviours: exit intent (mouse moving toward browser close), time on page (long dwell time suggesting indecision), cart value threshold (show the widget only for carts above a set value), specific page visits (product pages, checkout, pricing), or manual click. You have full control over trigger rules to match your store\'s conversion strategy.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall integrate with Shopify and WooCommerce?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall has native integrations for both Shopify and WooCommerce, plus a universal JavaScript snippet for any other platform. Setup takes under 5 minutes with no developer required. Call data integrates with your CRM and order management system via direct integrations or Zapier (1,000+ apps).',
      },
    },
    {
      '@type': 'Question',
      name: 'Can we use LimeCall for WhatsApp as well as phone callbacks?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Yes. LimeCall's WhatsApp click-to-chat feature lets shoppers start a WhatsApp conversation instead of a phone callback. This is particularly effective for international shoppers or mobile-first audiences who prefer messaging. You can offer both phone and WhatsApp options simultaneously on the same widget.",
      },
    },
    {
      '@type': 'Question',
      name: 'How does callback compare to email for cart recovery?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Cart abandonment emails average a 5–10% recovery rate. Phone callbacks deliver 3–5× higher conversion rates because they address objections in real time, build trust through a human voice, and create urgency. Callbacks are especially effective for high-value orders where the shopper has a genuine question — not just distraction — as the reason for abandonment.',
      },
    },
    {
      '@type': 'Question',
      name: 'What e-commerce businesses see the best results with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "LimeCall delivers the strongest ROI for stores with average order values above $100, B2B wholesale e-commerce, subscription businesses, and retailers selling products that require pre-purchase consultation (e.g., electronics, furniture, custom products). If your shoppers have questions before buying, a callback converts them. LimeCall is used by DTC brands, multi-channel retailers, and B2B wholesalers in 40+ countries.",
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumbs items={[{ name: 'E-Commerce', url: `${site.url}/ecommerce/` }]} />
      <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400">
        🛒 For E-Commerce Stores
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Cart Abandonment Recovery<br class="hidden sm:block" />
        <span class="text-lime-400">Callback — Close Sales in 28 Seconds</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300">
        70% of shoppers abandon their carts. Most won't come back. LimeCall connects your sales team with hesitant buyers in under 28 seconds — before they buy from your competitor.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center justify-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free Trial — 14 Days
        </a>
        <a href="/demo/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-dark-700 px-8 py-4 text-sm font-semibold text-white transition hover:border-lime-500/40 hover:text-lime-400">
          See It In Action →
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">★ Shopify &amp; WooCommerce Ready · No Developers · 5-Minute Setup</p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-dark-800 bg-dark-900/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <dt class="text-3xl font-extrabold text-lime-400">{s.value}</dt>
            <dd class="mt-1 text-sm text-dark-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Problem callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-orange-500/20 bg-orange-500/5 p-8">
        <h2 class="text-xl font-bold text-white mb-3">⚠️ Your Retargeting Ads Are Working. Your Follow-Up Isn't.</h2>
        <p class="text-dark-300">
          You spend thousands driving traffic to your store. Shoppers add to cart. Then they leave. Your retargeting ads bring some back — at high cost. But the fastest, cheapest, highest-converting recovery method is a phone call made within 28 seconds of abandonment. Most stores don't have this. You can.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">How LimeCall Works for E-Commerce</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: '01', title: 'Shopper Shows Purchase Intent', desc: 'LimeCall widget appears on product pages, cart, and checkout — or triggers on exit intent for high-value carts.' },
          { step: '02', title: 'Shopper Requests Callback', desc: 'One click to request a call. LimeCall simultaneously dials your sales team and the shopper.' },
          { step: '03', title: 'Sale Closed in Real Time', desc: 'Your rep answers questions, offers confidence, processes the order on the call. Average order value 3× higher vs self-serve.' },
        ].map(item => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-lg">{item.step}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-dark-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">Everything Your Store Needs to Close More Sales</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-dark-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">E-Commerce Use Cases</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'High-Value Cart Recovery', desc: 'Cart value above $200? Trigger an instant callback. Convert hesitant shoppers before they leave.' },
          { title: 'Pre-Purchase Questions', desc: 'Product page → callback request → questions answered → sale closed. No more "I\'ll think about it."' },
          { title: 'Subscription Upsell', desc: 'New customer on the call? Your rep offers the subscription tier. Lifetime value multiplied.' },
          { title: 'B2B Wholesale Enquiries', desc: 'Trade buyers have complex needs. Callback connects them to your wholesale team in seconds.' },
        ].map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="font-bold text-white mb-2">{u.title}</h3>
            <p class="text-sm text-dark-400">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case study quote -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <blockquote class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-10 text-center">
        <p class="text-xl text-white italic leading-relaxed">
          "$42,000 in abandoned cart revenue recovered in our first month. We added LimeCall to our checkout page and the widget paid for itself on day three."
        </p>
        <footer class="mt-6">
          <p class="font-bold text-lime-400">Marcus T.</p>
          <p class="text-sm text-dark-500">Head of E-Commerce, DTC furniture brand</p>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-4">LimeCall vs. Other Cart Recovery Methods</h2>
      <p class="text-center text-dark-400 text-sm mb-12 max-w-2xl mx-auto">
        Email and retargeting recover a fraction of abandoned carts. Callbacks close the ones that matter — high-value, high-intent buyers who just need a nudge.
      </p>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              {['Feature', 'LimeCall', 'Email Recovery', 'Retargeting Ads', 'Live Chat', 'SMS'].map(h => (
                <th class={`px-4 py-4 text-left font-semibold ${h === 'LimeCall' ? 'text-lime-400' : 'text-dark-300'}`}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['Response time', '28 seconds', '1–24 hours', '1–72 hours', 'Agent dependent', '1–60 min'],
              ['Recovery rate', '🟢 20–40%', '🟡 5–10%', '🟡 5–15%', '🟡 10–20%', '🟡 8–15%'],
              ['Order value impact', '3× higher', 'Baseline', 'Baseline', '~1.2×', '~1.1×'],
              ['Real-time objection handling', '✅ Yes', '❌ No', '❌ No', '✅ Yes', '❌ No'],
              ['Works without email', '✅ Yes', '❌ Requires email', '❌ Requires pixel', '✅ Yes', '⚠️ Requires number'],
              ['Ongoing ad spend', '❌ None', '❌ None', '⚠️ High cost', '❌ None', '❌ None'],
              ['Setup time', '5 minutes', '1–2 hours', '1–2 days', '1–2 hours', '1–2 hours'],
            ].map(([feature, ...vals]) => (
              <tr class="hover:bg-dark-800/30 transition">
                <td class="px-4 py-4 font-medium text-dark-200">{feature}</td>
                {vals.map((v, i) => (
                  <td class={`px-4 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Platform integration callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-dark-700 bg-dark-900/60 p-8 sm:p-10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
          <div class="shrink-0">
            <div class="flex items-center gap-3">
              <span class="rounded-xl bg-dark-800 px-4 py-2 text-sm font-bold text-white border border-dark-700">Shopify</span>
              <span class="text-dark-600">+</span>
              <span class="rounded-xl bg-dark-800 px-4 py-2 text-sm font-bold text-white border border-dark-700">WooCommerce</span>
            </div>
          </div>
          <div>
            <h2 class="text-lg font-bold text-white mb-1">5-Minute Setup on Any Platform</h2>
            <p class="text-dark-400 text-sm leading-relaxed">
              LimeCall works natively with Shopify and WooCommerce — no coding, no developer. Install the app or drop in the script tag, configure your routing rules, and go live. Connects to your CRM and order management via direct integrations or Zapier.
            </p>
            <a href="/integrations/" class="mt-3 inline-flex items-center text-sm font-semibold text-lime-400 hover:text-lime-300 transition">
              See all platform integrations →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ROI section -->
  <section class="py-16 sm:py-20 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-10">The Math on Cart Recovery Callbacks</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          { label: 'If you have 1,000 cart abandonments/month', value: '70 recoveries', sub: 'At 7% callback recovery rate (conservative)' },
          { label: 'Average order value $150 × 70 recoveries', value: '$10,500', sub: 'Additional monthly revenue from callbacks alone' },
          { label: 'LimeCall cost vs. revenue recovered', value: '50–100×', sub: 'Typical return on investment in first 90 days' },
        ].map(item => (
          <div class="rounded-xl border border-lime-500/20 bg-lime-500/5 p-6 text-center">
            <p class="text-sm text-dark-400 mb-3">{item.label}</p>
            <p class="text-3xl font-extrabold text-lime-400 mb-1">{item.value}</p>
            <p class="text-xs text-dark-500">{item.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WhatsApp callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-green-500/20 bg-green-500/5 p-8 flex flex-col sm:flex-row items-center gap-6">
        <div class="text-5xl shrink-0">💬</div>
        <div>
          <h2 class="text-xl font-bold text-white mb-2">Add WhatsApp to Your Recovery Stack</h2>
          <p class="text-dark-400 text-sm leading-relaxed mb-3">
            Some shoppers won't pick up the phone — but they will respond on WhatsApp. LimeCall's click-to-WhatsApp feature lets you offer both callback and WhatsApp on the same widget. Capture more hesitant buyers on the channel they prefer.
          </p>
          <a href="/click-to-whatsapp/" class="inline-flex items-center text-sm font-semibold text-lime-400 hover:text-lime-300 transition">
            Learn about WhatsApp click-to-chat →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {item.name}
              <span class="ml-4 shrink-0 text-lime-400 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-gradient-to-br from-lime-500/10 to-dark-900 border-t border-lime-500/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Recover Your Next Abandoned Cart</h2>
      <p class="mt-4 text-lg text-dark-300">14-day free trial · Shopify &amp; WooCommerce ready · 5-minute setup</p>
      <a href="/signup" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-lime-500 px-10 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
        Try Free — 14 Days →
      </a>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime · Trusted by 10,000+ businesses</p>
    </div>
  </section>

  <!-- Cross-links -->
  <div class="py-12 bg-dark-950 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore More" links={[
        { href: '/limecall-for-ecommerce-and-retail-2/', title: 'E-Commerce & Retail', desc: 'Full e-commerce and retail solution overview.' },
        { href: '/click-to-whatsapp/', title: 'WhatsApp Click-to-Chat', desc: 'Add WhatsApp to your recovery stack.' },
        { href: '/lead-capture-software/', title: 'Lead Capture Software', desc: 'Capture and qualify every inbound lead.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Plans from $0/month. Scale as you grow.' },
      ]} />
    </div>
  </div>
</Base>
