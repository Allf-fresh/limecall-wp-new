---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const seo = {
  title: `How It Works | Convert Leads | Callback Software | LimeCall`,
  description: `Tracy is the owner of her own luxury travel consultancy. She signs up for LimeCall and is able to qualify and convert leads within 28 seconds round the clock.`,
  canonical: `https://www.limecall.com/how-it-works/`,
};

const steps = [
  {
    n: "1",
    label: "Visitor sees your widget",
    heading: "A visitor lands on your site",
    desc: "LimeCall's lightweight widget loads on your website — on any page, for any visitor. It appears as a small, unobtrusive button that invites them to request an instant call back.",
    detail: "Triggers on: pricing pages, product pages, landing pages, checkout, or everywhere. Fully customizable color, text, and timing.",
  },
  {
    n: "2",
    label: "They request a callback",
    heading: "One click. They enter their number.",
    desc: "The visitor clicks the widget, enters their phone number, and hits call. The entire interaction takes under 10 seconds. No forms. No waiting room. No friction.",
    detail: "Optionally: ask for name, company, or a message. Or go frictionless with just a phone number.",
  },
  {
    n: "3",
    label: "Simultaneous connection",
    heading: "LimeCall dials both sides simultaneously",
    desc: "The moment the request is submitted, LimeCall dials your team's number and the visitor's number at the same time. The call connects in under 28 seconds.",
    detail: "Routes to the right rep based on availability, skills, territory, or round-robin. Falls back to the next available if the first rep doesn't pick up.",
  },
  {
    n: "4",
    label: "Live conversation",
    heading: "They're talking to your team",
    desc: "Your rep and the visitor are connected. The rep has the lead's context — page they came from, device, referral source, and any CRM data already on file.",
    detail: "Average conversation lasts 4 minutes. That's enough time to qualify, pitch, and close — or book the next step.",
  },
  {
    n: "5",
    label: "Logged & followed up",
    heading: "Everything is recorded and synced",
    desc: "The call is recorded automatically. Call duration, recording, and outcome sync to your CRM — HubSpot, Salesforce, Zoho, or Zendesk. Your pipeline is always up to date.",
    detail: "Missed the call? LimeCall sends an SMS to the visitor and queues the lead for your team with full context.",
  },
];

const stats = [
  { value: "28s", label: "Average time to connect" },
  { value: "3x", label: "More conversions vs. web forms" },
  { value: "80%", label: "Fewer missed leads" },
  { value: "5 min", label: "To set up and go live" },
];

const features = [
  {
    title: "Instant Callback",
    desc: "The core feature — connect website visitors with your team in under 28 seconds. Works 24/7. No hold music. No IVR maze.",
    href: "/click-2-call/",
  },
  {
    title: "Scheduled Callbacks",
    desc: "Visitors who aren't available right now can schedule a callback at a time that works for both sides. Reduce no-shows and fill your calendar.",
    href: "/conversation-scheduling/",
  },
  {
    title: "SMS & Web to Text",
    desc: "Not every visitor wants a phone call. Let them start a text conversation instead — capture leads who prefer messaging.",
    href: "/business-texting/",
  },
  {
    title: "Lead Distribution",
    desc: "Automatically route every inbound lead to the right rep based on skills, geography, availability, or custom rules.",
    href: "/lead-distribution/",
  },
  {
    title: "Virtual Numbers",
    desc: "Show local phone numbers in 50+ countries. Build trust with international visitors using a number that looks familiar to them.",
    href: "/virtual-numbers/",
  },
  {
    title: "Call Tracking & Analytics",
    desc: "See which campaigns, pages, and sources drive the most callbacks. Attribute conversions to channels and optimize your spend.",
    href: "/call-tracking/",
  },
];
---

<Base {...seo}>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'How It Works', url: seo.canonical }]} />
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        See LimeCall<br class="hidden sm:block" />
        <span class="text-lime-400">in Action</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        A visitor clicks your widget. LimeCall connects them to your team in 28 seconds. Here's exactly how it happens — from first click to logged call.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free — No CC Required</a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">Watch Demo →</a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Step-by-step flow -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-14 text-center text-2xl font-bold text-white sm:text-3xl">
        From widget click to live call — in 5 steps
      </h2>

      <div class="space-y-10">
        {steps.map((step, i) => (
          <div class="grid gap-6 sm:grid-cols-[80px_1fr] items-start">
            <div class="flex flex-col items-center gap-2">
              <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 text-xl font-extrabold text-lime-400 border border-lime-500/30">
                {step.n}
              </div>
              {i < steps.length - 1 && (
                <div class="hidden sm:block w-px flex-1 bg-dark-800 mt-2" style="height: 40px;"></div>
              )}
            </div>
            <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 sm:p-8">
              <p class="mb-1 text-xs font-bold uppercase tracking-widest text-lime-500/70">{step.label}</p>
              <h3 class="mb-3 text-xl font-bold text-white">{step.heading}</h3>
              <p class="text-dark-300 leading-relaxed">{step.desc}</p>
              <p class="mt-3 text-sm text-dark-500 leading-relaxed">{step.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Video placeholder -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/40">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">See it in 2 minutes</h2>
      <p class="mb-10 text-center text-dark-400">Watch how LimeCall connects a visitor to a sales rep in under 28 seconds.</p>
      <div class="relative overflow-hidden rounded-2xl border border-dark-700 bg-dark-950 aspect-video flex items-center justify-center">
        <div class="absolute inset-0 bg-gradient-to-br from-dark-900 to-dark-950"></div>
        <div class="relative z-10 text-center">
          <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-lime-500/20 border-2 border-lime-500/40 cursor-pointer hover:bg-lime-500/30 transition">
            <svg class="h-8 w-8 text-lime-400 ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
          <p class="text-white font-semibold">Watch the LimeCall Demo</p>
          <p class="mt-2 text-sm text-dark-400">2-minute walkthrough</p>
          <a href="/demo/" class="mt-6 inline-block rounded-xl bg-lime-500 px-8 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">Watch Full Demo →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature highlights -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Everything in the LimeCall platform</h2>
      <p class="mb-10 text-center text-dark-400 max-w-2xl mx-auto">LimeCall is more than a callback widget. It's a full lead-conversion platform with every channel you need to capture and convert website visitors.</p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <a href={f.href} class="group rounded-xl border border-dark-800 bg-dark-900/60 p-6 hover:border-lime-500/40 transition">
            <h3 class="mb-2 font-semibold text-white group-hover:text-lime-400 transition">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Setup section -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Set up in 5 minutes</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { n: "1", title: "Sign up free", desc: "Create your LimeCall account. No credit card required. Free plan available with 30 calls/month." },
          { n: "2", title: "Add the widget", desc: "Copy one snippet of code and paste into your website. Works with WordPress, Webflow, Shopify, or any HTML site." },
          { n: "3", title: "Start receiving calls", desc: "Your widget is live. The moment a visitor clicks, LimeCall connects them to you in under 28 seconds." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Ready to connect with your<br class="hidden sm:block" />
        next visitor in 28 seconds?
      </h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · Live in 5 minutes</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free Trial →</a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 font-bold text-white hover:border-lime-500/40 transition">View Pricing</a>
      </div>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore LimeCall" links={[
        { href: '/features/', title: 'All Features', desc: 'Every feature included in every plan.' },
        { href: '/integrations/', title: 'Integrations', desc: 'Connect LimeCall with your existing tools.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple plans starting at $0/month.' },
        { href: '/why-limecall/', title: 'Why LimeCall', desc: 'What makes LimeCall different.' },
      ]} />
    </div>
  </div>
</Base>
