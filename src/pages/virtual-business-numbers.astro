---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Virtual Business Numbers — Professional Numbers Instantly | LimeCall',
  description: 'Get a professional virtual business number in any country in minutes. 40+ countries, instant activation, no hardware needed. Port your existing number too.',
  canonical: `${site.url}/virtual-business-numbers/`,
};

const stats = [
  { value: '40+', label: 'Countries', sub: 'Local and toll-free numbers in every major market' },
  { value: 'Instant', label: 'Activation', sub: 'Your number is live in under 5 minutes' },
  { value: '0', label: 'Hardware Needed', sub: 'Use any device — desktop, laptop, or mobile' },
  { value: 'Free', label: 'Number Porting', sub: 'Keep your existing number when you switch' },
];

const features = [
  {
    icon: '📍',
    name: 'Local Numbers',
    description: 'Get numbers with local area codes in 40+ countries. Customers see a familiar local number and are more likely to answer your calls. Get a <a href="/uk-virtual-phone-number/" class="text-lime-400 hover:underline">UK virtual phone number</a> or a <a href="/us-virtual-phone-number/" class="text-lime-400 hover:underline">US virtual phone number</a> in minutes.',
  },
  {
    icon: '🆓',
    name: 'Toll-Free Numbers',
    description: 'Give customers a free-to-call number that projects enterprise credibility. Available in the US, UK, AU, CA, and more countries. Browse all options on our <a href="/virtual-numbers/" class="text-lime-400 hover:underline">virtual numbers</a> page.',
  },
  {
    icon: '✨',
    name: 'Vanity Numbers',
    description: 'Choose a memorable number pattern that spells your brand or is easy to recall. Perfect for advertising campaigns and brand awareness.',
  },
  {
    icon: '🔄',
    name: 'Number Porting',
    description: 'Keep your existing business number when switching to LimeCall. We handle the entire porting process — most numbers transfer in 5–10 business days.',
  },
  {
    icon: '📡',
    name: 'Call Forwarding',
    description: 'Forward calls from your virtual number to any phone — mobile, desk phone, or a team of agents. Rings wherever your team is working.',
  },
  {
    icon: '👥',
    name: 'Shared Team Number',
    description: 'Give your whole team one shared number. Calls ring to all available agents and the first to answer gets connected. No missed calls.',
  },
];

const useCases = [
  {
    icon: '🌍',
    title: 'Local Presence in New Markets',
    description: 'Entering a new country? Get a local number before you have an office. Customers trust local numbers and call them at far higher rates.',
  },
  {
    icon: '🏠',
    title: 'Remote Team Numbers',
    description: 'Your distributed team can all answer calls from a single business number regardless of where they are in the world.',
  },
  {
    icon: '📊',
    title: 'Campaign Tracking Numbers',
    description: 'Assign a unique virtual number to each campaign, channel, or landing page to measure exactly where each call originated.',
  },
  {
    icon: '🏢',
    title: 'Multi-Location Businesses',
    description: 'Each location gets its own local number with local routing — while you manage all numbers, teams, and analytics from one central dashboard.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Choose Your Country & Number Type',
    description: 'Select a country and choose from local, toll-free, or vanity number options. Browse available numbers and pick the one that fits your brand.',
  },
  {
    number: '02',
    title: 'Configure Routing & Team',
    description: 'Set which team members or devices should receive calls on this number. Configure business hours, voicemail, and ring strategy.',
  },
  {
    number: '03',
    title: 'Your Number is Live',
    description: 'Your virtual business number is active within minutes. Share it on your website, ads, and business cards — start receiving calls immediately.',
  },
];

const faqs = [
  {
    question: 'What is a virtual business number?',
    answer: 'A virtual business number is a telephone number that is not tied to a specific phone line or physical location. Calls to the number are routed over the internet (VoIP) to any device you choose — a mobile, a laptop app, or a desk phone. You get all the professionalism of a dedicated business number without any hardware.',
  },
  {
    question: 'How quickly can I get a virtual business number?',
    answer: 'Virtual numbers are activated instantly in most countries. After signing up for LimeCall, you can have a local or toll-free number live and receiving calls within 5 minutes. Number porting (transferring your existing number) typically takes 5–10 business days.',
  },
  {
    question: 'Can I keep my current business number?',
    answer: 'Yes. LimeCall supports number porting for the US, UK, Canada, Australia, and most other major countries. You submit a porting request in your dashboard, and we handle the process with your current carrier. Calls forward automatically during the transition so you never miss anything.',
  },
  {
    question: 'Do virtual business numbers work for SMS?',
    answer: 'Yes. LimeCall virtual numbers support both voice and SMS in supported countries. You can send and receive text messages from your business number, set up automated SMS responses, and manage all messages from the LimeCall dashboard.',
  },
  {
    question: 'How much do virtual business numbers cost?',
    answer: 'Virtual numbers are included in LimeCall\'s Pro plan at $99/month, which also includes unlimited widgets, 500 calls/month, API access, and more. Individual numbers can also be provisioned on lower plans. See our pricing page for current rates.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqJsonLd} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Virtual Business Numbers', url: `${site.url}/virtual-business-numbers/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        Virtual Numbers
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Get a Professional Business Number<br />
        <span class="text-lime-400">in Any Country in Minutes</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Local, toll-free, or vanity numbers in 40+ countries — activated instantly, no hardware required. Build local trust in new markets or give your remote team a professional number to share.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Get Your Number Free
        </a>
        <a
          href="/incoming-numbers"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          Browse Available Numbers
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Instant activation · Number porting available · No hardware needed</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/60 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-center">
        {stats.map((s) => (
          <div class="p-4">
            <div class="text-4xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-2 text-sm font-bold text-white">{s.label}</div>
            <div class="mt-1 text-xs text-dark-500">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Every Number Type Your<br />
          <span class="text-lime-400">Business Could Need</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Local, toll-free, vanity, ported — all managed from one dashboard, all powered by LimeCall's cloud infrastructure.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{f.name}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Who Gets Virtual Business<br />
          <span class="text-lime-400">Numbers from LimeCall?</span>
        </h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {useCases.map((uc) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-3">{uc.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Get Your Number Live in<br />
          <span class="text-lime-400">Under 5 Minutes</span>
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="relative flex flex-col rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="text-4xl font-extrabold text-lime-500/20 mb-4 leading-none">{step.number}</div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Your Business Number.<br />
        <span class="text-lime-400">Any Country. Instant Activation.</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        Get a local or toll-free number in 40+ countries — live in minutes, managed from one dashboard.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Get Your Number Now
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          View Pricing
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">Free plan available · Instant activation · No hardware required</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="Explore More Number Options"
        links={[
          { href: '/incoming-numbers', title: 'Incoming Numbers', desc: 'Manage all your inbound numbers from one place.' },
          { href: '/local-numbers', title: 'Local Numbers', desc: 'Get local area code numbers in any city or country.' },
          { href: '/toll-free-numbers', title: 'Toll-Free Numbers', desc: 'Give customers a free-to-call business number.' },
          { href: '/pricing', title: 'Pricing', desc: 'Virtual numbers included on Pro plan and above.' },
        ]}
      />
    </div>
  </section>
</Base>
