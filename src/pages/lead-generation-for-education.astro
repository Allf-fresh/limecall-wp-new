---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const industry = "Education";
const icon = "🎓";

const seo = {
  title: `Education Lead Generation Software | LimeCall`,
  description: `Convert prospective students into enrolled learners. LimeCall's instant callback software helps schools, colleges, and online course providers respond to enrollment inquiries in under 28 seconds.`,
  canonical: `https://www.limecall.com/lead-generation-for-education/`,
};

const useCases = [
  { title: "Instant Callback on Enrollment Inquiries", desc: "When a prospective student requests information, they're evaluating multiple institutions simultaneously. LimeCall connects your admissions team in under 28 seconds, making your institution the first to have a real conversation." },
  { title: "Admissions Team Call Routing", desc: "Route inquiries to the right admissions counselor based on program interest, study level, or geographic region. Give every prospective student a personalized first contact." },
  { title: "Open Day & Event Follow-Up Callbacks", desc: "Capture callback requests from event attendees and prospective students who explored your open day materials. Automate follow-up sequences to keep them engaged through the enrollment decision." },
  { title: "International Student Lead Capture", desc: "Prospective students from different time zones inquire at all hours. Capture callbacks overnight and queue them for your admissions team to action at the start of each day." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More enrollments initiated" },
  { value: "80%", label: "Reduction in missed inquiries" },
  { value: "5 min", label: "Setup time" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall improve student enrollment rates?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '79% of prospective students want to speak with an advisor before enrolling, and a 5-minute callback response increases enrollment conversion by up to 200%. LimeCall connects your admissions team with inquiring students in under 28 seconds, ensuring you have a real conversation before they commit to another institution.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall handle enrollment callbacks for international students in different time zones?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall captures callback requests 24/7, regardless of time zone. International inquiries made outside of your office hours are logged and queued for your admissions team to action at the start of the next business day. Students receive confirmation that their request was received, keeping them engaged.'
      }
    },
    {
      '@type': 'Question',
      name: 'How do admissions teams use LimeCall during open days and recruitment events?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall can be embedded in event follow-up emails, virtual open day landing pages, and prospectus download pages. Prospective students who attended an event can request a personal callback with an admissions counselor in a single click, significantly reducing drop-off between event attendance and enrollment application.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall route course inquiry calls to the right faculty or department?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Absolutely. LimeCall supports routing rules based on the page or program a student was viewing when they requested the callback. Engineering inquiries route to engineering admissions, business school inquiries to business faculty — ensuring every student speaks to the most relevant person first.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall integrate with education CRM systems like Salesforce or HubSpot?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall integrates with Salesforce, HubSpot, and other CRM platforms used in education. Every callback, call recording, and outcome is automatically synced to the student record, giving admissions teams a complete view of each prospect\'s engagement history without manual data entry.'
      }
    },
  ]
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `Education Lead Generation`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{icon}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        <span class="text-lime-400">{industry}</span> Lead Generation Software
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Convert prospective students into enrolled learners. Respond to admissions inquiries in under 28 seconds while interest is at its highest.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Built for {industry} institutions</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How LimeCall works for Education</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Student requests info", desc: "A prospective student browses your programs page and clicks the LimeCall widget to request a callback from admissions." },
          { step: "2", title: "Admissions team connected", desc: "LimeCall calls your admissions counselor and the student simultaneously, connecting them in under 28 seconds." },
          { step: "3", title: "Enrollment journey begins", desc: "The conversation is logged and followed up automatically with next steps if the call isn't answered." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison section -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Why instant callbacks beat waiting list forms for student enrollment</h2>
      <p class="mb-10 text-center text-dark-400 text-sm max-w-2xl mx-auto">79% of prospective students want to speak with an advisor before enrolling. A waiting list form makes them feel like a number — a callback makes them feel valued.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 text-sm font-bold text-dark-400 uppercase tracking-wider">Waiting List / Enquiry Form</div>
          <ul class="space-y-3 text-sm text-dark-400">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Student submits interest and waits for a generic response email</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Impersonal follow-up fails to address specific course questions</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Student enrolls at a competing institution that called them first</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> International students fall through time zone gaps</li>
          </ul>
        </div>
        <div class="rounded-xl border border-lime-500/30 bg-lime-950/10 p-6">
          <div class="mb-4 text-sm font-bold text-lime-400 uppercase tracking-wider">LimeCall Instant Callback</div>
          <ul class="space-y-3 text-sm text-dark-300">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Student is speaking to admissions in under 28 seconds</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Personal, expert conversation answers specific course concerns</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> You're the first institution to build a real relationship</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> International inquiries captured 24/7 and queued for morning action</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="cursor-pointer list-none font-semibold text-white flex justify-between items-center gap-4">
              <span>{faq.name}</span>
              <span class="shrink-0 text-lime-400 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to enroll more students?</h2>
      <p class="mt-4 text-dark-400">Set up in 5 minutes. No credit card required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4">
    <CrossLinks heading="More LimeCall Solutions" links={[
      { href: '/click-to-call-software/', title: 'Click to Call', desc: 'Instant callbacks from your website.' },
      { href: '/conversation-scheduling/', title: 'Schedule Callbacks', desc: 'Let students book a call at their convenience.' },
      { href: '/healthcare-lead-generation/', title: 'Healthcare Lead Gen', desc: 'Callbacks for medical practices and clinics.' },
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
    ]} />
  </div>
</Base>
