---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Real Estate Marketing Tools — Generate More Leads`,
  description: `The most effective real estate marketing tool is a callback widget. Connect buyers to agents in 28 seconds. 3x more property viewings booked.`,
  canonical: `https://www.limecall.com/real-estate-marketing-tools/`,
};

const stats = [
  { value: "70%", label: "of buyers call before visiting" },
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More property viewings booked" },
  { value: "5 min", label: "Setup time" },
];

const features = [
  { title: "Instant callback widget", desc: "Place a callback widget on any listing page. Buyers click and talk to an agent in under 28 seconds — before they browse elsewhere." },
  { title: "Lead routing to agents", desc: "Route incoming leads to the right agent automatically — by area, availability, or skill. Every buyer reaches the most relevant expert." },
  { title: "Call recording", desc: "Record every call for quality assurance, training, and compliance. Review conversations to improve agent performance." },
  { title: "CRM sync", desc: "Every call and lead is automatically logged to your CRM — no manual data entry, no missed follow-ups." },
  { title: "After-hours capture", desc: "Queue callback requests from evenings and weekends. Start every Monday with warm leads ready to call." },
  { title: "Virtual numbers for local presence", desc: "Use local virtual numbers in any market to increase answer rates and build trust with buyers and sellers." },
];

const useCases = [
  { title: "New listing inquiries", desc: "Buyers browsing a new listing can request an instant callback. Capture them at peak interest before a competitor does." },
  { title: "Open house follow-up", desc: "Automatically follow up with attendees who didn't book a second viewing. Convert warm contacts into committed buyers." },
  { title: "Buyer qualification", desc: "Connect new leads to an agent immediately to qualify their budget, timeline, and requirements while intent is high." },
  { title: "Seller consultations", desc: "Homeowners thinking about selling can request a valuation callback from your listing pages in seconds." },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What are the best real estate marketing tools?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The most effective real estate marketing tools combine lead capture, instant communication, and CRM automation. A callback widget like LimeCall connects buyers to agents in under 28 seconds — the single most impactful tool for converting website traffic into booked viewings.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I get more real estate leads online?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Add a callback widget to your property listings and landing pages. Buyers who can request an instant callback convert at 3x the rate of those who fill out a form and wait. Pair this with after-hours lead capture so no enquiry is lost outside office hours.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is a callback widget for real estate?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A callback widget is a button on your real estate website that lets a buyer enter their number and receive an instant call from an agent — typically within 28 seconds. It eliminates the friction of phone-tag and connects buyer to agent at the moment of highest intent.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall compare to Zillow leads?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Zillow sells shared leads that go to multiple agents simultaneously. LimeCall converts your own website traffic into exclusive leads that ring your agents instantly. Your leads, your pipeline, no competition from other agents.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I route leads to specific agents?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall\'s lead routing lets you assign incoming calls by area, agent availability, round-robin, or custom rules. A buyer enquiring about a specific neighbourhood can be routed directly to the specialist who knows it best.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Real Estate Marketing Tools', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Real Estate
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        The most effective real estate<br class="hidden sm:block" />
        <span class="text-lime-400">marketing tool is a callback widget</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        70% of buyers call before visiting a property. LimeCall connects them to your agents in 28 seconds — generating more viewings, more offers, and more closings.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free Trial →</a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Everything you need to generate property leads</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Use cases for real estate teams</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 font-semibold text-white">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { n: "1", title: "Buyer sees your listing", desc: "A buyer browsing your property listing or landing page clicks the callback button." },
          { n: "2", title: "LimeCall connects in 28s", desc: "LimeCall dials the buyer and your agent simultaneously — they're talking in under 28 seconds." },
          { n: "3", title: "Viewing booked", desc: "Agent answers at peak intent. Viewing is booked on the first call, not after days of phone-tag." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(q => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <summary class="cursor-pointer font-semibold text-white">{q.name}</summary>
            <p class="mt-3 text-sm text-dark-400 leading-relaxed">{q.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Generate more property leads today</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free Trial →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related resources" links={[
        { href: '/real-estate-lead-generation-software/', title: 'Real Estate Lead Generation', desc: 'Generate more seller and buyer leads online.' },
        { href: '/limecall-for-real-estate/', title: 'LimeCall for Real Estate', desc: 'The full real estate platform guide.' },
        { href: '/lead-routing-software/', title: 'Lead Routing Software', desc: 'Automatically route leads to the right agent.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
