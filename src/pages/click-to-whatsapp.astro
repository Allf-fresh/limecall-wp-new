---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Click-to-WhatsApp — Turn Ads Into Conversations | LimeCall`,
  description: `Connect Facebook and Instagram ads directly to WhatsApp chat. LimeCall's Click-to-WhatsApp solution generates leads, captures contact details, and starts real conversations instantly.`,
  canonical: `https://www.limecall.com/click-to-whatsapp/`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is click to WhatsApp?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Click to WhatsApp is a feature that lets people start a WhatsApp conversation with your business by clicking a button on your website, ad, or social media post. Instead of filling out a form, the visitor is taken directly into WhatsApp and can message you instantly — no app download needed if WhatsApp is already installed.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I add a WhatsApp button to my website?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You can add a WhatsApp button to your website using LimeCall. After connecting your WhatsApp Business number, LimeCall generates a widget snippet you paste into your site. The button appears on your pages and opens a WhatsApp chat with your number when clicked — setup takes about 5 minutes.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need WhatsApp Business to use click to WhatsApp?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For website buttons and click-to-chat links, a regular WhatsApp account technically works, but WhatsApp Business is strongly recommended. It gives you a business profile, automated greetings, quick replies, and access to the WhatsApp Business API for higher-volume messaging and analytics.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I track WhatsApp leads with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall captures lead details from WhatsApp conversations — including contact number, name (if shared), and the source (which ad, page, or campaign triggered the conversation). This data is stored in LimeCall and can be synced to your CRM for full attribution.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is click-to-WhatsApp different from click-to-call?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Click-to-call connects a visitor directly to a live phone call with your team within 28 seconds. Click-to-WhatsApp opens a messaging chat on WhatsApp. Both drive conversations, but click-to-call is better for immediate high-intent sales calls, while click-to-WhatsApp suits customers who prefer text-based communication or are browsing outside business hours.',
      },
    },
  ],
};

const features = [
  { title: "Instant WhatsApp Conversations", desc: "Ad clicks open a WhatsApp chat immediately. No landing page, no form — just an instant conversation with your lead." },
  { title: "Facebook & Instagram Ads", desc: "Connect Meta ad campaigns directly to WhatsApp. Set up Click-to-WhatsApp ads in minutes from your LimeCall dashboard." },
  { title: "Website Widget", desc: "Add a WhatsApp chat button to your website. Visitors click to start a conversation without leaving the page." },
  { title: "Lead Capture & Routing", desc: "Automatically capture contact details from WhatsApp conversations and route leads to the right sales rep." },
  { title: "Broadcast Responses", desc: "Send follow-up messages to leads who started a WhatsApp conversation with your brand." },
  { title: "Analytics & Attribution", desc: "Track which ads, keywords, and pages drive WhatsApp conversations. Attribute revenue back to campaigns." },
];

const steps = [
  { n: "1", title: "Connect WhatsApp Business", desc: "Link your WhatsApp Business number to LimeCall. Takes just a few minutes to authorize." },
  { n: "2", title: "Set up your ads or widget", desc: "Create Click-to-WhatsApp ads in Meta Ads Manager, or add the LimeCall WhatsApp widget to your website." },
  { n: "3", title: "Capture and convert leads", desc: "Leads click and land in WhatsApp. LimeCall captures their details and routes to your team." },
];

const stats = [
  { value: "2B+", label: "WhatsApp users worldwide" },
  { value: "98%", label: "WhatsApp message open rate" },
  { value: "5x", label: "Higher engagement vs email" },
  { value: "40%", label: "Higher ad conversion with Click-to-WhatsApp" },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Click-to-WhatsApp", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        WhatsApp Lead Generation
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Turn Clicks Into <span class="text-lime-400">WhatsApp Conversations</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Connect your ads and website to WhatsApp Business. Leads click, conversations start instantly, and your team closes deals in the world's most popular messaging app.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 py-10 bg-dark-900/40">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <p class="text-3xl font-extrabold text-lime-400">{s.value}</p>
            <p class="mt-1 text-sm text-dark-400">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Everything in Click-to-WhatsApp</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Click-to-call vs click-to-WhatsApp callout -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Which is right for you?</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-lime-500/20 bg-lime-950/20 p-6">
          <h3 class="mb-3 font-semibold text-lime-400">Click-to-Call</h3>
          <ul class="space-y-2 text-sm text-dark-300">
            <li>Best for: immediate high-intent sales conversations</li>
            <li>Connected in under 28 seconds</li>
            <li>Live voice call with a rep</li>
            <li>Ideal for complex or high-value sales</li>
          </ul>
        </div>
        <div class="rounded-xl border border-dark-700 bg-dark-900/50 p-6">
          <h3 class="mb-3 font-semibold text-white">Click-to-WhatsApp</h3>
          <ul class="space-y-2 text-sm text-dark-300">
            <li>Best for: async messaging and after-hours leads</li>
            <li>Familiar, preferred by many mobile users</li>
            <li>Supports media, documents, and links</li>
            <li>Works across 180+ countries on 2B+ devices</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 group">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between">
              {item.name}
              <span class="ml-4 text-lime-400 text-xl leading-none group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Start converting leads on WhatsApp</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall to drive WhatsApp conversations from ads and websites.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/whatsapp-link-generator/', title: 'WhatsApp Link Generator', desc: 'Generate direct WhatsApp links free.' },
        { href: '/business-texting/', title: 'Business Texting', desc: 'Full SMS platform for your business.' },
        { href: '/click-to-call-software/', title: 'Click-to-Call Software', desc: 'Voice callbacks connected in 28 seconds.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
