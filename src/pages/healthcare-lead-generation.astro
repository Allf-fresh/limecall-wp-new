---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const industry = "Healthcare";
const icon = "🏥";

const seo = {
  title: `Healthcare Lead Generation Software | LimeCall`,
  description: `Turn healthcare website visitors into patients. LimeCall's callback automation helps medical practices, clinics, and healthcare providers capture and convert more leads.`,
  canonical: `https://www.limecall.com/healthcare-lead-generation/`,
};

const useCases = [
  { title: "Instant Callback for Appointment Booking", desc: "Patients who call within 5 minutes of showing interest are 100x more likely to book. LimeCall connects your staff with interested visitors in under 28 seconds while the intent is still fresh." },
  { title: "After-Hours Lead Capture", desc: "Healthcare decisions don't stop at 5pm. Collect callback requests 24/7 and schedule follow-up calls during business hours so no patient inquiry is ever lost." },
  { title: "Multi-Location & Specialist Routing", desc: "Route calls to the right clinic, department, or specialist automatically based on patient need and location. Reduce transfers and improve patient satisfaction from the first interaction." },
  { title: "HIPAA-Conscious Call Handling", desc: "Maintain secure call handling with granular recording controls that respect patient privacy requirements. Give your compliance team confidence while keeping the patient experience smooth." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More appointments booked" },
  { value: "80%", label: "Reduction in missed leads" },
  { value: "5 min", label: "Setup time" },
];
---

<Base {...seo}>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `${industry} Lead Generation`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{icon}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        <span class="text-lime-400">{industry}</span> Lead Generation Software
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Convert website visitors into patients with instant callbacks. Respond in under 28 seconds while healthcare intent is at its peak.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Built for {industry} teams</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Patient shows interest", desc: "A prospective patient lands on your site and clicks the LimeCall widget to request a callback." },
          { step: "2", title: "Instant connection", desc: "LimeCall calls your front desk and the patient simultaneously, connecting them in under 28 seconds." },
          { step: "3", title: "Lead captured & logged", desc: "The conversation is recorded, logged, and automatically followed up if no one answers." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to grow your healthcare leads?</h2>
      <p class="mt-4 text-dark-400">Set up in 5 minutes. No credit card required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4">
    <CrossLinks heading="More LimeCall Solutions" links={[
      { href: '/click-to-call-software/', title: 'Click to Call', desc: 'Instant callbacks from your website.' },
      { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'Connect with leads in seconds.' },
      { href: '/lead-generation-for-education/', title: 'Education Lead Gen', desc: 'Callbacks for enrollment inquiries.' },
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
    ]} />
  </div>
</Base>
