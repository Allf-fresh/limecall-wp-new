---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Customer Services Software — Resolve Issues Faster`,
  description: `Resolve customer service issues before they become complaints. LimeCall delivers 28s callbacks, 95% first-contact resolution, and 40% lower churn.`,
  canonical: `https://www.limecall.com/customer-services/`,
};

const stats = [
  { value: "70%", label: "Give up after one failed contact" },
  { value: "28s", label: "Average callback time" },
  { value: "95%", label: "First-contact resolution" },
  { value: "40%", label: "Lower churn with fast response" },
];

const features = [
  { title: "Instant callback", desc: "Replace hold queues with instant callbacks. Customers request a call and receive one in 28 seconds — no waiting, no frustration." },
  { title: "Call routing", desc: "Route customers to the right department or agent automatically — by issue type, account tier, or language preference." },
  { title: "IVR / self-service options", desc: "Let customers resolve simple queries without an agent. Reserve your team for the complex, high-value interactions that need a human touch." },
  { title: "Call recording", desc: "Record every customer service interaction for quality assurance, dispute resolution, and agent training." },
  { title: "SLA tracking", desc: "Monitor response times and resolution rates in real time. Get alerts when SLAs are at risk before they're breached." },
  { title: "CRM logging", desc: "Every call is automatically logged to your CRM with full context — so agents never ask customers to repeat their story." },
];

const useCases = [
  { title: "Technical support", desc: "Customers with technical issues get connected to the right support engineer immediately. Faster resolution, fewer repeat contacts." },
  { title: "Billing and account issues", desc: "Sensitive account queries require a fast, human response. LimeCall ensures no billing dispute goes unanswered for hours." },
  { title: "Product guidance", desc: "Customers who need help getting the most from your product get connected to a specialist in seconds — reducing churn and driving adoption." },
  { title: "Escalation management", desc: "Escalated complaints are routed instantly to senior agents. Fast escalation handling protects retention and NPS." },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is customer services software?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Customer services software helps businesses handle inbound customer requests — including support tickets, phone calls, callbacks, and routing. LimeCall specialises in the phone channel, connecting customers to the right agent in under 28 seconds to resolve issues on the first contact.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does callback reduce customer service costs?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Callback reduces costs in three ways: it cuts call handle time (agents have more context before answering), reduces repeat contacts (issues get resolved first time), and lowers abandonment (customers don\'t hang up frustrated and call back twice). Teams using LimeCall typically see 40% lower operational costs.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall replace my call centre?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall can handle inbound callback routing, call recording, IVR, and CRM sync — covering the core functionality many teams need. It works alongside or as an alternative to traditional call centre platforms for businesses that primarily need inbound callback management.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is a good first-contact resolution rate?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Industry benchmarks suggest 70-75% is average and 85%+ is excellent. LimeCall helps teams reach 95%+ by ensuring agents have full context before every call — call history, CRM records, and the page the customer was on when they requested a callback.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I measure customer service quality?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Key metrics include first-contact resolution rate, average handle time, abandonment rate, CSAT, and NPS. LimeCall\'s dashboard tracks response times and call volumes. Paired with your CRM and survey tools, you get a complete view of service quality.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Customer Services Software', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Customer Services
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Resolve customer service issues<br class="hidden sm:block" />
        <span class="text-lime-400">before they become complaints</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        70% of customers give up after one failed contact attempt. LimeCall ensures every customer reaches an agent in 28 seconds — delivering 95% first-contact resolution and 40% lower churn.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free Trial →</a>
        <a href="/customer-support-software/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">Support Software</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Customer services tools that resolve issues fast</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Customer services use cases</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 font-semibold text-white">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { n: "1", title: "Customer requests callback", desc: "From your website, app, or support portal, the customer clicks the callback button — no hold queue, no frustration." },
          { n: "2", title: "Routed to right agent in 28s", desc: "LimeCall routes the call based on issue type or agent availability and connects customer to agent in 28 seconds." },
          { n: "3", title: "Issue resolved on first contact", desc: "The agent has full context — call history, CRM record — and resolves the issue first time. Call is logged automatically." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(q => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <summary class="cursor-pointer font-semibold text-white">{q.name}</summary>
            <p class="mt-3 text-sm text-dark-400 leading-relaxed">{q.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Resolve issues faster — start today</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free Trial →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related resources" links={[
        { href: '/customer-support-software/', title: 'Customer Support Software', desc: 'Full support platform for your team.' },
        { href: '/customer-care/', title: 'Customer Care Software', desc: 'Deliver a more personal customer care experience.' },
        { href: '/inbound-call-center-software/', title: 'Inbound Call Centre Software', desc: 'Handle high volumes of inbound calls efficiently.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
