---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const country = "UK";
const code = "+44";
const flag = "🇬🇧";

const seo = {
  title: `Get a UK Virtual Phone Number (${code}) | LimeCall`,
  description: `Get a UK virtual phone number (${code}) in 1 minute. Unlimited calling from web and mobile. Build a local presence in the United Kingdom with LimeCall.`,
  canonical: `https://www.limecall.com/get-uk-virtual-phone-number/`,
};

const features = [
  { title: "Instant Setup", desc: "Get your UK virtual number in minutes. No hardware, no SIM card, no contracts." },
  { title: "Smart Call Routing", desc: "Route incoming calls to any device or team member — mobile, desktop, or desk phone." },
  { title: "Call Recording", desc: "Record and review every call for quality assurance and compliance." },
  { title: "Callback Automation", desc: "Let website visitors request instant callbacks from your UK-based or global team." },
  { title: "SMS & WhatsApp", desc: "Send and receive SMS messages on your UK virtual number." },
  { title: "Analytics Dashboard", desc: "Full call analytics, reporting, and conversion tracking in one dashboard." },
];

const faqs = [
  {
    question: `What is a UK virtual phone number?`,
    answer: `A UK virtual phone number (${code}) is a telephone number that isn't tied to a physical phone line or SIM card. It routes calls over the internet to any device — mobile, laptop, or desk phone — anywhere in the world. Your customers in the UK dial a local number, and the call reaches you wherever you are.`,
  },
  {
    question: `Do I need to be in the UK to get a UK virtual number?`,
    answer: `No. Anyone can get a UK virtual phone number from anywhere in the world. LimeCall gives you a local ${code} number that UK customers can call at local rates, while your team answers from any country.`,
  },
  {
    question: `What types of UK virtual numbers are available?`,
    answer: `LimeCall offers local UK numbers with city-specific area codes (London 020, Manchester 0161, Birmingham 0121, Leeds 0113, etc.) as well as national 03xx numbers. Choose the number type that best fits your business needs.`,
  },
  {
    question: "How long does setup take?",
    answer: "Setup takes under 5 minutes. Sign up, choose your UK number, and you're ready to receive calls immediately — no waiting for hardware or SIM activation.",
  },
  {
    question: "Can I use a UK virtual number for callbacks?",
    answer: "Yes — LimeCall's callback automation lets website visitors request a call and your team calls them back within 28 seconds using your UK virtual number. This dramatically improves lead conversion rates.",
  },
  {
    question: `Are UK virtual numbers compliant with Ofcom regulations?`,
    answer: `LimeCall's UK virtual numbers are provisioned through licensed telecom partners and comply with Ofcom guidelines. All numbers are legitimate, registered numbers suitable for business use in the United Kingdom.`,
  },
];

const stats = [
  { value: "+44", label: "UK area code" },
  { value: "1 min", label: "Setup time" },
  { value: "28s", label: "Avg callback speed" },
  { value: "40+", label: "Countries available" },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `${country} Virtual Number`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a <span class="text-lime-400">UK Virtual Phone Number</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Local United Kingdom number ({code}) that works anywhere. Instant setup, no hardware. Route calls, automate callbacks, and close more deals.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your UK Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/30 py-10">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Everything included with your UK number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your UK number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall virtual numbers to connect with customers globally.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/virtual-numbers/', title: 'All Virtual Numbers', desc: 'Browse all available countries.' },
        { href: '/click-to-call-software/', title: 'Click to Call', desc: 'Let visitors call you instantly.' },
        { href: '/customer-callback-software/', title: 'Callback Software', desc: 'Automated callbacks in 28 seconds.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
