---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Use cases - LimeCall`,
  description: `Limecall provides extensive use and boundless potential. Use cases include marketing, sales, operations and customer care.`,
  canonical: `https://www.limecall.com/use-cases/`,
};

const industries = [
  {
    name: "Real Estate",
    tagline: "Turn property browsers into booked viewings",
    desc: "Connect buyers and sellers with the right agent instantly. Never lose a lead to a competitor who picked up faster.",
    href: "/limecall-for-real-estate/",
    stats: ["3x more viewings", "24/7 lead capture"],
  },
  {
    name: "Finance & Insurance",
    tagline: "Convert financial leads before they go cold",
    desc: "Mortgage enquiries, insurance quotes, and investment questions all convert best over the phone — and LimeCall gets you there first.",
    href: "/limecall-for-finance-insurance/",
    stats: ["28s callback", "100% calls logged"],
  },
  {
    name: "Travel & Tourism",
    tagline: "Book more holidays, answer every enquiry",
    desc: "Travel is an emotional purchase. Connect holidaymakers with destination specialists at the exact moment they're ready to book.",
    href: "/limecall-for-travel/",
    stats: ["3x more bookings", "Evening & weekend capture"],
  },
  {
    name: "Travel, Tourism & Aviation",
    tagline: "The full travel industry platform",
    desc: "Airlines, tour operators, hotels, and transfer services — LimeCall serves every segment of the travel and aviation industry.",
    href: "/limecall-for-travel-tourism-aviation/",
    stats: ["50+ countries", "Multi-language routing"],
  },
  {
    name: "Software & Technology",
    tagline: "Convert trials. Book more demos.",
    desc: "SaaS companies use LimeCall to activate trial users, book product demos, and convert high-intent enterprise visitors before they evaluate a competitor.",
    href: "/limecall-for-software-it-technology/",
    stats: ["3x more demos", "Instant response"],
  },
  {
    name: "E-commerce & Retail",
    tagline: "Rescue abandoned carts. Close big-ticket sales.",
    desc: "Answer product questions instantly, help hesitant buyers commit, and handle post-purchase support — all with a callback widget on your store.",
    href: "/limecall-for-ecommerce-and-retail-2/",
    stats: ["Fewer returns", "Higher AOV"],
  },
  {
    name: "Healthcare",
    tagline: "Connect patients with the right care team",
    desc: "Appointment booking, insurance queries, and treatment questions all convert better over the phone. LimeCall connects patients with your team instantly.",
    href: "/healthcare-lead-generation/",
    stats: ["Instant connection", "HIPAA-aware"],
  },
  {
    name: "Education",
    tagline: "Convert prospective students and parents",
    desc: "Enrollment enquiries, course questions, and admissions support — handled instantly by the right advisor. Never lose a prospective student to slow response.",
    href: "/lead-generation-for-education/",
    stats: ["3x enrollment rates", "Smart routing"],
  },
];

const roleLinks = [
  { title: "Sales Teams", desc: "Connect inbound leads to reps in 28 seconds.", href: "/for-sales-teams/" },
  { title: "Marketing Teams", desc: "Track which campaigns drive callbacks and revenue.", href: "/for-marketing-teams/" },
  { title: "Customer Support", desc: "Replace hold queues with instant callbacks.", href: "/customer-support-software/" },
  { title: "Customer Care", desc: "Build lasting relationships with instant, personal responses.", href: "/customer-care/" },
  { title: "Customer Services", desc: "Resolve issues on the first contact, every time.", href: "/customer-services/" },
  { title: "Real Estate Agents", desc: "Book more viewings with speed-to-lead automation.", href: "/limecall-for-real-estate/" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What industries use LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall is used across real estate, finance and insurance, travel and tourism, software and technology, e-commerce, healthcare, and education — as well as by individual sales and marketing teams in any industry where inbound phone leads matter.',
      },
    },
    {
      '@type': 'Question',
      name: 'What are the main use cases for callback software?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The main use cases are: inbound sales lead conversion (connecting website visitors to sales reps instantly), customer support (replacing hold queues with instant callbacks), and marketing attribution (tracking which campaigns generate phone enquiries). LimeCall covers all three.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I use LimeCall for support as well as sales?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall works equally well for sales teams (converting leads) and support teams (resolving customer issues via callback). You can run separate widgets for each team with different routing rules, agents, and tracking.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall work for e-commerce?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'E-commerce businesses use LimeCall to answer pre-purchase questions on high-value product pages, rescue abandoned carts by calling hesitant buyers, and handle post-purchase support. A callback widget on checkout pages reduces drop-off and increases average order value.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the most common LimeCall use case?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The most common use case is inbound sales lead conversion — placing a callback widget on high-intent pages (pricing, product, landing pages) so that website visitors can request an instant call and be connected to a sales rep within 28 seconds.',
      },
    },
  ],
};

const teamUses = [
  {
    team: "Sales Teams",
    tagline: "Call every inbound lead within 28 seconds",
    desc: "LimeCall turns your website into a live sales channel. Every high-intent visitor gets connected to the right rep — before they go to a competitor.",
    items: [
      "Instant callbacks from pricing and product pages",
      "Lead routing to the right rep automatically",
      "CRM sync — no manual data entry",
      "Slack alerts when new leads arrive",
    ],
    href: "/for-sales-teams/",
  },
  {
    team: "Marketing Teams",
    tagline: "Make your ad spend work harder",
    desc: "You pay to get traffic. LimeCall makes sure that traffic converts. Track which campaigns drive callbacks, attribute revenue accurately, and stop optimizing for clicks.",
    items: [
      "Track callbacks by source, campaign, and keyword",
      "Google Analytics and Tag Manager integration",
      "Facebook and Google Ads conversion tracking",
      "Landing page optimization with real call data",
    ],
    href: "/for-marketing-teams/",
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Use Cases', url: seo.canonical }]} />
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall for Every<br class="hidden sm:block" />
        <span class="text-lime-400">Team & Industry</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Whether you're a travel agency, SaaS startup, real estate firm, or e-commerce store — LimeCall connects you with your best leads in under 28 seconds.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free Trial →</a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- Industry verticals -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">By industry</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {industries.map(ind => (
          <a href={ind.href} class="group rounded-xl border border-dark-800 bg-dark-900/60 p-6 hover:border-lime-500/40 transition">
            <h3 class="mb-1 font-bold text-white group-hover:text-lime-400 transition">{ind.name}</h3>
            <p class="mb-3 text-xs font-semibold text-lime-500/70">{ind.tagline}</p>
            <p class="mb-4 text-xs text-dark-400 leading-relaxed">{ind.desc}</p>
            <div class="flex flex-wrap gap-2">
              {ind.stats.map(s => (
                <span class="rounded-full bg-dark-800 px-3 py-1 text-xs text-dark-300">{s}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- By team -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">By team</h2>
      <div class="grid gap-8 sm:grid-cols-2">
        {teamUses.map(t => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <h3 class="mb-1 text-xl font-bold text-white">{t.team}</h3>
            <p class="mb-4 text-sm font-semibold text-lime-400">{t.tagline}</p>
            <p class="mb-5 text-sm text-dark-400 leading-relaxed">{t.desc}</p>
            <ul class="mb-6 space-y-2">
              {t.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-dark-300">
                  <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href={t.href} class="text-sm font-semibold text-lime-400 hover:text-lime-300 transition">
              Learn more →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- By role -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">By role</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {roleLinks.map(r => (
          <a href={r.href} class="group rounded-xl border border-dark-800 bg-dark-900/60 p-6 hover:border-lime-500/40 transition">
            <h3 class="mb-1 font-bold text-white group-hover:text-lime-400 transition">{r.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{r.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(q => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <summary class="cursor-pointer font-semibold text-white">{q.name}</summary>
            <p class="mt-3 text-sm text-dark-400 leading-relaxed">{q.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick proof section -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-950/20 p-8 sm:p-10 text-center">
        <h2 class="text-2xl font-bold text-white mb-4">The common thread across every use case</h2>
        <p class="text-dark-300 leading-relaxed max-w-2xl mx-auto mb-6">
          Every industry, every team, every use case has the same underlying need: connect with your best leads as fast as possible, with as little friction as possible. LimeCall does exactly that — in 28 seconds, from any website, with no developer required.
        </p>
        <div class="grid grid-cols-3 gap-6 max-w-lg mx-auto">
          {[
            { v: "28s", l: "to connect" },
            { v: "3x", l: "more conversions" },
            { v: "5 min", l: "to set up" },
          ].map(s => (
            <div>
              <div class="text-3xl font-extrabold text-lime-400">{s.v}</div>
              <div class="mt-1 text-sm text-dark-400">{s.l}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to convert more of your leads?</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free Trial →</a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 font-bold text-white hover:border-lime-500/40 transition">View Pricing</a>
      </div>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore LimeCall" links={[
        { href: '/customers/', title: 'Customers', desc: 'See how real businesses use LimeCall.' },
        { href: '/features/', title: 'Features', desc: 'Every feature LimeCall offers.' },
        { href: '/integrations/', title: 'Integrations', desc: 'Connect LimeCall with your existing tools.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
