---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Callback Software for Construction & Contractors | LimeCall',
  description: 'LimeCall helps builders and contractors respond to quote requests in 28 seconds. Territory routing, mobile app for on-site reps, after-hours capture. Free trial.',
  canonical: 'https://www.limecall.com/construction/',
};

const stats = [
  { value: '64%', label: 'Of homeowners hire the first contractor who responds' },
  { value: '28s', label: 'LimeCall callback vs 3-day contractor average' },
  { value: '£8,500', label: 'Avg renovation project — every lead matters' },
  { value: '3×', label: 'More quotes submitted vs contact form alone' },
];

const features = [
  { icon: '📱', title: 'Mobile App for On-Site Reps', desc: 'Your estimators can receive and manage callbacks from the job site. iOS and Android app with push notifications so no lead goes unanswered while your team is on the tools.' },
  { icon: '📍', title: 'Territory Routing by Postcode', desc: 'Route inbound quote requests to the right regional estimator or team automatically — by postcode district, county, or custom territory boundaries.' },
  { icon: '🌙', title: 'After-Hours Lead Capture', desc: 'Homeowners browse builder websites evenings and weekends. LimeCall captures those enquiries and queues them for first-thing-Monday callback — before you lose them.' },
  { icon: '📋', title: 'Quote Follow-Up Callbacks', desc: 'Automatically trigger callbacks 48 hours after a quote is issued. Keep your pipeline warm and reduce the number of quotes that go cold with no response.' },
  { icon: '📞', title: 'Virtual Local Numbers', desc: 'Use local virtual numbers for each region you operate in. Homeowners are more likely to answer a call from a local number.' },
  { icon: '🔗', title: 'CRM Sync to BuilderTrend & CoConstruct', desc: 'Every callback automatically logged in BuilderTrend, CoConstruct, or your CRM via Zapier. Lead source, contact details, and call outcome captured every time.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Does LimeCall have a mobile app for contractors working on site?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall has a full-featured mobile app for iOS and Android. Your estimators and project managers can receive callback notifications, manage the lead queue, and handle calls from the job site. Push notifications ensure no callback request is missed even when your team is away from the office.',
      },
    },
    {
      '@type': 'Question',
      name: 'What happens to quote requests submitted after hours or at weekends?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "After-hours and weekend enquiries are captured and queued automatically in LimeCall. On Monday morning, your team sees a prioritised list of callbacks to work through. You can also configure the system to alert on-call estimators for urgent enquiries — for example, emergency repair call-outs or time-sensitive project enquiries.",
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall help us track which leads became quotes?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Every callback is logged with full details including lead source, contact information, call duration, and outcome notes. When integrated with BuilderTrend, CoConstruct, or your CRM via Zapier, you can track the full journey from initial enquiry through quote issued to project awarded — giving you a clear view of your sales pipeline.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can we route enquiries to different teams or trades automatically?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall supports routing by postcode district, region, trade type, or any custom logic. For example, roofing enquiries can go to your roofing estimators, new builds to your project managers, and emergency repairs to your on-call team. Routing rules are configured in your dashboard without any developer involvement.',
      },
    },
    {
      '@type': 'Question',
      name: 'How quickly can a construction business set up LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most construction businesses are live within 5 minutes. Add the widget to your website, configure territory routing rules, and the system is active. No IT team or developer required. We provide full onboarding support and can assist with routing configuration for multi-trade or multi-region operations.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does LimeCall cost for a building or contracting business?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall plans start from $35/month. With an average renovation project value of £8,500, a single additional project won from faster callback response typically covers 6–12 months of subscription cost. A 14-day free trial is available with no credit card required.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumbs items={[{ name: 'Construction', url: `${site.url}/construction/` }]} />
      <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400">
        🏗️ For Builders, Contractors & Developers
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Callback Software for Construction<br class="hidden sm:block" />
        <span class="text-lime-400">— Win Quotes by Responding First</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300">
        Quote requests come in on weekday afternoons and evenings. Most contractors respond days later — the job goes elsewhere. LimeCall connects homeowners to your team in 28 seconds, from any device.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center justify-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free Trial — 14 Days
        </a>
        <a href="/demo/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-dark-700 px-8 py-4 text-sm font-semibold text-white transition hover:border-lime-500/40 hover:text-lime-400">
          Book a Demo →
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">★ Mobile App for On-Site Teams · Territory Routing · No setup fee · Free trial</p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-dark-800 bg-dark-900/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <dt class="text-3xl font-extrabold text-lime-400">{s.value}</dt>
            <dd class="mt-1 text-sm text-dark-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Problem callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-red-500/20 bg-red-500/5 p-8">
        <h2 class="text-xl font-bold text-white mb-3">⚠️ The First Contractor to Call Back Gets the Job</h2>
        <p class="text-dark-300">
          A homeowner wants a loft conversion quote. They contact 5 builders. The one who calls back in 28 seconds gets the project. The others get a polite "thanks, we've already found someone." With an average renovation value of £8,500, every delayed response is a significant loss — and the Monday morning callback pile never shrinks without a system.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">How LimeCall Works for Builders & Contractors</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: '01', title: 'Homeowner Visits Your Website', desc: "LimeCall widget appears on your quote request page, services pages, and contact page. Homeowner enters their number — even at 9pm on a Sunday." },
          { step: '02', title: 'Routed to the Right Estimator', desc: 'LimeCall routes to the correct estimator or trade team by postcode, region, or project type. On-site reps receive callbacks on the mobile app.' },
          { step: '03', title: 'Connected in 28 Seconds', desc: 'Estimator greets the homeowner while they are still on your website — before any other builder has responded. Quote conversation starts immediately.' },
        ].map(item => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-lg">{item.step}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-dark-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">Built for Builders, Contractors & Developers</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-dark-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Construction Use Cases</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'New Quote Requests', desc: 'Website visitor → regional estimator in 28s → project scope discussed on the call and follow-up visit booked.' },
          { title: 'Planning Consultation Bookings', desc: 'Prospect on planning/design page → connected to project manager → consultation visit scheduled.' },
          { title: 'Subcontractor Enquiries', desc: 'Subbies visiting your trade partner page → routed to procurement team → relationship established fast.' },
          { title: 'Emergency Call-Outs', desc: 'Emergency repair page → on-call estimator connected instantly → job scoped, priced, and booked in minutes.' },
        ].map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="font-bold text-white mb-2">{u.title}</h3>
            <p class="text-sm text-dark-400">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case study / testimonial -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <blockquote class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-10 text-center">
        <p class="text-xl text-white italic leading-relaxed">
          "Our estimators used to spend Monday morning returning weekend enquiries — by which time half had already hired someone else. LimeCall changed everything. We now call back within 28 seconds, even on Saturday evening."
        </p>
        <footer class="mt-6">
          <p class="font-bold text-lime-400">Director</p>
          <p class="text-sm text-dark-500">Residential building company, Manchester</p>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">LimeCall vs. How Contractors Typically Handle Leads</h2>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              {['Feature', 'LimeCall', 'Phone/Voicemail', 'Contact Form', 'WhatsApp Only'].map(h => (
                <th class={`px-5 py-4 text-left font-semibold ${h === 'LimeCall' ? 'text-lime-400' : 'text-dark-300'}`}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['Response time', '28 seconds', '1–3 days', '2–48 hours', 'Variable'],
              ['After-hours capture', '✅ Queue + next-day callback', '❌ Voicemail dropped', '✅ Email stored', '⚠️ Message only'],
              ['Mobile app for on-site', '✅ iOS & Android', '✅ Standard phone', '❌ No', '✅ WhatsApp'],
              ['Territory routing', '✅ Postcode/region', '❌ No routing', '❌ No routing', '❌ No routing'],
              ['CRM auto-logging', '✅ Every call', '❌ Manual', '⚠️ Partial', '❌ Manual'],
              ['Quote conversion rate', '🟢 3× improvement', '🟡 Standard', '🔴 Low (slow)', '🟡 Medium'],
            ].map(([feature, ...vals]) => (
              <tr class="hover:bg-dark-800/30 transition">
                <td class="px-5 py-4 font-medium text-dark-200">{feature}</td>
                {vals.map((v, i) => (
                  <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Integration callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-dark-700 bg-dark-900/60 p-8 sm:p-10 flex flex-col sm:flex-row items-center gap-8">
        <div class="shrink-0 text-5xl">🔗</div>
        <div>
          <h2 class="text-xl font-bold text-white mb-2">Integrates with BuilderTrend, CoConstruct & More</h2>
          <p class="text-dark-400 text-sm leading-relaxed">
            LimeCall connects to BuilderTrend, CoConstruct, HubSpot, and 1,000+ tools via Zapier. Every callback is automatically logged with lead name, contact number, project type, postcode, call duration, and outcome notes — so your estimators always have context before they pick up the phone.
          </p>
          <a href="/integrations/" class="mt-4 inline-flex items-center text-sm font-semibold text-lime-400 hover:text-lime-300 transition">
            View all integrations →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile-first callout -->
  <section class="py-16 sm:py-20 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-10">Built for Teams That Work On-Site</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          { icon: '📱', title: 'iOS & Android App', desc: 'Your estimators get push notifications for every callback request. Accept, manage, and complete calls from the job site — no desk required.' },
          { icon: '🗺️', title: 'Postcode Territory Routing', desc: 'Define territories by postcode district or custom boundaries. LimeCall routes every lead to the right estimator automatically — no coordinator required.' },
          { icon: '🔔', title: 'Missed Lead Alerts', desc: 'If a callback is not answered within your SLA, LimeCall escalates to another team member and sends an alert — no lead falls through the cracks.' },
        ].map(item => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 text-center">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-dark-400">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {item.name}
              <span class="ml-4 shrink-0 text-lime-400 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-gradient-to-br from-lime-500/10 to-dark-900 border-t border-lime-500/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Win More Projects by Being First to Respond</h2>
      <p class="mt-4 text-lg text-dark-300">14-day free trial · Mobile app included · No setup fee</p>
      <a href="/signup" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-lime-500 px-10 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
        Try Free — 14 Days →
      </a>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime · Full onboarding support</p>
    </div>
  </section>

  <!-- Cross-links -->
  <div class="py-12 bg-dark-950 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore More" links={[
        { href: '/real-estate/', title: 'Real Estate Callback', desc: 'Connect estate agents with buyers fast.' },
        { href: '/insurance/', title: 'Insurance Callback Software', desc: 'Callback tools for insurance brokers.' },
        { href: '/virtual-business-numbers/', title: 'Virtual Local Numbers', desc: 'Local numbers for every region.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Plans from $35/month.' },
      ]} />
    </div>
  </div>
</Base>
