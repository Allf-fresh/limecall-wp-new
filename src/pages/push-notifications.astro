---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Push Notifications for Lead Engagement — Instant Alerts | LimeCall`,
  description: `LimeCall push notifications alert your team and leads instantly. 3x higher open rate vs email, real-time lead alerts, SMS fallback, and missed call recovery. Free trial.`,
  canonical: `https://www.limecall.com/push-notifications/`,
};

const stats = [
  { value: '3x', label: 'Higher open rate vs email' },
  { value: 'Instant', label: 'Delivery time' },
  { value: '40%', label: 'More lead re-engagement' },
  { value: 'Real-time', label: 'Team alerts' },
];

const features = [
  {
    title: 'Real-Time Lead Alerts',
    desc: 'The moment a new lead submits a form, clicks your widget, or calls your number, your team receives an instant push notification. No polling, no delays — your reps know immediately.',
    icon: '⚡',
  },
  {
    title: 'Browser Push Notifications',
    desc: 'LimeCall delivers push notifications directly to your team\'s desktop browser — even when they\'re not in the LimeCall dashboard. Reps see new lead alerts without switching tabs.',
    icon: '🖥️',
  },
  {
    title: 'SMS Fallback',
    desc: 'If a rep misses the browser notification, LimeCall automatically falls back to SMS. Critical alerts — like a high-value lead or a missed call — always get through, regardless of whether the rep is at their desk.',
    icon: '📱',
  },
  {
    title: 'Custom Notification Rules',
    desc: 'Define which events trigger which notifications and for whom. New call from a hot lead? Alert the account manager. Missed call on a weekend? Alert the on-call rep. Rules are fully configurable per team.',
    icon: '⚙️',
  },
  {
    title: 'Team Alerts',
    desc: 'Keep your whole team informed with configurable team-wide alerts for new calls, missed calls, new lead captures, and agent availability changes. Everyone stays in sync without extra meetings.',
    icon: '👥',
  },
  {
    title: 'Scheduled Campaigns',
    desc: 'Re-engage cold leads with scheduled push and SMS notification campaigns. Set the timing, target audience, and message — LimeCall delivers at the optimal time and tracks engagement automatically.',
    icon: '📅',
  },
];

const useCases = [
  {
    title: 'New Lead Alerts',
    desc: 'Your sales team can\'t respond to what they don\'t see. LimeCall sends an instant push notification the moment a new lead appears — so your rep can call back within seconds while the lead is still engaged.',
  },
  {
    title: 'Missed Call Recovery',
    desc: 'Every missed call is a potential lost deal. LimeCall sends an immediate alert when a call goes unanswered — with the caller\'s name, number, and source. Your rep can call back before the lead moves on.',
  },
  {
    title: 'Re-Engagement Campaigns',
    desc: 'Dormant leads who haven\'t been contacted in 30+ days are often still warm. LimeCall\'s scheduled notification campaigns let you reach them with a targeted push or SMS — and bring them back into your pipeline.',
  },
  {
    title: 'Product Updates & Announcements',
    desc: 'Use LimeCall\'s notification infrastructure to push product updates or promotions to opted-in customers. Segment by customer type, product, or activity level for targeted, relevant messaging.',
  },
];

const faqs = [
  {
    q: 'How are push notifications delivered?',
    a: 'LimeCall delivers push notifications via browser push (for desktop and mobile browsers), in-app alerts within the LimeCall dashboard, and SMS fallback. You can configure which channels are used per notification type. For critical alerts like missed calls, SMS fallback ensures delivery even when the rep is away from their screen.',
  },
  {
    q: 'Do leads need to opt in to receive push notifications?',
    a: 'For browser push notifications sent to leads (rather than your internal team), visitors need to opt in via a browser permission prompt. LimeCall provides a customisable opt-in prompt that you can display based on visitor behaviour — for example, after a form submission or after viewing a specific page.',
  },
  {
    q: 'Can I control which events trigger which notifications?',
    a: 'Yes. LimeCall\'s notification rule engine lets you define triggers (new lead, missed call, scheduled call, campaign response), specify which team members or groups receive the alert, and choose the delivery channel (browser push, SMS, or both). Rules can be scoped to specific campaigns, widgets, or lead sources.',
  },
  {
    q: 'What is the difference between team alerts and lead notifications?',
    a: 'Team alerts go to your internal team members — reps, managers, or support staff — to notify them of events that require action, like a new lead or missed call. Lead notifications go to the actual contacts in your database, such as reminders before a scheduled call or re-engagement campaign messages. Both types are configurable from the same LimeCall notifications dashboard.',
  },
  {
    q: 'How do I measure notification performance?',
    a: 'LimeCall tracks delivery rate, open rate, and click-through rate for all notification types. For re-engagement campaigns, you can see how many leads were re-engaged, how many resulted in calls, and the conversion rate. All data is available in the analytics dashboard and can be exported.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Push Notifications', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Push Notifications
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Alert your team and leads<br class="hidden sm:block" />
        <span class="text-lime-400">the instant it matters</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Real-time push notifications for new leads, missed calls, and re-engagement — delivered to browser, SMS, or both. 3x higher open rate than email.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white sm:text-3xl">
        Notifications that drive action
      </h2>
      <p class="mb-12 text-center text-dark-400 max-w-xl mx-auto">
        From new lead alerts to re-engagement campaigns, every notification is designed to connect the right person with the right information at the right moment.
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-3 text-2xl">{f.icon}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white sm:text-3xl">Use cases</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <h3 class="mb-3 font-semibold text-lime-400">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/50 p-5">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between gap-4">
              {f.q}
              <span class="shrink-0 text-lime-400 text-lg">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Never miss a lead again</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Cross links -->
  <div class="py-8 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related features" links={[
        { href: '/webhooks/', title: 'Webhooks', desc: 'Automate workflows triggered by call events.' },
        { href: '/lead-capture-software/', title: 'Lead Capture Software', desc: 'Capture every inbound lead from your website.' },
        { href: '/callbackautomation/', title: 'Callback Automation', desc: 'Instant automated callbacks for new leads.' },
        { href: '/integrations/', title: 'Integrations', desc: 'Connect LimeCall to your marketing stack.' },
      ]} />
    </div>
  </div>
</Base>
