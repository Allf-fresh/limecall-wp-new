---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const seo = {
  title: `Free Sales Tools — Phone Validator, ROI Calculator & More | LimeCall`,
  description: `Free tools for sales and marketing teams: phone number validator, speed-to-lead ROI calculator, callback widget generator, lead response time benchmark, and more.`,
  canonical: `https://www.limecall.com/free-tools/`,
};

const stats = [
  { value: '6', label: 'Free tools' },
  { value: '50k+', label: 'Monthly users' },
  { value: 'No signup', label: 'Required for most tools' },
  { value: '100%', label: 'Free, forever' },
];

const tools = [
  {
    icon: '📱',
    title: 'Phone Number Validator',
    desc: 'Instantly check whether a phone number is valid, whether it is a mobile or landline, and what country or carrier it belongs to. Useful for cleaning lead lists before calling campaigns.',
    badge: 'No signup',
    cta: 'Use Free',
  },
  {
    icon: '💰',
    title: 'Speed-to-Lead ROI Calculator',
    desc: 'Enter your monthly lead volume, current average response time, and average deal value. See exactly how much additional revenue faster response times could generate for your team.',
    badge: 'No signup',
    cta: 'Calculate ROI',
  },
  {
    icon: '🔧',
    title: 'Callback Widget Generator',
    desc: 'Configure and generate your LimeCall callback widget code in minutes — choose colors, position, and trigger behavior. Copy and paste it directly into your website. No account needed to generate.',
    badge: 'No signup',
    cta: 'Generate Widget',
  },
  {
    icon: '⏱️',
    title: 'Lead Response Time Benchmark',
    desc: 'Compare your current average lead response time against industry benchmarks by sector. See how you stack up against competitors and what improvement in contact rate you could expect from faster response.',
    badge: 'No signup',
    cta: 'See Benchmark',
  },
  {
    icon: '📋',
    title: 'Call Tracking Setup Guide',
    desc: 'A step-by-step PDF guide covering how to set up call tracking from scratch — including UTM parameters, dynamic number insertion, and integrating call data with Google Analytics and your CRM.',
    badge: 'Free download',
    cta: 'Download Guide',
  },
  {
    icon: '📝',
    title: 'Sales Script Templates',
    desc: 'Downloadable sales call scripts covering the most common objection-handling scenarios: pricing objections, competitor comparisons, timing objections, and gatekeepers. Editable in Word and Google Docs.',
    badge: 'Free download',
    cta: 'Download Scripts',
  },
];

const useCases = [
  {
    title: 'Clean Your Lead List',
    desc: 'Before you run a calling campaign, validate every number with our Phone Validator. Remove invalid numbers, separate mobile from landline, and focus your team on reachable leads.',
  },
  {
    title: 'Make the Case for Faster Response',
    desc: 'Use the ROI Calculator to quantify the revenue impact of reducing your response time. Export the results and share them with your manager to justify investing in callback automation.',
  },
  {
    title: 'Build Your First Callback Widget',
    desc: 'You do not need a LimeCall account to generate a widget. Use the Widget Generator to create a basic widget and test it on your site — then sign up when you are ready for the full feature set.',
  },
];
---

<Base {...seo}>

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Free Tools', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Free Tools
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Free tools for<br class="hidden sm:block" />
        <span class="text-lime-400">sales & marketing teams</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Six free tools — phone validator, ROI calculator, widget generator, benchmarks, and downloadable guides. No credit card. Most require no account at all.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tools grid -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white sm:text-3xl">All free tools</h2>
      <p class="mb-12 text-center text-dark-400 max-w-xl mx-auto">Practical tools built for sales and marketing teams that want to improve lead response and conversion.</p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {tools.map(t => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6 flex flex-col">
            <div class="mb-3 flex items-center justify-between">
              <span class="text-2xl">{t.icon}</span>
              <span class="rounded-full border border-lime-500/20 bg-lime-500/10 px-2.5 py-0.5 text-xs font-semibold text-lime-400">{t.badge}</span>
            </div>
            <h3 class="mb-2 font-semibold text-white">{t.title}</h3>
            <p class="flex-1 text-sm text-dark-400 leading-relaxed">{t.desc}</p>
            <div class="mt-5">
              <a href={site.cta.href} class="inline-block rounded-lg border border-lime-500/30 px-4 py-2 text-sm font-semibold text-lime-400 hover:bg-lime-500/10 transition">
                {t.cta} →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white sm:text-3xl">How teams use these tools</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {useCases.map(u => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <h3 class="mb-3 font-semibold text-lime-400">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready for the full platform?</h2>
      <p class="mt-4 text-dark-400">Start a free LimeCall trial and turn your best leads into live calls in under 28 seconds.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free Trial →
        </a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 font-bold text-white hover:border-lime-500/40 transition">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Cross links -->
  <div class="py-8 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related resources" links={[
        { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'Why responding in under 28 seconds changes everything.' },
        { href: '/call-tracking/', title: 'Call Tracking', desc: 'Track every call back to the exact source that generated it.' },
        { href: '/for-sales-teams/', title: 'For Sales Teams', desc: 'The full LimeCall feature set for high-performance sales teams.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Transparent plans starting from free.' },
      ]} />
    </div>
  </div>
</Base>
