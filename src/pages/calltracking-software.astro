---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const seo = {
  title: `Call Tracking Software for Modern Marketing Teams | LimeCall`,
  description: `Know exactly which campaigns, channels, and keywords drive phone calls. LimeCall's call tracking software connects your marketing spend directly to closed deals.`,
  canonical: `https://www.limecall.com/calltracking-software/`,
};

const features = [
  {
    icon: '📍',
    name: 'Dynamic Number Insertion',
    description: 'Automatically swap phone numbers on your website based on the traffic source. Every visitor sees a unique number tied to their campaign, keyword, or channel.',
  },
  {
    icon: '🗺️',
    name: 'Calls by Region (Heat Mapping)',
    description: 'Visualize call volume by geography. Understand which markets are driving the most calls and optimize your ad spend by region.',
  },
  {
    icon: '📊',
    name: 'Marketing Attribution Dashboard',
    description: 'See exactly which campaigns, ad groups, and keywords are driving phone calls — in real time. Connect marketing spend to actual revenue.',
  },
  {
    icon: '📉',
    name: 'Call Trends Reports',
    description: 'Analyze call volume over time, by day, hour, or rep. Use trends to optimize staffing levels and never miss a peak-demand window.',
  },
  {
    icon: '🔊',
    name: 'IVR & Geo Routing',
    description: 'Route calls intelligently with Interactive Voice Response menus and geo-based routing. Connect callers to the most relevant rep based on their location and intent.',
  },
  {
    icon: '🎙️',
    name: 'Call Recordings & Transcripts',
    description: 'Every tracked call is recorded and accessible in your dashboard. Review conversations to improve campaigns, train reps, and understand what callers actually want.',
  },
];

const useCases = [
  {
    title: 'PPC & Paid Search',
    description: 'Track which Google Ads keywords and campaigns drive phone calls. Optimize bidding based on call conversion data — not just clicks.',
    icon: '💰',
  },
  {
    title: 'SEO & Organic',
    description: 'Understand which organic landing pages generate the most calls. Invest in content that drives phone-ready prospects.',
    icon: '🔍',
  },
  {
    title: 'Social & Display Ads',
    description: 'Attribute phone calls to Facebook, Instagram, and display campaigns. See the full picture of your cross-channel ROI.',
    icon: '📱',
  },
  {
    title: 'Email Campaigns',
    description: 'Track calls driven by email campaigns with dedicated tracking numbers per email send. Know which messages convert to calls.',
    icon: '📧',
  },
];

const faqs = [
  {
    question: 'What is call tracking software?',
    answer: 'Call tracking software assigns unique phone numbers to different marketing channels, campaigns, or keywords. When someone calls that number, the software records which source drove the call — giving you full attribution for phone leads.',
  },
  {
    question: 'What is dynamic number insertion (DNI)?',
    answer: 'Dynamic number insertion automatically replaces the phone number shown on your website based on how each visitor arrived. A visitor from a Google Ad sees a different number than one from an organic search, letting LimeCall attribute each call to the correct source.',
  },
  {
    question: 'Can I track calls from Google Ads?',
    answer: 'Yes. LimeCall integrates with Google Ads to track which campaigns, ad groups, and keywords drive phone calls. You can import call conversion data back to Google Ads to optimize your bidding strategy.',
  },
  {
    question: 'Does LimeCall record tracked calls?',
    answer: 'Yes. All tracked calls can be recorded and stored in your LimeCall dashboard. Recordings are accessible with timestamps, caller details, and campaign attribution — perfect for quality assurance and campaign analysis.',
  },
  {
    question: 'How many tracking numbers do I need?',
    answer: 'It depends on how many channels you want to track. Most teams start with one number per major campaign or traffic source. LimeCall\'s Pro plan includes virtual numbers and unlimited tracking configurations.',
  },
  {
    question: 'Can I track calls from offline marketing?',
    answer: 'Yes. You can assign unique tracking numbers to print ads, billboards, TV spots, or any offline channel. When someone calls that number, LimeCall logs it with the source attribution you specify.',
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Call Tracking Software', url: `${site.url}/calltracking-software/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        Call Tracking Software
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Know Exactly What Drives<br />
        <span class="text-lime-400">Every Phone Call</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Track calls, texts, forms, and chats as easily as you track clicks. LimeCall's call tracking software connects every inbound call to the campaign, keyword, or channel that drove it.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm">
        <span class="flex items-center gap-2 text-dark-300">
          <svg class="h-4 w-4 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Campaign attribution
        </span>
        <span class="hidden h-4 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <svg class="h-4 w-4 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Dynamic number insertion
        </span>
        <span class="hidden h-4 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <svg class="h-4 w-4 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Rated 4.6/5 on G2 &amp; Capterra
        </span>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free — No Card Needed
        </a>
        <a
          href="/contact-us"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          Request a Demo
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">30-day money-back guarantee · Free plan available</p>
    </div>
  </section>

  <!-- Feature grid -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Robust Call Tracking <span class="text-lime-400">Functionality</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Everything your marketing team needs to measure, attribute, and optimize every phone call.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <FeatureCard icon={f.icon} name={f.name} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- Where are calls coming from -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-4">
          Attribution
        </div>
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Where Are Your <span class="text-lime-400">Calls Coming From?</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-2xl mx-auto">
          Stop guessing which channels work. LimeCall tracks calls across every marketing touchpoint — so you can cut waste and double down on what converts.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {useCases.map((uc) => (
          <div class="flex items-start gap-4 rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <span class="text-3xl flex-shrink-0">{uc.icon}</span>
            <div>
              <h3 class="font-bold text-white mb-1">{uc.title}</h3>
              <p class="text-sm text-dark-400 leading-relaxed">{uc.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Routing capabilities -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-2 items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-4">
            Call Routing
          </div>
          <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
            Route Calls Smarter, <span class="text-lime-400">Not Harder</span>
          </h2>
          <p class="mt-4 text-dark-400 leading-relaxed">
            Pair your tracking data with intelligent call routing to make sure every tracked call lands with the right rep — not just any rep.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              'IVR menus to qualify and route callers automatically',
              'Geo routing to connect callers with local reps',
              'Scheduled routing based on business hours and time zones',
              'Round-robin distribution to balance workload across your team',
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-dark-300">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
          <h3 class="text-lg font-bold text-white mb-6">Real-Time Analytics Dashboard</h3>
          <div class="space-y-5">
            {[
              { label: 'Calls from Paid Search', pct: 42, color: 'bg-lime-500' },
              { label: 'Calls from Organic SEO', pct: 28, color: 'bg-lime-600' },
              { label: 'Calls from Social Media', pct: 18, color: 'bg-lime-700' },
              { label: 'Calls from Direct / Other', pct: 12, color: 'bg-dark-600' },
            ].map((bar) => (
              <div>
                <div class="flex justify-between text-sm mb-1.5">
                  <span class="text-dark-400">{bar.label}</span>
                  <span class="font-bold text-white">{bar.pct}%</span>
                </div>
                <div class="h-2 rounded-full bg-dark-800">
                  <div class={`h-2 rounded-full ${bar.color}`} style={`width: ${bar.pct}%`}></div>
                </div>
              </div>
            ))}
          </div>
          <p class="mt-5 text-xs text-dark-600">Example attribution data — your results will vary.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Stop Guessing. Start <span class="text-lime-400">Tracking.</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        Set up LimeCall call tracking in minutes and finally know which campaigns drive real revenue.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free Trial
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          View Pricing
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">30-day money-back guarantee · Cancel anytime</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="Complete Your LimeCall Stack"
        links={[
          { href: '/click-to-call-software', title: 'Click to Call Software', desc: 'Turn website clicks into live phone calls instantly.' },
          { href: '/customer-callback-software', title: 'Callback Software', desc: 'Automated callbacks connecting prospects in 28 seconds.' },
          { href: '/speed-to-lead', title: 'Speed to Lead', desc: 'Respond to every lead in seconds, not hours.' },
          { href: '/virtual-numbers', title: 'Virtual Numbers', desc: 'Get local numbers in 40+ countries for call tracking.' },
          { href: '/lead-distribution', title: 'Lead Distribution', desc: 'Route every tracked call to the right rep.' },
          { href: '/pricing', title: 'Pricing', desc: 'Start free. Scale as your call volume grows.' },
        ]}
      />
    </div>
  </section>
</Base>
