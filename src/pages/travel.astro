---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Callback Software for Travel Agencies & Tour Operators | LimeCall',
  description: 'Convert travel enquiries 5x faster. LimeCall connects your sales consultants with holiday bookers in 28 seconds — capturing high-value package sales before competitors.',
  canonical: site.url + '/travel/',
};

const stats = [
  { value: '28s', label: 'Average connection time from enquiry to travel consultant' },
  { value: '£2,800', label: 'Average UK package holiday value — each call counts' },
  { value: '73%', label: 'Of travellers call before committing to a booking' },
  { value: '5×', label: 'Conversion rate vs email follow-up alone' },
];

const features = [
  { icon: '✈️', title: 'Holiday Enquiry Instant Callback', desc: 'Connect every website holiday enquiry to a consultant in 28 seconds. Whether it\'s a cruise, long-haul package, or city break, your team speaks with the booker while they\'re still on your site.' },
  { icon: '🗺️', title: 'Destination Specialist Routing', desc: 'Route enquiries automatically to your destination specialists. Long-haul to your Americas team, cruise to your cruising experts, ski to your alpine specialists — no hold music, no wrong team.' },
  { icon: '🌙', title: 'Out-of-Hours Lead Capture', desc: 'Holiday browsing happens at 9pm. LimeCall queues every after-hours enquiry and connects your team with bookers first thing in the morning — before any other agency calls.' },
  { icon: '💬', title: 'WhatsApp Itinerary Sharing', desc: 'After the initial call, consultants send full itineraries, destination guides, hotel photos, and price comparisons via WhatsApp — keeping the conversation warm and conversion rates high.' },
  { icon: '📋', title: 'CRM Sync — Travelport, Tourplan & HubSpot', desc: 'Every callback automatically logged in Travelport, Tourplan, or HubSpot. Enquiry source, destination requested, package value, call duration, and consultant outcome — zero manual entry.' },
  { icon: '👥', title: 'Group Booking Callbacks', desc: 'Group travel enquiries — weddings abroad, school trips, corporate events — are routed to your groups team with higher priority and longer call windows to handle complex multi-person bookings.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Does LimeCall work with website enquiry forms for travel agencies?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall integrates with any website enquiry form via webhook, Zapier, or direct API. When a traveller submits a holiday enquiry on your website, LimeCall captures the contact details and triggers an instant callback to your consultant within 28 seconds. You can also add the LimeCall click-to-call widget directly to your enquiry pages so visitors can request a callback without submitting a form. Both methods work alongside your existing website without any developer resource.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall handle out-of-hours enquiries for different timezones?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall captures all after-hours enquiries and queues them for the next available consultant. For agencies serving international customers across multiple timezones, you can configure separate business hours for each team and set routing rules so enquiries from Australian customers, for example, are handled by your early-opening team. You can also set up automated WhatsApp or SMS acknowledgement messages that send immediately on receipt of an out-of-hours enquiry, so the customer knows you\'ll call first thing.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall route group booking enquiries to a specialist team?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall\'s routing rules can identify group booking enquiries based on keywords in the form submission, the page that triggered the callback, or the number of passengers entered. Group enquiries are automatically routed to your groups team with configurable priority and call handling settings — including longer connection windows and multiple agent fallback — to ensure complex bookings are handled by the right consultant every time.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the typical booking conversion rate improvement with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Travel agencies using LimeCall report an average 5× improvement in enquiry-to-booking conversion compared to email follow-up alone. This is driven by the speed of response — 73% of travellers research multiple agencies before booking, and the first consultant to call back wins the sale in the majority of cases. Our travel agency customers typically see 40–60% more bookings converted from the same volume of website enquiries after implementing LimeCall.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall integrate with travel industry CRMs like Travelport?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall integrates with Travelport, Tourplan, and HubSpot via API or Zapier. Every callback is automatically logged — traveller name, contact number, destination enquired, package value discussed, call duration, and consultant outcome — keeping your CRM accurate and your pipeline up to date. For any CRM not on this list, Zapier connects LimeCall to 1,000+ tools with no developer required.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can consultants share itineraries via WhatsApp after a callback?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall\'s WhatsApp integration allows consultants to continue the post-call conversation via WhatsApp — sharing detailed itineraries, hotel photos, destination guides, and price breakdowns in the same thread. Research shows that travellers who receive follow-up content via WhatsApp within 30 minutes of an initial call are significantly more likely to confirm a booking. The entire conversation thread is also logged back to your CRM for full pipeline visibility.',
      },
    },
    {
      '@type': 'Question',
      name: 'How quickly can a travel agency go live with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most travel agencies are live within 5 minutes. Add the LimeCall widget to your website using a single code snippet or tag manager, configure your destination specialist routing and consultant assignments, and the system is active immediately. Enquiry form and CRM integrations typically take an additional 10–15 minutes via Zapier. No developer or IT resource is required, and our onboarding team will assist with setup and routing configuration.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is LimeCall suitable for independent travel agents as well as large operators?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall is used by independent travel consultants operating solo through to large tour operators with teams of 50+ consultants. Independent agents benefit from after-hours capture and the WhatsApp follow-up flow, while larger operators use the destination routing, group booking handling, and CRM integrations. Pricing starts at £0 per month for basic use, with paid plans from £29/month that cover most independent agent needs.',
      },
    },
  ],
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'LimeCall — Callback Software for Travel Agencies',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: 'Instant callback software for travel agencies and tour operators. Connects holiday enquiries to consultants in 28 seconds with destination routing, WhatsApp itinerary sharing, and CRM sync.',
  url: site.url + '/travel/',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'GBP',
    description: '14-day free trial, no credit card required',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '194',
  },
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={softwareSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumbs items={[{ name: 'Travel', url: site.url + '/travel/' }]} />
      <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400">
        ✈️ For Travel Agencies &amp; Tour Operators
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Book More Holidays with<br class="hidden sm:block" />
        <span class="text-lime-400">Instant Callback</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300">
        73% of travellers call before committing to a booking. LimeCall connects your consultants with holiday enquiries in 28 seconds — capturing high-value package sales before competitors even read their email.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/get-started/" class="inline-flex items-center justify-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free Trial — 14 Days
        </a>
        <a href="/demo/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-dark-700 px-8 py-4 text-sm font-semibold text-white transition hover:border-lime-500/40 hover:text-lime-400">
          Book a Demo →
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">★ Destination Specialist Routing · WhatsApp Itinerary Sharing · Trusted by Travel Agencies Across the UK</p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-dark-800 bg-dark-900/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <dt class="text-3xl font-extrabold text-lime-400">{s.value}</dt>
            <dd class="mt-1 text-sm text-dark-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Problem callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-orange-500/30 bg-orange-500/5 p-8">
        <h2 class="text-xl font-bold text-white mb-3">⚠️ Your Enquiries Are Being Booked with Competitors While You Write Follow-Up Emails</h2>
        <p class="text-dark-300">
          A couple submits a honeymoon enquiry on your website at 8pm. They've also enquired with two other agencies. By 9am the next day, all three have the email. The agency that calls first wins the £5,000 honeymoon package. Without LimeCall, that's a lottery. With LimeCall, your consultant calls in 28 seconds — while the couple is still browsing your website, excited and ready to book.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">How LimeCall Works for Travel Agencies</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: '01', title: 'Traveller Enquires on Your Website', desc: 'Via your enquiry form, holiday search page, destination landing page, or direct callback widget — LimeCall captures the enquiry and the contact details instantly.' },
          { step: '02', title: 'LimeCall Routes to the Right Specialist', desc: 'Routing rules match the enquiry to the correct destination specialist — long-haul to your Americas team, cruise to your specialist, group enquiries to your groups desk.' },
          { step: '03', title: 'Consultant Connected in 28 Seconds', desc: 'Your consultant speaks with the booker while they\'re still excited and on your site — before any competitor agency has read the email. First call wins the booking.' },
        ].map(item => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-lg">{item.step}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-dark-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">Built for Travel Agencies &amp; Tour Operators</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-dark-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Travel Agency Use Cases</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'Package Holiday Enquiries', desc: 'Traveller enquires on all-inclusive package → callback in 28s → consultant walks through options on call → booking confirmed with deposit.' },
          { title: 'Long-Haul & Cruise Specialists', desc: 'Cruise enquiry triggers routing to cruise specialist → itinerary shared via WhatsApp post-call → high-value booking secured.' },
          { title: 'Peak Season Campaigns (Jan–Mar)', desc: 'January sale traffic drives enquiry volume → LimeCall queues and routes automatically → no missed peak-window leads, maximum conversion.' },
          { title: 'Group & Wedding Travel', desc: 'Group booking enquiry identified by form field → routed to groups team with priority → complex itinerary discussion started on first call.' },
        ].map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="font-bold text-white mb-2">{u.title}</h3>
            <p class="text-sm text-dark-400">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case study -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <blockquote class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-10 text-center">
        <p class="text-xl text-white italic leading-relaxed">
          "We were converting about 12% of our website enquiries into bookings. Since adding LimeCall, that's 51%. Our consultants are on the phone in under a minute, and we follow up with the itinerary on WhatsApp. In our first year we added £340k in additional revenue. The destination routing means cruise enquiries never go to someone who doesn't know the ships."
        </p>
        <footer class="mt-6">
          <p class="font-bold text-lime-400">Managing Director</p>
          <p class="text-sm text-dark-500">Independent UK travel agency — 51% more bookings converted, £340k additional revenue in first year</p>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">LimeCall vs. Traditional Travel Enquiry Handling</h2>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              {['Feature', 'LimeCall', 'Email Follow-Up', 'Phone + Voicemail', 'Live Chat'].map(h => (
                <th class={`px-5 py-4 text-left font-semibold ${h === 'LimeCall' ? 'text-lime-400' : 'text-dark-300'}`}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['Response time', '28 seconds', 'Hours to next day', 'Hours or missed', 'Agent dependent'],
              ['Out-of-hours capture', '✅ Queue + AM callback', '✅ Stored, slow reply', '❌ Voicemail lost', '❌ No agent'],
              ['Destination routing', '✅ Specialist matching', '❌ None', '⚠️ Manual transfer', '⚠️ Manual'],
              ['WhatsApp follow-up', '✅ Post-call itinerary', '❌ Email only', '❌ No follow-up', '✅ Limited'],
              ['Group booking handling', '✅ Priority routing', '⚠️ Generic reply', '⚠️ Manual', '⚠️ Limited'],
              ['Booking conversion', '🟢 5× vs email', '🔴 Low (slow)', '🟡 Standard', '🟡 Medium'],
            ].map(([feature, ...vals]) => (
              <tr class="hover:bg-dark-800/30 transition">
                <td class="px-5 py-4 font-medium text-dark-200">{feature}</td>
                {vals.map((v, i) => (
                  <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Integration callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-dark-700 bg-dark-900/60 p-8 sm:p-10 flex flex-col sm:flex-row items-center gap-8">
        <div class="shrink-0 text-5xl">🔗</div>
        <div>
          <h2 class="text-xl font-bold text-white mb-2">Integrates with Your Travel Agency Tech Stack</h2>
          <p class="text-dark-400 text-sm leading-relaxed">
            LimeCall connects to Travelport, Tourplan, HubSpot, and 1,000+ tools via Zapier. Every callback is automatically logged — traveller name, destination enquired, package value, call duration, and consultant notes. Setup takes under 5 minutes with no developer required. Full Zapier templates available for common travel CRM setups.
          </p>
          <a href="/integrations/" class="mt-4 inline-flex items-center text-sm font-semibold text-lime-400 hover:text-lime-300 transition">
            View all integrations →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Industry context -->
  <section class="py-16 sm:py-20 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-10">Why Speed to Lead Wins Bookings in Travel</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          { icon: '📊', title: '£68bn UK Travel Market', desc: 'The UK travel market generates £68bn annually. With average package values of £2,800 and 73% of bookers calling before committing, the difference between first and second to call is enormous.' },
          { icon: '📅', title: 'Peak Booking Window: Jan–March', desc: 'The UK "wave season" — January to March — drives 40% of annual bookings. Agencies that capture peak-season enquiries fastest win the year. LimeCall ensures no wave-season lead goes cold.' },
          { icon: '📱', title: '73% Call Before Booking', desc: '73% of UK travellers make at least one phone call before confirming a holiday. The agency that makes that call happen — in 28 seconds — converts at 5× the rate of email-first competitors.' },
        ].map(item => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 text-center">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-dark-400">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {item.name}
              <span class="ml-4 shrink-0 text-lime-400 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-gradient-to-br from-lime-500/10 to-dark-900 border-t border-lime-500/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Start Booking More Holidays Today</h2>
      <p class="mt-4 text-lg text-dark-300">14-day free trial · Destination specialist routing · WhatsApp follow-up included</p>
      <a href="/get-started/" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-lime-500 px-10 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
        Try Free — 14 Days →
      </a>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime · Full onboarding support for travel agencies</p>
    </div>
  </section>

  <!-- Cross-links -->
  <div class="py-12 bg-dark-950 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore More" links={[
        { href: '/click-to-whatsapp/', title: 'Click to WhatsApp', desc: 'Share itineraries and photos via WhatsApp post-call.' },
        { href: '/customer-callback-software/', title: 'Callback Software', desc: 'Core callback features for any business.' },
        { href: '/lead-routing-software/', title: 'Lead Routing Software', desc: 'Route enquiries to destination specialists automatically.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Plans from £0/mo — paid for by a single booking.' },
      ]} />
    </div>
  </div>
</Base>
