---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const icon = "💰";

const seo = {
  title: `Increase Sales with Instant Callbacks | LimeCall`,
  description: `Accelerate your sales velocity with LimeCall. Connect with inbound leads in under 28 seconds, eliminate dropped opportunities, and boost revenue without increasing your ad spend.`,
  canonical: `https://www.limecall.com/increase-sales/`,
};

const useCases = [
  { title: "Accelerate Sales Velocity", desc: "The faster you connect with a lead, the more likely they are to buy. LimeCall reduces the time between a prospect showing interest and your team starting a real conversation from hours to under 28 seconds." },
  { title: "Eliminate Dropped Opportunities", desc: "Every unanswered inquiry is a lost sale. LimeCall's automated callback sequences ensure every lead is followed up — including after-hours requests and missed calls — so nothing falls through the cracks." },
  { title: "Increase Revenue from Existing Traffic", desc: "You're already paying for website traffic. LimeCall squeezes more revenue out of every visitor by turning passive browsers into active conversations — without increasing your ad spend by a single dollar." },
  { title: "Smart Lead Routing to Top Closers", desc: "Route high-value leads directly to your best closers based on lead score, deal size, or custom criteria. Put your strongest sales reps on your highest-potential opportunities every time." },
];

const stats = [
  { value: "391%", label: "Higher contact-to-close rate" },
  { value: "3x", label: "Close rate increase" },
  { value: "10–12x", label: "Vs. slow form follow-up" },
  { value: "28s", label: "Average callback time" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall increase sales?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall increases sales by connecting your reps with high-intent inbound leads in under 28 seconds. Research shows that contacting a lead within 1 minute of their inquiry increases conversion by 391%. LimeCall automates that instant connection so every lead gets a real conversation while they are still actively interested.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the fastest way to increase sales without more ad spend?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The fastest way to increase sales from existing traffic is to reduce your response time to inbound leads. Most businesses take hours or days to follow up. LimeCall connects reps to leads in 28 seconds, immediately unlocking more revenue from the traffic you are already paying for.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does calling leads faster really help close more deals?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — dramatically. Studies by MIT and the Harvard Business Review consistently show that lead response time is the single biggest factor in whether a lead converts. A lead contacted within 1 minute is 391% more likely to convert than one contacted 24 hours later.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much can I increase sales with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Results vary by industry and current response time, but LimeCall customers typically report a 2–4x increase in qualified conversations from the same volume of inbound leads. Teams that previously had multi-hour response times see the largest gains.',
      },
    },
    {
      '@type': 'Question',
      name: "What's the ROI of callback software?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The ROI of callback software like LimeCall is typically measured by comparing the increase in closed deals to the cost of the platform. Because LimeCall converts existing traffic more effectively, there is no incremental ad spend. Most customers recover the cost of LimeCall within their first additional closed deal each month.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `Increase Sales`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{icon}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        <span class="text-lime-400">Increase Sales</span> with Instant Callbacks
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Close more deals without increasing ad spend. Connect with inbound leads in under 28 seconds and watch your sales velocity climb.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How LimeCall increases your sales</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Lead shows buying intent", desc: "A high-intent prospect visits your pricing page, product page, or demo page and clicks the LimeCall callback widget." },
          { step: "2", title: "Sales rep connected instantly", desc: "LimeCall calls your sales rep and the prospect simultaneously, bridging them in under 28 seconds." },
          { step: "3", title: "Deal progressed", desc: "The call is logged in your CRM with full attribution. Automated follow-up sequences keep deals moving even after hours." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The sales math section -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">The sales math is simple</h2>
      <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-8">
        <div class="grid gap-6 sm:grid-cols-3 text-center">
          <div>
            <p class="text-4xl font-extrabold text-dark-400">2%</p>
            <p class="mt-2 text-sm text-dark-400">Avg. inbound lead conversion<br/>with slow follow-up (&gt;24h)</p>
          </div>
          <div class="flex items-center justify-center">
            <span class="text-3xl text-lime-400 font-bold">→</span>
          </div>
          <div>
            <p class="text-4xl font-extrabold text-lime-400">8–10%</p>
            <p class="mt-2 text-sm text-dark-300">Avg. inbound lead conversion<br/>with LimeCall (&lt;28s response)</p>
          </div>
        </div>
        <p class="mt-6 text-center text-sm text-dark-400">Same traffic. Same leads. More revenue — just by responding faster.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(q => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {q.name}
              <span class="ml-4 shrink-0 text-lime-400 transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{q.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to increase your sales today?</h2>
      <p class="mt-4 text-dark-400">Set up in 5 minutes. No credit card required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4">
    <CrossLinks heading="More LimeCall Solutions" links={[
      { href: '/for-sales-teams/', title: 'For Sales Teams', desc: 'Tools built for high-performing sales reps.' },
      { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'Why responding in seconds beats hours every time.' },
      { href: '/increase-your-website-conversions/', title: 'Increase Conversions', desc: 'Turn more website visitors into buyers.' },
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
    ]} />
  </div>
</Base>
