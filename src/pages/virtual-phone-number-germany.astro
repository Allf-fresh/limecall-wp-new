---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const country = "Germany";
const code = "+49";
const slug = "virtual-phone-number-germany";
const flag = "🇩🇪";

const seo = {
  title: `Get a Virtual Phone Number for Germany (${code}) | LimeCall`,
  description: `Get a Germany virtual phone number (${code}) instantly. No hardware needed. Route calls, enable callbacks, and grow your Germany business with LimeCall.`,
  canonical: `https://www.limecall.com/${slug}/`,
};

const features = [
  { title: "Instant Setup", desc: "Get your Germany virtual number in minutes. No hardware, no SIM card, no contracts." },
  { title: "Smart Call Routing", desc: "Route incoming calls to any device or team member — mobile, desktop, or desk phone." },
  { title: "Call Recording", desc: "Record and review every call for quality assurance and compliance." },
  { title: "Callback Automation", desc: "Let website visitors request instant callbacks from your Germany-based or global team." },
  { title: "SMS & WhatsApp", desc: "Send and receive SMS messages on your Germany virtual number." },
  { title: "Analytics Dashboard", desc: "Full call analytics, reporting, and conversion tracking in one dashboard." },
];

const faqs = [
  {
    q: `What is a Germany virtual phone number?`,
    a: `A Germany virtual phone number (${code}) is a telephone number that isn't tied to a physical phone line or SIM card. It routes calls over the internet to any device — mobile, laptop, or desk phone — anywhere in the world. Your customers in Germany dial a local number and the call reaches you wherever you are.`,
  },
  {
    q: `Do I need to be in Germany to get a German virtual number?`,
    a: `No. Anyone can get a Germany virtual phone number from anywhere in the world. LimeCall gives you a local ${code} number that German customers can call at local rates, while your team answers from any country.`,
  },
  {
    q: `What types of German virtual numbers are available?`,
    a: `LimeCall offers local German numbers with city-specific area codes (030 Berlin, 040 Hamburg, 089 Munich, 0221 Cologne, 069 Frankfurt, etc.) as well as national 0800 freephone numbers. Choose the format that best represents your German business presence.`,
  },
  {
    q: "How long does setup take?",
    a: "Setup takes under 5 minutes. Sign up, choose your Germany number, and you're ready to receive calls immediately — no waiting for hardware or SIM activation.",
  },
  {
    q: "Can I use a German virtual number for callbacks?",
    a: "Yes — LimeCall's callback automation lets website visitors request a call and your team calls them back within 28 seconds using your Germany virtual number. This dramatically improves lead conversion rates.",
  },
  {
    q: `Is a German virtual number compliant with BNetzA regulations?`,
    a: `LimeCall's Germany virtual numbers are provisioned through licensed carriers regulated by the Bundesnetzagentur (BNetzA — Federal Network Agency) and comply with German telecommunications laws. All numbers are legitimate, properly registered German numbers.`,
  },
];
---

<Base {...seo}>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `${country} Virtual Number`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a <span class="text-lime-400">{country} Virtual Phone Number</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Local {country} number ({code}) that works anywhere. Instant setup, no hardware. Route calls, automate callbacks, and close more deals.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your {country} Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Everything included with your {country} number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.q}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your {country} number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall virtual numbers to connect with customers globally.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/virtual-numbers/', title: 'All Virtual Numbers', desc: 'Browse all available countries.' },
        { href: '/click-to-call-software/', title: 'Click to Call', desc: 'Let visitors call you instantly.' },
        { href: '/customer-callback-software/', title: 'Callback Software', desc: 'Automated callbacks in 28 seconds.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
