---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { getPublishedContent } from '../../lib/supabase';
import { site } from '../../site.config';

const blogCategories = site.blog.categories;

const categories = blogCategories.map(slug => ({
  slug,
  name: slug.charAt(0).toUpperCase() + slug.slice(1).replace(/-/g, ' '),
  desc: `Articles in the ${slug.replace(/-/g, ' ')} category.`,
}));

const allPosts = await getPublishedContent('blog');
const latestPosts = allPosts.slice(0, 12);

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(p => p.category === cat.slug).length,
}));
---

<Base
  title={`Blog — ${site.name}`}
  description={`Guides, tips, and news from ${site.name}. Stay up to date with the latest best practices.`}
>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Blog', url: `${site.url}/blog` }]} />

      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">
          {site.name}
          <span class="text-lime-400"> Blog</span>
        </h1>
        <p class="mt-6 text-lg text-dark-300">
          Guides, tips, and news to help you get the most from {site.name}.
          <span class="text-dark-500">({allPosts.length} articles)</span>
        </p>
      </div>

      <!-- Categories -->
      <div class="mt-16">
        <h2 class="mb-8 text-2xl font-bold text-white">Browse by Category</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {categoryCounts.map((cat) => (
            <a
              href={`/blog/${cat.slug}`}
              class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6 transition-all hover:border-lime-500/50"
            >
              <div class="flex items-center justify-between">
                <h3 class="font-semibold text-white group-hover:text-lime-400">{cat.name}</h3>
                <span class="text-xs text-dark-500">{cat.count} articles</span>
              </div>
              <p class="mt-2 text-sm text-dark-400">{cat.desc}</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Latest Posts -->
      {latestPosts.length > 0 ? (
        <div class="mt-20">
          <h2 class="mb-8 text-2xl font-bold text-white">Latest Articles</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {latestPosts.map((post) => (
              <a
                href={post.category ? `/blog/${post.category}/${post.slug}` : `/blog/${post.slug}`}
                class="group rounded-xl border border-dark-800 bg-dark-900/50 overflow-hidden transition-all hover:border-dark-700"
              >
                <div class="p-6">
                  <span class="text-xs font-medium uppercase text-lime-400">{post.category || 'Blog'}</span>
                  <h3 class="mt-2 font-semibold text-white group-hover:text-lime-400">{post.title}</h3>
                  <p class="mt-2 text-sm text-dark-400 line-clamp-2">{post.meta_description || ''}</p>
                  {post.publish_date && (
                    <time class="mt-4 block text-xs text-dark-500" datetime={post.publish_date}>
                      {new Date(post.publish_date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="mt-20 rounded-xl border border-dark-800 bg-dark-900/50 p-12 text-center">
          <p class="text-dark-400">No articles yet. Connect Supabase to populate your blog.</p>
        </div>
      )}
    </div>
  </section>
</Base>
