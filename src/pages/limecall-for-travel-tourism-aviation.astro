---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const seo = {
  title: `Limecall for Travel Tourism Aviation | Helpdesk Software`,
  description: `Helpdesk software for Travel industry. Help to make great memories worldwide with LimeCall. Stay closer to your customers and help them faster.`,
  canonical: `https://www.limecall.com/limecall-for-travel-tourism-aviation/`,
};

const segments = [
  {
    name: "Travel Agencies",
    desc: "Package holiday and tour enquiries convert best when answered by a specialist within minutes. LimeCall puts your destination experts on the phone in 28 seconds.",
  },
  {
    name: "Airlines & Aviation",
    desc: "High-stakes booking changes, upgrades, and group travel require real-time human support. LimeCall routes customers to the right team instantly.",
  },
  {
    name: "Hotels & Resorts",
    desc: "Guests comparing accommodation need quick answers on availability, rates, and amenities. Callback converts the undecided — your front desk team, anytime.",
  },
  {
    name: "Tour Operators",
    desc: "Complex, multi-day itineraries require expert guidance. Let prospective travellers talk to your specialists before they book elsewhere.",
  },
  {
    name: "Airport Transfers & Ground Transport",
    desc: "Last-minute bookings and schedule changes need instant communication. LimeCall keeps your dispatch and booking team reachable at all times.",
  },
  {
    name: "Cruise Lines",
    desc: "Cruise bookings are emotional, high-value decisions. Connect prospects with cruise specialists who can guide them to the perfect voyage.",
  },
];

const benefits = [
  { title: "28-second callback", desc: "Connect with travellers while they're still on your website — before they click away to a comparison site or OTA." },
  { title: "Destination & route routing", desc: "Route callbacks by destination, language, booking type, or customer tier. Every traveller talks to the most relevant specialist." },
  { title: "Multi-language support", desc: "With virtual numbers in 50+ countries and multi-language routing, serve international travellers in their preferred language." },
  { title: "After-hours lead capture", desc: "Travel planning happens around the clock. Capture off-hours enquiries and queue them for your team — no lead is lost overnight." },
  { title: "SMS confirmation", desc: "Send instant SMS when a callback is requested or scheduled. Keep travellers informed and reduce no-shows." },
  { title: "CRM & helpdesk integration", desc: "Sync with HubSpot, Zendesk, or Salesforce. Every customer interaction is logged with full context — no matter how many times they've called." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More bookings vs. forms" },
  { value: "50+", label: "Countries supported" },
  { value: "24/7", label: "Lead capture" },
];
---

<Base {...seo}>
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Travel, Tourism & Aviation', url: seo.canonical }]} />
      <div class="inline-flex items-center rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400 mb-4">
        Travel · Tourism · Aviation
      </div>
      <h1 class="mt-2 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        The Travel Industry's<br class="hidden sm:block" />
        <span class="text-lime-400">Callback Platform</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Airlines, travel agencies, hotels, and tour operators use LimeCall to connect with travellers faster — and convert enquiries into bookings before the competition.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free Trial →</a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Segments -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Who in travel uses LimeCall</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {segments.map(s => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-lime-400">{s.name}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Key capabilities for travel businesses</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map(b => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{b.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Scenario -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-950/20 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-white mb-4">When every second matters — like during flight changes</h2>
        <p class="text-dark-300 leading-relaxed mb-4">
          A passenger discovers their connection is cancelled. They go to your website and click the callback widget. LimeCall routes the call to your nearest available rebooking specialist in under 28 seconds. The passenger is rebooked while still in the airport, before they've even tried calling the main line.
        </p>
        <p class="text-dark-400 text-sm">
          Happy customers remember the experience and come back to book again — directly.
        </p>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Help travellers book faster. Keep them coming back.</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free Trial →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="More solutions" links={[
        { href: '/limecall-for-travel/', title: 'Travel Agency', desc: 'Focused guide for travel agency teams.' },
        { href: '/limecall-for-real-estate/', title: 'Real Estate', desc: 'Convert property enquiries in under 28 seconds.' },
        { href: '/use-cases/', title: 'All Use Cases', desc: 'See how LimeCall works across every industry.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
