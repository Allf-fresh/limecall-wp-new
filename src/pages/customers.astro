---
import Base from '../layouts/Base.astro';

const seo = {
  title: `Spotlight on Customer Experiences - LimeCall`,
  description: `Learn how Cue enables clients to boost sales speed and streamline customer support.`,
  canonical: `https://www.limecall.com/customers/`,
};
---
<Base {...seo}>
