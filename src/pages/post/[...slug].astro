---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import CrossLinks from '../../components/CrossLinks.astro';
import { site } from '../../site.config';
import posts from '../../data/posts.json';

export async function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const seo = {
  title: post.seo_title || post.title,
  description: post.seo_description || '',
  canonical: post.canonical,
};

// Related posts: same category or random 4 posts
const related = posts
  .filter(p => p.slug !== post.slug)
  .sort(() => 0.5 - Math.random())
  .slice(0, 4);
---

<Base {...seo}>
  <!-- Article hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Blog', url: `${site.url}/post/` }, { name: post.title, url: seo.canonical }]} />
      <h1 class="mt-4 text-3xl font-extrabold leading-tight text-white sm:text-4xl" set:html={post.title} />
      <div class="mt-4 flex items-center gap-4 text-sm text-dark-400">
        <time datetime={post.date}>
          {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </div>
  </section>

  <!-- Article content -->
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="wp-content prose-dark" set:html={post.content} />
    </div>
  </section>

  <!-- Related posts -->
  {related.length > 0 && (
    <section class="border-t border-dark-800 py-12 sm:py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-8 text-xl font-bold text-white">More from the blog</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {related.map(r => (
            <a href={`/post/${r.slug}/`} class="rounded-xl border border-dark-800 bg-dark-900/60 p-5 hover:border-lime-500/30 transition group">
              <p class="text-xs text-dark-500 mb-2">{new Date(r.date).getFullYear()}</p>
              <h3 class="text-sm font-semibold text-white group-hover:text-lime-400 transition line-clamp-3" set:html={r.title} />
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <div class="py-8">
    <CrossLinks
      heading="Explore LimeCall"
      links={[
        { href: '/post/', title: 'All Articles', desc: 'Browse all blog posts and guides.' },
        { href: '/click-to-call-software/', title: 'Click-to-Call', desc: 'Connect with leads instantly.' },
        { href: '/virtual-numbers/', title: 'Virtual Numbers', desc: 'Get numbers in 50+ countries.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
