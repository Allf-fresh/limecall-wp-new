---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { site, competitors } from '../../site.config';
---

<Base
  title={`Compare ${site.name} — vs Competitors`}
  description={`See how ${site.name} compares to ${competitors.map(c => c.name).join(', ')} and more.`}
  canonical={`${site.url}/compare`}
>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Compare', url: `${site.url}/compare` }]} />

      <div class="text-center mb-12">
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">
          {site.name} vs the
          <span class="text-lime-400"> Competition</span>
        </h1>
        <p class="mt-4 text-lg text-dark-300">
          See how we compare to other options. Honest comparisons, no spin.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {competitors.map((competitor) => (
          <a
            href={`/compare/${site.name.toLowerCase().replace(/\s+/g, '-')}-vs-${competitor.slug}`}
            class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6 transition-all hover:border-lime-500/50"
          >
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-3">
                <span class="text-lg font-bold text-lime-400">{site.name}</span>
                <span class="text-dark-600 font-medium">vs</span>
                <span class="text-lg font-bold text-white">{competitor.name}</span>
              </div>
              <svg class="w-4 h-4 text-dark-500 group-hover:text-lime-400 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            <p class="text-sm text-dark-400">{competitor.tagline}</p>
          </a>
        ))}
      </div>

      <div class="mt-16 text-center rounded-xl border border-dark-800 bg-dark-900/50 p-8">
        <h2 class="text-xl font-bold text-white mb-2">Ready to switch?</h2>
        <p class="text-dark-400 mb-6">Try {site.name} risk-free. {site.cta.subtext}.</p>
        <a href={site.cta.href} class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-lime-500 hover:bg-lime-400 text-dark-950 font-bold transition">
          {site.cta.text}
        </a>
      </div>
    </div>
  </section>
</Base>
