---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Callback Software for Real Estate | LimeCall`,
  description: `Looking for Real Estate Sales Enablement & Callback Software? Convert and help your website visitors to find them a new home.`,
  canonical: `https://www.limecall.com/limecall-for-real-estate/`,
};

const challenges = [
  { title: "Buyers move fast", desc: "A buyer browsing listings is often talking to multiple agents. The first agent to get them on the phone wins the relationship — not the one who sends the best email." },
  { title: "After-hours enquiries", desc: "Most property searches happen in the evenings and weekends. Agencies with 9–5 response windows lose a huge proportion of their best leads." },
  { title: "Multiple team members", desc: "Routing the right enquiry to the right agent — based on area, property type, or buyer budget — is complex. Manual routing means delays and missed handoffs." },
];

const benefits = [
  { title: "Connect in 28 seconds", desc: "Buyer requests a callback from your listing page. Your agent is on the phone in under 28 seconds — before they browse to the next listing." },
  { title: "Smart lead routing", desc: "Route callbacks by property area, listing type, or price bracket. Luxury buyers talk to your luxury specialists automatically." },
  { title: "After-hours lead capture", desc: "Capture evening and weekend callback requests automatically. Agents arrive Monday to a prioritized queue of warm leads — ready to call." },
  { title: "Schedule viewings instantly", desc: "Can't talk right now? Let prospects schedule a viewing or callback directly from the widget. Your calendar stays full." },
  { title: "Call recordings for training", desc: "Record every callback automatically. Review calls for quality, train new agents, and ensure consistent service standards." },
  { title: "CRM integration", desc: "Every callback syncs to your CRM — HubSpot, Salesforce, or custom. Build a complete buyer history with zero manual data entry." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More viewings booked" },
  { value: "80%", label: "Fewer missed leads" },
  { value: "24/7", label: "Lead capture coverage" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall help real estate agents win more listings?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '70% of home buyers contact agents by phone first, and agents who callback in under 5 minutes close 8x more listings than those who respond hours later. LimeCall connects your agent with the buyer or seller in under 28 seconds — before they reach a competitor. The first agent to have a real conversation almost always wins the relationship.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall route property viewing requests to the right agent automatically?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall routing rules let you direct buyer callbacks based on property area, listing type, price bracket, or any other criteria. Luxury property enquiries go to your luxury specialist, first-time buyer queries to your dedicated first-time buyer team. No manual handoffs and no delays.'
      }
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall capture real estate leads outside business hours?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most property searches happen evenings and weekends. LimeCall captures all after-hours callback requests and queues them with timestamps for Monday morning. Agents arrive to a prioritized list of warm leads who are still actively looking. Without this system, these weekend leads typically go to agencies that respond faster.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall help qualify buyer budgets and preferences before the call?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall\'s callback widget can collect key information from the buyer before connecting the call — such as budget range, property type, and preferred area. This means your agent arrives on the call with context, turning the first conversation into a productive qualification and relationship-building session.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall integrate with real estate CRM platforms?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall integrates with major CRM platforms including HubSpot, Salesforce, and property-specific systems. Every callback, call recording, and call outcome is automatically synced to the buyer or vendor record, giving agents a complete interaction history without any manual data entry.'
      }
    },
  ]
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Real Estate', url: seo.canonical }]} />
      <div class="inline-flex items-center rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400 mb-4">
        Real Estate
      </div>
      <h1 class="mt-2 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Turn Property Browsers<br class="hidden sm:block" />
        <span class="text-lime-400">Into Booked Viewings</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Real estate agencies use LimeCall to respond to buyer and seller enquiries faster than the competition — and book more viewings as a result.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free Trial →</a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industry challenges -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">The real estate lead problem</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {challenges.map(c => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{c.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How LimeCall helps estate agents</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map(b => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{b.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How LimeCall works for Real Estate</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Buyer or seller shows interest", desc: "A prospect browses your listings page and clicks the LimeCall widget to request an immediate callback from one of your agents." },
          { step: "2", title: "Agent connected in seconds", desc: "LimeCall simultaneously calls your agent and the prospect, bridging them in under 28 seconds — before they visit another agency's site." },
          { step: "3", title: "Viewing booked & logged", desc: "The conversation is recorded, synced to your CRM, and a viewing is booked. Automatic follow-up handles missed calls." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison section -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Why callbacks book 8x more viewings than email follow-up</h2>
      <p class="mb-10 text-center text-dark-400 text-sm max-w-2xl mx-auto">70% of home buyers contact agents by phone first. Email delays the conversation. A callback starts the relationship immediately — on the buyer's terms.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 text-sm font-bold text-dark-400 uppercase tracking-wider">Email / Contact Form Follow-Up</div>
          <ul class="space-y-3 text-sm text-dark-400">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Buyer submits enquiry and moves on to browse more listings</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Generic email reply fails to address specific property questions</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Weekend leads go unanswered until Monday — buyer is gone</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> No routing — enquiries land in a shared inbox with no ownership</li>
          </ul>
        </div>
        <div class="rounded-xl border border-lime-500/30 bg-lime-950/10 p-6">
          <div class="mb-4 text-sm font-bold text-lime-400 uppercase tracking-wider">LimeCall Instant Callback</div>
          <ul class="space-y-3 text-sm text-dark-300">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Buyer is talking to your agent in under 28 seconds</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Personal conversation answers every property question on the spot</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Weekend enquiries queued and actioned first thing Monday</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Smart routing ensures the right agent takes every call</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Scenario -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-950/20 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-white mb-4">Sunday evening. Your best leads are online.</h2>
        <p class="text-dark-300 leading-relaxed mb-4">
          A family is browsing your listings on a Sunday evening. They find a 4-bed house that ticks every box. They click "Request a Callback." LimeCall captures the request and queues it for Monday morning. At 9am, your agent calls — and the family is still interested, still remembered the listing, and books a viewing before 9:30am.
        </p>
        <p class="text-dark-400 text-sm">
          Without LimeCall, that lead fills out a contact form and waits. By Monday they've already booked a viewing with another agency.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="cursor-pointer list-none font-semibold text-white flex justify-between items-center gap-4">
              <span>{faq.name}</span>
              <span class="shrink-0 text-lime-400 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Book more viewings. Lose fewer leads.</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free Trial →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="More solutions" links={[
        { href: '/limecall-for-finance-insurance/', title: 'Finance & Insurance', desc: 'Convert financial and mortgage leads faster.' },
        { href: '/limecall-for-travel/', title: 'Travel', desc: 'Capture travel enquiries in real time.' },
        { href: '/use-cases/', title: 'All Use Cases', desc: 'See how LimeCall works across every industry.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
