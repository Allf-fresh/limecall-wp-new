---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const country = "Romania";
const code = "+40";
const flag = "🇷🇴";

const seo = {
  title: `Romania Virtual Phone Numbers (+40) | LimeCall`,
  description: `Get a Romania virtual phone number (+40) instantly. No hardware needed. Route calls, enable callbacks, and grow your Romania business with LimeCall.`,
  canonical: `https://www.limecall.com/buy-romania-numbers/`,
};

const features = [
  { title: "Instant Setup", desc: "Get your Romania virtual number in minutes. No hardware, no SIM card, no contracts." },
  { title: "Smart Call Routing", desc: "Route incoming calls to any device or team member — mobile, desktop, or desk phone." },
  { title: "Call Recording", desc: "Record and review every call for quality assurance and compliance." },
  { title: "Callback Automation", desc: "Let website visitors request instant callbacks from your Romania-based or global team." },
  { title: "SMS & WhatsApp", desc: "Send and receive SMS messages on your Romania virtual number." },
  { title: "Analytics Dashboard", desc: "Full call analytics, reporting, and conversion tracking in one dashboard." },
];

const stats = [
  { value: "Instant", label: "Activation" },
  { value: "21", label: "Bucharest Area Code" },
  { value: "+40", label: "RO Country Code" },
  { value: "99.9%", label: "Uptime SLA" },
];

const countryFacts = [
  { title: "Country Code +40", desc: "Romania uses country code +40. Bucharest landline numbers start with area code 21, appearing internationally as +40 21 XX XX XX. Mobile numbers in Romania begin with +40 7XX." },
  { title: "Fast-Growing Tech Hub", desc: "Romania has a rapidly growing tech and outsourcing sector, with Bucharest and Cluj-Napoca as major IT centers. A local Romanian number helps international companies connect with this talent pool and customer base." },
  { title: "EU GDPR Applies", desc: "Romania is an EU member state, fully subject to GDPR. Call data, recordings, and customer information handled through LimeCall must comply with EU data protection requirements." },
];

const comparisonRows = [
  { aspect: "Setup Time", virtual: "Under 5 minutes", sim: "Days + in-country ID verification" },
  { aspect: "Monthly Cost", virtual: "From $4/mo", sim: "RON 15–60/mo plan" },
  { aspect: "Works Internationally", virtual: "Yes — route from anywhere", sim: "Roaming charges apply" },
  { aspect: "Bucharest Area Code (21)", virtual: "Yes, available", sim: "Depends on SIM region" },
  { aspect: "EU GDPR Tools", virtual: "Full compliance controls", sim: "Carrier dependent" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I get a Romanian phone number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sign up for LimeCall, select Romania, choose your preferred area code (Bucharest: 21, Cluj-Napoca: 264, Timisoara: 256), and your number activates instantly. No SIM card or Romanian residency required.',
      },
    },
    {
      '@type': 'Question',
      name: "What is Romania's country code?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Romania's country code is +40. A Romanian landline number looks like +40 21 XX XX XX (Bucharest), while mobile numbers are formatted as +40 7XX XXX XXX.",
      },
    },
    {
      '@type': 'Question',
      name: 'What is the Bucharest area code?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Bucharest uses area code 21. Internationally, Bucharest numbers are written as +40 21 XX XX XX. LimeCall provides Bucharest virtual numbers with the correct 021 area code.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do Romanians trust calls from foreign numbers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Romanian consumers and businesses are much more likely to answer calls from local +40 numbers than from unknown foreign numbers. A virtual Romanian number from LimeCall shows a local caller ID, significantly improving answer rates.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is a Romanian virtual number EU GDPR compliant?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall provides GDPR-compliant infrastructure. Romania is an EU member state, so all call data and recordings are handled in accordance with EU GDPR requirements and Romanian telecom regulations (ANCOM).',
      },
    },
  ],
};

const faqs = [
  {
    q: `What is a Romania virtual phone number?`,
    a: `A Romania virtual phone number (${code}) is a telephone number that isn't tied to a physical phone line or SIM card. It routes calls over the internet to any device — mobile, laptop, or desk phone — anywhere in the world. Your customers in Romania dial a local Romanian number, and the call reaches you wherever you are.`,
  },
  {
    q: `Do I need to be in Romania to get a Romanian virtual number?`,
    a: `No. Anyone can get a Romania virtual phone number from anywhere in the world. LimeCall gives you a local ${code} number that Romanian customers can call at local rates, while your team answers from any country.`,
  },
  {
    q: `What types of Romania virtual numbers are available?`,
    a: `LimeCall offers local Romania numbers with city-specific area codes (Bucharest, Cluj-Napoca, Timisoara, Iasi, Constanta, etc.) as well as national numbers. Choose the number type that best fits your business needs.`,
  },
  {
    q: "How long does setup take?",
    a: "Setup takes under 5 minutes. Sign up, choose your Romania number, and you're ready to receive calls immediately — no waiting for hardware or SIM activation.",
  },
  {
    q: "Can I use a Romania virtual number for callbacks?",
    a: "Yes — LimeCall's callback automation lets website visitors request a call and your team calls them back within 28 seconds using your Romania virtual number. This dramatically improves lead conversion rates.",
  },
  {
    q: `Are Romania virtual numbers compliant with ANCOM regulations?`,
    a: `LimeCall's Romania virtual numbers are provisioned through licensed telecom partners and comply with the National Regulatory Authority for Communications (ANCOM) guidelines. All numbers are legitimate, registered numbers suitable for business use.`,
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `${country} Virtual Number`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a <span class="text-lime-400">{country} Virtual Phone Number</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Local {country} number ({code}) that works anywhere. Instant setup, no hardware. Route calls, automate callbacks, and close more deals.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your {country} Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <p class="text-2xl font-extrabold text-lime-400">{s.value}</p>
            <p class="mt-1 text-xs text-dark-400 uppercase tracking-wide">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Everything included with your {country} number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Virtual vs SIM Comparison -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Virtual Romanian Number vs Romanian SIM Card</h2>
      <p class="mb-10 text-center text-sm text-dark-400">Why a virtual number beats a physical SIM for most businesses</p>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-6 py-4 text-left font-semibold text-dark-300">Feature</th>
              <th class="px-6 py-4 text-left font-semibold text-lime-400">Virtual Number (LimeCall)</th>
              <th class="px-6 py-4 text-left font-semibold text-dark-400">Romanian SIM Card</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800 ${i % 2 === 0 ? 'bg-dark-900/20' : ''}`}>
                <td class="px-6 py-4 font-medium text-white">{row.aspect}</td>
                <td class="px-6 py-4 text-dark-300">{row.virtual}</td>
                <td class="px-6 py-4 text-dark-500">{row.sim}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Country Facts -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Romania Telecom & Business Facts</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {countryFacts.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 text-sm font-bold text-lime-400 uppercase tracking-wide">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ with JSON-LD -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {item.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your {country} number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall virtual numbers to connect with customers globally.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/incoming-numbers/', title: 'Incoming Numbers', desc: 'DID numbers for inbound calls.' },
        { href: '/virtual-business-numbers/', title: 'Business Numbers', desc: 'Professional virtual numbers for teams.' },
        { href: '/buy-ukraine-numbers/', title: 'Ukraine Numbers', desc: 'Get a Ukrainian virtual phone number.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
