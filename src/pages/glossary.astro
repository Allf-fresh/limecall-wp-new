---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';
import glossary from '../data/glossary.json';

const seo = {
  title: 'LimeCall Glossary — Sales & Call Tracking Terms',
  description: 'Definitions for call tracking, lead generation, and sales automation terms. Your complete glossary for LimeCall features and industry terminology.',
  canonical: `${site.url}/glossary/`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is a call centre glossary?',
      acceptedAnswer: { '@type': 'Answer', text: 'A call centre glossary is a reference guide defining the key terms, metrics, and acronyms used in contact centre operations — such as AHT, FCR, IVR, and ASA — so that agents, managers, and stakeholders share a common vocabulary.' },
    },
    {
      '@type': 'Question',
      name: 'What does AHT mean?',
      acceptedAnswer: { '@type': 'Answer', text: 'AHT stands for Average Handle Time — the mean duration of a customer interaction, including talk time, hold time, and after-call wrap-up. It is a core call centre efficiency metric.' },
    },
    {
      '@type': 'Question',
      name: 'What is FCR?',
      acceptedAnswer: { '@type': 'Answer', text: 'FCR stands for First Call Resolution — the percentage of customer issues resolved on the very first contact, with no follow-up call required. A high FCR rate indicates effective agents and well-designed call flows.' },
    },
    {
      '@type': 'Question',
      name: 'What is a callback in call centres?',
      acceptedAnswer: { '@type': 'Answer', text: 'A callback is an automated phone call triggered when a customer requests to be called back rather than waiting on hold. Callback software like LimeCall can connect a website visitor with a sales rep in as little as 28 seconds.' },
    },
  ],
};

const stats = [
  { value: '100+', label: 'Terms Defined', sub: 'Across sales, calling, and marketing' },
  { value: '5', label: 'Categories', sub: 'Metrics, technology, call types, SMS, and CRM' },
  { value: '2026', label: 'Updated', sub: 'Reflects current industry standards' },
  { value: 'Free', label: 'Resource', sub: 'No sign-up required to access any definition' },
];

const glossaryHubs = [
  {
    title: 'Call Centre Glossary',
    desc: '50+ call centre and contact centre terms — metrics, IVR, ACD, FCR, and more. Plain-English definitions for every role.',
    href: '/call-centre-glossary/',
    count: '50+ terms',
  },
  {
    title: 'Sales Terminology Glossary',
    desc: '60+ sales terms defined — pipeline, speed-to-lead, conversion rate, BANT, and more. The essential vocabulary for modern sales teams.',
    href: '/sales-terminology-glossary/',
    count: '60+ terms',
  },
];

const quickTerms = [
  { term: 'Callback', def: 'An automated phone call triggered when a visitor requests a call from your website. See <a href="/customer-callback-software/" class="text-lime-400 hover:underline">customer callback software</a> for a full platform overview.' },
  { term: 'DNI', def: 'Dynamic Number Insertion — swapping phone numbers per visitor source for call attribution.' },
  { term: 'Speed-to-Lead', def: 'Time from lead submission to first contact attempt; under 1 minute dramatically boosts conversion. Learn more about <a href="/speed-to-lead/" class="text-lime-400 hover:underline">speed-to-lead software</a>.' },
  { term: 'CTA', def: 'Call-to-Action — a prompt encouraging a visitor to take the next step, like requesting a callback.' },
  { term: 'Warm Transfer', def: 'Connecting a live call with context passed to the next rep so the caller never repeats themselves.' },
  { term: 'AHT', def: 'Average Handle Time — the mean duration of a customer interaction including talk, hold, and wrap-up.' },
  { term: 'FCR', def: 'First Call Resolution — the percentage of issues resolved on the very first call, no follow-up needed.' },
  { term: 'Lead Routing', def: 'Automatically directing an inbound lead to the right sales rep based on rules like territory or skill.' },
  { term: 'IVR', def: 'Interactive Voice Response — an automated phone menu that routes callers via keypad or voice input.' },
  { term: 'Round-Robin', def: 'A lead-assignment method that cycles leads evenly through available reps for fair distribution.' },
  { term: 'Click-to-Call', def: 'A website button that initiates an instant phone call between a visitor and a sales rep.' },
  { term: 'Abandonment Rate', def: 'The percentage of callers who hang up before reaching an agent — a signal of long queue times.' },
  { term: 'NPS', def: 'Net Promoter Score — a loyalty measure asking how likely customers are to recommend your business.' },
  { term: 'CSAT', def: 'Customer Satisfaction Score — a post-call survey rating how satisfied a customer is with their interaction.' },
  { term: 'CRM', def: 'Customer Relationship Management software — stores contacts, tracks deals, and logs all interactions.' },
  { term: 'Predictive Dialer', def: 'An outbound system that auto-dials ahead of agents becoming free, maximising talk time.' },
  { term: 'ASA', def: 'Average Speed of Answer — mean time callers wait in queue before reaching a live agent.' },
  { term: 'SMS Broadcast', def: 'A bulk text message sent from a business number to a list of contacts simultaneously.' },
  { term: 'Virtual Number', def: 'A phone number not tied to a physical line — used to build local presence in multiple countries.' },
  { term: 'Lead Scoring', def: 'Ranking leads by conversion likelihood using behaviour, demographics, and engagement signals.' },
];

// Build A-Z index
const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const byLetter = Object.fromEntries(
  alphabet.map(letter => [
    letter,
    glossary.filter(e => e.title.toUpperCase().startsWith(letter)).sort((a, b) => a.title.localeCompare(b.title))
  ])
);
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Glossary', url: seo.canonical }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        Glossary
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        The LimeCall <span class="text-lime-400">Glossary</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Definitions for every call tracking, lead generation, and sales automation term you'll encounter. Browse the full glossaries below or scan the quick-reference grid for the most common terms.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Explore LimeCall Free
        </a>
        <a
          href="/call-centre-glossary/"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          Call Centre Glossary
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Free resource · 100+ terms · Updated 2026</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/60 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-center">
        {stats.map((s) => (
          <div class="p-4">
            <div class="text-4xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-2 text-sm font-bold text-white">{s.label}</div>
            <div class="mt-1 text-xs text-dark-500">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Glossary Hubs -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Full <span class="text-lime-400">Glossary Collections</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Dive into either detailed glossary for comprehensive, category-organised definitions with examples.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        {glossaryHubs.map((hub) => (
          <a
            href={hub.href}
            class="group rounded-2xl border border-dark-800 bg-dark-900/60 p-8 transition hover:border-lime-500/40 hover:bg-dark-900"
          >
            <div class="mb-3 inline-block rounded-full border border-lime-500/20 bg-lime-500/10 px-3 py-1 text-xs font-semibold text-lime-400">
              {hub.count}
            </div>
            <h3 class="mb-3 text-xl font-extrabold text-white group-hover:text-lime-400 transition-colors">
              {hub.title}
            </h3>
            <p class="text-sm text-dark-400 leading-relaxed">{hub.desc}</p>
            <div class="mt-5 text-sm font-semibold text-lime-400">Browse glossary →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick-Reference Grid -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Quick-Reference <span class="text-lime-400">Term Definitions</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          The 20 most common terms across call tracking, sales, and LimeCall features — one line each.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-2">
        {quickTerms.map((item) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 px-5 py-4 flex gap-3">
            <span class="mt-0.5 shrink-0 text-lime-400 font-bold text-sm w-32">{item.term}</span>
            <span class="text-sm text-dark-400 leading-relaxed">{item.def}</span>
          </div>
        ))}
      </div>

      <!-- A-Z Glossary Index -->
      <div class="mt-20">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">Browse All 409 Terms A–Z</h2>

        <!-- Letter jump nav -->
        <div class="flex flex-wrap gap-2 justify-center mb-10">
          {alphabet.map(letter => (
            byLetter[letter].length > 0 ? (
              <a href={`#letter-${letter}`} class="rounded-lg border border-dark-700 px-3 py-1.5 text-sm font-semibold text-dark-300 hover:border-lime-500/40 hover:text-lime-400 transition">
                {letter}
              </a>
            ) : (
              <span class="rounded-lg border border-dark-800 px-3 py-1.5 text-sm text-dark-600">{letter}</span>
            )
          ))}
        </div>

        <!-- Terms by letter -->
        {alphabet.map(letter => byLetter[letter].length > 0 && (
          <div id={`letter-${letter}`} class="mb-10">
            <h3 class="text-xl font-bold text-lime-400 mb-4 border-b border-dark-800 pb-2">{letter}</h3>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {byLetter[letter].map(entry => (
                <a href={`/glossary_cpt/${entry.slug}/`} class="rounded-lg border border-dark-800 bg-dark-900/40 px-4 py-3 hover:border-lime-500/30 hover:bg-dark-900 transition group">
                  <span class="text-sm font-medium text-white group-hover:text-lime-400 transition">{entry.title}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Ready to Put These Terms to Work?
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        LimeCall's callback and call tracking platform brings every concept in this glossary to life — from DNI and speed-to-lead to round-robin distribution and CRM logging. For a complete deep-dive, read the <a href="/lead-distribution-guide/" class="text-lime-400 hover:underline">lead distribution guide</a>.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Explore LimeCall Free
        </a>
        <a
          href="/how-it-works/"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          See How It Works
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">No credit card required · Free plan available · 5-minute setup</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="More Resources"
        links={[
          { href: '/call-centre-glossary/', title: 'Call Centre Glossary', desc: '50+ call centre terms with plain-English definitions.' },
          { href: '/sales-terminology-glossary/', title: 'Sales Terminology', desc: '60+ sales terms every rep and manager should know.' },
          { href: '/how-it-works/', title: 'How LimeCall Works', desc: 'See the callback and call tracking platform in action.' },
          { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans. Free tier available.' },
        ]}
      />
    </div>
  </section>
</Base>
