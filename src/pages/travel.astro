---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Lead Generation for Travel Companies — Instant Callbacks | LimeCall`,
  description: `LimeCall helps travel agencies and tour operators convert website visitors into bookings with instant callbacks in under 28 seconds. 3x more bookings, 80% fewer missed leads.`,
  canonical: `https://www.limecall.com/travel/`,
};

const stats = [
  { value: '28s', label: 'Avg. callback time' },
  { value: '3x', label: 'More bookings' },
  { value: '80%', label: 'Fewer missed leads' },
  { value: '5 min', label: 'Setup time' },
];

const useCases = [
  {
    title: 'Travel Booking Inquiries',
    desc: 'When a visitor lands on a package page and clicks your callback widget, LimeCall connects them with an available travel consultant in under 28 seconds — before they open a competitor\'s tab. High-intent moments captured, every time.',
  },
  {
    title: 'Last-Minute Deal Callbacks',
    desc: 'Last-minute travel buyers are impulsive and time-sensitive. LimeCall\'s instant callback ensures your team reaches them while the purchase intent is at its highest — turning promotional traffic into confirmed bookings.',
  },
  {
    title: 'Group Travel Consultation Calls',
    desc: 'Group travel inquiries are high-value but complex. Use LimeCall to route group inquiries directly to your specialist team, with call scheduling for longer consultations and automatic reminders to reduce no-shows.',
  },
  {
    title: 'Loyalty Member Callbacks',
    desc: 'Reward your best customers with priority access to a callback. LimeCall lets you configure your widget to route recognised loyalty members to a dedicated agent — no hold queues, no waiting.',
  },
];

const features = [
  {
    icon: '⚡',
    title: '28-Second Callback',
    desc: 'The moment a visitor clicks your widget, LimeCall simultaneously calls your available agent and the customer, patching them together in under 28 seconds. No manual dialling, no missed opportunities.',
  },
  {
    icon: '📅',
    title: 'Scheduled Callbacks',
    desc: 'Not every traveller wants to talk right now. Let them pick a time that works — LimeCall sends reminders to both the agent and the customer, dramatically reducing no-shows on scheduled consultation calls.',
  },
  {
    icon: '🔀',
    title: 'Smart Lead Routing',
    desc: 'Route inquiries by destination, trip type, or team availability. Cruise inquiries go to your cruise specialist. Adventure travel requests go to your adventure team. Every lead gets the right expert.',
  },
  {
    icon: '🗂️',
    title: 'CRM Auto-Logging',
    desc: 'Every call is automatically logged in your CRM with duration, outcome, and recording link. No manual data entry for your agents — they focus on selling holidays, not updating spreadsheets.',
  },
  {
    icon: '📊',
    title: 'Call Tracking',
    desc: 'Know which campaigns, ads, and pages generate the most valuable calls. LimeCall\'s call tracking ties every conversation back to its source, so you can invest more in what works.',
  },
  {
    icon: '🌍',
    title: 'Virtual Numbers',
    desc: 'Build trust with international customers using local phone numbers. LimeCall provides virtual numbers in 50+ countries — so your UK number shows for UK callers, your AU number for Australian travellers.',
  },
];

const steps = [
  {
    step: '01',
    title: 'Add the Widget',
    desc: 'Paste one line of JavaScript on your travel website and LimeCall\'s callback widget appears. Configure the look, feel, and trigger behaviour from your dashboard — no developer required.',
  },
  {
    step: '02',
    title: 'Set Up Your Team',
    desc: 'Add your travel consultants, configure routing rules by destination or product type, and set your availability hours. LimeCall handles after-hours requests with automatic queuing and scheduled callbacks.',
  },
  {
    step: '03',
    title: 'Start Converting',
    desc: 'Your first lead arrives, clicks the widget, and is connected to your team in 28 seconds. Every call is logged, recorded, and synced to your CRM. Watch your booking rate climb from day one.',
  },
];

const testimonials = [
  {
    quote: 'We used to lose 60% of our after-hours inquiries. LimeCall captures every one and queues them for our morning team. Our Monday-morning bookings have tripled.',
    name: 'Sophie L.',
    role: 'Head of Sales, Boutique Tour Operator',
  },
  {
    quote: 'Our group travel team now gets routed the right inquiries automatically. The routing rules took 10 minutes to set up and saved us hours of manual triaging every week.',
    name: 'Daniel K.',
    role: 'Sales Director, Group Travel Agency',
  },
];

const faqs = [
  {
    q: 'How does LimeCall help travel agencies get more bookings?',
    a: 'LimeCall adds a callback widget to your website that connects high-intent visitors with your travel consultants in under 28 seconds. Studies show leads contacted within 5 minutes are 9x more likely to convert. For travel, where purchase decisions are emotional and time-sensitive, this speed advantage translates directly into more confirmed bookings.',
  },
  {
    q: 'Can LimeCall handle after-hours travel inquiries?',
    a: 'Yes. LimeCall captures after-hours inquiries and presents them to your team the next morning as a prioritised callback list. You can also send an automatic SMS acknowledgement to the customer overnight to keep the conversation warm until your team is available.',
  },
  {
    q: 'Does LimeCall work for multi-destination tour operators?',
    a: 'Absolutely. Lead routing rules can be configured by destination, product type, or any other parameter. Inquiries about specific destinations or trip types are automatically routed to the right specialist in your team — improving both response time and customer experience.',
  },
  {
    q: 'How quickly can a travel agency get LimeCall set up?',
    a: 'Most travel agencies are live within 5 minutes. Paste the widget code on your site, add your team members, and configure your routing rules. No developer is needed. LimeCall offers onboarding support and a library of templates specifically for travel and hospitality businesses.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Travel Lead Generation', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Travel & Tourism
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Turn travel inquiries into<br class="hidden sm:block" />
        <span class="text-lime-400">bookings in 28 seconds</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Travel agencies and tour operators using LimeCall see 3x more bookings and 80% fewer missed leads. Connect your consultants with high-intent visitors before they click away.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white sm:text-3xl">Travel use cases</h2>
      <p class="mb-12 text-center text-dark-400 max-w-xl mx-auto">From last-minute holiday bookings to group travel consultations, LimeCall fits every type of travel inquiry.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <h3 class="mb-3 font-semibold text-lime-400">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white sm:text-3xl">Everything your travel team needs</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-3 text-2xl">{f.icon}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white sm:text-3xl">How it works</h2>
      <p class="mb-12 text-center text-dark-400 max-w-xl mx-auto">Live and taking bookings in under 5 minutes.</p>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map(s => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="mb-3 text-4xl font-extrabold text-lime-500/30">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">What travel teams say</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {testimonials.map(t => (
          <figure class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 flex flex-col">
            <blockquote class="flex-1 text-sm text-dark-300 leading-relaxed">
              <span class="text-2xl text-lime-500 font-bold leading-none">"</span>
              {t.quote}
            </blockquote>
            <figcaption class="mt-5 border-t border-dark-800 pt-4">
              <div class="font-semibold text-white text-sm">{t.name}</div>
              <div class="text-xs text-dark-500 mt-0.5">{t.role}</div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="font-semibold text-white mb-2">{f.q}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Start converting more travel inquiries</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Cross links -->
  <div class="py-8 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related resources" links={[
        { href: '/limecall-for-travel-tourism-aviation/', title: 'LimeCall for Travel & Aviation', desc: 'Full overview of LimeCall for travel, tourism, and aviation sectors.' },
        { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'How 28-second callbacks drive 391% higher contact rates.' },
        { href: '/call-tracking/', title: 'Call Tracking', desc: 'Track every call back to the exact campaign that generated it.' },
        { href: '/for-sales-teams/', title: 'For Sales Teams', desc: 'The full LimeCall feature set for high-performance sales teams.' },
      ]} />
    </div>
  </div>
</Base>
