---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const seo = {
  title: `SMS for Slack: Send & Receive Texts in Slack | LimeCall Integration`,
  description: `Connect LimeCall to Slack and manage all customer SMS conversations inside Slack channels. 2-way texting, instant alerts, team collaboration. Free to set up.`,
  canonical: `https://www.limecall.com/sms-for-slack/`,
};

const features = [
  { title: "SMS in Slack Channels", desc: "Customer SMS conversations appear directly in dedicated Slack channels. Your team replies without switching apps." },
  { title: "Two-Way Texting", desc: "Send and receive SMS in real time from Slack. Full conversation history visible to the whole team." },
  { title: "Team Collaboration", desc: "Tag teammates, discuss next steps in threads, and hand off conversations — all within Slack." },
  { title: "Instant Notifications", desc: "Get Slack notifications the moment a customer texts in. Never miss an inbound SMS again." },
  { title: "Easy OAuth Setup", desc: "Connect LimeCall to Slack in minutes with our OAuth integration. No developer or code required." },
  { title: "Context & History", desc: "See full conversation history, contact details, and previous interactions directly in Slack." },
];

const steps = [
  { n: "1", title: "Connect LimeCall to Slack", desc: "Click 'Add to Slack' in your LimeCall settings. Authorize the integration in one click via OAuth." },
  { n: "2", title: "Map numbers to channels", desc: "Assign each LimeCall phone number to a Slack channel. Texts arrive in the right channel automatically." },
  { n: "3", title: "Text from Slack", desc: "Reply to customer texts directly from Slack. Your messages are delivered as SMS to the customer." },
];

const faqs = [
  {
    question: 'Can you send SMS from Slack?',
    answer: 'Yes — with LimeCall\'s Slack integration. LimeCall bridges your Slack workspace with SMS so your team can send and receive text messages directly inside Slack channels without switching to another app.',
  },
  {
    question: 'How does the LimeCall Slack SMS integration work?',
    answer: 'Once you connect LimeCall to Slack via OAuth, you map each LimeCall phone number to a Slack channel. Inbound customer SMS appear in the channel, and replies sent from Slack are delivered as SMS to the customer.',
  },
  {
    question: 'Does the integration support two-way texting?',
    answer: 'Yes. LimeCall\'s Slack SMS integration supports full two-way texting. You can both receive customer texts and reply to them — all from Slack.',
  },
  {
    question: 'What LimeCall plan is required for SMS for Slack?',
    answer: 'SMS features are available on LimeCall\'s Starter and Pro plans. The Slack integration is included once SMS is enabled on your account.',
  },
  {
    question: 'Can multiple team members respond to the same SMS thread?',
    answer: 'Yes. Because SMS conversations appear in Slack channels, your whole team can see and discuss each conversation. You can use Slack threads to coordinate internally before responding to the customer.',
  },
  {
    question: 'How is LimeCall SMS for Slack different from a standalone SMS app?',
    answer: 'LimeCall keeps your team inside Slack — where they already work. No extra app to log into. SMS conversations are treated like any Slack message, with full threading, notifications, and search. It\'s also tied to your LimeCall phone numbers and CRM sync.',
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "SMS for Slack", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Slack Integration
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Send &amp; Receive SMS <span class="text-lime-400">Inside Slack</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Your team already lives in Slack. Now your SMS conversations can too. LimeCall's Slack integration brings two-way customer texting directly into your workspace — no app switching, no missed messages.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Connect Slack Free →
        </a>
        <a href="/integrations/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View All Integrations
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Free plan available · No developer required · Setup in minutes</p>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Everything you need for SMS in Slack</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Set up in 3 steps</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison: LimeCall vs alternatives -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          LimeCall SMS for Slack vs. <span class="text-lime-400">Alternatives</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Not all SMS-in-Slack solutions are equal. Here's how LimeCall compares.
        </p>
      </div>
      <div class="overflow-x-auto rounded-2xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900/80">
              <th class="px-6 py-4 text-left font-semibold text-white">Feature</th>
              <th class="px-6 py-4 text-center font-semibold text-lime-400">LimeCall</th>
              <th class="px-6 py-4 text-center font-semibold text-dark-400">Standalone SMS App</th>
              <th class="px-6 py-4 text-center font-semibold text-dark-400">Slack Bots Only</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['2-way SMS in Slack', '✓', '✗ (separate app)', '✗ (outbound only)'],
              ['No app switching', '✓', '✗', 'Partial'],
              ['Team collaboration', '✓ Full threading', 'Limited', '✓'],
              ['Call + SMS on same number', '✓', '✗', '✗'],
              ['CRM sync', '✓ Automatic', 'Varies', '✗'],
              ['Business phone numbers', '✓ 50+ countries', 'Limited', '✗'],
              ['Free plan available', '✓', 'Rarely', 'Varies'],
            ].map(([feature, limecall, standalone, bot]) => (
              <tr class="bg-dark-950/40 hover:bg-dark-900/40 transition">
                <td class="px-6 py-4 font-medium text-white">{feature}</td>
                <td class="px-6 py-4 text-center text-lime-400 font-medium">{limecall}</td>
                <td class="px-6 py-4 text-center text-dark-400">{standalone}</td>
                <td class="px-6 py-4 text-center text-dark-400">{bot}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Why it matters -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Why teams love SMS for Slack</h2>
      <div class="space-y-4">
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-5">
          <p class="text-dark-300 leading-relaxed">"Switching between apps kills focus. With SMS in Slack, our sales team responds to leads in seconds without breaking their workflow."</p>
          <p class="mt-3 text-sm text-dark-500">— Faster response = higher conversion rates</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-5">
          <p class="text-dark-300 leading-relaxed">"Customer texts go to a Slack channel. The whole team sees them, we discuss who handles it, and we never drop a ball."</p>
          <p class="mt-3 text-sm text-dark-500">— Better team coordination on customer conversations</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Start texting customers from Slack</h2>
      <p class="mt-4 text-dark-400">Connect LimeCall to Slack in minutes. No developer required. No extra apps.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/business-texting/', title: 'Business Texting', desc: 'Full SMS platform for your business.' },
        { href: '/shared-inbox/', title: 'Shared Inbox', desc: 'Team SMS inbox for collaboration.' },
        { href: '/integrations/', title: 'All Integrations', desc: 'Connect LimeCall to your stack.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
