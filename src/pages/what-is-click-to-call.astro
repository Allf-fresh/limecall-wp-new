---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'What is Click to Call? How It Works & Benefits',
  description: 'Click to call lets website visitors start a phone call with one click — no dialling required. Learn how it works and why it converts 3x more leads.',
  canonical: `${site.url}/what-is-click-to-call/`,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'What is Click to Call? How It Works, Benefits & Best Practices',
  description: seo.description,
  datePublished: '2024-01-15',
  dateModified: '2025-03-01',
  author: { '@type': 'Organization', name: 'LimeCall Team' },
  publisher: { '@type': 'Organization', name: 'LimeCall', url: site.url },
  mainEntityOfPage: { '@type': 'WebPage', '@id': seo.canonical },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is click to call?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Click to call is a technology that lets a website visitor initiate a phone call with a business by clicking a button or link — with no manual dialling required. On mobile, it uses the device\'s native dialler via a tel: link. On desktop, it uses browser-based WebRTC or a callback trigger that connects the visitor and an agent via simultaneous outbound dials.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the difference between click to call and callback?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Click to call (using a tel: link or WebRTC) connects the visitor immediately using their own device to dial your number — the visitor makes the call. Callback (as offered by LimeCall) works differently: the visitor enters their number and the software dials both parties simultaneously, connecting them when both answer. Callback removes the need for the visitor to be near their phone or initiate the dial, and typically converts better because there is even less friction.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does click to call work on desktop?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — with caveats. A simple tel: link only works on desktop if the user has a softphone or communication app (like Skype, Teams, or FaceTime) configured as the default handler. Browser-based WebRTC click to call works on any device with a microphone. The most reliable cross-device solution is a callback trigger: the visitor enters their number and receives a call — no browser permissions or app required.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I add click to call to my website?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'There are three ways. (1) Add a tel: link in HTML: <a href="tel:+441234567890">Call Us</a> — works instantly on mobile. (2) Add a LimeCall widget — a single JavaScript snippet adds a floating callback button that works on all devices in under 5 minutes. (3) Add a Google Ads call extension in your ad campaigns to show your number directly in search ads with a click-to-call button on mobile.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why does click to call convert better than forms?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Click to call converts up to 3× better than contact forms because it eliminates friction at the most critical moment — when a visitor has high intent and is ready to speak with someone. Forms require the visitor to type, wait, and hope someone follows up. A click-to-call interaction is immediate, synchronous, and creates a live conversation — the format with the highest close rate.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is click to call free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A basic tel: link is free to add to any website and costs nothing beyond your standard phone minutes. Browser-based WebRTC click to call typically requires a paid plan with a VoIP provider. LimeCall\'s callback widget — the most conversion-effective form of click to call — starts at $35/month and includes call tracking, recording, and CRM integration.',
      },
    },
  ],
};

const types = [
  {
    name: 'tel: Link (Mobile Tap-to-Call)',
    code: '<a href="tel:+441234567890">Call Us Free</a>',
    desc: 'The simplest implementation. A hyperlink that opens the device\'s native phone dialler on mobile. Free to add, no software required. Works perfectly on smartphones but limited on desktop.',
    best: 'Mobile-first sites, local businesses',
  },
  {
    name: 'Browser-Based WebRTC Call',
    code: 'JavaScript WebRTC API',
    desc: 'Uses the browser\'s built-in WebRTC protocol to make a VoIP call directly from the browser — no app or phone dialler needed. Works on desktop and mobile. Requires microphone permission.',
    best: 'Desktop users, SaaS products',
  },
  {
    name: 'Callback Trigger (LimeCall)',
    code: 'Visitor enters number → system dials both',
    desc: 'The most effective variant. Visitor clicks the widget and enters their number. The software simultaneously dials the visitor\'s phone and an available agent — connecting both when they answer. Zero browser permissions required.',
    best: 'Sales pages, highest conversion rate',
  },
];

const benefits = [
  { stat: '3×', label: 'More conversions', sub: 'vs. contact forms on the same page' },
  { stat: '0', label: 'Friction steps', sub: 'One click to start a conversation' },
  { stat: '57%', label: 'Prefer phone', sub: 'Of buyers for high-value decisions' },
  { stat: '28s', label: 'To connect', sub: 'With LimeCall callback variant' },
];

const implementations = [
  {
    method: 'HTML tel: Link',
    difficulty: 'Easiest',
    snippet: `<a href="tel:+441234567890" class="btn-call">
  📞 Call Us Now
</a>`,
    note: 'Best for mobile. Add to your nav, footer, and contact page.',
  },
  {
    method: 'LimeCall Widget',
    difficulty: 'Recommended',
    snippet: `<!-- Paste before </body> -->
<script src="https://limecall.com/widget.js"
  data-key="YOUR_KEY"></script>`,
    note: 'Works on all devices. Includes call tracking, recording, and CRM sync.',
  },
  {
    method: 'Google Ads Call Extension',
    difficulty: 'For PPC',
    snippet: 'Add in Google Ads > Assets > Call assets\nEnter your number — shows on mobile search ads',
    note: 'Enables click-to-call directly from your search ads on mobile.',
  },
];

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'What is Click to Call? How It Works, Benefits & Best Practices',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.speakable-answer', '.speakable-summary'],
  },
  url: seo.canonical,
};
---

<Base {...seo}>
  <JsonLd schema={articleSchema} />
  <JsonLd schema={faqSchema} />
  <JsonLd schema={speakableSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'What is Click to Call', url: `${site.url}/what-is-click-to-call/` }]} />

      <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400">
        Definition
      </div>

      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        What is <span class="text-lime-400">Click to Call?</span>
      </h1>

      <p class="speakable-answer mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Click to call is a website feature that lets visitors start a phone call with your business using a single click — no manual dialling required. It removes the friction between a high-intent visitor and a live conversation, converting up to 3× more leads than a contact form.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="/click-to-call-software/" class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Add Click to Call to Your Site
        </a>
        <a href="/customer-callback-software/" class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          See LimeCall →
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Converts 3× more leads · Works on all devices · 5-minute setup</p>
    </div>
  </section>

  <!-- Definition block -->
  <section class="py-14 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-white mb-4">Click to Call — Definition</h2>
        <p class="text-dark-200 leading-relaxed text-base">
          <strong class="text-white">Click to call</strong> is any mechanism on a website, email, or digital ad that initiates a phone call when a user clicks or taps it — eliminating the need to manually dial a number. The term covers three distinct implementations: simple tel: hyperlinks that open a mobile dialler, browser-based WebRTC calls that use the computer's microphone, and callback triggers (like LimeCall) where the system dials both parties and connects them.
        </p>
        <p class="mt-4 text-dark-300 leading-relaxed text-sm">
          Each variant reduces friction at a different level. The callback approach — where the visitor just enters their number and both parties are dialled automatically — produces the highest conversion rates because it works equally well on desktop, requires no browser permissions, and connects in 28 seconds.
        </p>
      </div>
    </div>
  </section>

  <!-- Benefits stats -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-14 sm:py-18">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Why Click to Call <span class="text-lime-400">Works</span>
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 text-center">
        {benefits.map((b) => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-4xl font-extrabold text-lime-400">{b.stat}</div>
            <div class="mt-2 font-bold text-white text-sm">{b.label}</div>
            <div class="mt-1 text-xs text-dark-500">{b.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Types -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          3 Types of <span class="text-lime-400">Click to Call</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">Not all click-to-call implementations are equal. Here is how they compare.</p>
      </div>
      <div class="speakable-summary grid gap-6 sm:grid-cols-3">
        {types.map((t, i) => (
          <div class={`rounded-2xl border p-7 ${i === 2 ? 'border-lime-500/30 bg-lime-500/5' : 'border-dark-800 bg-dark-900/60'}`}>
            <div class="mb-3 inline-block rounded-full border border-dark-700 bg-dark-800 px-3 py-1 text-xs font-mono text-dark-400">
              {i === 2 ? '★ Recommended' : `Type ${i + 1}`}
            </div>
            <h3 class="text-base font-bold text-white mb-3">{t.name}</h3>
            <p class="text-sm text-dark-400 leading-relaxed mb-3">{t.desc}</p>
            <div class="rounded-lg bg-dark-800/80 px-3 py-2 font-mono text-xs text-lime-400 break-all">{t.code}</div>
            <p class="mt-3 text-xs text-dark-500">Best for: {t.best}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Implementation -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          How to <span class="text-lime-400">Implement Click to Call</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">Three implementation paths — from the simplest HTML link to a full callback platform.</p>
      </div>
      <div class="space-y-6">
        {implementations.map((impl, i) => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="flex items-start gap-5 flex-col sm:flex-row">
              <div class="shrink-0">
                <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-sm">{i + 1}</div>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 flex-wrap mb-2">
                  <h3 class="text-base font-bold text-white">{impl.method}</h3>
                  <span class={`rounded-full px-2 py-0.5 text-xs font-semibold ${impl.difficulty === 'Recommended' ? 'bg-lime-500/20 text-lime-400' : 'bg-dark-700 text-dark-400'}`}>
                    {impl.difficulty}
                  </span>
                </div>
                <p class="text-sm text-dark-500 mb-3">{impl.note}</p>
                <pre class="overflow-x-auto rounded-lg bg-dark-800 px-4 py-3 font-mono text-xs text-lime-300 whitespace-pre-wrap">{impl.snippet}</pre>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Frequently Asked <span class="text-lime-400">Questions</span>
        </h2>
      </div>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {item.name}
              <span class="ml-4 shrink-0 text-lime-400 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-lime-500/20 bg-gradient-to-br from-lime-500/10 to-dark-900 py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Add Click to Call to Your Website Today
      </h2>
      <p class="mt-4 text-lg text-dark-300">
        LimeCall's callback widget is the most effective click-to-call solution — works on all devices, includes call tracking, and connects visitors with your team in 28 seconds.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/signup" class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free — 5 Minutes to Set Up
        </a>
        <a href="/pricing/" class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40">
          View Pricing →
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">No credit card required · Free plan available · GDPR compliant</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="Related Resources"
        links={[
          { href: '/click-to-call-software/', title: 'Click to Call Software', desc: 'LimeCall\'s full click-to-call platform — features, integrations, and demo.' },
          { href: '/customer-callback-software/', title: 'Customer Callback Software', desc: 'The callback variant of click to call — highest conversion rate.' },
          { href: '/click-to-whatsapp/', title: 'Click to WhatsApp', desc: 'Let visitors start a WhatsApp conversation with one click.' },
          { href: '/pricing/', title: 'LimeCall Pricing', desc: 'Simple, transparent plans starting at $35/month. Free tier available.' },
        ]}
      />
    </div>
  </section>
</Base>
