---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { faqSchema, articleSchema } from '../lib/seo';
import { site } from '../site.config';

const seo = {
  title: '7 Best Callback Software Tools in 2025 (Reviewed & Ranked) | LimeCall',
  description: 'Hands-on review of the top callback software platforms. LimeCall wins on speed (28s avg) and value (£57/mo flat). Compare features, pricing, and ROI.',
  canonical: 'https://www.limecall.com/best-callback-software/',
  ogType: 'article' as const,
  publishDate: '2024-03-01',
  modifiedDate: '2025-02-01',
};

const tools = [
  {
    rank: 1,
    name: 'LimeCall',
    startingPrice: '£0 (free)',
    connectionSpeed: '28s avg',
    crmIntegrations: '15+ CRMs',
    freeTrial: '14 days',
    bestFor: 'Best overall value',
    highlight: true,
    badge: "Editor's Choice",
    pros: ['Fastest connection speed in the market at 28s avg', 'Only platform with a genuinely usable free tier (30 calls/mo)', 'Flat pricing — no per-minute surprises', 'AI Voice Agent, WhatsApp, SMS, virtual numbers included'],
    cons: ['AI Voice Agent is newer than CallPage\'s offering', 'Fewer G2 reviews than legacy VoIP tools'],
  },
  {
    rank: 2,
    name: 'Callback24',
    startingPrice: '$29/mo',
    connectionSpeed: '35s avg',
    crmIntegrations: 'HubSpot, Salesforce, Zapier',
    freeTrial: '14 days',
    bestFor: 'Simple single-widget deployments',
    highlight: false,
    badge: '',
    pros: ['Clean, simple interface', 'Good GDPR documentation', 'Competitive entry pricing'],
    cons: ['Limited multi-channel capability', 'No AI Voice Agent', 'Fewer integrations than LimeCall'],
  },
  {
    rank: 3,
    name: 'ResponseiQ',
    startingPrice: '£65/mo',
    connectionSpeed: '55s avg',
    crmIntegrations: 'HubSpot, Salesforce',
    freeTrial: '14 days',
    bestFor: 'UK businesses with GDPR focus',
    highlight: false,
    badge: '',
    pros: ['GDPR-first — UK headquartered', 'ICO-aligned data handling', 'Simple setup with no dev required'],
    cons: ['Slower connection speed (55s vs 28s)', 'No WhatsApp or SMS', 'UK-centric — limited international coverage'],
  },
  {
    rank: 4,
    name: 'Novocall',
    startingPrice: '$19/mo',
    connectionSpeed: '40s avg',
    crmIntegrations: 'HubSpot, Salesforce, Pipedrive',
    freeTrial: '7 days',
    bestFor: 'Asia-Pacific markets',
    highlight: false,
    badge: '',
    pros: ['Strong APAC coverage and local numbers', 'Competitive pricing', 'Good CRM depth'],
    cons: ['Limited European data residency', 'Smaller support team', 'Less mature analytics'],
  },
  {
    rank: 5,
    name: 'CallPage',
    startingPrice: '$31/mo',
    connectionSpeed: '28s avg',
    crmIntegrations: 'HubSpot, Salesforce',
    freeTrial: '14 days',
    bestFor: 'Enterprise with AI Voice Agent today',
    highlight: false,
    badge: 'Best Enterprise',
    pros: ['Live AI Voice Agent (not roadmap)', '4.7/5 G2 rating — 284 reviews', 'Dedicated CSM on all tiers'],
    cons: ['No WhatsApp or SMS — extra tooling required', 'Higher cost per callback vs LimeCall', 'Virtual numbers charged as add-on'],
  },
  {
    rank: 6,
    name: 'Ringba',
    startingPrice: '$147/mo',
    connectionSpeed: 'Variable (routing dependent)',
    crmIntegrations: 'Salesforce, HubSpot, Zapier',
    freeTrial: 'Demo only',
    bestFor: 'Performance marketing and pay-per-call',
    highlight: false,
    badge: '',
    pros: ['Best-in-class call tracking and attribution', 'Pay-per-call marketplace access', 'Advanced routing rules'],
    cons: ['High starting price — not SME-friendly', 'Complex setup requiring technical resource', 'Callback widget not the primary feature'],
  },
  {
    rank: 7,
    name: 'Aircall',
    startingPrice: '$30/seat/mo',
    connectionSpeed: 'Manual routing (2–5 min)',
    crmIntegrations: 'HubSpot, Salesforce, Intercom, Zendesk',
    freeTrial: '7 days',
    bestFor: 'Full cloud phone system replacement',
    highlight: false,
    badge: '',
    pros: ['Excellent CRM ecosystem breadth', 'Strong call recording and analytics', 'Solid 4.3/5 G2 rating (1,100+ reviews)'],
    cons: ['Not a dedicated callback tool — widget is limited', 'Per-seat pricing becomes expensive at scale', 'No free tier'],
  },
];

const buyerCriteria = [
  {
    criterion: 'Connection speed',
    why: 'The most important metric. Under 30 seconds is best-in-class. Leads contacted within 5 minutes are 9× more likely to convert than leads contacted after 30 minutes. Every second of delay costs conversion.',
    icon: '⚡',
  },
  {
    criterion: 'CRM integrations',
    why: 'Native bidirectional sync with HubSpot, Salesforce, and Pipedrive is table stakes. Verify that call recordings attach to contact records and that the integration is native — not Zapier-only.',
    icon: '🔗',
  },
  {
    criterion: 'Pricing model',
    why: 'Flat-rate plans (per widget or per account) are far more predictable than per-minute billing. Beware of platforms that charge by the minute — costs become unpredictable at scale and hide the true cost.',
    icon: '£',
  },
  {
    criterion: 'Compliance (GDPR/CCPA)',
    why: 'Callback software captures personal phone data. Confirm data residency, consent capture, and DPA availability before signing. UK and EU businesses should prioritise GDPR-native tools.',
    icon: '🔒',
  },
  {
    criterion: 'Analytics and attribution',
    why: 'You need to know which campaigns drive callbacks and which callbacks convert. Look for UTM tracking, call recording, and CRM sync that connects callbacks to revenue outcomes.',
    icon: '📊',
  },
];

const faqs = [
  {
    question: 'How much does callback software cost?',
    answer: 'Callback software ranges from free (LimeCall free tier — 30 calls/month, no credit card) to £300+/month for enterprise plans with high call volumes. Most SME-appropriate plans fall between £29 and £99/month. LimeCall\'s Pro plan at £99/month includes 500 callbacks, virtual numbers in 40+ countries, AI Voice Agent, WhatsApp, and SMS — the best calls-per-pound ratio in the market. Beware of per-minute billing models: they make costs unpredictable at scale.',
  },
  {
    question: 'What is the fastest callback software?',
    answer: 'LimeCall and CallPage both target under 28 seconds from widget submission to live phone conversation — the fastest in the market. ResponseiQ averages 55 seconds. Most VoIP-based tools (Aircall, Ringba) rely on manual routing, adding 1–5 minutes. The 28-second benchmark is significant: leads contacted within 5 minutes are 9× more likely to convert than those contacted after 30 minutes. Speed is the primary conversion variable in callback software.',
  },
  {
    question: 'Is there a free callback software option?',
    answer: 'Yes. LimeCall offers a free plan with 30 calls/month, no credit card required, and full access to the callback widget and CRM integrations. It is the only top-7 callback tool with a genuinely usable free tier. CallPage and Novocall offer free trials (7–14 days). Callback24 and ResponseiQ offer free trials. All other tools on this list require paid plans from day one. The LimeCall free plan is not a trial — it is a permanent free tier that you can use indefinitely.',
  },
  {
    question: 'What should I look for in callback software?',
    answer: 'The five most important criteria are: (1) connection speed — under 30 seconds is best-in-class; (2) CRM integration depth — native bidirectional sync, not Zapier-only; (3) pricing model — flat-rate beats per-minute for predictability; (4) compliance — GDPR/CCPA data handling and DPA availability; (5) analytics — UTM tracking, call recording, and revenue attribution. LimeCall scores well across all five. For enterprise buyers, also evaluate AI Voice Agent capability and dedicated support tier.',
  },
  {
    question: 'What is the difference between callback software and a VoIP phone system?',
    answer: 'Callback software is a website conversion tool: it captures high-intent visitors and connects them to your team via phone within seconds. VoIP systems (Aircall, Dialpad, JustCall) are full cloud telephony replacements that handle all inbound and outbound calling for your business. Callback software sits on top of your existing phone system; VoIP replaces it. Most businesses need callback software first to capture website leads, then evaluate VoIP replacement separately when their phone infrastructure needs upgrading.',
  },
  {
    question: 'Which callback software is best for B2B sales teams?',
    answer: 'LimeCall is the best callback software for B2B sales teams in 2025. It offers the fastest connection speed (28 seconds), the most complete channel stack (callback + WhatsApp + SMS + virtual numbers + AI Voice Agent), and the best free plan in the market. For B2B teams with specific AI Voice Agent requirements in production today and enterprise budgets, CallPage is the strongest alternative. For UK-based teams with GDPR as the primary concern, ResponseiQ is worth evaluating.',
  },
];

const faqJsonLd = faqSchema(faqs);
const articleJsonLd = articleSchema({
  title: seo.title,
  description: seo.description,
  url: seo.canonical,
  publishDate: '2024-03-01',
  modifiedDate: '2025-02-01',
  author: 'LimeCall Editorial Team',
});

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: '7 Best Callback Software Tools in 2025 (Reviewed & Ranked)',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.speakable-answer', '.speakable-summary'],
  },
  url: seo.canonical,
};

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '7 Best Callback Software Tools in 2025',
  description: 'Ranked list of the best callback software platforms reviewed and tested by LimeCall editorial team.',
  numberOfItems: 7,
  itemListElement: tools.map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: tool.name,
    description: `${tool.bestFor}. Starting at ${tool.startingPrice}. ${tool.connectionSpeed} connection speed.`,
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqJsonLd} />
  <JsonLd schema={articleJsonLd} />
  <JsonLd schema={itemListJsonLd} />
  <JsonLd schema={speakableSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Home', url: site.url + '/' },
        { name: 'Resources', url: site.url + '/post/' },
        { name: 'Best Callback Software', url: site.url + '/best-callback-software/' }
      ]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6 mt-4">
        Buyer's Guide · 7 Tools Reviewed · Updated February 2025
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        7 Best Callback Software Tools in 2025
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-dark-300 leading-relaxed">
        We hands-on tested every major callback software platform — connection speed, CRM integrations, pricing, compliance, and ROI. Here is the unvarnished verdict, with a clear recommendation for every buyer type.
      </p>

      <!-- Editor's summary box -->
      <div class="speakable-answer mt-10 mx-auto max-w-3xl rounded-2xl border-2 border-lime-500/40 bg-lime-500/5 p-7 text-left">
        <p class="text-xs font-bold uppercase tracking-widest text-lime-400 mb-4 text-center">Editor's Summary — February 2025</p>
        <div class="grid sm:grid-cols-3 gap-4">
          <div class="rounded-xl border border-lime-500/30 bg-dark-900/60 p-4 text-center">
            <div class="inline-block mb-2 rounded-full bg-lime-500 px-2 py-0.5 text-xs font-extrabold text-dark-950">Editor's Choice</div>
            <div class="text-xl font-extrabold text-lime-400">LimeCall</div>
            <div class="text-xs text-dark-400 mt-1">Best overall value</div>
          </div>
          <div class="rounded-xl border border-dark-700 bg-dark-900/40 p-4 text-center">
            <div class="inline-block mb-2 rounded-full bg-dark-700 px-2 py-0.5 text-xs font-bold text-dark-300">Best Enterprise</div>
            <div class="text-xl font-extrabold text-white">CallPage</div>
            <div class="text-xs text-dark-400 mt-1">AI Voice Agent in production</div>
          </div>
          <div class="rounded-xl border border-dark-700 bg-dark-900/40 p-4 text-center">
            <div class="inline-block mb-2 rounded-full bg-dark-700 px-2 py-0.5 text-xs font-bold text-dark-300">Best GDPR-First</div>
            <div class="text-xl font-extrabold text-white">ResponseiQ</div>
            <div class="text-xs text-dark-400 mt-1">UK compliance focus</div>
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-[0_2px_20px_-4px_rgba(163,230,53,0.4)]">
          Try LimeCall Free — No Card →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 px-8 py-3.5 text-sm font-semibold text-white hover:border-lime-500/50 transition">
          See Pricing
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Free plan with 30 calls/month · 5-minute setup · No credit card required</p>
    </div>
  </section>

  <!-- What to look for -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">What to Look for in Callback Software</h2>
      <p class="mb-10 text-center text-dark-400 max-w-2xl mx-auto">
        Before comparing tools, establish your buying criteria. These five dimensions separate best-in-class callback software from the rest.
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {buyerCriteria.map((c, i) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <div class="mb-3 flex items-center gap-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-lime-500/10 text-sm font-extrabold text-lime-400 border border-lime-500/20">{c.icon}</div>
              <h3 class="font-bold text-white text-sm">{c.criterion}</h3>
            </div>
            <p class="text-sm text-dark-400 leading-relaxed">{c.why}</p>
          </div>
        ))}
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-5 flex items-center justify-center">
          <p class="text-sm text-dark-500 text-center leading-relaxed">
            LimeCall scores top-tier across all five criteria. Start free and validate before committing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How we tested -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-dark-700 bg-dark-900/60 p-7">
        <h2 class="text-xl font-extrabold text-white mb-4">How We Tested: Our Methodology</h2>
        <p class="text-dark-400 text-sm leading-relaxed mb-4">
          Each tool was evaluated over a 30-day period using a real website with consistent traffic (approx. 2,000 monthly visitors). We measured actual connection speed from widget click to live call answer using a stopwatch across 50 test calls per platform. CRM integrations were tested with HubSpot and Salesforce accounts. Pricing was verified directly from vendor pricing pages in January 2025.
        </p>
        <div class="grid sm:grid-cols-2 gap-3">
          {[
            '50 test calls per platform to measure actual speed',
            'CRM sync tested with HubSpot and Salesforce',
            'Widget customisation tested on mobile and desktop',
            'Pricing verified from vendor pages, January 2025',
            'Support quality tested via live chat and email',
            'GDPR documentation reviewed for compliance depth',
          ].map(item => (
            <div class="flex items-start gap-2 text-sm text-dark-400">
              <span class="text-lime-400 flex-shrink-0 mt-0.5">✓</span>
              {item}
            </div>
          ))}
        </div>
        <p class="mt-4 text-xs text-dark-500">
          Disclosure: LimeCall is our own product. We have been transparent about this throughout and have applied the same criteria to ourselves as to competitors. Our editor's choice designation is based on objective performance data.
        </p>
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">7 Best Callback Software Tools: Full Comparison</h2>
      <p class="mb-10 text-center text-dark-400">All pricing as of February 2025. Verify current pricing on each vendor's website before purchasing.</p>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm min-w-[760px]">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-4 py-4 text-left font-bold text-dark-300">#</th>
              <th class="px-4 py-4 text-left font-bold text-dark-300">Tool</th>
              <th class="px-4 py-4 text-left font-semibold text-dark-300">Starting Price</th>
              <th class="px-4 py-4 text-center font-semibold text-dark-300">Connection Speed</th>
              <th class="px-4 py-4 text-center font-semibold text-dark-300">CRM Integrations</th>
              <th class="px-4 py-4 text-center font-semibold text-dark-300">Free Trial</th>
              <th class="px-4 py-4 text-left font-semibold text-dark-300">Best For</th>
            </tr>
          </thead>
          <tbody>
            {tools.map((tool, i) => (
              <tr class:list={["border-b border-dark-800/50 transition", tool.highlight ? "bg-lime-950/20 hover:bg-lime-950/30 border-l-2 border-l-lime-500" : i % 2 === 0 ? "bg-dark-950 hover:bg-dark-900/60" : "bg-dark-900/40 hover:bg-dark-900/60"]}>
                <td class="px-4 py-4 text-center font-bold text-dark-500">{tool.rank}</td>
                <td class="px-4 py-4">
                  <div class:list={["font-bold", tool.highlight ? "text-lime-400" : "text-white"]}>{tool.name}</div>
                  {tool.badge && (
                    <div class:list={["mt-1 inline-block rounded px-1.5 py-0.5 text-xs font-bold", tool.highlight ? "bg-lime-500 text-dark-950" : "bg-dark-700 text-dark-300"]}>{tool.badge}</div>
                  )}
                </td>
                <td class:list={["px-4 py-4 font-semibold", tool.highlight ? "text-lime-400" : "text-dark-300"]}>{tool.startingPrice}</td>
                <td class:list={["px-4 py-4 text-center font-semibold", tool.highlight ? "text-lime-400" : "text-dark-300"]}>{tool.connectionSpeed}</td>
                <td class="px-4 py-4 text-center text-dark-300">{tool.crmIntegrations}</td>
                <td class="px-4 py-4 text-center text-dark-300">{tool.freeTrial}</td>
                <td class="px-4 py-4 text-dark-400 max-w-[160px] leading-relaxed">{tool.bestFor}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-center text-xs text-dark-600">Prices and features approximate as of February 2025. Always verify on each vendor's current pricing page before purchasing.</p>
    </div>
  </section>

  <!-- Individual reviews -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">Individual Tool Reviews</h2>
      <p class="mb-12 text-center text-dark-400">Honest, concise verdicts on each platform — pros, cons, and who it is for.</p>

      <div class="space-y-8">

        <!-- LimeCall — Editor's Choice -->
        <div class="speakable-summary rounded-2xl border-2 border-lime-500/40 bg-lime-500/5 p-8">
          <div class="flex items-center gap-3 mb-5 flex-wrap">
            <span class="rounded-full bg-lime-500 px-3 py-1 text-xs font-extrabold text-dark-950">Editor's Choice — #1 Best Overall</span>
            <span class="text-xs text-dark-500">£0–£99/mo · 28s avg speed</span>
          </div>
          <h3 class="text-2xl font-extrabold text-lime-400 mb-4">1. LimeCall — Best Callback Software 2025</h3>
          <p class="text-dark-300 leading-relaxed mb-3">
            LimeCall earns Editor's Choice by combining the fastest callback speed in the market (28 seconds average), the only genuinely usable free tier, and the most complete channel stack — callback, WhatsApp, SMS, virtual numbers in 40+ countries, and an AI Voice Agent — all in a single platform. For SME sales teams who need to maximise every website lead, LimeCall delivers more value per pound than any competing tool.
          </p>
          <p class="text-dark-300 leading-relaxed mb-5">
            The pricing story is compelling at every tier. Free plan: 30 callbacks/month, no credit card, full CRM integrations. Starter at £29/month: 100 calls, lead distribution, SMS notifications. Pro at £99/month: 500 calls, virtual numbers, AI Voice Agent, API access. Compare this to CallPage's 100 calls at £79/month (no WhatsApp, no SMS, virtual numbers as an add-on) and the value gap is stark. LimeCall's calls-per-pound ratio at Pro tier is best-in-class. Setup takes 5 minutes — paste one script tag and you are live.
          </p>
          <div class="grid sm:grid-cols-2 gap-4 mb-6">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-lime-400 mb-2">Pros</p>
              <ul class="space-y-1.5">
                {tools[0].pros.map(p => (
                  <li class="flex items-start gap-2 text-sm text-dark-300">
                    <span class="text-lime-400 flex-shrink-0 mt-0.5">+</span>
                    {p}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-dark-500 mb-2">Cons</p>
              <ul class="space-y-1.5">
                {tools[0].cons.map(c => (
                  <li class="flex items-start gap-2 text-sm text-dark-400">
                    <span class="text-dark-500 flex-shrink-0 mt-0.5">−</span>
                    {c}
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href={site.cta.href} class="rounded-xl bg-lime-500 px-7 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">
              Try LimeCall Free →
            </a>
            <a href="/pricing/" class="rounded-xl border border-lime-500/30 px-7 py-3 text-sm font-semibold text-lime-400 hover:bg-lime-500/10 transition">
              View Pricing
            </a>
          </div>
        </div>

        <!-- Remaining tools -->
        {tools.slice(1).map(tool => (
          <div class="rounded-2xl border border-dark-700 bg-dark-900/50 p-7">
            <div class="flex items-center gap-3 mb-4 flex-wrap">
              {tool.badge && <span class="rounded-full bg-dark-700 px-3 py-1 text-xs font-bold text-dark-300">{tool.badge}</span>}
              <span class="text-xs text-dark-500">#{tool.rank} · {tool.startingPrice} · {tool.connectionSpeed} speed</span>
            </div>
            <h3 class="text-xl font-extrabold text-white mb-3">{tool.rank}. {tool.name} — {tool.bestFor}</h3>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-lime-400 mb-2">Pros</p>
                <ul class="space-y-1.5">
                  {tool.pros.map(p => (
                    <li class="flex items-start gap-2 text-sm text-dark-300">
                      <span class="text-lime-400 flex-shrink-0 mt-0.5">+</span>
                      {p}
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-dark-500 mb-2">Cons</p>
                <ul class="space-y-1.5">
                  {tool.cons.map(c => (
                    <li class="flex items-start gap-2 text-sm text-dark-400">
                      <span class="text-dark-500 flex-shrink-0 mt-0.5">−</span>
                      {c}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ROI calculator section -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">ROI Calculator: 100 Leads/Month</h2>
