---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const city = "Paris";
const country = "France";
const code = "+33";
const flag = "🇫🇷";

const seo = {
  title: `Paris Virtual Phone Numbers (+33) | LimeCall`,
  description: `Get a Paris virtual phone number with a local French dialing code (+33). No hardware needed. Route calls, enable callbacks, and build a Paris presence with LimeCall.`,
  canonical: `https://www.limecall.com/paris-virtual-phone-numbers/`,
};

const features = [
  { title: "Instant Setup", desc: "Get your Paris virtual number in minutes. No hardware, no SIM card, no contracts." },
  { title: "Smart Call Routing", desc: "Route incoming calls to any device or team member — mobile, desktop, or desk phone." },
  { title: "Call Recording", desc: "Record and review every call for quality assurance and compliance." },
  { title: "Callback Automation", desc: "Let website visitors request instant callbacks from your Paris-based or global team." },
  { title: "SMS & WhatsApp", desc: "Send and receive SMS messages on your Paris virtual number." },
  { title: "Analytics Dashboard", desc: "Full call analytics, reporting, and conversion tracking in one dashboard." },
];

const stats = [
  { value: "Instant", label: "Activation" },
  { value: "01", label: "Paris Area Code" },
  { value: "99.9%", label: "Uptime SLA" },
  { value: "GDPR", label: "Compliant" },
];

const countryFacts = [
  { title: "France Country Code +33", desc: "France uses country code +33. Paris local numbers begin with 01 when dialled domestically, appearing as +33 1 XX XX XX XX internationally. A local Paris number immediately signals presence in the French capital." },
  { title: "Local Trust Matters in France", desc: "French consumers and businesses strongly prefer calling and receiving calls from local numbers. An international or unknown number is often ignored — a Paris local number builds immediate credibility." },
  { title: "GDPR & ARCEP Compliance", desc: "Operating in France requires compliance with both EU GDPR for data handling and ARCEP (the French telecom regulator) for number usage. LimeCall virtual numbers are provisioned through ARCEP-licensed partners." },
];

const comparisonRows = [
  { aspect: "Setup Time", virtual: "Under 5 minutes", sim: "Days + in-person ID required" },
  { aspect: "Monthly Cost", virtual: "From $4/mo", sim: "€20–50/mo plan + device" },
  { aspect: "Works Internationally", virtual: "Yes — route from anywhere", sim: "Roaming charges apply" },
  { aspect: "Paris Area Code (01)", virtual: "Yes, included", sim: "Depends on SIM region" },
  { aspect: "GDPR Data Controls", virtual: "Full data control in dashboard", sim: "Carrier holds data" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I get a Paris virtual phone number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sign up for LimeCall, select France as your country, choose a Paris area code (01), and your number is provisioned instantly. No SIM card, no hardware, and no visit to France required.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the Paris area code?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Paris uses area code 01 within France. Internationally, Paris numbers are written as +33 1 XX XX XX XX. LimeCall provides Paris virtual numbers with the correct 01 area code.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I send and receive SMS with a French virtual number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall French virtual numbers support two-way SMS. You can send and receive text messages to and from French numbers directly from the LimeCall web or mobile app.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is a Paris virtual number GDPR compliant?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall operates in compliance with EU GDPR. Call data and recordings are handled according to GDPR requirements, with options for data residency and retention settings in your dashboard.',
      },
    },
    {
      '@type': 'Question',
      name: 'How will French customers see my caller ID?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'When you call out using your LimeCall Paris number, French customers will see a local Paris number (+33 1 XX XX XX XX) on their screen — exactly as if you were calling from a Paris office.',
      },
    },
  ],
};

const faqs = [
  {
    q: `What is a Paris virtual phone number?`,
    a: `A Paris virtual phone number is a French telephone number (${code}) with a Paris area code that isn't tied to a physical phone line. It routes calls over the internet to any device anywhere in the world. Callers in Paris and France dial a local number, and the call reaches you wherever you are.`,
  },
  {
    q: `Do I need to be in Paris to get a Paris virtual number?`,
    a: `No. Anyone can get a Paris virtual phone number from anywhere in the world. LimeCall gives you a local Paris number that French customers can call at local rates, while your team answers from any country.`,
  },
  {
    q: `What is the area code for Paris, France?`,
    a: `Paris uses the area code 01 within France, and the international dialing code for France is ${code}. So a Paris number looks like +33 1 XX XX XX XX. LimeCall provides Paris local numbers with the correct area code.`,
  },
  {
    q: "How long does setup take?",
    a: "Setup takes under 5 minutes. Sign up, choose your Paris number, and you're ready to receive calls immediately — no waiting for hardware or SIM activation.",
  },
  {
    q: "Can I use a Paris virtual number for callbacks?",
    a: "Yes — LimeCall's callback automation lets website visitors request a call and your team calls them back within 28 seconds using your Paris virtual number. This dramatically improves lead conversion rates.",
  },
  {
    q: `Are Paris virtual numbers compliant with ARCEP regulations?`,
    a: `LimeCall's France virtual numbers are provisioned through licensed telecom partners and comply with ARCEP (Autorité de Régulation des Communications Électroniques et des Postes) guidelines. All numbers are legitimate, registered numbers suitable for business use.`,
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `${city} Virtual Number`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a <span class="text-lime-400">{city} Virtual Phone Number</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Local {city}, {country} number ({code}) that works anywhere. Instant setup, no hardware. Build a Paris presence without a Paris office.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your {city} Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <p class="text-2xl font-extrabold text-lime-400">{s.value}</p>
            <p class="mt-1 text-xs text-dark-400 uppercase tracking-wide">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Everything included with your {city} number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Virtual vs SIM Comparison -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Paris Virtual Number vs French SIM Card</h2>
      <p class="mb-10 text-center text-sm text-dark-400">Why a virtual number beats a physical SIM for most businesses</p>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-6 py-4 text-left font-semibold text-dark-300">Feature</th>
              <th class="px-6 py-4 text-left font-semibold text-lime-400">Virtual Number (LimeCall)</th>
              <th class="px-6 py-4 text-left font-semibold text-dark-400">French SIM Card</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800 ${i % 2 === 0 ? 'bg-dark-900/20' : ''}`}>
                <td class="px-6 py-4 font-medium text-white">{row.aspect}</td>
                <td class="px-6 py-4 text-dark-300">{row.virtual}</td>
                <td class="px-6 py-4 text-dark-500">{row.sim}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Country Facts -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">France Telecom & Business Facts</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {countryFacts.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 text-sm font-bold text-lime-400 uppercase tracking-wide">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ with JSON-LD -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {item.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your {city} number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall virtual numbers to build a local presence globally.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/get-virtual-phone-number-france/', title: 'France Virtual Numbers', desc: 'All French virtual number options.' },
        { href: '/incoming-numbers/', title: 'Incoming Numbers', desc: 'DID numbers for inbound calls.' },
        { href: '/virtual-business-numbers/', title: 'Business Numbers', desc: 'Professional virtual numbers for teams.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
