---
import Base from '../../layouts/Base.astro';

const seo = {
  title: `Use Cases - LimeCall`,
  description: `Explore LimeCall use cases across travel, real estate, finance, e-commerce and more. See how callback automation drives conversions in your industry.`,
  canonical: `https://www.limecall.com/usecase`,
};
---
<Base {...seo}>
  <div class="wp-content max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-white mb-8">LimeCall Use Cases</h1>
    <p class="text-dark-300 mb-6">Explore how LimeCall helps businesses across different industries convert website visitors into sales calls.</p>
    <ul class="space-y-3">
      <li><a href="/usecase/travel" class="text-lime-400 hover:text-lime-300">Travel Industry →</a></li>
      <li><a href="/use-cases" class="text-lime-400 hover:text-lime-300">All Use Cases →</a></li>
    </ul>
  </div>
</Base>
