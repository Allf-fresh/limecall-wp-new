---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Customer Support Software — Faster Resolution, Happier Customers | LimeCall`,
  description: `Deliver exceptional customer support with LimeCall. Instant callbacks, shared SMS inbox, virtual numbers, and full call analytics — all the tools your support team needs.`,
  canonical: `https://www.limecall.com/customer-support-software/`,
};

const stats = [
  { value: "28s", label: "Avg. callback time" },
  { value: "90%", label: "CSAT improvement" },
  { value: "80%", label: "Faster resolution" },
  { value: "5 min", label: "Setup time" },
];

const features = [
  {
    title: "Instant Callback for Support",
    desc: "Customers request a callback from your website, portal, or email footer and connect with a support agent in under 28 seconds. No hold music, no queue frustration.",
    icon: "⚡",
  },
  {
    title: "Call Routing to Specialists",
    desc: "Route support calls to the right team or specialist automatically based on issue type, language, or customer tier. Customers get expert help faster — agents work more efficiently.",
    icon: "🔀",
  },
  {
    title: "Call Recording for QA",
    desc: "Record every support call automatically for quality assurance, agent training, and dispute resolution. Accessible from your LimeCall dashboard and synced to your CRM.",
    icon: "🎙️",
  },
  {
    title: "Zendesk & HubSpot Sync",
    desc: "Every call and callback is automatically logged in Zendesk, HubSpot, Freshdesk, or your CRM of choice — with call recording, duration, and agent notes. No manual data entry.",
    icon: "🗂️",
  },
  {
    title: "Shared Team Inbox",
    desc: "Your support team manages all inbound callbacks and customer messages in one shared inbox. Assign, reply, and resolve together — with full visibility across the team.",
    icon: "📥",
  },
  {
    title: "SLA Timer Alerts",
    desc: "Set SLA targets for callback response time and get real-time alerts when tickets are approaching breach. Never miss a support SLA commitment again.",
    icon: "⏱️",
  },
];

const useCases = [
  {
    title: "Tier-1 Support Callbacks",
    desc: "Replace the hold queue with an instant callback. When a customer contacts support, they click the callback widget and LimeCall connects them to a Tier-1 agent in seconds. Satisfaction scores improve immediately.",
  },
  {
    title: "Escalation Routing",
    desc: "When a Tier-1 agent needs to escalate, LimeCall transfers the call instantly to a specialist — with a whisper summary so the receiving agent has full context without making the customer repeat themselves.",
  },
  {
    title: "VIP Customer Callback Queue",
    desc: "Create a priority callback queue for high-value accounts. VIP customers skip the standard queue and connect to a dedicated support rep, reinforcing the relationship and protecting retention.",
  },
  {
    title: "After-Hours Call Capture",
    desc: "Support requests come in around the clock. LimeCall captures after-hours callbacks and queues them for the morning shift. Every customer gets a confirmed callback — no request falls through the cracks.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall differ from traditional helpdesk software?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Traditional helpdesk software (Zendesk, Freshdesk) manages support tickets across email, chat, and phone. LimeCall specifically handles the phone and callback channel — giving customers an instant callback instead of a hold queue, and giving support teams smart call routing, call recording, and automatic CRM logging. LimeCall integrates with your existing helpdesk so both systems work together seamlessly.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall replace live chat for customer support?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No — LimeCall and live chat serve different needs. Live chat is ideal for quick text-based questions. LimeCall handles situations where a phone call resolves the issue faster — complex problems, billing disputes, or customers who prefer voice. Many support teams use LimeCall to escalate from chat to callback when the issue requires a human conversation.',
      },
    },
    {
      '@type': 'Question',
      name: 'What integrations does LimeCall support for customer support?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall integrates with Zendesk, HubSpot Service Hub, Freshdesk, Intercom, Salesforce Service Cloud, and Pipedrive. Every call is automatically logged with call recording, duration, and notes. Zapier support extends integration to 5,000+ additional tools. The Zendesk integration automatically creates tickets from every callback.',
      },
    },
    {
      '@type': 'Question',
      name: 'What pricing tiers are available for support teams?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall offers Starter, Pro, and Enterprise plans for support teams. Starter includes instant callback, call routing, and basic CRM integration. Pro adds call recording, advanced routing rules, SLA alerts, and priority support. Enterprise adds dedicated account management, custom SLAs, and white-glove onboarding. Visit the pricing page for current plan details.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall manage the call queue during high volume?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'During high-volume periods, LimeCall queues callback requests and connects them to agents in order of receipt. Customers receive an SMS confirmation with an estimated wait time — eliminating frustration from uncertainty. Managers can see real-time queue depth in the LimeCall dashboard and redistribute load across available agents or trigger overflow routing to additional teams.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Customer Support Software", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Customer Support Software
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Customer Support That <span class="text-lime-400">Customers Actually Love</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Replace hold queues with instant callbacks. Let customers reach you by phone, text, or WhatsApp — and manage everything from one LimeCall dashboard.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white sm:text-3xl">Everything your support team needs</h2>
      <p class="mb-12 text-center text-dark-400 max-w-xl mx-auto">
        Six core features designed to reduce resolution time, improve CSAT, and give managers full visibility over every support call.
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-3 text-2xl">{f.icon}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Support use cases</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <h3 class="mb-3 font-semibold text-lime-400">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">A better support experience — step by step</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">1</div>
          <h3 class="mb-2 font-semibold text-white">Customer clicks callback</h3>
          <p class="text-sm text-dark-400">Instead of sitting on hold, the customer clicks the callback button on your site, portal, or email footer. LimeCall captures their request instantly.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">2</div>
          <h3 class="mb-2 font-semibold text-white">LimeCall routes to available agent</h3>
          <p class="text-sm text-dark-400">LimeCall identifies the right support agent based on issue type, language, or availability — and connects the customer in under 28 seconds.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">3</div>
          <h3 class="mb-2 font-semibold text-white">Issue resolved — logged automatically</h3>
          <p class="text-sm text-dark-400">The call is recorded, notes are synced to your helpdesk, and the customer receives an SMS summary. Every interaction is tracked for quality review.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">LimeCall callback vs live chat vs email support</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800">
              <th class="pb-3 text-left text-dark-400 font-medium">Metric</th>
              <th class="pb-3 text-center text-lime-400 font-semibold">LimeCall Callback</th>
              <th class="pb-3 text-center text-dark-300 font-medium">Live Chat</th>
              <th class="pb-3 text-center text-dark-300 font-medium">Email Support</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              { metric: "Response time", callback: "Under 28 seconds", chat: "1–5 minutes", email: "Hours to days" },
              { metric: "Resolution rate (first contact)", callback: "High — full conversation", chat: "Medium — text limits depth", email: "Low — multi-message needed" },
              { metric: "Customer satisfaction", callback: "Very high", chat: "High", email: "Medium" },
              { metric: "Works after hours", callback: "Yes — queued callbacks", chat: "Bot only", email: "Yes — slow reply" },
              { metric: "Call/chat recording", callback: "Full recording + transcript", chat: "Chat log", email: "Email thread" },
            ].map(row => (
              <tr>
                <td class="py-3 text-dark-400">{row.metric}</td>
                <td class="py-3 text-center text-lime-400 font-medium">{row.callback}</td>
                <td class="py-3 text-center text-dark-300">{row.chat}</td>
                <td class="py-3 text-center text-dark-400">{row.email}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="cursor-pointer list-none font-semibold text-white group-open:text-lime-400">{faq.name}</summary>
            <p class="mt-3 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Upgrade your customer support today</h2>
      <p class="mt-4 text-dark-400">Thousands of support teams use LimeCall to deliver faster, better support. Start your free trial.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">Start Free Trial →</a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 font-bold text-white hover:border-lime-500/40 transition">View Pricing</a>
      </div>
    </div>
  </section>

  <div class="py-8 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="Explore More"
        links={[
          { href: '/integration-zendesk/', title: 'Zendesk Integration', desc: 'Auto-log every call as a Zendesk ticket.' },
          { href: '/inbound-call-center-software/', title: 'Inbound Call Center', desc: 'Full inbound call center platform.' },
          { href: '/shared-inbox/', title: 'Shared Inbox', desc: 'Team SMS inbox for support.' },
          { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
        ]}
      />
    </div>
  </div>
</Base>
