---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Callback Software for Insurance Brokers | LimeCall',
  description: 'LimeCall connects insurance leads to brokers in 28 seconds. FCA-compliant call recording, lead routing by product type, and CRM sync. Free trial.',
  canonical: 'https://www.limecall.com/insurance/',
};

const stats = [
  { value: '78%', label: 'Of insurance leads choose the first broker to call back' },
  { value: '28s', label: 'LimeCall callback vs 6-hour industry average' },
  { value: '4×', label: 'More policies quoted vs email-only follow-up' },
  { value: '$2,400', label: 'Avg policy value — every lead counts' },
];

const features = [
  { icon: '🔒', title: 'FCA-Compliant Call Recording', desc: 'All calls recorded and stored to FCA standards. Configurable retention periods, full audit trail, and encrypted storage for regulatory compliance.' },
  { icon: '🗂️', title: 'Lead Routing by Product Type', desc: 'Route enquiries to the right specialist automatically — life, home, motor, or commercial insurance — based on the page the prospect visited.' },
  { icon: '🌙', title: 'After-Hours Quote Capture', desc: 'Prospects requesting quotes outside business hours are queued and called back first thing. No lead lost to out-of-hours silence.' },
  { icon: '📍', title: 'Virtual Numbers for Local Presence', desc: 'Use local UK or international virtual numbers so prospects see a familiar area code — improving answer rates and trust.' },
  { icon: '🔗', title: 'CRM Sync to Applied & Salesforce', desc: 'Every callback automatically logged in Applied Epic, Salesforce, or your CRM of choice — prospect name, number, product interest, and call outcome.' },
  { icon: '💬', title: 'Click-to-WhatsApp for Document Sharing', desc: 'After the call, trigger a WhatsApp message so clients can securely share documents, IDs, and policy details without friction.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is LimeCall compliant with FCA requirements for call recording?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall records and stores all calls in line with FCA requirements for regulated firms. Recordings are encrypted at rest and in transit, with configurable retention periods and full audit logs available on demand. We sign Data Processing Agreements (DPAs) with all insurance customers as standard.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long are call recordings stored?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Call recording retention periods are fully configurable in LimeCall. For FCA-regulated insurance firms, the standard requirement is a minimum of 5 years. You can set your retention period to match your compliance obligations, and recordings can be exported or deleted on request with a full audit trail.',
      },
    },
    {
      '@type': 'Question',
      name: 'What happens to insurance enquiries outside office hours?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "After-hours enquiries are captured in LimeCall's callback queue. At the start of the next business day, your brokers see a prioritised list and can work through callbacks systematically. You can also configure emergency routing to an on-call line for urgent claims or time-sensitive enquiries.",
      },
    },
    {
      '@type': 'Question',
      name: 'How much does LimeCall cost for insurance brokers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall plans start from $35/month. Insurance brokers typically see a return on investment within the first week — a single additional policy conversion often covers several months of subscription cost. A 14-day free trial is available with no credit card required.',
      },
    },
    {
      '@type': 'Question',
      name: 'How quickly can our brokerage go live with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most insurance brokerages are live within 5 minutes. Add the LimeCall widget to your website, configure your routing rules by product type, and the system is active immediately. No IT team or developer is required. Full onboarding support is included for all insurance customers.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which CRMs and insurance platforms does LimeCall integrate with?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall integrates directly with Salesforce, HubSpot, and Applied Epic, as well as 1,000+ tools via Zapier. Every callback is automatically logged with prospect name, contact number, product interest, call duration, and outcome notes — keeping your pipeline fully up to date.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumbs items={[{ name: 'Insurance', url: `${site.url}/insurance/` }]} />
      <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400">
        🛡️ For Insurance Brokers & IFAs
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Callback Software for Insurance Brokers<br class="hidden sm:block" />
        <span class="text-lime-400">— Connect Leads in 28 Seconds</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300">
        Insurance leads go cold in minutes. Policy enquiries expect instant response. LimeCall connects your website visitors to the right broker in 28 seconds — FCA-compliant, 24/7.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center justify-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free Trial — 14 Days
        </a>
        <a href="/demo/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-dark-700 px-8 py-4 text-sm font-semibold text-white transition hover:border-lime-500/40 hover:text-lime-400">
          Book a Demo →
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">★ FCA-Compliant Call Recording · Trusted by insurance brokers in 40+ countries · No setup fee</p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-dark-800 bg-dark-900/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <dt class="text-3xl font-extrabold text-lime-400">{s.value}</dt>
            <dd class="mt-1 text-sm text-dark-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Problem callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-red-500/20 bg-red-500/5 p-8">
        <h2 class="text-xl font-bold text-white mb-3">⚠️ Insurance Leads Don't Wait</h2>
        <p class="text-dark-300">
          A customer enquired about public liability cover at 7pm. Without LimeCall, they bought from a competitor by 9am. Insurance prospects compare multiple brokers simultaneously — whoever calls first earns the relationship. The average broker responds in 6 hours. LimeCall responds in 28 seconds.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">How LimeCall Works for Insurance Brokers</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: '01', title: 'Prospect Visits Your Policy Page', desc: 'LimeCall widget appears on key pages — get a quote, contact us, product pages for life, home, motor, or commercial cover.' },
          { step: '02', title: 'Prospect Requests Instant Callback', desc: 'Enters their number; LimeCall routes to the right specialist by product type, postcode, or available broker.' },
          { step: '03', title: 'Connected to Broker in 28 Seconds', desc: 'Broker greets the prospect while they are still on your website and actively comparing — close the quote before they look elsewhere.' },
        ].map(item => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-lg">{item.step}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-dark-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">Built for Insurance Brokers & IFAs</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-dark-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Insurance Use Cases</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'New Policy Enquiries', desc: 'Website visitor → right product specialist in 28s → quote provided on the call while prospect is still comparing.' },
          { title: 'Renewal Retention Calls', desc: 'Proactive callback queue for renewals due in 30 days — retain clients before they shop around.' },
          { title: 'Claims First Notice', desc: 'Claims page → broker connected immediately → first notice of loss taken on the call with full recording.' },
          { title: 'Cross-Sell Appointments', desc: 'Existing client portal → trigger callback opportunity → cross-sell home, life, or commercial cover on the call.' },
        ].map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="font-bold text-white mb-2">{u.title}</h3>
            <p class="text-sm text-dark-400">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case study / testimonial -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <blockquote class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-10 text-center">
        <p class="text-xl text-white italic leading-relaxed">
          "We went from 12% enquiry-to-policy rate to 34% in 60 days. LimeCall connects our brokers to prospects while they're still comparing quotes online. The FCA-compliant recording meant our compliance team signed off on deployment immediately."
        </p>
        <footer class="mt-6">
          <p class="font-bold text-lime-400">Operations Director</p>
          <p class="text-sm text-dark-500">Commercial insurance brokerage, Birmingham</p>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">LimeCall vs. Other Insurance Lead Contact Methods</h2>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              {['Feature', 'LimeCall', 'Phone Only', 'Email Follow-Up', 'Live Chat'].map(h => (
                <th class={`px-5 py-4 text-left font-semibold ${h === 'LimeCall' ? 'text-lime-400' : 'text-dark-300'}`}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['Response time', '28 seconds', 'Rep availability', '2–24 hours', 'Agent dependent'],
              ['FCA call recording', '✅ Automatic', '⚠️ Manual setup', '❌ Not applicable', '❌ No voice'],
              ['After-hours capture', '✅ Queue + AM callback', '❌ Missed', '✅ Email stored', '❌ No agent'],
              ['Product-type routing', '✅ Automatic', '⚠️ Manual', '❌ None', '⚠️ Manual'],
              ['CRM auto-logging', '✅ Every call', '⚠️ Manual entry', '⚠️ Partial', '⚠️ Text only'],
              ['Conversion rate', '🟢 34%+ reported', '🟡 12–18%', '🔴 Low (slow)', '🟡 Medium'],
            ].map(([feature, ...vals]) => (
              <tr class="hover:bg-dark-800/30 transition">
                <td class="px-5 py-4 font-medium text-dark-200">{feature}</td>
                {vals.map((v, i) => (
                  <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Integration callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-dark-700 bg-dark-900/60 p-8 sm:p-10 flex flex-col sm:flex-row items-center gap-8">
        <div class="shrink-0 text-5xl">🔗</div>
        <div>
          <h2 class="text-xl font-bold text-white mb-2">Integrates with Applied Epic, Salesforce & More</h2>
          <p class="text-dark-400 text-sm leading-relaxed">
            LimeCall connects to Applied Epic, Salesforce, HubSpot, and 1,000+ tools via Zapier. Every callback is automatically logged — prospect name, number, product interest, call duration, and outcome notes — keeping your pipeline current without manual data entry. Setup takes under 5 minutes.
          </p>
          <a href="/integrations/" class="mt-4 inline-flex items-center text-sm font-semibold text-lime-400 hover:text-lime-300 transition">
            View all integrations →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Compliance trust section -->
  <section class="py-16 sm:py-20 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-10">FCA-Ready by Design</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          { icon: '🔒', title: 'Encrypted Call Recording', desc: 'All calls recorded and encrypted in transit and at rest using AES-256. Full audit trail available for FCA review at any time.' },
          { icon: '📋', title: 'Configurable Retention', desc: 'Set retention periods to match FCA requirements (minimum 5 years for regulated firms). Export or delete recordings on request.' },
          { icon: '📄', title: 'Data Processing Agreements', desc: 'We sign DPAs with all insurance customers as standard. GDPR-compliant data handling with clearly defined controller/processor responsibilities.' },
        ].map(item => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 text-center">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-dark-400">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-dark-500">
        LimeCall is trusted by insurance brokers and IFAs across 40+ countries. <a href="/gdpr/" class="text-lime-400 hover:text-lime-300 transition">Read our compliance documentation →</a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {item.name}
              <span class="ml-4 shrink-0 text-lime-400 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-gradient-to-br from-lime-500/10 to-dark-900 border-t border-lime-500/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Stop Losing Insurance Leads to Faster Brokers</h2>
      <p class="mt-4 text-lg text-dark-300">14-day free trial · FCA-compliant recording · No setup fee</p>
      <a href="/signup" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-lime-500 px-10 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
        Try Free — 14 Days →
      </a>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime · Full onboarding support</p>
    </div>
  </section>

  <!-- Cross-links -->
  <div class="py-12 bg-dark-950 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore More" links={[
        { href: '/mortgage-broker/', title: 'Mortgage Broker Callback', desc: 'Callback software for mortgage advisers.' },
        { href: '/real-estate/', title: 'Real Estate Callback', desc: 'Connect estate agents with buyers fast.' },
        { href: '/virtual-business-numbers/', title: 'Virtual Numbers', desc: 'Local numbers for every office location.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Plans from $35/month.' },
      ]} />
    </div>
  </div>
</Base>
