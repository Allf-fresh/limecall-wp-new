---
import Base from '../../../layouts/Base.astro';
import Breadcrumbs from '../../../components/seo/Breadcrumbs.astro';
import { getContentByCategory } from '../../../lib/supabase';
import { site } from '../../../site.config';

const posts = await getContentByCategory('blog', 'how-to');
---

<Base
  title={`How-To Guides — ${site.name}`}
  description={`Step-by-step how-to guides for ${site.name}. Learn how to get the most from your account.`}
  canonical={`${site.url}/blog/how-to/`}
>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs
        items={[
          { name: 'Blog', url: `${site.url}/blog` },
          { name: 'How-To', url: `${site.url}/blog/how-to` },
        ]}
      />

      <div class="mx-auto max-w-3xl mb-12">
        <h1 class="text-3xl font-extrabold text-white sm:text-4xl">
          How-To <span class="text-lime-400">Guides</span>
        </h1>
        <p class="mt-4 text-lg text-dark-300">
          Step-by-step guides to help you get the most from {site.name}.
        </p>
      </div>

      {posts.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a
              href={`/blog/how-to/${post.slug}`}
              class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6 transition-all hover:border-dark-700"
            >
              <h2 class="font-semibold text-white group-hover:text-lime-400">{post.title}</h2>
              <p class="mt-2 text-sm text-dark-400 line-clamp-2">{post.meta_description}</p>
              <time class="mt-3 block text-xs text-dark-500">{post.publish_date}</time>
            </a>
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-12 text-center">
          <p class="text-dark-400">How-to guides coming soon.</p>
        </div>
      )}
    </div>
  </section>
</Base>
