---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import CrossLinks from '../../components/CrossLinks.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { site } from '../../site.config';

const seo = {
  title: `LimeCall Comparison Hub | How We Stack Up vs Competitors`,
  description: `Independent side-by-side comparisons of LimeCall vs 8 top callback and cloud calling platforms. See pricing, features, and ROI data.`,
  canonical: `${site.url}/compare/`,
};

const comparisons = [
  {
    slug: '/limecall-vs-callpage/',
    opponent: 'CallPage',
    tagline: '5x more calls per £ vs CallPage',
    keyAdvantage: '5x more calls per £ vs CallPage',
    badges: ['Free plan', 'SMS & WhatsApp', 'Lead distribution'],
    category: 'Callback Software',
    desc: 'CallPage is a callback widget competitor. LimeCall matches every feature and adds SMS, WhatsApp, virtual numbers, and a free plan with no credit card required.',
  },
  {
    slug: '/limecall-vs-aircall/',
    opponent: 'Aircall',
    tagline: 'Flat rate vs £30/user/mo per seat',
    keyAdvantage: 'Flat rate vs £30/user/mo per seat',
    badges: ['No per-seat minimum', 'Callback widget', 'Free plan available'],
    category: 'Cloud Phone System',
    desc: 'Aircall is a full cloud phone platform aimed at enterprise call centres. LimeCall focuses on callback conversion — ideal for sales teams who want to capture inbound leads fast, without paying for an entire phone system.',
  },
  {
    slug: '/limecall-vs-justcall/',
    opponent: 'JustCall',
    tagline: 'No per-minute charges',
    keyAdvantage: 'No per-minute charges',
    badges: ['Free plan', 'Callback widget', 'No per-seat lock-in'],
    category: 'Cloud Phone System',
    desc: 'JustCall is a cloud communications platform for sales and support. LimeCall specialises in converting website visitors into calls within 28 seconds — a use case JustCall does not natively address.',
  },
  {
    slug: '/limecall-vs-ringover/',
    opponent: 'Ringover',
    tagline: '28s vs industry 6-minute avg',
    keyAdvantage: '28s vs industry 6-minute avg',
    badges: ['Simpler setup', 'Callback widget', 'No long contracts'],
    category: 'Cloud Phone System',
    desc: 'Ringover is a UCaaS platform with calling, SMS, and video. LimeCall is purpose-built for callback conversion — simpler to deploy, easier to prove ROI, and starts free.',
  },
  {
    slug: '/limecall-vs-dialpad/',
    opponent: 'Dialpad',
    tagline: 'SMB pricing vs enterprise contracts',
    keyAdvantage: 'SMB pricing vs enterprise contracts',
    badges: ['No AI upsell required', 'Faster setup', 'Free plan'],
    category: 'AI Cloud Phone',
    desc: 'Dialpad bundles AI transcription and voice intelligence into a full UCaaS platform. LimeCall focuses on one high-value outcome — connecting website leads to sales reps in under 28 seconds — at a fraction of the cost.',
  },
  {
    slug: '/limecall-vs-cloudtalk/',
    opponent: 'CloudTalk',
    tagline: 'Setup in 2 mins vs 2 weeks',
    keyAdvantage: 'Setup in 2 mins vs 2 weeks',
    badges: ['Callback widget', 'Free plan', 'Simpler pricing'],
    category: 'Cloud Phone System',
    desc: 'CloudTalk is a call centre platform for inbound and outbound teams. LimeCall complements or replaces CloudTalk for companies focused on converting website visitors into immediate phone conversations.',
  },
  {
    slug: null,
    opponent: 'Talkdesk',
    tagline: '£57/mo flat vs £85/user/mo',
    keyAdvantage: '£57/mo flat vs £85/user/mo',
    badges: ['Flat rate pricing', 'No enterprise contracts', 'Free plan'],
    category: 'Enterprise Cloud Phone',
    desc: 'Talkdesk is an enterprise cloud contact centre platform with per-seat pricing that scales steeply. LimeCall delivers callback conversion at a flat, predictable monthly rate — with no minimum seats and no professional services upsell.',
  },
  {
    slug: null,
    opponent: 'Freshdesk',
    tagline: 'Sales tool vs support tool',
    keyAdvantage: 'Sales tool vs support tool',
    badges: ['Conversion-focused', 'Callback widget', 'Lead distribution'],
    category: 'Helpdesk + Calling',
    desc: 'Freshdesk Calling is designed for support ticket deflection. LimeCall is built for sales conversion — connecting high-intent website visitors with your sales team in under 28 seconds.',
  },
  {
    slug: null,
    opponent: 'Twilio',
    tagline: 'Ready-made vs build-your-own',
    keyAdvantage: 'Ready-made vs build-your-own',
    badges: ['No coding required', 'Instant setup', 'Callback widget included'],
    category: 'Communications Platform',
    desc: 'Twilio is a developer API platform — powerful but requiring engineering resources to build a callback system. LimeCall is ready-made: add one script tag and you have a fully featured callback system live in minutes.',
  },
  {
    slug: '/limecall-vs-ringcentral/',
    opponent: 'RingCentral',
    tagline: '£57/mo flat vs £20-35/user/mo',
    keyAdvantage: '£57/mo flat vs £20-35/user/mo',
    badges: ['Flat rate pricing', 'Callback widget', 'No per-seat fees'],
    category: 'Cloud Phone System',
    desc: 'RingCentral is a full UCaaS platform with per-seat pricing that escalates quickly for growing teams. LimeCall offers a flat monthly rate focused on callback conversion — no per-user fees, no long contracts, and purpose-built for turning website visitors into sales calls.',
  },
  {
    slug: '/limecall-vs-vonage/',
    opponent: 'Vonage',
    tagline: 'No per-minute charges',
    keyAdvantage: 'No per-minute charges',
    badges: ['Predictable pricing', 'Callback widget', 'Free plan'],
    category: 'Cloud Communications',
    desc: 'Vonage charges per-minute rates that make costs unpredictable as call volumes grow. LimeCall includes all minutes in a flat monthly plan — no per-minute surprises, no metered billing, and a free plan to get started with zero risk.',
  },
  {
    slug: '/limecall-vs-8x8/',
    opponent: '8x8',
    tagline: 'SMB self-serve vs enterprise pro-services',
    keyAdvantage: 'SMB self-serve vs enterprise pro-services',
    badges: ['Self-serve setup', 'No pro-services needed', 'Free plan'],
    category: 'Enterprise Cloud Phone',
    desc: '8x8 is an enterprise-grade UCaaS platform that typically requires professional services for deployment. LimeCall is built for SMBs who want to self-serve — install in 2 minutes, no IT team required, and start converting website visitors into calls immediately.',
  },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'LimeCall Competitor Comparisons',
  description: 'Independent side-by-side comparisons of LimeCall vs every major callback and cloud calling platform.',
  numberOfItems: comparisons.length,
  itemListElement: comparisons.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `LimeCall vs ${c.opponent}`,
    url: c.slug ? `https://www.limecall.com${c.slug}` : `https://www.limecall.com/compare/`,
    description: c.desc,
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How did you test these tools?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Each comparison is based on direct product trials, published pricing pages, G2 and Capterra review data, and structured feature checklists tested by our team. We sign up for paid trials where available and verify all pricing data against official sources. Every comparison includes a "last updated" date.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are the comparisons unbiased?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We are transparent that these comparisons are published by LimeCall. We do our best to be factually accurate and call out areas where competitors genuinely excel. We include cases where a competitor may be the better choice for specific use cases. Our goal is to help you make the right decision — even if that means recommending an alternative.',
      },
    },
    {
      '@type': 'Question',
      name: 'How often are the comparisons updated?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We review and update each comparison at least once per quarter, or whenever a competitor makes a significant pricing or feature change. Each page displays its last updated date. If you spot outdated information, you can contact us and we will prioritise a review.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which LimeCall alternative is best for small businesses?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For small businesses, LimeCall itself offers the best value — starting free with 30 calls/month and scaling affordably. Among alternatives, CallPage is the closest competitor but lacks a free plan. Aircall and Dialpad are better suited to enterprises needing a full UCaaS stack rather than focused callback conversion.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall integrate with the tools these competitors integrate with?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall integrates with HubSpot, Salesforce, Pipedrive, Zoho CRM, Slack, Zapier, Google Analytics, Google Ads, and 50+ other tools. See our full integrations directory for the complete list.',
      },
    },
  ],
};

const differentiators = [
  {
    title: "28-Second Connection",
    desc: "LimeCall connects website visitors with your sales team in under 28 seconds — while they're still engaged and on your page. No other tool matches this speed-to-lead.",
  },
  {
    title: "Omni-Channel: Voice + SMS + WhatsApp",
    desc: "Unlike narrowly-focused callback tools, LimeCall handles calls, SMS, and WhatsApp from a single platform — so no lead slips through the cracks regardless of their preferred channel.",
  },
  {
    title: "Intelligent Lead Distribution",
    desc: "Automatically route inbound leads to the right rep based on skills, territory, or availability. Most competitors offer round-robin at best. LimeCall goes further.",
  },
  {
    title: "Free Plan. No Credit Card.",
    desc: "Start with 30 calls/month completely free. No trial expiry, no credit card required. Competitors typically require a paid plan from day one.",
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={itemListSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Comparisons', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        12 honest comparisons · Updated 2026
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall vs<br class="hidden sm:block" />
        <span class="text-lime-400">The Competition</span>
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Transparent pricing comparisons matter — because hidden per-seat fees and per-minute charges add up fast. We publish honest, independent assessments of how LimeCall stacks up so you can make the right call for your team.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Try LimeCall Free →</a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">See Pricing</a>
      </div>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime</p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/80 py-6">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-3 gap-6 text-center">
        <div>
          <div class="text-2xl font-bold text-lime-400">12</div>
          <div class="mt-1 text-xs text-dark-400">Competitor comparisons</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">100%</div>
          <div class="mt-1 text-xs text-dark-400">Honest, no spin</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">2026</div>
          <div class="mt-1 text-xs text-dark-400">Data updated</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison cards grid -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 class="text-2xl font-bold text-white">LimeCall vs Every Major Alternative</h2>
        <p class="mt-2 text-dark-400">Click any comparison for a full feature-by-feature breakdown.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {comparisons.map(c => (
          <div class="group relative flex flex-col rounded-xl border border-dark-800 bg-dark-900/60 p-6 transition-all hover:border-lime-500/40">
            <div class="mb-1 flex items-center justify-between">
              <span class="text-xs font-semibold uppercase tracking-wider text-dark-500">{c.category}</span>
              {c.slug && (
                <svg class="h-4 w-4 text-dark-600 group-hover:text-lime-400 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              )}
            </div>
            <div class="mb-3 flex items-center gap-2">
              <span class="text-sm font-bold text-lime-400">LimeCall</span>
              <span class="text-dark-600">vs</span>
              <span class="text-sm font-bold text-white">{c.opponent}</span>
            </div>
            <p class="mb-2 text-sm font-semibold text-lime-400/90 leading-snug">{c.keyAdvantage}</p>
            <p class="flex-1 text-xs text-dark-400 leading-relaxed">{c.desc}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {c.badges.map(b => (
                <span class="rounded-full bg-lime-500/10 px-2.5 py-0.5 text-xs font-semibold text-lime-400/80">{b}</span>
              ))}
            </div>
            {c.slug ? (
              <a href={c.slug} class="mt-4 text-xs font-semibold text-lime-500 hover:text-lime-400 transition">Full comparison →</a>
            ) : (
              <span class="mt-4 text-xs text-dark-600">Detailed guide coming soon</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LimeCall advantage -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 class="text-2xl font-bold text-white">The LimeCall Advantage</h2>
        <p class="mt-2 text-dark-400">Four reasons teams consistently choose LimeCall — regardless of which alternative they came from.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {differentiators.map((d, i) => (
          <div class="flex gap-4 rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-lime-500/10 text-sm font-bold text-lime-400">
              {i + 1}
            </div>
            <div>
              <h3 class="font-semibold text-white mb-1">{d.title}</h3>
              <p class="text-sm text-dark-400 leading-relaxed">{d.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to see the difference?</h2>
      <p class="mt-4 text-dark-400">Join 10,000+ teams. No credit card. Cancel anytime.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free — No Credit Card →
      </a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore LimeCall" links={[
        { href: '/callback-software-guide/', title: 'Callback Software Guide', desc: 'The definitive guide to callback software in 2026.' },
        { href: '/best-callback-software/', title: 'Best Callback Software', desc: 'Top-rated callback tools ranked and reviewed.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans. No hidden fees.' },
        { href: '/limecall-vs-callpage/', title: 'LimeCall vs CallPage', desc: 'Side-by-side feature and pricing comparison.' },
        { href: '/limecall-vs-aircall/', title: 'LimeCall vs Aircall', desc: 'Callback widget vs cloud call centre.' },
        { href: '/integrations/', title: 'Integrations', desc: 'Connect LimeCall to your existing stack.' },
      ]} />
    </div>
  </div>
</Base>
