---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const seo = {
  title: `Virtual Phone Numbers — Local Presence in 40+ Countries | LimeCall`,
  description: `Get virtual phone numbers in 40+ countries instantly. Build local trust, track calls by number, and manage everything from one LimeCall dashboard.`,
  canonical: `https://www.limecall.com/virtual-numbers/`,
};

const features = [
  {
    icon: '🌍',
    name: 'Numbers in 40+ Countries',
    description: 'Buy local, national, or toll-free virtual numbers in over 40 countries. Appear local to customers in every market you serve — no physical office required.',
  },
  {
    icon: '📞',
    name: 'Click to Call Integration',
    description: 'Pair virtual numbers with LimeCall\'s click-to-call widget. Visitors in any country can call your local number with a single click — connecting instantly to your team.',
  },
  {
    icon: '🎙️',
    name: 'Call Recording & Storage',
    description: 'All calls to your virtual numbers are recorded and stored securely. Accessible anytime from your dashboard for quality review, training, and compliance.',
  },
  {
    icon: '🔀',
    name: 'Call & Lead Routing',
    description: 'Route calls to virtual numbers to any rep, team, or device globally. Use round-robin, skills-based, or time-based routing rules across all your numbers.',
  },
  {
    icon: '📊',
    name: 'Per-Number Analytics',
    description: 'Track call volume, response rates, and conversion data for each virtual number individually. Know exactly which numbers — and which markets — are performing.',
  },
  {
    icon: '💬',
    name: 'SMS on Virtual Numbers',
    description: 'Send and receive SMS messages on your virtual numbers. Use two-way text for follow-ups, appointment reminders, and lead nurturing — all from one platform.',
  },
];

const countries = [
  'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
  'France', 'Netherlands', 'Spain', 'Italy', 'Poland',
  'Sweden', 'Norway', 'Denmark', 'Finland', 'Belgium',
  'Switzerland', 'Austria', 'Brazil', 'Mexico', 'India',
  'Singapore', 'Hong Kong', 'Japan', 'South Africa', '+20 more',
];

const useCases = [
  {
    icon: '🏢',
    title: 'Multi-Market Businesses',
    description: 'Serve customers in multiple countries without opening local offices. Get numbers in every market you operate and manage them all from one dashboard.',
  },
  {
    icon: '📈',
    title: 'Sales Teams',
    description: 'Give each sales rep a dedicated virtual number in their target market. Track performance by number and ensure every call is logged and recorded.',
  },
  {
    icon: '🛠️',
    title: 'Marketing Campaigns',
    description: 'Assign unique virtual numbers to different campaigns, regions, or channels. Track which local markets respond best to your advertising.',
  },
  {
    icon: '🤝',
    title: 'Support Teams',
    description: 'Offer customers a local number to call for support — dramatically reducing call hesitation and increasing customer satisfaction scores.',
  },
];

const faqs = [
  {
    question: 'What is a virtual phone number?',
    answer: 'A virtual phone number is a telephone number that is not tied to a physical phone line or device. Calls to a virtual number are forwarded to any phone, computer, or team based on your routing rules. LimeCall provides virtual numbers in 40+ countries.',
  },
  {
    question: 'How quickly can I get a virtual number?',
    answer: 'In most countries, you can get a virtual number instantly after signing up for a LimeCall Pro plan. Simply select your country, choose a number, and it\'s active within minutes.',
  },
  {
    question: 'Can I port my existing phone number to LimeCall?',
    answer: 'Number porting is available in select countries. Contact LimeCall support to check availability for your specific number and region.',
  },
  {
    question: 'Can I send SMS with a virtual number?',
    answer: 'Yes. LimeCall\'s virtual numbers support two-way SMS in supported countries. Use your virtual numbers for text follow-ups, confirmations, and lead nurturing alongside voice calls.',
  },
  {
    question: 'Are calls to virtual numbers recorded?',
    answer: 'Yes. All calls to LimeCall virtual numbers can be automatically recorded and stored. Recordings are available in your dashboard and can be downloaded or listened to at any time.',
  },
  {
    question: 'Which plan includes virtual numbers?',
    answer: 'Virtual numbers are included in the LimeCall Pro plan ($99/month). This plan includes unlimited widgets, virtual numbers, web-to-text, API access, and priority support.',
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Virtual Numbers', url: `${site.url}/virtual-numbers/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        Virtual Phone Numbers
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Local Numbers.<br />
        <span class="text-lime-400">Global Reach.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Get virtual phone numbers in 40+ countries instantly. Build local trust with customers worldwide — and manage every call, recording, and lead from a single LimeCall dashboard.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm">
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">40+</span>
          countries available
        </span>
        <span class="hidden h-5 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <svg class="h-4 w-4 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Instant activation
        </span>
        <span class="hidden h-5 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <svg class="h-4 w-4 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Voice + SMS support
        </span>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free — No Card Needed
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          See Pricing
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Virtual numbers available on Pro plan · 30-day money-back guarantee</p>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          One Platform for <span class="text-lime-400">All Your Numbers</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          LimeCall virtual numbers come with the full power of the LimeCall platform — routing, recording, analytics, and SMS all included.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <FeatureCard icon={f.icon} name={f.name} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- Countries grid -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Available in <span class="text-lime-400">40+ Countries</span>
        </h2>
        <p class="mt-4 text-dark-400">
          Select from local, national, and toll-free number types across every major market.
        </p>
      </div>
      <div class="flex flex-wrap gap-2 justify-center">
        {countries.map((country) => (
          <span class="rounded-lg border border-dark-800 bg-dark-900/60 px-4 py-2 text-sm text-dark-300">
            {country}
          </span>
        ))}
      </div>
      <p class="mt-6 text-center text-sm text-dark-500">
        Don't see your country? <a href="/contact-us" class="text-lime-400 hover:underline">Contact us</a> — we're adding new regions regularly.
      </p>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Who Uses <span class="text-lime-400">Virtual Numbers?</span>
        </h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {useCases.map((uc) => (
          <div class="flex items-start gap-4 rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <span class="text-3xl flex-shrink-0">{uc.icon}</span>
            <div>
              <h3 class="font-bold text-white mb-2">{uc.title}</h3>
              <p class="text-sm text-dark-400 leading-relaxed">{uc.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Compatible with everything -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-2 items-center">
        <div>
          <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
            Compatible with <span class="text-lime-400">Every Device &amp; Platform</span>
          </h2>
          <p class="mt-4 text-dark-400 leading-relaxed">
            LimeCall virtual numbers work on desktops, tablets, and mobile phones. Integrate with your existing stack and manage calls wherever your team works.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              'Works on iOS, Android, Mac, and Windows',
              'Integrates with WordPress, Webflow, Shopify, and more',
              'Connects to HubSpot, Salesforce, Pipedrive via native integrations',
              '1000+ integrations via Zapier and webhooks',
              'Full API access on Pro plan for custom workflows',
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-dark-300">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-950/30 to-dark-900/80 p-8 text-center">
          <div class="text-6xl mb-4">🌐</div>
          <h3 class="text-xl font-bold text-white mb-3">Never Miss a Call, Anywhere</h3>
          <p class="text-sm text-dark-400 leading-relaxed mb-6">
            Set offline hours, configure automated follow-ups, and ensure every call to your virtual numbers is handled — even when your team is unavailable.
          </p>
          <div class="grid grid-cols-2 gap-3 text-left">
            {['Call forwarding', 'Voicemail', 'SMS follow-ups', 'Auto-scheduling'].map((item) => (
              <div class="flex items-center gap-2 text-sm text-dark-300">
                <svg class="h-4 w-4 text-lime-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Go Global with <span class="text-lime-400">Local Numbers</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        Get virtual numbers in 40+ countries, activate in minutes, and start building local trust with customers everywhere you sell.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free Trial
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          View Pricing
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">Virtual numbers on Pro plan · 30-day money-back guarantee · Cancel anytime</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="More from LimeCall"
        links={[
          { href: '/click-to-call-software', title: 'Click to Call Software', desc: 'Pair virtual numbers with one-click web calling.' },
          { href: '/customer-callback-software', title: 'Callback Software', desc: 'Automated callbacks from your website in 28 seconds.' },
          { href: '/calltracking-software', title: 'Call Tracking', desc: 'Track calls per virtual number and per campaign.' },
          { href: '/speed-to-lead', title: 'Speed to Lead', desc: 'Respond to every lead instantly, wherever they call from.' },
          { href: '/business-texting', title: 'Web to Text', desc: 'Send and receive SMS on your virtual numbers.' },
          { href: '/pricing', title: 'Pricing', desc: 'Virtual numbers included on the Pro plan.' },
        ]}
      />
    </div>
  </section>
</Base>
