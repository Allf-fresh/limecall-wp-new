---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Customer Care Software — Proactive Callbacks That Delight | LimeCall`,
  description: `Give customers the fastest, most personal care experience. LimeCall connects them to a care agent in 28 seconds. 90% CSAT improvement, 3x retention rate.`,
  canonical: `https://www.limecall.com/customer-care/`,
};

const stats = [
  { value: "90%", label: "CSAT improvement" },
  { value: "28s", label: "Average callback time" },
  { value: "80%", label: "Faster issue resolution" },
  { value: "3x", label: "Higher retention rate" },
];

const features = [
  { title: "Proactive care callbacks", desc: "Don't wait for customers to complain. Trigger outbound callbacks to at-risk customers before issues escalate — turning potential churn into loyalty." },
  { title: "Customer health alerts", desc: "Set automated alerts based on customer usage signals, missed renewals, or support ticket spikes. Your care team knows who needs attention before they ask." },
  { title: "Churn prevention workflows", desc: "Route at-risk customers to senior retention specialists automatically. Purpose-built workflows for cancellation saves, renewal calls, and win-back campaigns." },
  { title: "VIP callback queue", desc: "Priority routing for your highest-value customers. VIP accounts skip the queue and are connected to their dedicated care specialist within seconds." },
  { title: "NPS survey triggers post-call", desc: "Automatically send NPS or CSAT surveys after every care call. Capture feedback while the experience is fresh and close the loop on detractors." },
  { title: "CRM history on every call", desc: "Agents see the full customer history — past calls, purchases, open tickets, and CRM notes — before they even say hello. No more asking customers to repeat themselves." },
];

const useCases = [
  { title: "At-risk customer callbacks", desc: "Proactively call customers showing churn signals — declining usage, overdue renewals, unresolved tickets — before they leave." },
  { title: "Renewal calls", desc: "Trigger automated renewal outreach at the right time in the customer lifecycle. Care agents call with full context and the right offers ready." },
  { title: "Post-purchase follow-up", desc: "Reach out after a purchase or onboarding milestone to ensure customers are succeeding. Proactive care prevents early churn and builds loyalty." },
  { title: "Loyalty programme calls", desc: "Personal callbacks to reward loyal customers, announce exclusive offers, or gather feedback. Make your best customers feel like VIPs." },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the difference between customer care and customer support?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Customer support is reactive — it responds to issues after they happen. Customer care is proactive — it anticipates customer needs, monitors account health, and reaches out before problems escalate. LimeCall supports both: instant callbacks for reactive support and automated outreach workflows for proactive care.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do proactive callbacks prevent churn?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Proactive callbacks reach customers before they decide to leave. By identifying churn signals — low usage, unresolved tickets, upcoming renewals — and triggering outbound calls from a care specialist, businesses can address concerns directly. Customers who receive proactive outreach are significantly more likely to renew.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall identify at-risk customers automatically?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall can trigger callback workflows based on CRM data, support ticket events, or custom signals you define. When a customer crosses a threshold — like submitting three support tickets in a week or not logging in for 30 days — an automatic callback to a care specialist is queued. Your team acts at the right moment, every time.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall integrate with our CRM for customer history?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall integrates with HubSpot, Salesforce, Zoho, and other CRMs. When a care agent picks up a callback, they see the full customer record — past calls, purchases, open tickets, and notes — before the conversation starts. No asking customers to repeat their history.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does NPS collection work after a care call?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'After every customer care call, LimeCall can automatically trigger an NPS or CSAT survey via SMS or email. Surveys are sent within minutes of call completion while the experience is fresh. Responses are collected and tied to the call record so managers can identify patterns and close the loop with detractors.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Customer Care Software', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Customer Care
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Proactive care callbacks that<br class="hidden sm:block" />
        <span class="text-lime-400">delight customers and prevent churn</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Don't wait for customers to complain. LimeCall enables proactive care callbacks, VIP routing, and churn prevention workflows — delivering 90% CSAT improvement and 3x higher retention.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free Trial →</a>
        <a href="/customer-callback-software/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">Callback Software</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Customer care tools that make a real difference</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Customer care use cases</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 font-semibold text-white">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { n: "1", title: "Signal detected or request made", desc: "A customer triggers a churn alert, requests a callback, or your proactive workflow fires. LimeCall queues the outreach immediately." },
          { n: "2", title: "Agent connected with full context", desc: "The care agent receives the callback with full CRM history, past interactions, and relevant context — before they say a word." },
          { n: "3", title: "Issue resolved, NPS triggered", desc: "The agent resolves the issue or completes the proactive call. A post-call NPS survey fires automatically. Call is recorded and logged." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(q => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <summary class="cursor-pointer font-semibold text-white">{q.name}</summary>
            <p class="mt-3 text-sm text-dark-400 leading-relaxed">{q.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Make every customer feel cared for</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free Trial →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related resources" links={[
        { href: '/customer-support-software/', title: 'Customer Support Software', desc: 'LimeCall for support teams.' },
        { href: '/retention/', title: 'Retention', desc: 'Keep customers with proactive outreach.' },
        { href: '/shared-inbox/', title: 'Shared Inbox', desc: 'Manage all customer conversations in one place.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
