---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const country = "Belgium";
const code = "+32";
const slug = "virtual-phone-number-belgium";
const flag = "🇧🇪";

const seo = {
  title: `Belgium Virtual Phone Number — Get a +32 Number | LimeCall`,
  description: `Get a Belgium virtual phone number (+32) from $35/mo. Brussels, Antwerp, Ghent numbers. Instant 5-min setup, no SIM required. Receive calls from anywhere.`,
  canonical: `https://www.limecall.com/${slug}/`,
};

const faqs = [
  {
    question: `Can I get a Belgium virtual number without being in Belgium?`,
    answer: `Yes. LimeCall provisions genuine Belgian numbers (+32) that you can use from anywhere in the world. Belgian callers dial a local number and your team answers via the LimeCall app, browser, or any forwarded device — no physical presence in Belgium required.`,
  },
  {
    question: `What is the country code for Belgium?`,
    answer: `Belgium's international dialling code is +32. Belgian landline numbers begin with 02 (Brussels), 03 (Antwerp), 09 (Ghent), or 04 (Liège). Mobile numbers begin with 04 followed by the operator prefix. When dialling from outside Belgium, dial +32 then drop the leading 0.`,
  },
  {
    question: `How much does a Belgium virtual phone number cost?`,
    answer: `LimeCall's Belgium virtual numbers start from $35 per month. This includes the number rental plus per-minute rates for inbound calls. There are no setup fees and you can cancel at any time. See the pricing page for a full rate breakdown.`,
  },
  {
    question: `Can I make outbound calls showing a Belgian caller ID?`,
    answer: `Yes. LimeCall lets you place outbound calls displaying your Belgian +32 number as the caller ID. Belgian recipients see a familiar local number, which significantly improves answer rates for sales and support teams calling into Belgium.`,
  },
  {
    question: `How quickly can I get a Belgium virtual number?`,
    answer: `Your Belgium virtual number is active within 5 minutes of signing up. No hardware, no SIM card, and no waiting for postal delivery. Choose your Belgian city prefix, configure call routing, and start receiving calls immediately.`,
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Virtual Numbers', url: 'https://www.limecall.com/virtual-numbers/' },
        { name: 'Belgium Virtual Number', url: seo.canonical }
      ]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a <span class="text-lime-400">Belgium Virtual Phone Number</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Get a local Belgium number ({code}) without being physically present in Belgium. Instant 5-minute setup, no hardware, no SIM card required.
      </p>
      <!-- Trust signals -->
      <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm text-dark-400">
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Active in 5 minutes</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Cancel anytime</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> 30-day money-back guarantee</span>
      </div>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your Belgium Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/80 py-6">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        <div>
          <div class="text-2xl font-bold text-lime-400">+32</div>
          <div class="mt-1 text-xs text-dark-400">Belgium prefix</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">5 min</div>
          <div class="mt-1 text-xs text-dark-400">Setup time</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">$35/mo</div>
          <div class="mt-1 text-xs text-dark-400">Starting from</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">40+</div>
          <div class="mt-1 text-xs text-dark-400">Countries covered</div>
        </div>
      </div>
    </div>
  </section>

  <!-- What is a Belgium virtual number -->
  <section class="py-16 sm:py-20 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-3xl font-bold text-white">What is a Belgium virtual phone number?</h2>
      <p class="text-dark-300 leading-relaxed mb-4">
        A Belgium virtual phone number is a real Belgian telephone number — with a genuine +32 country code — that is hosted in the cloud rather than tied to a physical SIM card or landline in Belgium. Calls to your Belgian number are routed over the internet to any device you choose: your mobile phone, laptop, desk phone, or SIP endpoint anywhere in the world.
      </p>
      <p class="text-dark-300 leading-relaxed mb-4">
        For businesses expanding into the Belgian market, a virtual number creates a trusted local presence without the cost of a physical office. Belgium is home to the European Union headquarters and NATO, making it one of Europe's most important business hubs. A Brussels (02) or Antwerp (03) prefix signals to Belgian callers that you are a local, accessible business.
      </p>
      <p class="text-dark-300 leading-relaxed">
        LimeCall virtual numbers include call routing, recording, CRM integration, and the same callback widget technology that connects website visitors to your team in under 28 seconds.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20 border-t border-dark-800 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">How to get your Belgium number in 3 steps</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">1</div>
          <h3 class="mb-2 font-semibold text-white">Choose your number</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Pick a Belgian city prefix — Brussels (02), Antwerp (03), Ghent (09), Liège (04), Bruges (050), Charleroi (071) — or a national Belgian mobile-style number.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">2</div>
          <h3 class="mb-2 font-semibold text-white">Configure routing</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Forward calls to any device, agent, or phone number globally. Set up IVR menus, voicemail, ring groups, or time-based routing rules.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">3</div>
          <h3 class="mb-2 font-semibold text-white">Receive calls anywhere</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Your Belgium number goes live in minutes. Belgian customers call a local number and your team answers from any country in the world.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Features included with your Belgium number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Receive calls on any device</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Answer Belgian calls on your mobile, laptop, browser, or SIP phone. Switch between devices without missing a call.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Call recording</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Record every incoming and outgoing Belgium call automatically. Review calls for quality assurance and coaching from your dashboard.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">CRM sync</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Every Belgian call is logged automatically in HubSpot, Salesforce, Pipedrive, and 50+ CRM integrations. No manual data entry.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Multilingual support</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Belgium has three official languages — Dutch, French, and German. Route calls to the right agent based on language preference with LimeCall's IVR.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">No physical SIM required</h3>
          <p class="text-sm text-dark-400 leading-relaxed">100% cloud-based. No SIM card, no hardware, no Belgian address required. Fully compliant and operational from day one.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Callback widget</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Show your Belgium +32 number on your website callback widget. Visitors click to call and connect to your team in under 28 seconds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20 bg-dark-900/40 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Who uses Belgium virtual numbers?</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🏛️</div>
          <h3 class="mb-2 font-semibold text-white">EU & institutions</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Companies working with EU institutions and NATO need a credible Brussels presence. A +32 02 number instantly signals Brussels-based operations.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">📞</div>
          <h3 class="mb-2 font-semibold text-white">Callback widget</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Display your Belgium +32 number in the LimeCall callback widget. Convert Belgian website visitors into calls within 28 seconds.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">💼</div>
          <h3 class="mb-2 font-semibold text-white">Sales teams</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Outbound sales teams calling Belgian prospects see dramatically higher answer rates when calling from a recognised +32 local number.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🎧</div>
          <h3 class="mb-2 font-semibold text-white">Customer support</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Route Belgian customer support calls to your global team. Belgian callers pay local rates while your agents work remotely worldwide.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Did you know -->
  <section class="py-16 sm:py-20 border-t border-dark-800">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-8">
        <h2 class="mb-6 text-xl font-bold text-white">Belgium phone system facts</h2>
        <ul class="space-y-3 text-sm text-dark-300 leading-relaxed">
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>Belgium's international dialling code is <strong class="text-white">+32</strong>. When dialling from abroad, drop the leading 0 from the area code.</span></li>
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>Major Belgian city codes: <strong class="text-white">Brussels 02</strong>, <strong class="text-white">Antwerp 03</strong>, <strong class="text-white">Ghent 09</strong>, <strong class="text-white">Liège 04</strong>, <strong class="text-white">Bruges 050</strong>, <strong class="text-white">Namur 081</strong>.</span></li>
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>Belgium has three official languages — <strong class="text-white">Dutch</strong> (Flanders), <strong class="text-white">French</strong> (Wallonia), and <strong class="text-white">German</strong> (East Cantons). LimeCall's IVR supports language-based call routing to serve all Belgian callers.</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-20 bg-dark-900/40 border-t border-dark-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-bold text-white">Virtual number vs other Belgium number options</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800">
              <th class="py-3 pr-6 text-left font-semibold text-dark-400">Feature</th>
              <th class="py-3 px-4 text-left font-semibold text-lime-400">LimeCall Virtual</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Local SIM</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Toll-free</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Existing mobile</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            <tr>
              <td class="py-3 pr-6 text-dark-300">Setup time</td>
              <td class="py-3 px-4 text-white">5 minutes</td>
              <td class="py-3 px-4 text-dark-400">Days to weeks</td>
              <td class="py-3 px-4 text-dark-400">1–3 days</td>
              <td class="py-3 px-4 text-dark-400">Immediate</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Physical presence needed</td>
              <td class="py-3 px-4 text-white">No</td>
              <td class="py-3 px-4 text-dark-400">Yes — must be in Belgium</td>
              <td class="py-3 px-4 text-dark-400">Partial</td>
              <td class="py-3 px-4 text-dark-400">No</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Local Belgian number</td>
              <td class="py-3 px-4 text-white">Yes (+32)</td>
              <td class="py-3 px-4 text-dark-400">Yes</td>
              <td class="py-3 px-4 text-dark-400">No (0800 prefix)</td>
              <td class="py-3 px-4 text-dark-400">Foreign number</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Works from anywhere</td>
              <td class="py-3 px-4 text-white">Yes — globally</td>
              <td class="py-3 px-4 text-dark-400">Roaming charges apply</td>
              <td class="py-3 px-4 text-dark-400">Yes</td>
              <td class="py-3 px-4 text-dark-400">Yes</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Multiple numbers</td>
              <td class="py-3 px-4 text-white">Yes — unlimited</td>
              <td class="py-3 px-4 text-dark-400">One per SIM</td>
              <td class="py-3 px-4 text-dark-400">Limited</td>
              <td class="py-3 px-4 text-dark-400">One per device</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your Belgium number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall to connect with Belgian customers — from anywhere in the world.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/virtual-numbers/', title: 'All Virtual Numbers', desc: 'Browse all available countries.' },
        { href: '/virtual-business-numbers/', title: 'Virtual Business Numbers', desc: 'Business-grade virtual numbers.' },
        { href: '/virtual-phone-number-netherlands/', title: 'Netherlands Virtual Number', desc: 'Get a Netherlands +31 number.' },
        { href: '/virtual-phone-number-spain/', title: 'Spain Virtual Number', desc: 'Get a Spain +34 number.' },
        { href: '/pricing/', title: 'Pricing', desc: 'See all LimeCall plans.' },
      ]}
    />
  </div>
</Base>
