---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import postsData from '../../data/posts.json';
import { site } from '../../site.config';

const allPosts = postsData;

// CollectionPage JSON-LD listing the 10 most recent posts
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'LimeCall Blog',
  description: 'Sales, lead generation and callback tips from the LimeCall team.',
  url: `${site.url}/post/`,
  hasPart: allPosts.slice(0, 10).map((p) => ({
    '@type': 'Article',
    headline: p.seo_title || p.title,
    url: `${site.url}/post/${p.slug}/`,
    datePublished: p.date,
  })),
};
---

<Base
  title="LimeCall Blog — Sales, Lead Generation & Callback Tips"
  description="Get LimeCall's advice on the best ways to convert website visitors, engage leads, and support your customers. Delivered straight from our team."
  canonical="https://www.limecall.com/post/"
>
  <JsonLd schema={collectionSchema} />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center mb-14">
        <span class="inline-block mb-4 rounded-full bg-lime-500/10 px-4 py-1.5 text-sm font-semibold text-lime-400">Blog</span>
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">
          LimeCall
          <span class="text-lime-400"> Blog</span>
        </h1>
        <p class="mt-6 text-lg text-dark-300">
          Guides, tips, and news to help you convert more website visitors into sales calls.
          {allPosts.length > 0 && <span class="text-dark-500"> ({allPosts.length} articles)</span>}
        </p>
      </div>

      {/* Posts Grid — all 220 posts */}
      {allPosts.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {allPosts.map((post) => (
            <a
              href={`/post/${post.slug}/`}
              class="group rounded-xl border border-dark-800 bg-dark-900/50 overflow-hidden transition-all hover:border-dark-700 flex flex-col"
            >
              <div class="p-6 flex-1 flex flex-col">
                <h2 class="font-semibold text-white group-hover:text-lime-400 transition line-clamp-2 flex-1">
                  {post.title}
                </h2>
                {(post.seo_description || post.excerpt) && (
                  <p class="mt-2 text-sm text-dark-400 line-clamp-2">{post.seo_description || post.excerpt}</p>
                )}
                {post.date && (
                  <time class="mt-4 block text-xs text-dark-500" datetime={post.date}>
                    {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-16 text-center">
          <p class="text-dark-400 text-lg">Blog posts coming soon.</p>
        </div>
      )}

      {/* LimeCall content promo */}
      <div class="mt-20 rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-500/5 to-dark-900 p-10 text-center">
        <h2 class="text-2xl font-bold text-white mb-3">Want more conversions?</h2>
        <p class="text-dark-300 mb-6 max-w-lg mx-auto">
          Join thousands of businesses using LimeCall to turn website visitors into sales calls — instantly.
        </p>
        <a
          href="/signup"
          class="inline-block rounded-xl bg-lime-500 px-8 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition"
        >
          TRY FOR FREE
        </a>
      </div>
    </div>
  </section>
</Base>
