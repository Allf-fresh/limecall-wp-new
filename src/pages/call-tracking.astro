---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Call Tracking Software — Know What Drives Calls | LimeCall`,
  description: `LimeCall call tracking attributes every phone lead to its marketing source. Dynamic number insertion, call recording, and CRM sync. 5-min setup, free trial.`,
  canonical: `https://www.limecall.com/call-tracking/`,
};

const stats = [
  { value: "40%", label: "Lower cost-per-lead" },
  { value: "3x", label: "ROI visibility" },
  { value: "100%", label: "Call attribution" },
  { value: "5 min", label: "Setup time" },
];

const features = [
  { title: "Source Attribution", desc: "Know exactly which ad, keyword, or page drove each call. Attribute every phone lead to its marketing source." },
  { title: "Dynamic Number Insertion", desc: "Assign unique phone numbers to each campaign, channel, or landing page. Calls reveal which sources work best." },
  { title: "Call Recording", desc: "Record every tracked call automatically. Review conversations to improve messaging, training, and quality." },
  { title: "Call Analytics Dashboard", desc: "See call volume, duration, peak times, and conversion rates by source, campaign, keyword, or landing page." },
  { title: "Google Ads Integration", desc: "Connect call tracking to Google Ads. Import call conversions to optimize bidding and improve ROAS." },
  { title: "CRM Sync", desc: "Every tracked call logs to your CRM automatically — with source, keyword, recording, and contact details." },
];

const useCases = [
  { title: "PPC Campaign Optimization", desc: "See which Google and Meta ad campaigns drive the most calls. Cut wasted spend and double down on winners." },
  { title: "SEO Attribution", desc: "Track which organic keywords lead to phone calls. Prove SEO ROI and optimize for high-intent terms." },
  { title: "Landing Page Testing", desc: "A/B test landing pages and measure the impact on call volume. Optimize for phone conversions, not just clicks." },
  { title: "Sales Training", desc: "Listen to recorded calls to coach reps, identify objection patterns, and improve your sales scripts." },
];

const steps = [
  { n: "1", title: "Unique numbers assigned", desc: "LimeCall generates a unique tracking number for each campaign, channel, ad group, or landing page you want to measure." },
  { n: "2", title: "Visitor calls — source tracked", desc: "When a visitor calls, LimeCall captures their session data and maps the call back to the exact source, keyword, and page." },
  { n: "3", title: "Data flows to CRM & analytics", desc: "Call data — source, recording, duration, outcome — syncs instantly to your CRM, Google Ads, and analytics platform." },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is call tracking?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Call tracking is a technology that lets businesses identify which marketing campaigns, keywords, ads, or web pages are generating inbound phone calls. Each source gets a unique tracking number, and when a visitor calls that number, the software attributes the call to the correct source and records details like caller ID, duration, and recording.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does dynamic number insertion work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Dynamic number insertion (DNI) automatically swaps the phone number displayed on your website based on how a visitor arrived. A visitor from a Google Ads campaign sees a different number than one from organic search or a Facebook ad. This lets LimeCall track exactly which source drove each call without any extra steps for the visitor.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does call tracking work with Google Ads?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall integrates directly with Google Ads to import call conversions. This allows Google\'s Smart Bidding to optimize for phone call conversions, not just clicks. You can track which keywords, ad groups, and campaigns are generating the most valuable calls and adjust your bids accordingly.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is call tracking different from call recording?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Call recording captures the audio of a phone conversation for later review. Call tracking is the broader attribution system that identifies which marketing source drove each call. LimeCall does both: every tracked call can also be recorded automatically, giving you both attribution data and the conversation content.',
      },
    },
    {
      '@type': 'Question',
      name: 'What CRMs does LimeCall call tracking integrate with?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall integrates with Salesforce, HubSpot, Pipedrive, Zoho CRM, and dozens more via native integrations and Zapier. Every tracked call automatically creates or updates a CRM record with source, keyword, call recording, duration, and caller details — giving your sales team complete context.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Call Tracking", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Call Tracking Software
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Know Exactly What's <span class="text-lime-400">Driving Your Calls</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        LimeCall's call tracking software attributes every phone lead to its marketing source. Stop guessing which campaigns work — know for certain, and grow faster.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-b border-dark-800 bg-dark-900/30 py-10">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <p class="text-3xl font-extrabold text-lime-400">{s.value}</p>
            <p class="mt-1 text-sm text-dark-400">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Call tracking features</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Use cases</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 font-semibold text-white">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How call tracking works</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(faq => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/50 p-5 open:pb-4">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between gap-4">
              {faq.name}
              <span class="shrink-0 text-lime-400 text-lg">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Start tracking your calls today</h2>
      <p class="mt-4 text-dark-400">LimeCall's call tracking is free to start. Set up in 5 minutes, no developer required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/form-tracking/', title: 'Form Tracking', desc: 'Track form submissions and sources.' },
        { href: '/lead-capture-software/', title: 'Lead Capture Software', desc: 'Capture every inbound lead.' },
        { href: '/callbackautomation/', title: 'Callback Automation', desc: 'Automate inbound callbacks.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
