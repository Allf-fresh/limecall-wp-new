---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const tool = "Webflow";

const seo = {
  title: `Boost Webflow Conversions with Effortless Callbacks with LimeCall`,
  description: `Maximize Webflow conversions! Try LimeCall's callbacks & texting for lead capture, streamlined communication & deal closure. Try LimeCall Now`,
  canonical: `https://www.limecall.com/limecall-for-webflow/`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I add LimeCall to Webflow?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Adding LimeCall to Webflow takes about 5 minutes. Copy your LimeCall widget snippet from the dashboard, then go to Webflow Project Settings → Custom Code → Footer Code and paste the snippet. Publish your site and the callback widget is live instantly — no plugins or developer needed.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall work with Webflow CMS?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall works on all Webflow page types including static pages, CMS collection pages, and dynamic templates. Because the widget loads via a single JavaScript snippet, it appears on every page type automatically once the code is added to your project.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I trigger the LimeCall widget on specific Webflow pages only?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. You can add the LimeCall snippet to individual Webflow pages instead of the global project settings. Alternatively, use LimeCall\'s dashboard targeting rules to show the widget only on specific URLs or URL patterns — for example, only on your pricing or features pages.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does the LimeCall widget affect Webflow page speed?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. The LimeCall widget script is loaded asynchronously and does not block page rendering. It has minimal impact on Webflow\'s Core Web Vitals scores. The script is served from a global CDN to ensure fast loading worldwide.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I style the LimeCall widget to match my Webflow design?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall\'s widget is fully customisable — you can change the button colour, position, size, text, and timing from your LimeCall dashboard without touching any code. This makes it easy to match your Webflow brand guidelines.',
      },
    },
  ],
};

const stats = [
  { value: "5 min", label: "Webflow setup time" },
  { value: "1", label: "Snippet to paste and go" },
  { value: "10-12x", label: "More conversions vs forms" },
  { value: "0", label: "Code skills required" },
];

const howItWorks = [
  { n: "1", title: "Copy the LimeCall widget snippet", desc: "Get your unique JavaScript snippet from the LimeCall dashboard. One line of code is all you need." },
  { n: "2", title: "Paste into Webflow's custom code section", desc: "In Webflow, go to Project Settings → Custom Code → Footer Code and paste your snippet. Done." },
  { n: "3", title: "Publish — widget goes live immediately", desc: "Hit Publish in Webflow. Your callback widget appears instantly on every page you've targeted." },
];

const steps = [
  { n: "1", title: "Copy your LimeCall snippet", desc: "Get your unique embed code from the LimeCall dashboard — a single JavaScript snippet, no plugins required." },
  { n: "2", title: "Paste into Webflow", desc: "Add the snippet to your Webflow project's custom code section. Works in the head, body, or on specific pages." },
  { n: "3", title: "Go live and capture leads", desc: "Publish your Webflow site. The callback widget appears instantly — styled to match your brand." },
];

const benefits = [
  { title: "No-code embed", desc: "One script tag is all it takes. No Webflow plugins, no custom code complexity — paste and publish." },
  { title: "Pixel-perfect styling", desc: "Customize the widget color, position, text, and timing to match your Webflow design system perfectly." },
  { title: "Page-level targeting", desc: "Show the callback widget only on high-intent pages like pricing, features, or contact — not on every page." },
  { title: "Callback in 28 seconds", desc: "Visitors request a call and get connected with your team in under 28 seconds — while they're still on your site." },
  { title: "Lead data captured", desc: "Every callback request captures visitor name, phone, and the page they converted on — ready for your CRM." },
  { title: "Works with CMS pages", desc: "LimeCall works on static pages, CMS templates, and dynamic Webflow pages — embed once, works everywhere." },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `LimeCall for ${tool}`, url: seo.canonical }]} />
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall for <span class="text-lime-400">{tool}</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Add instant callback to any Webflow site with one snippet. Turn high-intent visitors into live conversations — no dev work, no plugins.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Add to Webflow Free →</a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {howItWorks.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">What you get</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map(b => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{b.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Code snippet example -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-dark-700 bg-dark-900/80 p-8">
        <h2 class="text-xl font-bold text-white mb-2">That's literally all you need</h2>
        <p class="text-dark-400 text-sm mb-6">Add LimeCall to any Webflow page via Project Settings → Custom Code → Footer Code.</p>
        <div class="rounded-xl bg-dark-950 border border-dark-800 p-5 font-mono text-sm text-lime-400 overflow-x-auto">
          <span class="text-dark-500">&lt;!-- LimeCall Widget --&gt;</span><br />
          <span class="text-dark-400">&lt;script</span> <span class="text-lime-300">src</span>=<span class="text-white">"https://widget.limecall.com/widget.js"</span><br />
          <span class="ml-8 text-lime-300">data-id</span>=<span class="text-white">"YOUR_WIDGET_ID"</span><br />
          <span class="ml-8 text-lime-300">async</span><span class="text-dark-400">&gt;&lt;/script&gt;</span>
        </div>
        <p class="mt-4 text-xs text-dark-500">Replace YOUR_WIDGET_ID with the ID from your LimeCall dashboard.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 group">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between">
              {item.name}
              <span class="ml-4 text-lime-400 text-xl leading-none group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to add LimeCall to your Webflow site?</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="More ways to embed LimeCall" links={[
        { href: '/limecall-for-wordpress/', title: 'LimeCall for WordPress', desc: 'Install with our official WordPress plugin.' },
        { href: '/click-to-call-software/', title: 'Click-to-Call Software', desc: 'Learn how our core callback feature works.' },
        { href: '/how-it-works/', title: 'How It Works', desc: 'See the full LimeCall flow end to end.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
