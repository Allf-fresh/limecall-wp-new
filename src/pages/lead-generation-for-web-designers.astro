---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const industry = "Web Designers";
const icon = "💻";

const seo = {
  title: `Lead Generation for Web Designers & Agencies | LimeCall`,
  description: `Win more web design projects by responding to client inquiries instantly. LimeCall's callback software helps freelance designers and agencies connect with project requests in under 28 seconds.`,
  canonical: `https://www.limecall.com/lead-generation-for-web-designers/`,
};

const useCases = [
  { title: "Instant Callback on Project Inquiries", desc: "Prospective clients searching for a web designer often reach out to several studios in the same session. LimeCall connects you with the prospect in under 28 seconds, ensuring you're the first designer to have a real conversation." },
  { title: "Project Scoping & Discovery Call Booking", desc: "Capture discovery call requests from your portfolio site 24/7. Schedule them at a time that suits both parties so your calendar fills with qualified project opportunities, not cold outreach." },
  { title: "Client Onboarding Follow-Up", desc: "After a proposal is sent, prospects go quiet. Use LimeCall to trigger a personal callback offer after proposal delivery — a timely human touchpoint that pushes deals over the line." },
  { title: "Retainer & Maintenance Lead Capture", desc: "Monthly retainers and site maintenance agreements are high-value recurring revenue. Capture inbound interest from existing clients and warm leads with a seamless callback that feels personal, not transactional." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More projects won" },
  { value: "80%", label: "Reduction in missed leads" },
  { value: "5 min", label: "Setup time" },
];
---

<Base {...seo}>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `Lead Generation for Web Designers`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{icon}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Lead Generation for <span class="text-lime-400">Web Designers</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Win more web design projects by being the first to respond. Connect with project inquiries and discovery call requests in under 28 seconds.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Built for freelancers and web design studios</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Client views your portfolio", desc: "A prospective client browses your work and clicks the LimeCall widget to request a project discussion callback." },
          { step: "2", title: "You're connected instantly", desc: "LimeCall calls you and the prospect simultaneously, connecting you both in under 28 seconds." },
          { step: "3", title: "Project scoped & logged", desc: "The call is recorded and noted automatically. Follow-up reminders keep warm prospects moving through your pipeline." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to win more web design clients?</h2>
      <p class="mt-4 text-dark-400">Set up in 5 minutes. No credit card required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4">
    <CrossLinks heading="More LimeCall Solutions" links={[
      { href: '/lead-generation-for-digital-marketing-agencies/', title: 'Agency Lead Gen', desc: 'Lead gen tools built for digital agencies.' },
      { href: '/click-to-call-software/', title: 'Click to Call', desc: 'Instant callbacks from your website.' },
      { href: '/conversation-scheduling/', title: 'Schedule Callbacks', desc: 'Let clients book discovery calls at their convenience.' },
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
    ]} />
  </div>
</Base>
