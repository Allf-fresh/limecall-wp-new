---
import { site } from '../site.config';

const navLinks = site.nav;
const cta = site.cta;
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-dark-800 bg-dark-950/95 backdrop-blur-md">
  <nav aria-label="Main navigation" class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3.5 sm:px-6 lg:px-8">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 flex-shrink-0" aria-label={`${site.name} Home`}>
      <svg width="20" height="26" viewBox="0 0 22 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M3 9 L10 1 L10 21 L21 21 L21 27 L3 27 Z" fill="#a3e635"/>
      </svg>
      <span class="text-xl font-bold tracking-tight leading-none">
        <span class="text-lime-400">{site.name}</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden items-center gap-1 md:flex">
      {navLinks.map((item) => (
        <li class={item.children ? 'relative group' : ''}>
          {item.children ? (
            <>
              <button
                class:list={[
                  'flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:text-lime-400 hover:bg-dark-900',
                  item.href && currentPath.startsWith(item.href) ? 'text-lime-400' : 'text-dark-300',
                ]}
                aria-haspopup="true"
              >
                {item.label}
                <svg class="w-3 h-3 mt-px transition-transform duration-150 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="invisible absolute left-1/2 top-full z-50 -translate-x-1/2 pt-2 opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                <div class="w-64 rounded-xl border border-dark-800 bg-dark-950 p-2 shadow-2xl shadow-black/40">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'flex flex-col rounded-lg px-3 py-2.5 transition-colors',
                        currentPath.startsWith(child.href) ? 'bg-dark-900 text-lime-400' : 'hover:bg-dark-900',
                      ]}
                    >
                      <span class:list={['text-sm font-medium', currentPath.startsWith(child.href) ? 'text-lime-400' : 'text-white']}>{child.label}</span>
                      {child.desc && <span class="mt-0.5 text-xs text-dark-500">{child.desc}</span>}
                    </a>
                  ))}
                  {item.href && (
                    <div class="mt-1 border-t border-dark-800/60 pt-1">
                      <a href={item.href} class="flex items-center gap-1 rounded-lg px-3 py-2 text-xs font-medium text-dark-500 hover:text-lime-400 transition-colors">
                        View all {item.label.toLowerCase()} →
                      </a>
                    </div>
                  )}
                </div>
              </div>
            </>
          ) : (
            <a
              href={item.href}
              class:list={[
                'rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:text-lime-400 hover:bg-dark-900',
                item.href && (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))) ? 'text-lime-400' : 'text-dark-300',
              ]}
            >
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA group -->
    <div class="hidden items-center gap-3 md:flex">
      <a
        href={cta.login.href}
        class="text-sm font-medium text-dark-400 transition-colors hover:text-white"
      >
        {cta.login.text}
      </a>
      <a
        href={cta.href}
        class="rounded-lg bg-lime-500 px-4 py-2 text-sm font-bold text-dark-950 transition-colors hover:bg-lime-400"
      >
        {cta.text}
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-toggle"
      class="rounded-lg p-2 text-dark-400 hover:bg-dark-900 hover:text-white md:hidden transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-menu" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-dark-800 md:hidden">
    <div class="px-4 py-4 space-y-1">

      {navLinks.map((item) => (
        item.children ? (
          <div class="py-1">
            <p class="px-3 py-1.5 text-xs font-bold uppercase tracking-widest text-dark-500">{item.label}</p>
            {item.children.map((child) => (
              <a
                href={child.href}
                class:list={[
                  'block rounded-lg px-3 py-2 text-sm font-medium transition-colors',
                  currentPath.startsWith(child.href)
                    ? 'bg-dark-800 text-lime-400'
                    : 'text-dark-300 hover:bg-dark-900 hover:text-white',
                ]}
              >
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a
            href={item.href}
            class:list={[
              'block rounded-lg px-3 py-2.5 text-sm font-medium transition-colors',
              item.href && currentPath.startsWith(item.href) && item.href !== '/'
                ? 'bg-dark-800 text-lime-400'
                : 'text-dark-300 hover:bg-dark-900 hover:text-white',
            ]}
          >
            {item.label}
          </a>
        )
      ))}

      <!-- Mobile CTAs -->
      <div class="mt-3 flex flex-col gap-2 border-t border-dark-800 pt-4">
        <a
          href={cta.login.href}
          class="rounded-lg px-3 py-2.5 text-center text-sm font-medium text-dark-400 hover:bg-dark-900 hover:text-white transition-colors"
        >
          {cta.login.text}
        </a>
        <a
          href={cta.href}
          class="rounded-lg bg-lime-500 px-3 py-3 text-center text-sm font-bold text-dark-950 hover:bg-lime-400 transition-colors"
        >
          {cta.text}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconMenu  = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconMenu?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });

  // Keyboard accessibility for desktop dropdowns
  document.querySelectorAll<HTMLButtonElement>('[aria-haspopup="true"]').forEach((btn) => {
    const li = btn.closest('li');
    if (!li) return;
    btn.setAttribute('aria-expanded', 'false');

    li.addEventListener('focusin', () => btn.setAttribute('aria-expanded', 'true'));
    li.addEventListener('focusout', (e: FocusEvent) => {
      if (!li.contains(e.relatedTarget as Node)) btn.setAttribute('aria-expanded', 'false');
    });
    li.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') { btn.setAttribute('aria-expanded', 'false'); btn.focus(); }
    });
  });
</script>
