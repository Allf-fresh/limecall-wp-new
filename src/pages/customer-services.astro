---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Customer Services Software — Faster Help, Higher Satisfaction | LimeCall`,
  description: `Resolve customer service issues faster with LimeCall. Multi-channel service callbacks, SLA timer, skills-based routing, 90% CSAT, 80% first-call resolution.`,
  canonical: `https://www.limecall.com/customer-services/`,
};

const stats = [
  { value: "90%", label: "CSAT improvement" },
  { value: "28s", label: "Average callback time" },
  { value: "4.5★", label: "Average post-call rating" },
  { value: "80%", label: "First-call resolution rate" },
];

const features = [
  { title: "Multi-channel service requests", desc: "Accept service requests via phone callback, SMS, WhatsApp, or web form. All routed through the same platform and queued in priority order." },
  { title: "SLA callback timer", desc: "Set SLA response time targets per service tier. LimeCall alerts your team when a callback SLA is approaching and auto-escalates breaches." },
  { title: "Skills-based routing", desc: "Route service requests to the agent with the right skills for the issue — billing queries to billing specialists, technical issues to engineers." },
  { title: "Recorded calls for compliance", desc: "Every customer service interaction is recorded and stored securely. Replay calls for dispute resolution, quality assurance, and regulatory compliance." },
  { title: "Shared service inbox", desc: "All service requests — calls, callbacks, messages, and tickets — in one shared inbox. No issue falls through the cracks between channels or team members." },
  { title: "Post-call CSAT", desc: "Automatically send a CSAT survey after every service call. Capture satisfaction scores and feedback in real time, tied to the agent and call record." },
];

const useCases = [
  { title: "Inbound service requests", desc: "Customers with service needs request a callback and are connected to the right agent in 28 seconds — no hold queue, no frustration." },
  { title: "Warranty claims", desc: "Warranty and product issue calls require specialist knowledge. LimeCall routes to the right team instantly and logs every interaction for compliance." },
  { title: "Technical support", desc: "Complex technical issues get routed to engineers with the right expertise. Full call recording ensures knowledge is captured for future training." },
  { title: "Billing inquiries", desc: "Sensitive billing queries are handled by dedicated billing agents. SLA timers ensure no billing dispute waits longer than your service standards allow." },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is customer services software?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Customer services software helps businesses handle inbound service requests across multiple channels — phone, SMS, web, and chat. LimeCall specialises in callback-driven service delivery, connecting customers to the right agent in 28 seconds with skills-based routing, SLA tracking, and full call recording.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does skills-based routing improve service quality?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Skills-based routing ensures every service request reaches the agent best equipped to resolve it on the first contact. A billing dispute goes to a billing specialist. A technical fault goes to an engineer. This reduces transfers, lowers handle time, and dramatically improves first-call resolution rates.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is an SLA callback timer and how does it work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'An SLA callback timer tracks the time between a service request and the callback being made. LimeCall lets you set SLA targets per customer tier or issue type. If a callback is approaching its SLA deadline without being answered, the system escalates to a supervisor and alerts the team — ensuring no SLA is breached without action.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall support multi-channel service requests?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall consolidates service requests from phone callbacks, SMS, WhatsApp, and web forms into a single shared service inbox. Every request is tracked, prioritised, and assigned — regardless of which channel the customer used to reach out.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does post-call CSAT collection work in LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'After every service call, LimeCall automatically sends a CSAT survey to the customer via SMS or email. The survey is sent within minutes of call completion. Scores and feedback are captured in the LimeCall dashboard and tied to the agent, call recording, and customer record for full context.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Customer Services Software', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Customer Services
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Faster help, higher satisfaction —<br class="hidden sm:block" />
        <span class="text-lime-400">built for service teams</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        LimeCall gives your service team skills-based routing, SLA callback timers, multi-channel request management, and post-call CSAT — all in one platform. 90% CSAT improvement, 80% first-call resolution.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free Trial →</a>
        <a href="/customer-support-software/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">Support Software</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Customer services tools that resolve issues fast</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Customer services use cases</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 font-semibold text-white">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { n: "1", title: "Service request comes in", desc: "Customer submits a request via callback widget, SMS, WhatsApp, or web form. SLA timer starts immediately." },
          { n: "2", title: "Skills-based routing fires", desc: "LimeCall matches the request to the best-skilled available agent and connects them within 28 seconds." },
          { n: "3", title: "Issue resolved, CSAT captured", desc: "Agent resolves the issue with full CRM context. Call is recorded and a post-call CSAT survey fires automatically." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(q => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <summary class="cursor-pointer font-semibold text-white">{q.name}</summary>
            <p class="mt-3 text-sm text-dark-400 leading-relaxed">{q.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Resolve issues faster — start today</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free Trial →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related resources" links={[
        { href: '/customer-support-software/', title: 'Customer Support Software', desc: 'Full support platform for your team.' },
        { href: '/customer-care/', title: 'Customer Care Software', desc: 'Deliver a more personal customer care experience.' },
        { href: '/inbound-call-center-software/', title: 'Inbound Call Centre Software', desc: 'Handle high volumes of inbound calls efficiently.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
