---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import { site, features } from '../../site.config';
---

<Base
  title="Features - LimeCall"
  description="LimeCall features — it's all about making your business goals a reality. Grow sales through real-time customer conversations. Click2Call, Lead Distribution, Virtual Numbers, and more."
  canonical="https://www.limecall.com/features"
>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Features', url: `${site.url}/features` }]} />

      <div class="max-w-3xl mb-12">
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">
          Everything in <span class="text-lime-400">{site.name}</span>
        </h1>
        <p class="mt-4 text-lg text-dark-300">
          Powerful tools for converting website visitors into sales calls. Click2Call, Lead Distribution, Schedule Callbacks, Virtual Numbers, Web to Text — and more.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((feature) => (
          <FeatureCard
            icon={feature.icon}
            name={feature.name}
            description={feature.description}
            href={`/features/${feature.slug}`}
          />
        ))}
      </div>

      <div class="mt-16 rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-500/10 to-dark-900 p-8 md:p-12 text-center">
        <h2 class="text-2xl font-bold text-white mb-3">Ready to get started?</h2>
        <p class="text-dark-300 mb-6">{site.cta.subtext}</p>
        <a href={site.cta.href} class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg bg-lime-500 hover:bg-lime-400 text-dark-950 font-bold transition">
          {site.cta.text}
        </a>
      </div>
    </div>
  </section>
</Base>
