---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Personal CRM for Sales Professionals | LimeCall`,
  description: `Track every prospect, call, and follow-up in one place. LimeCall auto-logs every call, records conversations, and keeps your pipeline current. 5 min setup.`,
  canonical: `https://www.limecall.com/personal-crm-for-sales-professionals/`,
};

const stats = [
  { value: "3x", label: "More deals with consistent follow-up" },
  { value: "100%", label: "Call logging — automatic" },
  { value: "28s", label: "To first contact" },
  { value: "5 min", label: "Setup time" },
];

const features = [
  { title: "Auto-call logging", desc: "Every inbound and outbound call is automatically logged — with duration, timestamp, and call recording. Zero manual entry." },
  { title: "Contact timeline", desc: "See the full history of every prospect in one view. Every call, every note, every follow-up — from first touch to closed deal." },
  { title: "Follow-up reminders", desc: "Set reminders directly from a call. Never let a warm prospect go cold because you forgot to follow up." },
  { title: "Call recording per contact", desc: "Every call recording is stored against the contact record. Review what was said before your next call — never ask the same question twice." },
  { title: "Pipeline tracking", desc: "Move deals through your personal pipeline stages. See at a glance what needs attention, what's stalled, and what's close to closing." },
  { title: "Notes sync", desc: "Add notes during or after calls. Synced across your devices and your CRM — so your notes are always where you need them." },
];

const useCases = [
  { title: "Prospect management", desc: "Keep every prospect organised with a full timeline of interactions. Know exactly where each conversation left off." },
  { title: "Customer relationship tracking", desc: "Track existing customer relationships with the same precision as new prospects. Renewals, upsells, and referrals all start with great records." },
  { title: "Deal follow-up", desc: "See which deals are overdue for a follow-up call and act immediately — from a single dashboard view." },
  { title: "Rep performance review", desc: "Managers can review individual rep activity — calls made, recordings reviewed, deals progressed — to coach more effectively." },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is a personal CRM?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A personal CRM is a tool that helps individual sales professionals track their own contacts, calls, and follow-ups — separate from (or alongside) a shared team CRM. It gives you a private, organised view of your pipeline so nothing slips through the cracks.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is a personal CRM different from a team CRM?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A team CRM (like Salesforce or HubSpot) is shared across the whole organisation. A personal CRM is focused on the individual rep — giving them a lightweight, private tool to manage their own relationships and activity without depending on the company-wide system.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall work as a personal CRM?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall auto-logs every call you make or receive, stores recordings against each contact, and gives you a full timeline per prospect. It works standalone as a lightweight personal CRM, or alongside your team\'s CRM with automatic sync.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I track all my calls in one place?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall captures 100% of calls — inbound and outbound — and logs them automatically. You get a complete call history per contact, with recordings, duration, and notes, all in one timeline view.',
      },
    },
    {
      '@type': 'Question',
      name: 'What sales professionals use personal CRMs?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Independent consultants, real estate agents, financial advisors, account executives, and anyone who manages their own book of business benefit from a personal CRM. It is especially valuable when you need more control and visibility than a shared team system provides.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Personal CRM for Sales Professionals', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Sales Professionals
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Track every prospect, call,<br class="hidden sm:block" />
        <span class="text-lime-400">and follow-up in one place</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        LimeCall auto-logs every call, stores recordings per contact, and keeps your personal pipeline current — so you can close 3x more deals with consistent follow-up.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Start Free Trial →</a>
        <a href="/for-sales-teams/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">For Sales Teams</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Everything a sales pro needs to stay organised</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How sales professionals use LimeCall</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 font-semibold text-white">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { n: "1", title: "Lead calls or you call them", desc: "Whether a prospect requests a callback or you dial out, LimeCall handles the connection automatically." },
          { n: "2", title: "Call auto-logged with details", desc: "LimeCall captures the call, records it, and saves everything — caller, duration, page of origin — against the contact record." },
          { n: "3", title: "Full timeline in CRM", desc: "Your contact record now has a complete timeline: every call, every recording, every note — ready for your next interaction." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(q => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <summary class="cursor-pointer font-semibold text-white">{q.name}</summary>
            <p class="mt-3 text-sm text-dark-400 leading-relaxed">{q.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Never lose a follow-up again</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free Trial →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related resources" links={[
        { href: '/for-sales-teams/', title: 'For Sales Teams', desc: 'LimeCall for the whole sales team.' },
        { href: '/lead-management-system/', title: 'Lead Management System', desc: 'Manage your entire lead pipeline.' },
        { href: '/call-tracking/', title: 'Call Tracking', desc: 'Track every call back to its source.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
