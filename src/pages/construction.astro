---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Callback Software for Construction Companies | LimeCall',
  description: 'Never miss a site inquiry. LimeCall connects construction leads with your team in 28 seconds — from tender requests to subcontractor calls.',
  canonical: 'https://www.limecall.com/construction/',
};

const stats = [
  { value: '67%', label: 'Of construction calls missed during active site hours' },
  { value: '28s', label: 'LimeCall callback connection vs hours of missed calls' },
  { value: '3.2×', label: 'More tenders won with instant lead response' },
  { value: '£2.8M', label: 'Pipeline captured by one UK firm in 90 days' },
];

const features = [
  { icon: '📋', title: 'Tender & Bid Inquiry Callback', desc: 'When a potential client submits a tender inquiry on your website, LimeCall instantly connects them to your estimating team — before they send the same RFQ to three competitors.' },
  { icon: '👷', title: 'Site Manager Direct-Dial Routing', desc: 'Route urgent site calls directly to the relevant site manager by project, postcode, or division. No more calls lost in a central switchboard while teams are on-site.' },
  { icon: '🔧', title: 'Subcontractor Coordination Callbacks', desc: 'Schedule and manage callback queues for subcontractor check-ins, RFI responses, and procurement queries — keeping every trade coordinated without constant phone tag.' },
  { icon: '💬', title: 'WhatsApp for Site Photos & Documents', desc: 'After the call, automatically trigger a WhatsApp message so clients and subcontractors can share site photos, drawings, and snag lists without email delays.' },
  { icon: '🔗', title: 'CRM Sync — BuilderTrend & CoConstruct', desc: 'Every callback automatically logged in BuilderTrend, CoConstruct, or your CRM of choice — lead name, number, project type, and call outcome captured without manual data entry.' },
  { icon: '🌙', title: 'Out-of-Hours Emergency Routing', desc: "Construction emergencies don't respect office hours. Configure after-hours routing to an on-call manager or emergency response team, with full call recording for audit trails." },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall work when site teams are offline or out of mobile range?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "LimeCall queues all incoming callback requests when teams are unavailable. When a site manager or estimator returns to connectivity, they see a prioritised list of callbacks with the caller's name, number, and inquiry details. You can also configure fallback routing to an office number, a different team member, or an emergency line — ensuring no tender or client inquiry goes unanswered.",
      },
    },
    {
      '@type': 'Question',
      name: 'Which CRM and project management platforms does LimeCall integrate with?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall integrates natively with BuilderTrend, CoConstruct, Salesforce, and HubSpot. It also connects to 1,000+ tools via Zapier, including Procore, Builderpad, and most project management platforms. Every callback is automatically logged with caller details, project type, call duration, and outcome notes — eliminating manual data entry for your estimating and project teams.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can we use WhatsApp to share site photos and drawings with clients?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. After every callback, LimeCall can automatically send a WhatsApp message to the caller, enabling clients and subcontractors to share site photos, architectural drawings, snag lists, and compliance documents in seconds. This replaces slow email chains and keeps project communication centralised in a single thread per contact.',
      },
    },
    {
      '@type': 'Question',
      name: 'How quickly can a construction company go live with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most construction businesses are live in under 5 minutes. Add the LimeCall widget to your website or tender inquiry page, configure routing to your estimating team or site managers, and the system is active immediately. No developer or IT team is required. We provide full onboarding support, including routing configuration for multiple divisions or project types.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall route calls differently for residential vs. commercial construction projects?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall supports intelligent lead routing based on the page visited, project type selected, or custom form fields. Residential inquiries can be routed to your domestic team while commercial or infrastructure leads go directly to your senior estimators. You can also route by geography, postcode, or project value to match your business structure.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall record calls for compliance and audit purposes?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. All calls handled through LimeCall are automatically recorded and stored with configurable retention periods. For construction firms dealing with tender disputes, health and safety inquiries, or contract negotiations, having a full audio and timestamp record is invaluable. Recordings are encrypted at rest and in transit, and a full audit trail is available on demand.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does LimeCall cost for construction businesses?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall plans start from $35/month. For construction companies where a single won tender can be worth tens of thousands of pounds, the ROI is realised in the first additional lead conversion. A 14-day free trial is available with no credit card required, and full onboarding support is included.',
      },
    },
  ],
};

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'LimeCall for Construction Companies',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web, iOS, Android',
  description: 'Callback software for construction companies. Connects tender inquiries, site managers, and subcontractors in 28 seconds. BuilderTrend and CoConstruct CRM integration.',
  url: 'https://www.limecall.com/construction/',
  offers: {
    '@type': 'Offer',
    price: '35',
    priceCurrency: 'USD',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: '35',
      priceCurrency: 'USD',
      unitText: 'MONTH',
    },
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '124',
    bestRating: '5',
  },
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={softwareAppSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumbs items={[{ name: 'Construction', url: `${site.url}/construction/` }]} />
      <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400">
        🏗️ For Construction Companies & Contractors
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Callback Software for Construction Companies<br class="hidden sm:block" />
        <span class="text-lime-400">— Win More Tenders in 28 Seconds</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300">
        Construction companies miss 67% of calls during site hours. Every missed tender inquiry is a lost contract. LimeCall connects your leads to the right team member in 28 seconds — whether they're in the office or on-site.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center justify-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free Trial — 14 Days
        </a>
        <a href="/demo/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-dark-700 px-8 py-4 text-sm font-semibold text-white transition hover:border-lime-500/40 hover:text-lime-400">
          Book a Demo →
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">★ BuilderTrend & CoConstruct Integration · Trusted by contractors in 40+ countries · No setup fee</p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-dark-800 bg-dark-900/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <dt class="text-3xl font-extrabold text-lime-400">{s.value}</dt>
            <dd class="mt-1 text-sm text-dark-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Problem callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-red-500/20 bg-red-500/5 p-8">
        <h2 class="text-xl font-bold text-white mb-3">⚠️ Construction Leads Don't Wait for Callbacks</h2>
        <p class="text-dark-300">
          A facilities manager submitted a tender inquiry for a £400,000 refurbishment at 10am on a Tuesday. Your site team was unavailable. By 2pm, a competitor had already called, scoped the project, and booked a site visit. Construction is one of the most competitive industries for lead response — procurement managers send the same RFQ to multiple contractors simultaneously. The firm that responds first controls the conversation.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">How LimeCall Works for Construction Companies</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: '01', title: 'Prospect Visits Your Tender or Contact Page', desc: 'LimeCall widget appears on your tender inquiry, project quotation, or contact pages — capturing leads at peak intent before they move to the next contractor on their list.' },
          { step: '02', title: 'Lead Requests Instant Callback', desc: 'Prospect enters their number and project type. LimeCall routes to the right estimator, site manager, or division — residential, commercial, or infrastructure — in seconds.' },
          { step: '03', title: 'Connected to Your Team in 28 Seconds', desc: 'Your estimator speaks to the prospect while they are still engaged, scopes the project on the call, and books a site visit — before the prospect emails three more contractors.' },
        ].map(item => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-lg">{item.step}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-dark-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">Built for Construction Companies & Contractors</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-dark-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Construction Use Cases</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'Tender & Bid Inquiries', desc: 'Procurement manager submits RFQ → estimating team connected in 28s → project scoped and site visit booked before competitors respond.' },
          { title: 'Subcontractor Onboarding', desc: 'New subcontractor submits interest form → trade coordinator callback → procurement check completed on the call with full recording.' },
          { title: 'Emergency Site Issues', desc: 'After-hours site emergency → on-call manager connected instantly → issue triaged and response team dispatched with call audit trail.' },
          { title: 'Client Progress Updates', desc: 'Client portal or update request page → project manager callback → client briefed and decision accelerated without email chains.' },
        ].map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="font-bold text-white mb-2">{u.title}</h3>
            <p class="text-sm text-dark-400">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case study / testimonial -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <blockquote class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-10 text-center">
        <p class="text-xl text-white italic leading-relaxed">
          "We were missing tender inquiries every day because our estimators were on-site. LimeCall connected those leads to whoever was available, and we saw a 47% increase in tender conversions within 90 days. We've captured £2.8M in new pipeline that would otherwise have gone to competitors."
        </p>
        <footer class="mt-6">
          <p class="font-bold text-lime-400">Managing Director</p>
          <p class="text-sm text-dark-500">Commercial construction firm, United Kingdom</p>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">LimeCall vs. Other Construction Lead Contact Methods</h2>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              {['Feature', 'LimeCall', 'Phone Only', 'Email Follow-Up', 'Contact Form'].map(h => (
                <th class={`px-5 py-4 text-left font-semibold ${h === 'LimeCall' ? 'text-lime-400' : 'text-dark-300'}`}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['Response time', '28 seconds', 'Rep availability', '2–24 hours', '24–72 hours'],
              ['Works during site hours', '✅ Always on', '❌ Often missed', '✅ Received but slow', '✅ Received but slow'],
              ['After-hours lead capture', '✅ Queue + AM callback', '❌ Missed', '✅ Email stored', '✅ Stored, slow response'],
              ['CRM auto-logging', '✅ Every call', '⚠️ Manual entry', '⚠️ Partial', '❌ Manual'],
              ['WhatsApp integration', '✅ Post-call trigger', '❌ Not available', '❌ Not available', '❌ Not available'],
              ['Tender conversion rate', '🟢 3.2× improvement', '🟡 Baseline', '🔴 Low (slow)', '🔴 Very low'],
            ].map(([feature, ...vals]) => (
              <tr class="hover:bg-dark-800/30 transition">
                <td class="px-5 py-4 font-medium text-dark-200">{feature}</td>
                {vals.map((v, i) => (
                  <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Integration callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-dark-700 bg-dark-900/60 p-8 sm:p-10 flex flex-col sm:flex-row items-center gap-8">
        <div class="shrink-0 text-5xl">🔗</div>
        <div>
          <h2 class="text-xl font-bold text-white mb-2">Integrates with BuilderTrend, CoConstruct & More</h2>
          <p class="text-dark-400 text-sm leading-relaxed">
            LimeCall connects directly to BuilderTrend, CoConstruct, Salesforce, HubSpot, and 1,000+ tools via Zapier. Every callback is automatically logged — lead name, number, project type, call duration, and outcome notes — keeping your CRM current without manual data entry. Setup takes under 5 minutes with no developer required.
          </p>
          <a href="/integrations/" class="mt-4 inline-flex items-center text-sm font-semibold text-lime-400 hover:text-lime-300 transition">
            View all integrations →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust signals -->
  <section class="py-16 sm:py-20 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-10">Why Construction Companies Trust LimeCall</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          { icon: '📞', title: '28-Second Connection', desc: 'From lead request to live conversation in 28 seconds. By the time competitors read an email notification, your estimator is already on the call scoping the project.' },
          { icon: '📍', title: 'Virtual Numbers for Regional Presence', desc: 'Use local virtual numbers for each region or division, so prospects see a familiar area code — improving answer rates for outbound callbacks from your team.' },
          { icon: '🔒', title: 'Recorded & Compliant', desc: 'Every call recorded and stored with configurable retention. Invaluable for tender dispute resolution, H&S compliance, and contract negotiations with full audit trails.' },
        ].map(item => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 text-center">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-dark-400">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-dark-500">
        Trusted by construction companies and contractors across 40+ countries. <a href="/case-studies/" class="text-lime-400 hover:text-lime-300 transition">Read customer case studies →</a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {item.name}
              <span class="ml-4 shrink-0 text-lime-400 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-gradient-to-br from-lime-500/10 to-dark-900 border-t border-lime-500/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Stop Losing Tenders to Faster Competitors</h2>
      <p class="mt-4 text-lg text-dark-300">14-day free trial · BuilderTrend & CoConstruct integration · No setup fee</p>
      <a href="/signup" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-lime-500 px-10 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
        Try Free — 14 Days →
      </a>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime · Full onboarding support included</p>
    </div>
  </section>

  <!-- Cross-links -->
  <div class="py-12 bg-dark-950 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore More" links={[
        { href: '/virtual-business-numbers/', title: 'Virtual Business Numbers', desc: 'Local numbers for every office or region.' },
        { href: '/click-to-whatsapp/', title: 'Click-to-WhatsApp', desc: 'Share site photos and documents instantly.' },
        { href: '/lead-routing-software/', title: 'Lead Routing Software', desc: 'Route tender inquiries to the right team.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Plans from $35/month.' },
      ]} />
    </div>
  </div>
</Base>
