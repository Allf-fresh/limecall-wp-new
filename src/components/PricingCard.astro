---
interface Props {
  plan: {
    name: string;
    subtitle: string;
    monthly: number;
    annual: number;
    features: string[];
    notIncluded?: string[];
    cta: { text: string; href: string };
    highlighted: boolean;
  };
  billing: 'monthly' | 'annual';
}
const { plan, billing } = Astro.props;
const price = billing === 'annual' ? plan.annual : plan.monthly;
---
<div class:list={[
  'rounded-2xl border p-8 flex flex-col',
  plan.highlighted
    ? 'border-lime-500 bg-dark-900'
    : 'border-dark-800 bg-dark-900/50'
]}>
  {plan.highlighted && (
    <div class="mb-4 inline-flex items-center gap-1.5 rounded-full bg-lime-500/15 px-3 py-1 text-xs font-semibold text-lime-400 w-fit">
      Most Popular
    </div>
  )}
  <h3 class="text-xl font-bold text-white">{plan.name}</h3>
  <p class="mt-1 text-sm text-dark-400">{plan.subtitle}</p>
  <div class="mt-6 flex items-baseline gap-1">
    <span class="text-4xl font-bold text-white">${price}</span>
    <span class="text-dark-400">/mo</span>
  </div>
  <ul class="mt-8 space-y-3 flex-1">
    {plan.features.map(f => (
      <li class="flex items-start gap-2.5 text-sm text-dark-300">
        <span class="mt-0.5 text-lime-400">&#10003;</span>
        {f}
      </li>
    ))}
    {plan.notIncluded?.map(f => (
      <li class="flex items-start gap-2.5 text-sm text-dark-600 line-through">
        <span class="mt-0.5">&#10007;</span>
        {f}
      </li>
    ))}
  </ul>
  <a
    href={plan.cta.href}
    class:list={[
      'mt-8 block rounded-xl py-3 text-center text-sm font-bold transition-colors',
      plan.highlighted
        ? 'bg-lime-500 text-dark-950 hover:bg-lime-400'
        : 'bg-dark-800 text-white hover:bg-dark-700'
    ]}
  >
    {plan.cta.text}
  </a>
</div>
