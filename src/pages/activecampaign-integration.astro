---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const crm = "ActiveCampaign";
const slug = "activecampaign-integration";

const seo = {
  title: 'LimeCall + ActiveCampaign Integration | LimeCall',
  description: 'Connect LimeCall callbacks to ActiveCampaign in minutes. Auto-add contacts, trigger automations on call outcome, sync tags, and track which campaigns drove each call.',
  canonical: 'https://www.limecall.com/activecampaign-integration/',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall integrate with ActiveCampaign?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall connects to ActiveCampaign via a native integration available in your LimeCall dashboard. Authorise the connection with your ActiveCampaign API key and URL, then configure which automations, lists, and tags LimeCall should trigger. Every callback outcome — answered, missed, demo booked — fires the corresponding ActiveCampaign automation automatically without any developer work.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall add contacts to ActiveCampaign lists automatically?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. When a website visitor requests a LimeCall callback, their phone number, name, and any captured form fields are automatically added to your chosen ActiveCampaign list. If a contact already exists in ActiveCampaign, LimeCall updates the record and logs the call event rather than creating a duplicate. You can route contacts to different lists based on the widget they used or the page they called from.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I trigger ActiveCampaign automations based on call outcome?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall call outcomes — such as "demo booked", "not interested", "follow-up required", or "voicemail" — can each trigger a different ActiveCampaign automation. For example, a "demo booked" outcome can instantly enrol the contact in a pre-demo nurture sequence, while a "not interested" outcome can add a suppression tag to pause further email outreach. Each outcome maps to an automation you define in ActiveCampaign.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall sync call tags to ActiveCampaign contact records?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Any tag applied to a call in LimeCall — such as the agent name, call outcome, product discussed, or callback widget source — can be synced directly to the corresponding ActiveCampaign contact record as an ActiveCampaign tag. This enables you to segment your ActiveCampaign lists by call history and personalise email follow-ups based on what was discussed on the call.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I use ActiveCampaign deal stages to prioritise LimeCall callbacks?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall can read ActiveCampaign deal pipeline data to prioritise your callback queue. Contacts in high-value deal stages — such as "Proposal Sent" or "Negotiation" — can be surfaced to agents first via LimeCall\'s priority routing. This ensures your team calls back the warmest leads fastest, directly improving pipeline velocity.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is the ActiveCampaign integration available on all LimeCall plans?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The ActiveCampaign integration is available on the LimeCall Pro plan and above, which includes 500 calls per month, custom integrations, and full API access. You can start a free trial of the Pro plan to test the integration before committing. The Starter plan includes basic Zapier connectivity for ActiveCampaign if you prefer a Zapier-based approach.',
      },
    },
  ],
};

const stats = [
  { value: "28s", label: "Average callback speed" },
  { value: "5 min", label: "Setup time — no developer" },
  { value: "6,000+", label: "ActiveCampaign automations triggered" },
  { value: "500", label: "Calls/mo on Pro plan" },
];

const features = [
  {
    title: "Auto-add contacts to ActiveCampaign lists",
    desc: "Every LimeCall callback request automatically adds the caller to your chosen ActiveCampaign list — name, phone, email, and the page they called from. No manual data entry, no missed contacts.",
  },
  {
    title: "Trigger automations on call outcome",
    desc: "Map each LimeCall outcome — demo booked, not interested, follow-up required — to a different ActiveCampaign automation. A 'demo booked' call instantly starts a pre-demo nurture sequence without any manual steps.",
  },
  {
    title: "Sync call tags to contact records",
    desc: "Tags applied in LimeCall — agent name, product, call disposition, widget source — sync directly to ActiveCampaign contact records, enabling precise list segmentation and personalised email campaigns.",
  },
  {
    title: "Use deal stages to prioritise callback queue",
    desc: "Pull ActiveCampaign deal stage data into LimeCall's callback queue. Contacts in high-value pipeline stages are surfaced to agents first, ensuring your hottest opportunities are never left waiting.",
  },
  {
    title: "Track campaign attribution for each callback",
    desc: "UTM parameters from the page where the callback was requested sync to ActiveCampaign as contact fields. See exactly which campaign, medium, and source drove each phone lead — no guesswork.",
  },
  {
    title: "Personalise email sequences with call outcome data",
    desc: "Use call outcome tags in ActiveCampaign to branch email automation paths. A caller who requested a product demo receives different follow-ups than one who asked about pricing — automatically.",
  },
];

const useCases = [
  {
    role: "Marketing Automation",
    title: "Call outcome enters the right nurture track",
    desc: "When a LimeCall callback ends with 'demo booked', ActiveCampaign instantly enrols the contact in a pre-demo sequence with confirmation emails, calendar invites, and preparation content — all triggered by the call outcome, zero manual steps.",
  },
  {
    role: "Sales Teams",
    title: "Priority callbacks for hot pipeline deals",
    desc: "Contacts in ActiveCampaign deal stages 'Proposal Sent' or 'Negotiation' are automatically surfaced at the top of the LimeCall callback queue. Your reps always call back the highest-value prospects first.",
  },
  {
    role: "Lead Nurturing",
    title: "Segment email lists by call history",
    desc: "Tag contacts in ActiveCampaign with their LimeCall call history — number of callbacks, last call outcome, products discussed. Build hyper-targeted email segments based on real phone conversations, not just web behaviour.",
  },
  {
    role: "Attribution Reporting",
    title: "Trace callbacks to the campaign that drove them",
    desc: "Every LimeCall callback captures the UTM source, medium, campaign, and keyword from the referring page. These sync to ActiveCampaign contact fields, giving marketing full visibility into which campaigns generate phone leads.",
  },
];

const comparisonRows = [
  { feature: "Auto-add contacts to lists", limecall: true, manual: false, others: "Partial" },
  { feature: "Trigger automations on call outcome", limecall: true, manual: false, others: false },
  { feature: "Sync call tags to contacts", limecall: true, manual: false, others: false },
  { feature: "Campaign attribution sync", limecall: true, manual: false, others: "Partial" },
  { feature: "Deal stage priority routing", limecall: true, manual: false, others: false },
  { feature: "5-minute setup", limecall: true, manual: "N/A", others: false },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Integrations', url: 'https://www.limecall.com/integrations/' },
        { name: crm, url: seo.canonical },
      ]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Native Integration · 5-minute setup · No developers
      </div>
      <h1 class="mt-5 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall + <span class="text-lime-400">ActiveCampaign</span>:<br class="hidden sm:block" />
        Turn Every Callback into an Automation
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Connect LimeCall callbacks to ActiveCampaign in minutes. Auto-add contacts to lists, trigger nurture automations on call outcome, and track which campaigns drove every phone lead.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Connect ActiveCampaign Free →
        </a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          Watch Demo
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Data flow diagram -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">How a callback flows into ActiveCampaign</h2>
      <p class="mb-12 text-center text-dark-400 text-sm max-w-2xl mx-auto">
        From the moment a visitor clicks your widget to the automation firing in ActiveCampaign — every step is automatic.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-0">
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">1</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Visitor requests callback</h3>
          <p class="mt-1 text-xs text-dark-400">Clicks LimeCall widget on your website</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">2</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Call connected</h3>
          <p class="mt-1 text-xs text-dark-400">LimeCall bridges visitor and rep in 28 seconds</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">3</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Outcome tagged</h3>
          <p class="mt-1 text-xs text-dark-400">Rep marks outcome: demo booked, follow-up, etc.</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[180px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">4</div>
          <h3 class="mt-3 text-sm font-semibold text-white">ActiveCampaign fires</h3>
          <p class="mt-1 text-xs text-dark-400">Contact added, tags synced, automation triggered</p>
        </div>
      </div>

      <!-- Setup steps -->
      <div class="mt-14 grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 1</div>
          <h3 class="mb-2 font-semibold text-white">Connect with your API key</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Go to LimeCall → Integrations → ActiveCampaign. Enter your ActiveCampaign API URL and key. The connection verifies instantly — under 2 minutes.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 2</div>
          <h3 class="mb-2 font-semibold text-white">Map outcomes to automations</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Choose which LimeCall call outcome triggers which ActiveCampaign automation. Map tags, lists, and deal stage updates to each outcome in the visual mapper.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 3</div>
          <h3 class="mb-2 font-semibold text-white">Go live and verify</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Enable the integration and make a test callback. Your ActiveCampaign contact will appear and the automation will fire within seconds. You're done.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Everything the LimeCall + ActiveCampaign integration does</h2>
      <p class="mb-10 text-center text-dark-400 text-sm">Six capabilities that connect your phone channel to your marketing automation stack.</p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f, i) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 hover:border-lime-500/30 transition">
            <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-lg bg-lime-500/15 text-sm font-extrabold text-lime-400">{i + 1}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Who uses LimeCall + ActiveCampaign and how</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-2 inline-block rounded-full bg-lime-500/15 px-3 py-1 text-xs font-bold text-lime-400">{uc.role}</div>
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">LimeCall + ActiveCampaign vs the alternatives</h2>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="py-4 px-5 text-left font-semibold text-dark-300">Feature</th>
              <th class="py-4 px-5 text-center font-semibold text-lime-400">LimeCall + ActiveCampaign</th>
              <th class="py-4 px-5 text-center font-semibold text-dark-400">Manual logging</th>
              <th class="py-4 px-5 text-center font-semibold text-dark-400">Other callback tools</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800/50 ${i % 2 === 0 ? 'bg-dark-950/40' : 'bg-dark-900/20'}`}>
                <td class="py-3 px-5 text-dark-300">{row.feature}</td>
                <td class="py-3 px-5 text-center">
                  {row.limecall === true
                    ? <span class="text-lime-400 font-bold">Yes</span>
                    : <span class="text-dark-500">{row.limecall}</span>}
                </td>
                <td class="py-3 px-5 text-center">
                  {row.manual === false
                    ? <span class="text-dark-600">No</span>
                    : <span class="text-dark-400">{row.manual}</span>}
                </td>
                <td class="py-3 px-5 text-center">
                  {row.others === false
                    ? <span class="text-dark-600">No</span>
                    : <span class="text-dark-400">{row.others}</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 group">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between">
              {item.name}
              <span class="ml-4 text-lime-400 text-xl leading-none group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to connect LimeCall with ActiveCampaign?</h2>
      <p class="mt-4 text-dark-400">5-minute setup · No developers · Free trial included</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free →
        </a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-10 py-4 font-bold text-white hover:border-lime-500/40 transition">
          Book a Demo
        </a>
      </div>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="More Integrations" links={[
        { href: '/salesforce-integration/', title: 'LimeCall + Salesforce', desc: 'Auto-create Leads and log call Activities in Salesforce.' },
        { href: '/zapier-integration/', title: 'LimeCall + Zapier', desc: 'Connect LimeCall to 6,000+ apps with Zapier.' },
        { href: '/limecall-for-hubspot/', title: 'LimeCall + HubSpot', desc: 'Log every call in HubSpot automatically.' },
        { href: '/google-ads-integration/', title: 'LimeCall + Google Ads', desc: 'Track which campaigns drive callback requests.' },
        { href: '/integrations/', title: 'All Integrations', desc: 'See every tool LimeCall connects with.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple plans that include CRM integrations.' },
      ]} />
    </div>
  </div>
</Base>
