---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const seo = {
  title: `Lead Qualification Software | LimeCall`,
  description: `Qualify inbound leads automatically with LimeCall. Route calls to the right place, score leads in real time, and ensure your sales team only talks to ready-to-buy prospects.`,
  canonical: `https://www.limecall.com/lead-qualification/`,
};

const features = [
  { title: "IVR-Based Qualification", desc: "Use automated IVR menus to ask leads qualifying questions before connecting them to a rep. Filter out unqualified callers automatically." },
  { title: "Web Form Scoring", desc: "Score leads based on their form inputs — company size, budget, timeline — and route high-value leads first." },
  { title: "Behavioral Signals", desc: "Identify high-intent leads based on pages visited, time on site, and content engaged with. Prioritize accordingly." },
  { title: "Real-Time Lead Scoring", desc: "Assign a lead score the moment a visitor converts. Your team always knows which leads to call first." },
  { title: "Instant Routing by Score", desc: "Route high-score leads to senior reps immediately. Lower-scored leads can go to a nurture sequence." },
  { title: "Qualification Analytics", desc: "Track qual rates by source, channel, and campaign. Understand where your best leads come from." },
];

const steps = [
  { n: "1", title: "Define your ideal lead", desc: "Set the criteria that make a lead qualified — company size, budget, role, intent, and more." },
  { n: "2", title: "Score automatically", desc: "LimeCall scores every inbound lead in real time based on your criteria. No manual review needed." },
  { n: "3", title: "Route to close", desc: "Qualified leads go directly to your best reps. Unqualified leads go to nurture — automatically." },
];
---

<Base {...seo}>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Lead Qualification", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Lead Qualification Software
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Qualify Leads Automatically, <span class="text-lime-400">Before They Reach Your Team</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Stop wasting your team's time on unqualified prospects. LimeCall's lead qualification software scores and filters leads in real time — so your reps only talk to buyers.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Lead qualification features</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How lead qualification works</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Let your team focus on closing</h2>
      <p class="mt-4 text-dark-400">Automate lead qualification with LimeCall. Your team talks to buyers, not browsers.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/lead-routing-software/', title: 'Lead Routing Software', desc: 'Route qualified leads to the right rep.' },
        { href: '/lead-management-system/', title: 'Lead Management', desc: 'Full lead management platform.' },
        { href: '/instant-lead-routing/', title: 'Instant Lead Routing', desc: 'Route leads in real time.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
