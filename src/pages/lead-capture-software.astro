---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const seo = {
  title: `Lead Capture Software | LimeCall`,
  description: `LimeCall's lead capture software converts website visitors into calls and conversations. Click-to-call, callback automation, and web-to-text — all in one platform.`,
  canonical: `https://www.limecall.com/lead-capture-software/`,
};

const features = [
  { title: "Multi-Channel Capture", desc: "Capture leads through calls, callbacks, SMS, and chat. Meet visitors on their preferred channel." },
  { title: "Instant Call Connection", desc: "When a visitor clicks your call button, LimeCall connects your team and the visitor in under 28 seconds." },
  { title: "Automated Callback Scheduling", desc: "Let visitors schedule callbacks at their convenience. LimeCall sends reminders and automates the call." },
  { title: "Lead Qualification Engine", desc: "Qualify leads in real time using IVR menus, pre-call questions, and routing rules before they reach your team." },
  { title: "Full Attribution Tracking", desc: "Know exactly which page, ad, or keyword drove each lead. Attribute revenue back to the right campaigns." },
  { title: "Real-Time Notifications", desc: "Your team gets instant alerts — via SMS, email, or Slack — the moment a new lead is captured." },
];

const integrations = [
  "Salesforce", "HubSpot", "Pipedrive", "Zoho CRM", "Zapier", "Slack", "Google Analytics", "Facebook Ads"
];
---

<Base {...seo}>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Lead Capture Software", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Lead Capture Software
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Lead Capture Software That <span class="text-lime-400">Converts Traffic</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        LimeCall's lead capture software turns anonymous website visitors into live sales conversations. Connect through calls, callbacks, and SMS — before leads go cold.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Lead capture software features</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="border-t border-dark-800 py-14 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-xl font-bold text-white">Integrates with your existing stack</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {integrations.map(i => (
          <span class="rounded-full border border-dark-700 bg-dark-800 px-4 py-2 text-sm font-medium text-dark-300">{i}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Start capturing more leads today</h2>
      <p class="mt-4 text-dark-400">LimeCall installs in minutes. No developer required. Start a free trial now.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/lead-capture/', title: 'Lead Capture Overview', desc: 'All lead capture channels.' },
        { href: '/lead-routing-software/', title: 'Lead Routing Software', desc: 'Route leads to the right rep.' },
        { href: '/lead-qualification/', title: 'Lead Qualification', desc: 'Qualify leads automatically.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
