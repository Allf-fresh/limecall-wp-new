---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Callback Software for University Enrolment | LimeCall',
  description: 'LimeCall converts student enquiries into enrolments with instant callbacks. Connect admissions advisors with prospective students in 28 seconds. Free trial.',
  canonical: 'https://www.limecall.com/education/',
};

const stats = [
  { value: '28s', label: 'Student connected to admissions advisor' },
  { value: '60%', label: 'Reduction in enquiry drop-off' },
  { value: '3×', label: 'More enrolments vs email follow-up' },
  { value: '40+', label: 'Countries — full international support' },
];

const features = [
  { icon: '🎓', title: 'Course-Based Routing', desc: 'Route enquiries to the right faculty, department, or advisor automatically.' },
  { icon: '🌍', title: 'International Student Support', desc: 'Local virtual numbers in 40+ countries — students call at local rates.' },
  { icon: '📅', title: 'Open Day Booking', desc: 'Callback triggers invite students to book open days and campus visits.' },
  { icon: '🌙', title: 'After-Hours Capture', desc: 'Students research at night; callbacks queued for 9am the next morning.' },
  { icon: '🔒', title: 'GDPR Compliant', desc: 'All student data handled securely with full compliance and audit trails.' },
  { icon: '📊', title: 'Enrolment Attribution', desc: 'Track which campaigns (ads, events, email) actually generate enrolments.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall help universities increase student enrolments?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall places a callback widget on your course and programme pages. When a prospective student clicks it, they\'re connected to an admissions advisor within 28 seconds — while their interest is highest. This dramatically reduces drop-off compared to email follow-up, which averages a 24-hour response time.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall handle enquiries for multiple departments or faculties?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall\'s intelligent routing directs enquiries to the correct faculty, department, or admissions advisor based on which course page triggered the callback. You can create separate routing rules for undergraduate, postgraduate, international, and distance learning enquiries.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is LimeCall GDPR compliant for handling student data?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall is fully GDPR compliant. All call data is encrypted in transit and at rest. You control data retention periods, and full audit logs are available. We sign data processing agreements (DPAs) with all institutional customers.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall support international student enquiries?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall provides local virtual phone numbers in 40+ countries, so international students can call at local rates. You can also route international enquiries to specific advisors with language skills or regional knowledge.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can we use LimeCall for open day booking and post-event follow-up?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall works for both inbound (student initiates callback from website) and outbound campaigns (callbacks to open day attendees, enquiry lists, or event registrants). Most institutions use both to maximise their conversion pipeline.',
      },
    },
    {
      '@type': 'Question',
      name: 'How quickly can an education provider get started?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most education providers are live within 5 minutes. Add the widget code to your website, configure your routing rules in the dashboard, and the system is active. No IT team or developer required.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumbs items={[{ name: 'Education', url: `${site.url}/education/` }]} />
      <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400">🎓 For Universities &amp; Colleges</div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">Callback Software for<br class="hidden sm:block" /> <span class="text-lime-400">University Enrolment</span></h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300">Prospective students research 5–8 institutions before deciding. LimeCall connects your admissions team with enquiring students in 28 seconds — before they enrol somewhere else.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center justify-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">Start Free Trial — 14 Days</a>
        <a href="/demo/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-dark-700 px-8 py-4 text-sm font-semibold text-white transition hover:border-lime-500/40 hover:text-lime-400">Book a Demo →</a>
      </div>
      <p class="mt-4 text-xs text-dark-500">★ GDPR Compliant · Trusted by universities in 40+ countries · 14-day free trial</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-dark-800 bg-dark-900/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <dt class="text-3xl font-extrabold text-lime-400">{s.value}</dt>
            <dd class="mt-1 text-sm text-dark-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Problem callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-red-500/20 bg-red-500/5 p-8">
        <h2 class="text-xl font-bold text-white mb-3">⚠️ 64% of Student Enquiries Get No Response Within an Hour</h2>
        <p class="text-dark-300">A prospective student fills out an enquiry form. They've also filled it in at 4 other institutions. The first admissions team to call wins the enrolment. Every hour you wait, your conversion rate drops by half. The average email follow-up takes 24 hours. LimeCall takes 28 seconds.</p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">How LimeCall Works for Admissions</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: '01', title: 'Student Visits Course Page', desc: 'LimeCall widget appears: "Speak to an admissions advisor in 28 seconds." Student clicks.' },
          { step: '02', title: 'Routed to Right Department', desc: 'LimeCall routes to undergraduate, postgraduate, or international admissions automatically.' },
          { step: '03', title: 'Advisor Converts on the Call', desc: 'Student gets personalised guidance; enrolment process initiated during the call.' },
        ].map(item => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-lg">{item.step}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-dark-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">Built for Education Providers</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-dark-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Admissions Use Cases</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'Undergraduate Enquiries', desc: 'Course page visitor → admissions advisor in 28s → application started on the call.' },
          { title: 'International Applications', desc: 'Overseas student → international admissions team with local number and language support.' },
          { title: 'Postgraduate Conversion', desc: 'Professional considering an MBA → instant callback from postgrad advisor.' },
          { title: 'Open Day Follow-Up', desc: 'Automated callbacks to all open day attendees within 24 hours of the event.' },
        ].map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="font-bold text-white mb-2">{u.title}</h3>
            <p class="text-sm text-dark-400">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case study -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <blockquote class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-10 text-center">
        <p class="text-xl text-white italic leading-relaxed">"We increased our conversion rate from enquiry to enrolment by 140% after deploying LimeCall on our course pages. The speed-to-call made the difference — students felt valued from the first second."</p>
        <footer class="mt-6">
          <p class="font-bold text-lime-400">Dr. Patricia M.</p>
          <p class="text-sm text-dark-500">Head of Admissions, UK University</p>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">LimeCall vs. Traditional Admissions Follow-Up</h2>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              {['Metric', 'LimeCall', 'Email Follow-Up', 'Contact Form', 'Phone Only'].map(h => (
                <th class={`px-5 py-4 text-left font-semibold ${h === 'LimeCall' ? 'text-lime-400' : 'text-dark-300'}`}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['Response time', '28 seconds', '24 hours avg', '1–48 hours', 'Rep availability'],
              ['Enrolment conversion', '🟢 3× higher', '🟡 Baseline', '🔴 Low', '🟡 Standard'],
              ['International reach', '✅ 40+ countries', '✅ Global', '✅ Global', '🟡 Expensive'],
              ['After-hours capture', '✅ Queue + AM callback', '✅ Received', '✅ Form stored', '❌ Missed'],
              ['GDPR compliant', '✅ Full compliance', '✅', '⚠️ Config needed', '⚠️ Manual'],
            ].map(([feature, ...vals]) => (
              <tr class="hover:bg-dark-800/30 transition">
                <td class="px-5 py-4 font-medium text-dark-200">{feature}</td>
                {vals.map((v, i) => (
                  <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {item.name}
              <span class="ml-4 shrink-0 text-lime-400 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-br from-lime-500/10 to-dark-900 border-t border-lime-500/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Start Converting More Student Enquiries Today</h2>
      <p class="mt-4 text-lg text-dark-300">14-day free trial. GDPR compliant. No IT team required.</p>
      <a href="/signup" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-lime-500 px-10 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">Try Free — 14 Days →</a>
    </div>
  </section>

  <CrossLinks heading="Explore More" links={[
    { href: '/lead-generation-tools/', title: 'Lead Generation Tools', desc: 'Fill your enquiry pipeline.' },
    { href: '/virtual-business-numbers/', title: 'Virtual Numbers', desc: '40+ countries covered.' },
    { href: '/customer-callback-software/', title: 'Callback Software', desc: 'Core callback features.' },
    { href: '/pricing/', title: 'Pricing', desc: 'Plans from $35/month.' },
  ]} />
</Base>
