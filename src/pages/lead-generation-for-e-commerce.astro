---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const industry = "E-Commerce";
const icon = "🛒";

const seo = {
  title: `E-Commerce Lead Generation Software | LimeCall`,
  description: `Recover abandoned carts and boost e-commerce revenue. LimeCall's instant callbacks help online stores connect with hesitant shoppers in under 28 seconds to close more sales.`,
  canonical: `https://www.limecall.com/lead-generation-for-e-commerce/`,
};

const useCases = [
  { title: "Cart Abandonment Callbacks", desc: "Over 70% of shoppers abandon their cart. Trigger a callback offer at the moment a customer tries to leave — a real human conversation is the most powerful cart recovery tool available." },
  { title: "Pre-Purchase Support Callbacks", desc: "Some buyers have questions before they commit. LimeCall lets high-value prospects request an instant callback from a product expert, reducing hesitation and increasing order value." },
  { title: "Post-Purchase Upsell Calls", desc: "Connect with recent buyers at the right moment to suggest complementary products. Proactive post-purchase outreach drives repeat revenue and builds customer loyalty." },
  { title: "24/7 Lead Capture for Global Stores", desc: "International customers shop at all hours. Capture callback requests overnight and queue them for your team's next shift so no high-intent shopper is ever ignored." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More orders completed" },
  { value: "80%", label: "Reduction in missed leads" },
  { value: "5 min", label: "Setup time" },
];
---

<Base {...seo}>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `E-Commerce Lead Generation`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{icon}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        <span class="text-lime-400">{industry}</span> Lead Generation Software
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Recover abandoned carts and close hesitant shoppers with instant callbacks. Turn browser sessions into completed orders.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Built for {industry} stores</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Shopper hesitates", desc: "A visitor browses your store or starts to abandon their cart and sees the LimeCall callback offer." },
          { step: "2", title: "Instant human connection", desc: "LimeCall calls your support team and the shopper simultaneously, connecting them in under 28 seconds." },
          { step: "3", title: "Sale completed", desc: "A real conversation answers objections, builds trust, and converts the hesitant visitor into a buyer." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to recover more e-commerce revenue?</h2>
      <p class="mt-4 text-dark-400">Set up in 5 minutes. No credit card required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4">
    <CrossLinks heading="More LimeCall Solutions" links={[
      { href: '/limecall-for-ecommerce-and-retail-2/', title: 'LimeCall for E-Commerce', desc: 'Full platform overview for online stores.' },
      { href: '/click-to-call-software/', title: 'Click to Call', desc: 'Instant callbacks from your website.' },
      { href: '/increase-your-website-conversions/', title: 'Increase Conversions', desc: 'Turn more visitors into buyers.' },
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
    ]} />
  </div>
</Base>
