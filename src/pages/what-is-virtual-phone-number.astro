---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'What is a Virtual Phone Number? How It Works',
  description: 'A virtual phone number works over the internet, letting you make and receive calls from any device, anywhere. No SIM card or physical phone line required.',
  canonical: `${site.url}/what-is-virtual-phone-number/`,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: seo.title,
  description: seo.description,
  datePublished: '2024-01-20',
  dateModified: '2025-03-01',
  author: { '@type': 'Organization', name: 'LimeCall Team' },
  publisher: { '@type': 'Organization', name: 'LimeCall', url: site.url },
  mainEntityOfPage: { '@type': 'WebPage', '@id': seo.canonical },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does a virtual phone number cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Virtual phone numbers typically cost $5-$30 per month for a local number and $10-$50 per month for a toll-free number. International numbers vary by country ($5-$100/month). Many providers, including LimeCall, bundle virtual numbers with their callback and phone system plans — so you may not need a separate number subscription.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I get a virtual phone number for free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, some providers offer free virtual numbers with limitations. Google Voice provides a free US number for personal use. TextNow and TextFree offer free numbers with ads. However, free numbers typically lack business features like call routing, recording, analytics, and CRM integration. For business use, paid plans starting at $5-$10/month are recommended.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the difference between a virtual number and VoIP?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A virtual phone number is the number itself — an identifier that is not tied to a physical phone line. VoIP (Voice over Internet Protocol) is the technology that carries the call over the internet. You need VoIP technology to use a virtual number, but VoIP can also work with traditional phone numbers. Think of the virtual number as the address and VoIP as the delivery method.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I keep my existing number and add a virtual number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. You can add a virtual number alongside your existing phone number. Most providers also support number porting — transferring your existing number to their virtual platform. This lets you keep the number your customers already know while gaining all the benefits of a virtual phone system.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are virtual phone numbers legal?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, virtual phone numbers are legal in most countries. They are widely used by businesses of all sizes for legitimate purposes — local presence, remote work, marketing tracking, and cost reduction. However, regulations vary by country, and some require identity verification to prevent fraud. Always check local telecom regulations.',
      },
    },
  ],
};

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: seo.title,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.speakable-answer', '.speakable-summary'],
  },
  url: seo.canonical,
};

const numberTypes = [
  { name: 'Local Numbers', desc: 'Numbers with local area codes that give your business a presence in any city or region — even if you are not physically located there. Customers are 4x more likely to answer local numbers.', example: '(212) 555-0100 — New York' },
  { name: 'Toll-Free Numbers', desc: 'Numbers starting with 800, 888, 877, etc. that are free for callers. Project a national, professional image and remove cost barriers for customers.', example: '1-800-555-0199 — Nationwide' },
  { name: 'International Numbers', desc: 'Local numbers in foreign countries that route to your team anywhere. Let customers in 100+ countries call a local number that reaches your global team.', example: '+44 20 7946 0958 — London, UK' },
  { name: 'Vanity Numbers', desc: 'Numbers that spell a word or phrase on the dial pad. Easy to remember and ideal for marketing — boosting ad recall by up to 84%.', example: '1-800-LIMECAL' },
];

const benefits = [
  { title: 'Local Presence Anywhere', desc: 'Get local numbers in any city or country without opening a physical office. Customers are 4x more likely to answer calls from local numbers.' },
  { title: 'Privacy Protection', desc: 'Keep your personal number private. Use a virtual number for business calls, client communication, or online listings without exposing personal details.' },
  { title: 'Work From Anywhere', desc: 'Receive business calls on your mobile, laptop, or desk phone — wherever you are. No forwarding hassles or missed calls.' },
  { title: 'Significant Cost Savings', desc: 'Virtual numbers cost 60-80% less than traditional phone lines. No hardware, no installation, no maintenance contracts.' },
  { title: 'Advanced Call Features', desc: 'Get call routing, recording, analytics, voicemail-to-email, and CRM integration — features that cost thousands with traditional phone systems.' },
  { title: 'Easy Scalability', desc: 'Add or remove numbers in minutes. Scale from 1 to 1,000 numbers without any infrastructure changes.' },
];

const useCases = [
  { name: 'Business Expansion', desc: 'Get local numbers in new markets before physically expanding. Test demand with a local presence in any city or country.' },
  { name: 'Remote Teams', desc: 'Give every remote team member a business number that routes to their personal device — maintaining a professional image from anywhere.' },
  { name: 'Marketing Tracking', desc: 'Assign unique virtual numbers to each campaign, ad, or landing page. Track which channels drive the most calls and conversions.' },
  { name: 'Customer Support', desc: 'Offer local or toll-free numbers that route to your support team with IVR, queue management, and callback options.' },
];

const pricing = [
  { type: 'Local Number', monthly: '$5 - $15/mo', setup: 'Free - $10', best: 'Single-city businesses' },
  { type: 'Toll-Free Number', monthly: '$10 - $50/mo', setup: 'Free - $25', best: 'National brands' },
  { type: 'International Number', monthly: '$5 - $100/mo', setup: '$10 - $50', best: 'Global businesses' },
  { type: 'Vanity Number', monthly: '$15 - $50/mo', setup: '$25 - $100', best: 'Marketing & branding' },
  { type: 'LimeCall (bundled)', monthly: 'From $35/mo', setup: 'Free', best: 'Callback + virtual numbers' },
];
---

<Base {...seo}>
  <JsonLd schema={articleSchema} />
  <JsonLd schema={faqSchema} />
  <JsonLd schema={speakableSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'What is a Virtual Phone Number', url: `${site.url}/what-is-virtual-phone-number/` }]} />

      <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400">
        Definition
      </div>

      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        What is a <span class="text-lime-400">Virtual Phone Number?</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        A virtual phone number is a telephone number that is not tied to a specific phone line or SIM card. Instead, it uses Voice over Internet Protocol (VoIP) to route calls over the internet to any device — mobile, desktop, or desk phone — anywhere in the world.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="/signup" class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Get a Virtual Number — Free
        </a>
        <a href="/virtual-business-numbers/" class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          Virtual Business Numbers →
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Numbers in 100+ countries · No hardware required · Cancel anytime</p>
    </div>
  </section>

  <!-- Definition block -->
  <section class="py-14 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-white mb-4">Virtual Phone Number — Definition</h2>
        <p class="text-dark-200 leading-relaxed text-base">
          <strong class="text-white">A virtual phone number</strong> is a cloud-based telephone number that uses the internet (VoIP) to make and receive calls instead of a traditional copper phone line or cellular network. It can be assigned to any device with an internet connection — smartphone, laptop, tablet, or IP desk phone — giving businesses and individuals complete geographic flexibility.
        </p>
        <p class="mt-4 text-dark-300 leading-relaxed text-sm">
          Virtual numbers look and function like regular phone numbers to callers. The difference is entirely behind the scenes: calls are routed over the internet instead of physical telephone infrastructure, reducing costs by 60-80% while adding powerful features like call routing, recording, and analytics.
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          How Virtual Numbers <span class="text-lime-400">Work</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">VoIP technology routes calls over the internet instead of phone lines.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-sm">01</div>
          <h3 class="text-base font-bold text-white mb-2">Caller Dials Your Number</h3>
          <p class="text-sm text-dark-400 leading-relaxed">A customer dials your virtual number — local, toll-free, or international. It looks like any regular phone number.</p>
        </div>
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-sm">02</div>
          <h3 class="text-base font-bold text-white mb-2">Call Hits the Cloud</h3>
          <p class="text-sm text-dark-400 leading-relaxed">The call is received by your VoIP provider's cloud infrastructure and routing rules are applied — time of day, availability, skill-based routing.</p>
        </div>
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-sm">03</div>
          <h3 class="text-base font-bold text-white mb-2">Routed to Any Device</h3>
          <p class="text-sm text-dark-400 leading-relaxed">The call is forwarded over the internet to your chosen device — mobile phone, desktop app, or IP desk phone — anywhere in the world.</p>
        </div>
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-sm">04</div>
          <h3 class="text-base font-bold text-white mb-2">Connected & Logged</h3>
          <p class="text-sm text-dark-400 leading-relaxed">You answer the call on your device. The call is automatically recorded, logged in your CRM, and analytics are tracked in real time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Types of Virtual Numbers -->
  <section class="py-14 sm:py-18">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Types of <span class="text-lime-400">Virtual Numbers</span>
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {numberTypes.map((t) => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <h3 class="text-base font-bold text-white mb-3">{t.name}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{t.desc}</p>
            <p class="mt-3 text-xs text-lime-400 font-mono">{t.example}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Benefits of <span class="text-lime-400">Virtual Numbers</span>
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map((b) => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <h3 class="text-base font-bold text-white mb-3">{b.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="py-14 sm:py-18">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Use Cases for <span class="text-lime-400">Virtual Numbers</span>
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map((uc) => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <h3 class="text-base font-bold text-white mb-3">{uc.name}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Table -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Virtual Number <span class="text-lime-400">Pricing</span>
        </h2>
      </div>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              <th class="px-5 py-4 text-left font-semibold text-dark-300">Number Type</th>
              <th class="px-5 py-4 text-left font-semibold text-dark-300">Monthly Cost</th>
              <th class="px-5 py-4 text-left font-semibold text-dark-300">Setup Fee</th>
              <th class="px-5 py-4 text-left font-semibold text-dark-300">Best For</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {pricing.map((row) => (
              <tr class={`hover:bg-dark-800/30 transition ${row.type === 'LimeCall (bundled)' ? 'bg-lime-500/5' : ''}`}>
                <td class={`px-5 py-4 font-medium ${row.type === 'LimeCall (bundled)' ? 'text-lime-400' : 'text-dark-200'}`}>{row.type}</td>
                <td class={`px-5 py-4 ${row.type === 'LimeCall (bundled)' ? 'font-semibold text-white' : 'text-dark-400'}`}>{row.monthly}</td>
                <td class="px-5 py-4 text-dark-400">{row.setup}</td>
                <td class="px-5 py-4 text-dark-400">{row.best}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Frequently Asked <span class="text-lime-400">Questions</span>
        </h2>
      </div>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((item) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {item.name}
              <span class="ml-4 shrink-0 text-lime-400 group-open:rotate-180 transition-transform">&#9662;</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-lime-500/20 bg-gradient-to-br from-lime-500/10 to-dark-900 py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Get Your Virtual Number Today
      </h2>
      <p class="mt-4 text-lg text-dark-300">
        LimeCall provides virtual numbers in 100+ countries — bundled with instant callback, call routing, and CRM integration.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/signup" class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free — No Card Required
        </a>
        <a href="/pricing/" class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40">
          View Pricing →
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">Free plan available · Numbers in 100+ countries · GDPR compliant</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="Learn More"
        links={[
          { href: '/virtual-business-numbers/', title: 'Virtual Business Numbers', desc: 'Local, toll-free, and international virtual numbers for your business.' },
          { href: '/virtual-pbx/', title: 'Virtual PBX', desc: 'Cloud phone system with routing, recording, and analytics.' },
          { href: '/virtual-phone-number-spain/', title: 'Virtual Phone Number Spain', desc: 'Get a Spanish virtual number for your European expansion.' },
          { href: '/pricing/', title: 'LimeCall Pricing', desc: 'Simple, transparent plans starting at $35/month.' },
        ]}
      />
    </div>
  </section>
</Base>
