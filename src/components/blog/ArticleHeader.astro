---
interface Props {
  title: string;
  description: string | null;
  category: string | null;
  author: string;
  publishDate: string;
  updatedAt: string | null;
  readingTime: number;
  schemaType: string;
}

const {
  title,
  description,
  category,
  author,
  publishDate,
  updatedAt,
  readingTime,
  schemaType,
} = Astro.props;

const categoryStyles: Record<string, string> = {
  streaming:  'border-blue-500/20 bg-blue-500/10 text-blue-400',
  privacy:    'border-purple-500/20 bg-purple-500/10 text-purple-400',
  torrenting: 'border-orange-500/20 bg-orange-500/10 text-orange-400',
  unblocking: 'border-cyan-500/20 bg-cyan-500/10 text-cyan-400',
  security:   'border-red-500/20 bg-red-500/10 text-red-400',
  'how-to':   'border-lime-500/20 bg-lime-500/10 text-lime-400',
  news:       'border-blue-500/20 bg-blue-500/10 text-blue-400',
  guides:     'border-green-500/20 bg-green-500/10 text-green-400',
};

const badgeStyle = category
  ? (categoryStyles[category] ?? 'border-dark-700 bg-dark-800 text-dark-400')
  : 'border-dark-700 bg-dark-800 text-dark-400';

const categoryHref = category ? `/blog/${category}` : '/blog';
const categoryLabel = category
  ? (category.charAt(0).toUpperCase() + category.slice(1))
  : 'Blog';

function formatDate(dateStr: string | null): string {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  } catch {
    return dateStr;
  }
}

const publishedFormatted = formatDate(publishDate);
const updatedFormatted = updatedAt && updatedAt !== publishDate ? formatDate(updatedAt) : null;
const isHowTo = schemaType === 'HowTo';
---

<header class="mb-8 pt-4">
  <div class="flex flex-wrap items-center gap-3 text-sm mb-4">
    <a
      href={categoryHref}
      class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-wider transition hover:opacity-80 ${badgeStyle}`}
    >
      {isHowTo ? 'How-To Guide' : categoryLabel}
    </a>
    <span class="flex items-center gap-1.5 text-dark-500">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
      </svg>
      {readingTime} min read
    </span>
    <time datetime={publishDate} class="text-dark-500">{publishedFormatted}</time>
    {updatedFormatted && (
      <span class="text-dark-600 text-xs">(Updated {updatedFormatted})</span>
    )}
    {author && (
      <span class="text-dark-500">by <span class="text-dark-400 font-medium">{author}</span></span>
    )}
  </div>
  <h1 class="text-3xl font-extrabold text-white sm:text-4xl leading-tight mb-4">{title}</h1>
  {description && (
    <p class="text-lg text-dark-300 leading-relaxed max-w-2xl">{description}</p>
  )}
</header>
