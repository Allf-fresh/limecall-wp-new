---
import Base from '../layouts/Base.astro';

const seo = {
  title: `Callback Software Company Contact Us - LimeCall`,
  description: `Get In Touch With Us To Get Introduced To LimeCall Free Callback Software And For Any Related Queries.`,
  canonical: `https://www.limecall.com/contact-us`,
};
---
<Base {...seo}>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <span class="inline-block mb-4 rounded-full bg-lime-500/10 px-4 py-1.5 text-sm font-semibold text-lime-400">Contact Us</span>
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">
          Get in <span class="text-lime-400">Touch</span>
        </h1>
        <p class="mt-4 text-lg text-dark-300">
          Have a question about LimeCall? We'd love to help. Our team typically responds within 24 hours.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 mb-10">
        <a href="mailto:support@limecall.com" class="rounded-xl border border-dark-800 bg-dark-900/50 p-6 hover:border-lime-500/30 transition group">
          <div class="text-2xl mb-3">📧</div>
          <h3 class="font-semibold text-white mb-1 group-hover:text-lime-400 transition">Email Support</h3>
          <p class="text-sm text-dark-400">support@limecall.com</p>
          <p class="text-xs text-dark-500 mt-2">24h response on business days</p>
        </a>
        <a href="/demo" class="rounded-xl border border-dark-800 bg-dark-900/50 p-6 hover:border-lime-500/30 transition group">
          <div class="text-2xl mb-3">🎥</div>
          <h3 class="font-semibold text-white mb-1 group-hover:text-lime-400 transition">Book a Demo</h3>
          <p class="text-sm text-dark-400">See LimeCall live with our team</p>
          <p class="text-xs text-dark-500 mt-2">Free 30-minute walkthrough</p>
        </a>
        <a href="https://app.limecall.com/login" target="_blank" rel="noopener" class="rounded-xl border border-dark-800 bg-dark-900/50 p-6 hover:border-lime-500/30 transition group">
          <div class="text-2xl mb-3">💬</div>
          <h3 class="font-semibold text-white mb-1 group-hover:text-lime-400 transition">Live Chat</h3>
          <p class="text-sm text-dark-400">Chat with us in the app</p>
          <p class="text-xs text-dark-500 mt-2">Available on all plans</p>
        </a>
        <a href="/partnership" class="rounded-xl border border-dark-800 bg-dark-900/50 p-6 hover:border-lime-500/30 transition group">
          <div class="text-2xl mb-3">🤝</div>
          <h3 class="font-semibold text-white mb-1 group-hover:text-lime-400 transition">Partnerships</h3>
          <p class="text-sm text-dark-400">Reseller & agency programs</p>
          <p class="text-xs text-dark-500 mt-2">partnerships@limecall.com</p>
        </a>
      </div>

      <div class="rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-500/5 to-dark-900 p-8 text-center">
        <h2 class="text-xl font-bold text-white mb-2">Ready to try LimeCall?</h2>
        <p class="text-dark-400 mb-6 text-sm">Start free — no credit card required.</p>
        <a href="/signup" class="inline-block rounded-xl bg-lime-500 px-8 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">
          TRY FOR FREE
        </a>
      </div>
    </div>
  </section>
</Base>
