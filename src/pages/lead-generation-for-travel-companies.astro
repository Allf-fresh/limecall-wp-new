---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const industry = "Travel";
const icon = "✈️";

const seo = {
  title: `Travel Lead Generation Software | LimeCall`,
  description: `Turn travel browsers into booked holidays. LimeCall's instant callback software helps travel agencies and tour operators respond to booking inquiries in under 28 seconds.`,
  canonical: `https://www.limecall.com/lead-generation-for-travel-companies/`,
};

const useCases = [
  { title: "Instant Callback on Booking Inquiries", desc: "Travel is a high-consideration purchase. When a prospect is on your tour page or has started a booking, LimeCall connects your travel consultant in under 28 seconds — before they head to a comparison site." },
  { title: "Itinerary & Package Consultation Callbacks", desc: "Complex trips need expert guidance. Let prospects request a callback from a specialist who can build a custom itinerary, answer destination questions, and convert interest into a confirmed booking." },
  { title: "Multi-Destination Specialist Routing", desc: "Route callback requests to the right destination expert — whether it's Caribbean cruises, European city breaks, or adventure travel in Southeast Asia. Give every prospect a genuinely knowledgeable first call." },
  { title: "After-Hours & International Lead Capture", desc: "Travel inspiration strikes at midnight and across time zones. Capture callback requests 24/7 and queue them for your consultants so every potential booking is followed up personally." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More bookings confirmed" },
  { value: "80%", label: "Reduction in missed leads" },
  { value: "5 min", label: "Setup time" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Why are phone calls so important for travel bookings?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '87% of travel bookings over $1,000 involve a phone call at some point in the purchase journey. High-value travel is a complex, emotional decision — customers want to speak to an expert to get reassurance about itineraries, pricing, and logistics. A 28-second callback triples travel package conversion compared to form-only follow-up.'
      }
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall help travel agencies convert more package inquiries?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall places a callback widget on your tour and destination pages. When a prospect is browsing a package and clicks "Speak to an Expert," LimeCall connects them with the right travel consultant in under 28 seconds — while their excitement about the trip is at its peak and before they visit a competitor\'s site.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can travel agencies route callbacks to destination specialists?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall routing rules let you direct Caribbean inquiries to your Caribbean specialists, Asia tours to your Asia team, and cruise bookings to your cruise consultants. Prospects always speak to someone with genuine destination knowledge, which dramatically improves conversion and booking value.'
      }
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall handle last-minute travel inquiries?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Last-minute travel requests are time-critical. LimeCall connects the prospect to your consultant in under 28 seconds, allowing you to check availability, confirm pricing, and secure the booking before the customer goes elsewhere. You can also configure priority routing so last-minute requests reach your most available consultant instantly.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall capture international travel inquiries across different time zones?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Absolutely. LimeCall captures callback requests 24/7 and queues them for the next available consultant. For international markets, you can configure local business hours per region so prospects are always called back within a reasonable window. All inquiries are logged so no potential booking falls through the cracks.'
      }
    },
  ]
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `Travel Lead Generation`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{icon}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        <span class="text-lime-400">{industry}</span> Lead Generation Software
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Turn travel browsers into booked holidays. Connect with booking inquiries in under 28 seconds while wanderlust is at its peak.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Built for {industry} companies</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How LimeCall works for Travel Companies</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Traveller shows interest", desc: "A prospect browses your tour packages or destination pages and clicks the LimeCall widget to talk to a travel expert." },
          { step: "2", title: "Consultant connected fast", desc: "LimeCall calls your travel consultant and the prospect simultaneously, connecting them in under 28 seconds." },
          { step: "3", title: "Booking journey begins", desc: "The consultation is recorded and logged. Automatic follow-up keeps the prospect warm if they need more time." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison section -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Why callbacks triple travel package conversion vs. online booking engines</h2>
      <p class="mb-10 text-center text-dark-400 text-sm max-w-2xl mx-auto">87% of high-value travel bookings involve a phone call. An online booking engine captures simple trips — but a personal expert call closes complex, high-margin packages.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 text-sm font-bold text-dark-400 uppercase tracking-wider">Online Booking Engine Only</div>
          <ul class="space-y-3 text-sm text-dark-400">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Complex itinerary questions go unanswered — prospect abandons</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> High-value packages rarely convert without personal consultation</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> No upsell opportunity for upgrades, extensions, or add-ons</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> International time zone gaps lose overnight leads</li>
          </ul>
        </div>
        <div class="rounded-xl border border-lime-500/30 bg-lime-950/10 p-6">
          <div class="mb-4 text-sm font-bold text-lime-400 uppercase tracking-wider">LimeCall Instant Callback</div>
          <ul class="space-y-3 text-sm text-dark-300">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Expert consultant on the phone in 28 seconds to answer every question</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Personal service converts high-value, complex itineraries</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Live upsell opportunity on every call — higher average booking value</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> International inquiries captured and queued 24/7</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="cursor-pointer list-none font-semibold text-white flex justify-between items-center gap-4">
              <span>{faq.name}</span>
              <span class="shrink-0 text-lime-400 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to skyrocket your travel bookings?</h2>
      <p class="mt-4 text-dark-400">Set up in 5 minutes. No credit card required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4">
    <CrossLinks heading="More LimeCall Solutions" links={[
      { href: '/limecall-for-travel-tourism-aviation/', title: 'LimeCall for Travel', desc: 'Full platform overview for travel companies.' },
      { href: '/click-to-call-software/', title: 'Click to Call', desc: 'Instant callbacks from your website.' },
      { href: '/conversation-scheduling/', title: 'Schedule Callbacks', desc: 'Let travellers book a consultation that suits them.' },
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
    ]} />
  </div>
</Base>
