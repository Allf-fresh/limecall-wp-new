---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const industry = "Automotive";
const icon = "🚗";

const seo = {
  title: `Automotive Lead Generation Software | LimeCall`,
  description: `Turn car shoppers into showroom visits. LimeCall's instant callback software helps dealerships respond to test drive requests and trade-in inquiries in under 28 seconds.`,
  canonical: `https://www.limecall.com/lead-generation-for-automotive/`,
};

const useCases = [
  { title: "Instant Callback on Test Drive Requests", desc: "Car buyers browse dozens of listings before deciding. When they request a test drive, LimeCall connects your sales team in under 28 seconds — before they call a competing dealership." },
  { title: "Trade-In Inquiry Routing", desc: "Route trade-in valuation requests to the right appraiser or sales rep instantly. Capture high-intent leads who are actively looking to upgrade their vehicle." },
  { title: "Multi-Dealership Call Routing", desc: "For dealer groups with multiple locations, automatically route calls to the closest or most appropriate dealership based on the customer's location or vehicle interest." },
  { title: "Service Department Lead Capture", desc: "Capture service appointment requests 24/7. Schedule callbacks during service hours so your service writers start every day with a full booking queue." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More test drives booked" },
  { value: "80%", label: "Reduction in missed leads" },
  { value: "5 min", label: "Setup time" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How quickly can a dealership callback a car buyer using LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall connects your dealership sales rep with the car buyer in under 28 seconds. As soon as the shopper clicks the callback widget on your website or vehicle listing page, LimeCall simultaneously dials your sales team and the prospect, bridging them in real time.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall handle trade-in inquiry callbacks automatically?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall can route trade-in valuation requests directly to your appraisal team or a dedicated sales rep. You can set up routing rules so trade-in inquiries always reach the right person, reducing wait times and improving the customer experience.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall work for dealer groups with multiple locations?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Absolutely. LimeCall supports multi-location dealer groups with intelligent routing. Calls can be distributed to the nearest dealership, a specific brand location, or based on inventory type. You manage all locations from a single dashboard.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can we capture after-hours car buyer leads with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Car shoppers often browse in the evenings and weekends. LimeCall captures callback requests 24/7 and schedules them for your sales team during business hours, so your team starts every day with a warm pipeline of interested buyers.'
      }
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall compare to just having a phone number on a dealership website?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A phone number requires the buyer to make the effort to call — and most won\'t. LimeCall\'s callback widget removes that friction: the shopper enters their number and LimeCall calls them back in 28 seconds. Dealerships using LimeCall see 3x more test drive bookings compared to passive phone numbers alone.'
      }
    },
  ]
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `Automotive Lead Generation`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{icon}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        <span class="text-lime-400">{industry}</span> Lead Generation Software
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Turn car shoppers into showroom visits. Connect with dealership leads in under 28 seconds before they drive off to your competitor.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Built for {industry} dealerships</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How LimeCall works for Automotive</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Shopper shows interest", desc: "A car buyer browses your inventory online and clicks the LimeCall widget to request a callback or test drive." },
          { step: "2", title: "Sales rep connected fast", desc: "LimeCall calls your sales rep and the shopper simultaneously, connecting them in under 28 seconds." },
          { step: "3", title: "Lead captured & followed up", desc: "The call is recorded, logged, and automatically followed up if the rep is with another customer." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison section -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Why phone callbacks beat online enquiry forms</h2>
      <p class="mb-10 text-center text-dark-400 text-sm max-w-2xl mx-auto">68% of car buyers want to speak to a dealer before visiting a showroom. A web form makes them wait — a callback wins the moment.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 text-sm font-bold text-dark-400 uppercase tracking-wider">Web Enquiry Form</div>
          <ul class="space-y-3 text-sm text-dark-400">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Buyer submits form and waits hours for a reply</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> By the time you respond, they've booked a test drive elsewhere</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> No ability to handle trade-in or financing questions in real time</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Leads arrive in an unmanaged email inbox</li>
          </ul>
        </div>
        <div class="rounded-xl border border-lime-500/30 bg-lime-950/10 p-6">
          <div class="mb-4 text-sm font-bold text-lime-400 uppercase tracking-wider">LimeCall Instant Callback</div>
          <ul class="space-y-3 text-sm text-dark-300">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Buyer is connected to a sales rep in under 28 seconds</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> You're the first dealership they speak to — every time</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Trade-in, financing, and test drive questions answered live</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> All leads logged in your CRM automatically</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="cursor-pointer list-none font-semibold text-white flex justify-between items-center gap-4">
              <span>{faq.name}</span>
              <span class="shrink-0 text-lime-400 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to drive more automotive sales?</h2>
      <p class="mt-4 text-dark-400">Set up in 5 minutes. No credit card required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4">
    <CrossLinks heading="More LimeCall Solutions" links={[
      { href: '/click-to-call-software/', title: 'Click to Call', desc: 'Instant callbacks from your website.' },
      { href: '/lead-distribution/', title: 'Lead Distribution', desc: 'Route every lead to the right rep automatically.' },
      { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'Connect with leads in seconds, not hours.' },
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
    ]} />
  </div>
</Base>
