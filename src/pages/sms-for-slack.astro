---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const seo = {
  title: `Send & Receive SMS in Slack | LimeCall SMS for Slack`,
  description: `Send and receive SMS directly inside Slack with LimeCall. Seamless 2-way texting, team collaboration on customer conversations, without leaving Slack.`,
  canonical: `https://www.limecall.com/sms-for-slack/`,
};

const features = [
  { title: "SMS in Slack Channels", desc: "Customer SMS conversations appear directly in dedicated Slack channels. Your team replies without switching apps." },
  { title: "Two-Way Texting", desc: "Send and receive SMS in real time from Slack. Full conversation history visible to the whole team." },
  { title: "Team Collaboration", desc: "Tag teammates, discuss next steps in threads, and hand off conversations — all within Slack." },
  { title: "Instant Notifications", desc: "Get Slack notifications the moment a customer texts in. Never miss an inbound SMS again." },
  { title: "Easy Setup", desc: "Connect LimeCall to Slack in minutes with our OAuth integration. No developer required." },
  { title: "Context & History", desc: "See full conversation history, contact details, and previous interactions directly in Slack." },
];

const steps = [
  { n: "1", title: "Connect LimeCall to Slack", desc: "Click 'Add to Slack' in your LimeCall settings. Authorize the integration in one click." },
  { n: "2", title: "Map numbers to channels", desc: "Assign each LimeCall phone number to a Slack channel. Texts arrive in the right channel automatically." },
  { n: "3", title: "Text from Slack", desc: "Reply to customer texts directly from Slack. Your messages are delivered as SMS to the customer." },
];
---

<Base {...seo}>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "SMS for Slack", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Slack Integration
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Send & Receive SMS <span class="text-lime-400">Inside Slack</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Your team already lives in Slack. Now your SMS conversations can too. LimeCall's Slack integration brings two-way customer texting directly into your workspace.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Connect Slack →
        </a>
        <a href="/integrations/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View All Integrations
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Everything you need for SMS in Slack</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Set up in 3 steps</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why it matters -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Why teams love SMS for Slack</h2>
      <div class="space-y-4">
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-5">
          <p class="text-dark-300 leading-relaxed">"Switching between apps kills focus. With SMS in Slack, our sales team responds to leads in seconds without breaking their workflow."</p>
          <p class="mt-3 text-sm text-dark-500">— Faster response = higher conversion rates</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-5">
          <p class="text-dark-300 leading-relaxed">"Customer texts go to a Slack channel. The whole team sees them, we discuss who handles it, and we never drop a ball."</p>
          <p class="mt-3 text-sm text-dark-500">— Better team coordination on customer conversations</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Start texting customers from Slack</h2>
      <p class="mt-4 text-dark-400">Connect LimeCall to Slack in minutes. No developer required. No extra apps.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/business-texting/', title: 'Business Texting', desc: 'Full SMS platform for your business.' },
        { href: '/shared-inbox/', title: 'Shared Inbox', desc: 'Team SMS inbox for collaboration.' },
        { href: '/integrations/', title: 'All Integrations', desc: 'Connect LimeCall to your stack.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
