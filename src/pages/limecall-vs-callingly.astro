---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const competitor = "Callingly";
const competitorSlug = "callingly";

const seo = {
  title: `LimeCall vs ${competitor} — Which is Better in 2026? | LimeCall`,
  description: `LimeCall vs ${competitor}: honest side-by-side comparison. Is Callingly limiting your sales? See why teams choose LimeCall for faster callbacks, more channels, and better value.`,
  canonical: `https://www.limecall.com/limecall-vs-${competitorSlug}/`,
};

const features = [
  { feature: "Instant Callback (28 sec)", limecall: true, competitor: true },
  { feature: "Click-to-Call Widget", limecall: true, competitor: true },
  { feature: "Lead Distribution", limecall: true, competitor: true },
  { feature: "SMS & WhatsApp", limecall: true, competitor: false },
  { feature: "Virtual Phone Numbers (40+ countries)", limecall: true, competitor: false },
  { feature: "CRM Integrations", limecall: true, competitor: true },
  { feature: "Call Recording", limecall: true, competitor: false },
  { feature: "Free Plan (no credit card)", limecall: true, competitor: false },
  { feature: "Shared SMS Inbox", limecall: true, competitor: false },
  { feature: "Speed-to-Lead Automation", limecall: true, competitor: true },
];

const reasons = [
  { title: "More communication channels", desc: "LimeCall adds SMS, WhatsApp, and virtual numbers on top of callbacks — everything in one place. Callingly focuses narrowly on instant calling." },
  { title: "Better pricing", desc: "LimeCall delivers more features at a lower cost. No per-seat surprises, no hidden per-minute charges." },
  { title: "Call recording included", desc: "Record every call for coaching and compliance. LimeCall includes call recording — Callingly does not." },
  { title: "Free to start", desc: "LimeCall offers a free plan with no credit card required. Test drive the full platform before you commit." },
  { title: "Shared SMS inbox", desc: "Your whole team can collaborate on text conversations in a shared inbox. Callingly has no equivalent." },
  { title: "Simple widget setup", desc: "Add the LimeCall widget to any website in under 5 minutes. No developer, no complex configuration." },
];

const pricing = [
  {
    tool: "LimeCall",
    highlight: true,
    tiers: [
      { name: "Free", price: "$0/mo", note: "30 calls/month, no credit card" },
      { name: "Starter", price: "$29/mo", note: "100 calls, SMS, lead distribution" },
      { name: "Pro", price: "$99/mo", note: "500 calls, virtual numbers, API, call recording" },
    ],
  },
  {
    tool: "Callingly",
    highlight: false,
    tiers: [
      { name: "No free plan", price: "—", note: "Paid plan required to start" },
      { name: "Basic", price: "~$25/mo", note: "Callbacks only, no SMS or recording" },
      { name: "Growth", price: "~$75/mo", note: "More calls, no virtual numbers" },
    ],
  },
];

const differentiators = [
  {
    title: "SMS & WhatsApp — Callingly has neither",
    desc: "Callingly focuses exclusively on instant phone calls. LimeCall lets you follow up via SMS and WhatsApp from the same platform, capturing leads who don't answer their phone.",
  },
  {
    title: "Virtual Numbers in 40+ Countries",
    desc: "Callingly doesn't offer virtual numbers. LimeCall lets your team present local caller IDs in over 40 countries — dramatically improving answer rates for outbound follow-up.",
  },
  {
    title: "Call Recording for Coaching",
    desc: "Callingly doesn't record calls. LimeCall includes call recording on paid plans so managers can coach reps, review conversations, and maintain compliance records.",
  },
  {
    title: "Shared Team SMS Inbox",
    desc: "LimeCall's shared inbox lets your entire team collaborate on SMS threads with leads. Callingly has no text messaging capability at all.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Callingly?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Callingly is a speed-to-lead calling tool that instantly dials your sales reps when a new lead fills out a form on your website. It focuses on instant phone connection but does not offer SMS, WhatsApp, virtual numbers, or call recording.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why choose LimeCall over Callingly?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall covers everything Callingly does — instant lead calling and lead distribution — and adds SMS, WhatsApp, virtual phone numbers in 40+ countries, call recording, a shared team inbox, and a free plan. It\'s a more complete platform at a competitive price.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall have all of Callingly\'s features?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall includes instant callback, lead distribution, and CRM integrations that Callingly offers — and extends beyond with call recording, SMS, WhatsApp, virtual numbers, and a shared inbox that Callingly does not have.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much cheaper is LimeCall compared to Callingly?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall starts completely free (no credit card), while Callingly requires a paid plan from day one. On paid tiers, LimeCall offers more features — call recording, SMS, virtual numbers — at comparable or lower pricing.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I migrate from Callingly to LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Migration is straightforward: (1) Sign up for LimeCall free — no credit card needed. (2) Add the LimeCall widget to your website or configure the lead form webhook trigger (takes under 10 minutes). (3) Connect your CRM using LimeCall\'s native integrations. Most teams are fully live within a day.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Compare', url: 'https://www.limecall.com/compare/' }, { name: `LimeCall vs ${competitor}`, url: seo.canonical }]} />
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall vs <span class="text-lime-400">{competitor}</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300">
        An honest comparison. See why growing sales teams choose LimeCall over {competitor} for faster lead response, more channels, and better value.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">
          Try LimeCall Free →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 px-8 py-3.5 text-sm font-semibold text-white hover:border-lime-500/50 transition">
          See Pricing
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime</p>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Feature Comparison</h2>
      <div class="overflow-hidden rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-6 py-4 text-left font-semibold text-dark-300">Feature</th>
              <th class="px-6 py-4 text-center font-bold text-lime-400">LimeCall</th>
              <th class="px-6 py-4 text-center font-semibold text-dark-400">{competitor}</th>
            </tr>
          </thead>
          <tbody>
            {features.map((row, i) => (
              <tr class:list={["border-b border-dark-800/50", i % 2 === 0 ? "bg-dark-950" : "bg-dark-900/40"]}>
                <td class="px-6 py-3.5 text-dark-300">{row.feature}</td>
                <td class="px-6 py-3.5 text-center">
                  {row.limecall
                    ? <span class="text-lime-400 text-base">✓</span>
                    : <span class="text-dark-600 text-base">✗</span>}
                </td>
                <td class="px-6 py-3.5 text-center">
                  {row.competitor
                    ? <span class="text-dark-300 text-base">✓</span>
                    : <span class="text-dark-600 text-base">✗</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing comparison -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Pricing Comparison</h2>
      <p class="mb-10 text-center text-dark-400">LimeCall starts free. Callingly requires a paid plan from day one.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        {pricing.map(p => (
          <div class:list={["rounded-xl border p-6", p.highlight ? "border-lime-500/30 bg-dark-900/60" : "border-dark-800 bg-dark-900/40"]}>
            <h3 class:list={["mb-4 text-lg font-bold", p.highlight ? "text-lime-400" : "text-dark-300"]}>{p.tool}</h3>
            <div class="space-y-3">
              {p.tiers.map(t => (
                <div class="flex items-start justify-between gap-2">
                  <div>
                    <div class="text-sm font-semibold text-white">{t.name}</div>
                    <div class="text-xs text-dark-500">{t.note}</div>
                  </div>
                  <div class:list={["text-sm font-bold whitespace-nowrap", p.highlight ? "text-lime-400" : "text-dark-400"]}>{t.price}</div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-xs text-dark-600">Pricing approximate. Check each vendor's website for current rates.</p>
    </div>
  </section>

  <!-- Key differentiators -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">What LimeCall Has That {competitor} Doesn't</h2>
      <p class="mb-10 text-center text-dark-400">Four capabilities that make LimeCall the more complete platform.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        {differentiators.map(d => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-lime-400">{d.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why switch -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Why teams switch from {competitor} to LimeCall</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {reasons.map(r => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{r.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Migration tip -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-lime-500/20 bg-lime-500/5 p-8">
        <h2 class="mb-2 text-xl font-bold text-white">Migration Tip: Switch in Under an Hour</h2>
        <p class="text-dark-300 leading-relaxed mb-6">
          Callingly connects to leads via CRM webhooks. LimeCall supports the same webhook triggers — so you can point your existing CRM events at LimeCall without any workflow rebuild. Sign up free, replace the webhook URL, and you're live.
        </p>
        <div class="space-y-2 mb-6">
          {[
            "Sign up free — no credit card, instant access",
            "Replace your Callingly webhook URL with LimeCall's",
            "Connect Slack, HubSpot, or Salesforce in one click",
            "Enable call recording and SMS follow-up",
          ].map(step => (
            <div class="flex items-center gap-2 text-sm text-dark-300">
              <svg class="h-4 w-4 flex-shrink-0 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
              {step}
            </div>
          ))}
        </div>
        <a href={site.cta.href} class="inline-block rounded-xl bg-lime-500 px-6 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free Migration →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to make the switch?</h2>
      <p class="mt-4 text-dark-400">Join thousands who chose LimeCall over {competitor}. No credit card. Cancel anytime.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free — No Credit Card →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <CrossLinks heading="Explore LimeCall" links={[
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      { href: '/click-2-call/', title: 'Click to Call', desc: 'Instant website callbacks.' },
      { href: '/features/', title: 'Features', desc: 'Everything LimeCall does.' },
      { href: '/customers/', title: 'Customers', desc: 'See who uses LimeCall.' },
    ]} />
  </div>
</Base>
