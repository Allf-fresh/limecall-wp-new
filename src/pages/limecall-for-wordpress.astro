---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const tool = "WordPress";

const seo = {
  title: `Powerful Lead Capture Plugin For WordPress Website | LimeCall`,
  description: `Struggling to convert website visitors into paying customers? Integrate LimeCall with WordPress for lead capture via website callbacks.`,
  canonical: `https://www.limecall.com/limecall-for-wordpress/`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I add LimeCall to WordPress?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You can add LimeCall to WordPress in two ways: install our official plugin from the WordPress.org plugin directory, or paste the LimeCall widget JavaScript snippet into your theme\'s footer. Both methods take under 5 minutes and require no coding skills.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is there a LimeCall WordPress plugin?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall has an official WordPress plugin available in the WordPress.org plugin directory. Search for "LimeCall" in the Plugins section of your WordPress dashboard, install, and enter your API key to activate the callback widget on your site.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need a developer to install LimeCall on WordPress?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No developer is needed. The LimeCall WordPress plugin installs with one click from the plugin directory, and all configuration is done through a simple settings panel in your WordPress dashboard. No code, no FTP, no technical knowledge required.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall work with WooCommerce?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall works seamlessly with WooCommerce. You can add callback widgets to product pages, cart, checkout, and any WooCommerce page. This lets shoppers talk to someone instantly at the moment they\'re most likely to convert.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does the LimeCall widget slow down my WordPress site?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. The LimeCall widget script is loaded asynchronously and has a negligible impact on page load time. It does not block rendering, and the script is served from a fast global CDN. Most sites see no measurable impact on Core Web Vitals.',
      },
    },
  ],
};

const stats = [
  { value: "5 min", label: "WordPress install time" },
  { value: "10-12x", label: "More conversions vs forms" },
  { value: "0", label: "Lines of code required" },
  { value: "40+", label: "Countries supported" },
];

const howItWorks = [
  { n: "1", title: "Install LimeCall plugin or paste widget code", desc: "Find LimeCall in the WordPress plugin directory and install with one click — or paste our snippet into your theme footer." },
  { n: "2", title: "Widget appears on your WordPress site", desc: "Configure which pages show the widget from your LimeCall dashboard. Target high-intent pages like pricing, product, or contact." },
  { n: "3", title: "Leads call — your team responds in 28s", desc: "Visitors request a callback. LimeCall dials your team and connects both parties in under 28 seconds." },
];

const steps = [
  { n: "1", title: "Install the LimeCall plugin", desc: "Search for 'LimeCall' in the WordPress plugin directory and install with one click. No FTP, no manual uploads." },
  { n: "2", title: "Connect your account", desc: "Enter your LimeCall API key in the plugin settings. Your widget configuration syncs automatically from the dashboard." },
  { n: "3", title: "Activate and convert", desc: "Enable the plugin and your callback widget is live across your WordPress site — on every page where you want it." },
];

const benefits = [
  { title: "Official WordPress plugin", desc: "Install directly from the WordPress.org plugin directory. Compatible with all major themes and page builders." },
  { title: "Works with WooCommerce", desc: "Add callback widgets to product pages and checkout — capture buyers at the exact moment they need reassurance." },
  { title: "Elementor & Divi ready", desc: "LimeCall integrates cleanly with Elementor, Divi, Beaver Builder, and Gutenberg — no conflicts, no broken layouts." },
  { title: "Page-level control", desc: "Show the widget on specific pages, posts, or post types. Use shortcodes to embed anywhere in your content." },
  { title: "Lead notifications", desc: "Get instant email, SMS, and Slack alerts when a visitor requests a callback from your WordPress site." },
  { title: "GDPR compliant", desc: "LimeCall's WordPress plugin is GDPR ready — data consent options built in for European visitors." },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `LimeCall for ${tool}`, url: seo.canonical }]} />
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall for <span class="text-lime-400">{tool}</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Turn your WordPress site into a lead-capture machine. Install our plugin in minutes and start connecting with visitors via instant callback.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Install Plugin Free →</a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How it works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {howItWorks.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">What you get</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map(b => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{b.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WooCommerce callout -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-950/20 p-8 sm:p-10">
        <h2 class="text-xl font-bold text-white mb-4">Turn WooCommerce browsers into buyers</h2>
        <p class="text-dark-300 leading-relaxed mb-4">
          Shoppers who have a question while browsing don't want to fill out a form or wait for an email reply. With LimeCall on your WooCommerce store, they click a button and talk to someone in under 28 seconds — at the exact moment they're ready to buy.
        </p>
        <p class="text-dark-400 text-sm">
          Works on product pages, cart, checkout, and any custom WooCommerce page.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 group">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between">
              {item.name}
              <span class="ml-4 text-lime-400 text-xl leading-none group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to add LimeCall to your WordPress site?</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="More ways to embed LimeCall" links={[
        { href: '/limecall-for-webflow/', title: 'LimeCall for Webflow', desc: 'Add LimeCall to Webflow with one snippet.' },
        { href: '/click-to-call-software/', title: 'Click-to-Call Software', desc: 'Learn how our core callback feature works.' },
        { href: '/how-it-works/', title: 'How It Works', desc: 'See the full LimeCall flow end to end.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      ]} />
    </div>
  </div>
</Base>
