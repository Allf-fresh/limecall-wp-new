---
interface Props {
  url: string;
  title: string;
  layout: 'horizontal' | 'vertical';
}

const { url, title, layout } = Astro.props;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const shareLinks = [
  {
    label: 'X / Twitter',
    href: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
    viewBox: '0 0 24 24',
    fill: true,
  },
  {
    label: 'LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
    viewBox: '0 0 24 24',
    fill: true,
  },
  {
    label: 'Reddit',
    href: `https://reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`,
    icon: `<path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>`,
    viewBox: '0 0 24 24',
    fill: true,
  },
];
---

<div class={layout === 'vertical' ? 'rounded-xl border border-dark-800 bg-dark-900 p-4' : ''}>
  {layout === 'vertical' && (
    <p class="text-xs font-semibold uppercase tracking-wider text-dark-500 mb-3">Share</p>
  )}
  <div class={layout === 'vertical' ? 'flex flex-col gap-2' : 'flex items-center gap-3'}>
    {shareLinks.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Share on ${link.label}`}
        title={`Share on ${link.label}`}
        class={
          layout === 'vertical'
            ? 'flex items-center gap-2.5 rounded-lg border border-dark-700 bg-dark-800 px-3 py-2 text-sm text-dark-400 hover:border-dark-600 hover:text-lime-400 transition'
            : 'flex items-center justify-center w-9 h-9 rounded-lg border border-dark-700 bg-dark-800 text-dark-400 hover:text-lime-400 hover:border-dark-600 transition'
        }
      >
        <svg
          class="w-4 h-4 flex-shrink-0"
          viewBox={link.viewBox}
          fill={link.fill ? 'currentColor' : 'none'}
          stroke={link.fill ? 'none' : 'currentColor'}
          set:html={link.icon}
        />
        {layout === 'vertical' && <span>{link.label}</span>}
      </a>
    ))}

    <button
      type="button"
      data-copy-url={url}
      aria-label="Copy link"
      title="Copy link"
      class={
        layout === 'vertical'
          ? 'flex items-center gap-2.5 rounded-lg border border-dark-700 bg-dark-800 px-3 py-2 text-sm text-dark-400 hover:border-dark-600 hover:text-lime-400 transition text-left'
          : 'flex items-center justify-center w-9 h-9 rounded-lg border border-dark-700 bg-dark-800 text-dark-400 hover:text-lime-400 hover:border-dark-600 transition'
      }
    >
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
      {layout === 'vertical' && <span>Copy link</span>}
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy-url]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const copyUrl = btn.dataset.copyUrl;
      if (!copyUrl) return;
      navigator.clipboard.writeText(copyUrl).then(() => {
        const original = btn.innerHTML;
        btn.innerHTML = btn.innerHTML.replace(
          /<span>Copy link<\/span>/,
          '<span class="text-lime-400">Copied!</span>'
        );
        setTimeout(() => { btn.innerHTML = original; }, 2000);
      }).catch(() => {});
    });
  });
</script>
