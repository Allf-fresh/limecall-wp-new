---
import Base from '../../layouts/Base.astro';
import posts from '../../data/posts.json';

export async function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const seo = {
  title: post.seo_title,
  description: post.seo_description,
  canonical: post.canonical,
};
---

<Base {seo}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8">
      <time class="text-sm text-gray-500" datetime={post.date}>
        {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl" set:html={post.title} />
    </header>
    <div class="wp-content prose prose-lg max-w-none" set:html={post.content} />
  </article>
</Base>
