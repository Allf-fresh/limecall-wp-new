---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Customer Retention Software — Keep Customers Longer | LimeCall',
  description: 'Proactive callbacks that keep customers from churning. 5x cheaper to retain than acquire. Prevent 67% of churn with timely outreach. 3x higher LTV.',
  canonical: `${site.url}/retention/`,
};

const stats = [
  { value: '5x', label: 'Cheaper to Retain', sub: 'than acquiring an equivalent new customer' },
  { value: '67%', label: 'Churn is Preventable', sub: 'when at-risk customers are contacted proactively' },
  { value: '28s', label: 'Callback Speed', sub: 'when a customer needs help or shows churn signals' },
  { value: '3x', label: 'Higher LTV', sub: 'for customers who receive proactive success calls' },
];

const features = [
  {
    icon: '📞',
    name: 'Proactive Callback Campaigns',
    description: 'Schedule automated callback campaigns for onboarding, health checks, and renewal milestones. Reach every customer before problems become cancellations.',
  },
  {
    icon: '🚨',
    name: 'At-Risk Customer Alerts',
    description: 'Connect your product data or CRM to trigger alerts when a customer shows churn signals — low usage, missed logins, support tickets, or NPS drop.',
  },
  {
    icon: '🔄',
    name: 'Re-Engagement Workflows',
    description: 'Automatically trigger a callback to dormant customers who haven\'t logged in or engaged in a defined period. Catch disengagement before it becomes cancellation.',
  },
  {
    icon: '⭐',
    name: 'Customer Satisfaction Calls',
    description: 'Schedule periodic satisfaction calls at key customer lifecycle moments — 30 days, 90 days, renewal time. Build relationships that make cancellation feel wrong.',
  },
  {
    icon: '🔔',
    name: 'Renewal Reminder Callbacks',
    description: 'Automatically call customers 30 days before renewal to address objections, discuss expansion opportunities, and secure the renewal before the invoice drops.',
  },
  {
    icon: '✅',
    name: 'Success Check-In Calls',
    description: 'Schedule regular success check-in calls triggered by product milestones, feature adoption events, or time intervals. Prove value proactively, not reactively.',
  },
];

const useCases = [
  {
    icon: '🏢',
    title: 'SaaS Customer Success',
    description: 'CS teams use LimeCall to trigger proactive calls when usage drops, features go untouched, or NPS surveys come back negative — turning at-risk accounts into advocates.',
  },
  {
    icon: '📦',
    title: 'Subscription & E-commerce',
    description: 'Call subscription customers before their renewal date to personalise the experience, address concerns, and reduce involuntary churn from payment failures.',
  },
  {
    icon: '🏦',
    title: 'Financial Services',
    description: 'Proactively call clients when market events, portfolio performance, or life events indicate a need for reassurance — reducing account closure rates dramatically.',
  },
  {
    icon: '🎓',
    title: 'Education & Membership',
    description: 'Call students or members who have stopped engaging with content or events. A personal phone call is far more effective at re-activating than an email.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Define Your At-Risk Signals',
    description: 'Connect your CRM or product analytics to LimeCall. Define what "at-risk" looks like — low usage, missed logins, support tickets, negative NPS, approaching renewal.',
  },
  {
    number: '02',
    title: 'LimeCall Triggers the Callback',
    description: 'When a customer hits an at-risk threshold, LimeCall automatically schedules and dials the customer success rep and the customer — no manual intervention needed.',
  },
  {
    number: '03',
    title: 'Retain the Customer',
    description: 'Your CS rep speaks with an at-risk customer who feels valued and heard. The conversation is logged, outcomes tracked, and follow-up sequences scheduled automatically.',
  },
];

const faqs = [
  {
    question: 'How does LimeCall help with customer retention?',
    answer: 'LimeCall powers proactive callback campaigns that reach customers before they decide to cancel. By triggering automatic callbacks at key lifecycle moments — onboarding, health checks, renewals, re-engagement — LimeCall ensures every at-risk customer hears from a human voice, not just an automated email. Customers who receive personal calls have 3x higher lifetime value.',
  },
  {
    question: 'What is a proactive callback retention strategy?',
    answer: 'A proactive callback strategy means calling customers before they have a problem or a reason to cancel — not in response to a cancellation request. This includes onboarding calls (build early value), 30/60/90-day health checks, proactive renewal conversations, and re-engagement calls for dormant users. Research shows 67% of churn is preventable with timely outreach.',
  },
  {
    question: 'When should I call at-risk customers?',
    answer: 'The optimal time to call an at-risk customer is the moment they show a churn signal — not after they have submitted a cancellation. Key signals include: login frequency drops below their baseline, they haven\'t used a core feature in 14+ days, they submitted a negative CSAT survey, a key user left the company, or their renewal is 30 days away. LimeCall can trigger callbacks automatically at any of these points.',
  },
  {
    question: 'How do I know who is at risk of churning?',
    answer: 'Common churn signals include: reduced product usage, decreased login frequency, increased support ticket volume, low NPS scores, key stakeholder turnover, and missed renewal payments. You can connect these signals to LimeCall via webhook or CRM integration — so when a customer hits your defined threshold, an automatic callback fires immediately.',
  },
  {
    question: 'Can I automate retention calls with LimeCall?',
    answer: 'Yes. LimeCall\'s programmable callback API and Zapier integration allow you to automate retention calls triggered by any data signal. Common automations include: low NPS score triggers a CS manager callback, 14 days of inactivity triggers a re-engagement call, and 30 days before renewal triggers a proactive renewal conversation. All callbacks are logged to your CRM with call recordings.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqJsonLd} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Customer Retention', url: `${site.url}/retention/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        Customer Retention
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Proactive Callbacks that<br />
        <span class="text-lime-400">Keep Customers from Churning</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Retention is 5x cheaper than acquisition. LimeCall triggers proactive callbacks when customers show at-risk signals — turning potential cancellations into loyal, high-LTV accounts.
      </p>

      <div class="mt-8 inline-flex items-center gap-4 rounded-2xl border border-lime-500/20 bg-lime-500/5 px-6 py-4">
        <div class="text-left">
          <div class="text-3xl font-extrabold text-lime-400">67%</div>
          <div class="text-sm text-dark-300">of churn is preventable</div>
        </div>
        <div class="h-10 w-px bg-dark-700"></div>
        <div class="text-left text-sm text-dark-400 max-w-xs">
          Research shows 67% of customer churn is avoidable with timely, proactive outreach.
        </div>
      </div>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free — No Card Needed
        </a>
        <a
          href="/contact-us"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          Request a Demo
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Free plan available · No developer needed · Integrates with your CRM</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/60 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-center">
        {stats.map((s) => (
          <div class="p-4">
            <div class="text-4xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-2 text-sm font-bold text-white">{s.label}</div>
            <div class="mt-1 text-xs text-dark-500">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Tools for Proactive<br />
          <span class="text-lime-400">Customer Retention</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          LimeCall helps customer success and account management teams reach customers before problems escalate into cancellations.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{f.name}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Proactive Retention Across<br />
          <span class="text-lime-400">Every Industry</span>
        </h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {useCases.map((uc) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-3">{uc.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          How Retention Callbacks<br />
          <span class="text-lime-400">Work in Practice</span>
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="relative flex flex-col rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="text-4xl font-extrabold text-lime-500/20 mb-4 leading-none">{step.number}</div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Stop Losing Customers You Already Won.<br />
        <span class="text-lime-400">Start Retaining with Proactive Callbacks.</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        Set up automated retention callbacks in minutes. Reach at-risk customers before they cancel — automatically.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free Trial
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          View Pricing
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">No credit card required · Free plan available · Cancel anytime</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="More LimeCall Use Cases"
        links={[
          { href: '/customer-callback-software', title: 'Customer Callback Software', desc: 'Automated callbacks for every customer touchpoint.' },
          { href: '/speed-to-lead', title: 'Speed to Lead', desc: 'Respond to new leads in under 28 seconds.' },
          { href: '/for-sales-teams', title: 'For Sales Teams', desc: 'LimeCall tools built specifically for sales and CS teams.' },
          { href: '/pricing', title: 'Pricing', desc: 'Start free. Upgrade as your team grows.' },
        ]}
      />
    </div>
  </section>
</Base>
