---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';
import FeatureCard from '../components/FeatureCard.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { faqSchema } from '../lib/seo';
import { site, plans, features } from '../site.config';
import postsData from '../data/posts.json';

const latestPosts = postsData.slice(0, 3);
const featuredFeatures = features.slice(0, 6);

const faqs = [
  {
    question: 'How does LimeCall connect website visitors to my sales team?',
    answer: 'LimeCall places a callback widget on your website. When a visitor clicks it and enters their phone number, LimeCall simultaneously dials your sales rep and the visitor, connecting them in an average of 28 seconds.',
  },
  {
    question: 'How long does it take to set up LimeCall?',
    answer: 'Setup takes under 5 minutes. You paste a single JavaScript snippet into your website — no developer required. Works with WordPress, Webflow, Shopify, and any HTML site.',
  },
  {
    question: 'Does LimeCall work with my CRM?',
    answer: 'Yes. LimeCall integrates natively with HubSpot, Salesforce, Pipedrive, and Zoho. All call data, recordings, and lead info sync automatically after every call.',
  },
  {
    question: 'What happens when my team is offline?',
    answer: 'When your team is unavailable, visitors can schedule a callback for a specific time. LimeCall sends your team reminders and ensures no lead is ever lost.',
  },
  {
    question: 'Is there a free plan?',
    answer: 'Yes. LimeCall offers a free Basic plan with 30 calls per month — no credit card required. Upgrade to a paid plan as your call volume grows.',
  },
];
---

<Base
  title={`${site.name} — ${site.tagline}`}
  description={site.description}
  canonical={`${site.url}/`}
>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
    <div class="absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 -translate-x-1/2 h-[600px] w-[800px] rounded-full bg-lime-500/10 blur-[120px]"></div>
    </div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <span class="inline-block mb-6 rounded-full bg-lime-500/10 px-4 py-1.5 text-sm font-semibold text-lime-400">
          #1 Callback Automation Platform
        </span>
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl leading-tight">
          Turn Website Visitors Into
          <span class="text-lime-400"> Sales Calls in 28 Seconds</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-dark-300 sm:text-xl">
          LimeCall connects your sales team with website visitors instantly — before they bounce to a competitor. No hold music. No friction. Just more conversations and more closed deals.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <Button href={site.cta.href} size="lg">
            {site.cta.text}
          </Button>
          <Button href="/how-it-works" variant="outline" size="lg">
            See How It Works
          </Button>
        </div>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-dark-400">
          <span>&#10003; {site.cta.subtext}</span>
          <span>&#10003; 28 second average callback</span>
          <span>&#10003; Up to 300% more conversions</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof stats row -->
  <section class="border-y border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4 text-center">
        <div>
          <div class="text-4xl font-extrabold text-lime-400">3x</div>
          <div class="mt-1 text-sm text-dark-400">more leads vs. web forms</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-lime-400">28s</div>
          <div class="mt-1 text-sm text-dark-400">average callback time</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-lime-400">50+</div>
          <div class="mt-1 text-sm text-dark-400">countries covered</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-lime-400">10,000+</div>
          <div class="mt-1 text-sm text-dark-400">businesses trust LimeCall</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20 border-b border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">How LimeCall Works</h2>
        <p class="mt-4 text-lg text-dark-400">From widget click to live sales call in three automated steps.</p>
      </div>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="relative flex flex-col items-center text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-full bg-lime-500/20 border-2 border-lime-500/40 text-2xl font-extrabold text-lime-400 mb-5">1</div>
          <h3 class="text-lg font-bold text-white mb-2">Visitor clicks your widget</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Your LimeCall button appears on your website. A visitor enters their phone number and clicks — it takes under 10 seconds.</p>
        </div>
        <div class="relative flex flex-col items-center text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-full bg-lime-500/20 border-2 border-lime-500/40 text-2xl font-extrabold text-lime-400 mb-5">2</div>
          <h3 class="text-lg font-bold text-white mb-2">LimeCall dials both sides</h3>
          <p class="text-sm text-dark-400 leading-relaxed">LimeCall simultaneously dials your sales rep and the visitor. Both pick up and are instantly bridged — in under 28 seconds.</p>
        </div>
        <div class="relative flex flex-col items-center text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-full bg-lime-500/20 border-2 border-lime-500/40 text-2xl font-extrabold text-lime-400 mb-5">3</div>
          <h3 class="text-lg font-bold text-white mb-2">Call logged, CRM updated</h3>
          <p class="text-sm text-dark-400 leading-relaxed">The call is recorded, tagged, and synced to your CRM automatically. Your pipeline is always up to date — zero manual entry.</p>
        </div>
      </div>
      <div class="mt-10 text-center">
        <a href="/how-it-works" class="text-lime-400 hover:text-lime-300 font-medium text-sm transition">
          See the full flow in detail →
        </a>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-16 sm:py-20 border-b border-dark-800">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Everything you need to convert more leads</h2>
        <p class="mt-4 text-lg text-dark-400">Built for sales and marketing teams who want results, not complexity.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredFeatures.map((feature) => (
          <FeatureCard
            icon={feature.icon}
            name={feature.name}
            description={feature.description}
            href={`/features/${feature.slug}`}
          />
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/features" class="text-lime-400 hover:text-lime-300 font-medium text-sm transition">
          View all features →
        </a>
        <div class="mt-8 text-center">
          <a href="/click-to-call-software" class="text-dark-400 hover:text-lime-400 text-sm mr-6 transition">Click-to-Call</a>
          <a href="/customer-callback-software" class="text-dark-400 hover:text-lime-400 text-sm mr-6 transition">Callback Software</a>
          <a href="/lead-distribution" class="text-dark-400 hover:text-lime-400 text-sm mr-6 transition">Lead Distribution</a>
          <a href="/virtual-numbers" class="text-dark-400 hover:text-lime-400 text-sm mr-6 transition">Virtual Numbers</a>
          <a href="/business-texting" class="text-dark-400 hover:text-lime-400 text-sm transition">Web to Text</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20 border-b border-dark-800 bg-dark-900/30">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Built for every team that sells</h2>
        <p class="mt-4 text-lg text-dark-400">LimeCall fits into any workflow — from high-volume sales floors to solo consultants.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">💼</div>
          <h3 class="font-bold text-white mb-2">Sales Teams</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Connect with inbound leads instantly. Auto-route to the right rep. Never let a hot prospect go cold.</p>
          <a href="/for-sales-teams" class="mt-3 block text-xs text-lime-400 hover:text-lime-300 transition">For Sales Teams →</a>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">📣</div>
          <h3 class="font-bold text-white mb-2">Marketing Teams</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Track which campaigns drive phone calls. Assign unique numbers per channel and measure ROI precisely.</p>
          <a href="/for-marketing-teams" class="mt-3 block text-xs text-lime-400 hover:text-lime-300 transition">For Marketing →</a>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">🛒</div>
          <h3 class="font-bold text-white mb-2">E-commerce</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Recover abandoning shoppers with a quick call. Reduce cart abandonment and boost average order value.</p>
          <a href="/limecall-for-ecommerce-and-retail-2" class="mt-3 block text-xs text-lime-400 hover:text-lime-300 transition">For E-commerce →</a>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">🎧</div>
          <h3 class="font-bold text-white mb-2">Customer Support</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Offer instant callback instead of hold music. Customers prefer it and your team handles more calls efficiently.</p>
          <a href="/use-cases" class="mt-3 block text-xs text-lime-400 hover:text-lime-300 transition">All Use Cases →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="py-14 border-b border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-dark-500 mb-8">Integrates with your existing stack</p>
      <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10">
        {['HubSpot', 'Salesforce', 'Slack', 'Zendesk', 'WordPress', 'Webflow', 'Zapier', 'Pipedrive'].map((name) => (
          <span class="rounded-lg border border-dark-800 bg-dark-900/60 px-5 py-2.5 text-sm font-medium text-dark-300 hover:border-lime-500/30 hover:text-white transition">
            {name}
          </span>
        ))}
      </div>
      <a href="/integrations" class="mt-8 inline-block text-xs text-lime-400 hover:text-lime-300 transition">View all integrations →</a>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 sm:py-20 border-b border-dark-800 bg-dark-900/30">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold text-white sm:text-3xl">Trusted by sales teams worldwide</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
          <p class="text-dark-300 leading-relaxed text-sm italic">"LimeCall increased our inbound call volume by 80% in the first month. The setup was under 15 minutes."</p>
          <p class="mt-4 text-xs text-dark-500">— Sales Director, LimeCall customer</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
          <p class="text-dark-300 leading-relaxed text-sm italic">"We respond to every lead in under 30 seconds now. Our close rate went up 3x compared to using contact forms."</p>
          <p class="mt-4 text-xs text-dark-500">— Head of Growth, B2B SaaS company</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
          <p class="text-dark-300 leading-relaxed text-sm italic">"The CRM sync alone saved our team 2 hours per day. Every call is automatically logged — no manual entry needed."</p>
          <p class="mt-4 text-xs text-dark-500">— VP Sales, LimeCall customer</p>
        </div>
      </div>
      <div class="mt-8 text-center">
        <span class="text-sm text-dark-500">Rated <span class="font-bold text-white">4.6/5</span> on G2 &amp; Capterra</span>
      </div>
    </div>
  </section>

  <!-- Pricing Preview -->
  <section class="py-16 sm:py-20 border-b border-dark-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Simple, transparent pricing</h2>
      <p class="mt-4 text-lg text-dark-400">Start for free, upgrade when you're ready.</p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 max-w-2xl mx-auto">
        {plans.map((plan) => (
          <div class:list={[
            'rounded-xl border p-6 text-left',
            plan.highlighted ? 'border-lime-500/50 bg-dark-900' : 'border-dark-800 bg-dark-900/50',
          ]}>
            {plan.highlighted && (
              <span class="inline-block mb-2 text-xs font-semibold text-lime-400 uppercase tracking-wider">Most Popular</span>
            )}
            <h3 class="text-lg font-bold text-white">{plan.name}</h3>
            <p class="text-dark-400 text-sm mt-1">{plan.subtitle}</p>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-3xl font-bold text-white">${plan.monthly}</span>
              <span class="text-dark-400 text-sm">/mo</span>
            </div>
            <a
              href={plan.cta.href}
              class:list={[
                'mt-5 block rounded-lg py-2.5 text-center text-sm font-bold transition',
                plan.highlighted
                  ? 'bg-lime-500 text-dark-950 hover:bg-lime-400'
                  : 'border border-dark-700 text-white hover:border-lime-500/40 hover:text-lime-400',
              ]}
            >
              {plan.cta.text}
            </a>
          </div>
        ))}
      </div>
      <p class="mt-6 text-dark-500 text-sm">
        <a href="/pricing" class="text-lime-400 hover:text-lime-300">See full pricing details →</a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-20 border-b border-dark-800 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Teaser -->
  <section class="py-16 sm:py-20 border-b border-dark-800">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
        <div>
          <h2 class="text-2xl font-bold text-white">Latest from the blog</h2>
          <p class="mt-1 text-dark-400">Guides, tips, and news.</p>
        </div>
        <a href="/post" class="text-sm text-lime-400 hover:text-lime-300 font-medium transition hidden sm:block">
          View all →
        </a>
      </div>

      {latestPosts.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-3">
          {latestPosts.map((post) => (
            <a
              href={`/post/${post.slug}/`}
              class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6 transition-all hover:border-dark-700"
            >
              <h3 class="mt-2 font-semibold text-white group-hover:text-lime-400 transition line-clamp-2">{post.title}</h3>
              <p class="mt-2 text-sm text-dark-400 line-clamp-2">
                {post.excerpt ? post.excerpt : post.content.replace(/<[^>]+>/g, '').slice(0, 150)}
              </p>
              {post.date && (
                <time class="mt-4 block text-xs text-dark-500" datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-12 text-center">
          <p class="text-dark-400">Blog posts coming soon.</p>
        </div>
      )}

      <div class="mt-8 text-center sm:hidden">
        <a href="/post" class="text-sm text-lime-400 hover:text-lime-300 font-medium">View all posts →</a>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Ready to convert more website visitors?
      </h2>
      <p class="mt-4 text-lg text-dark-400">
        Join thousands of businesses using LimeCall to turn website traffic into revenue. {site.cta.subtext}.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={site.cta.href} size="lg">
          {site.cta.text}
        </Button>
        <Button href="/click-to-call-software" variant="outline" size="lg">
          See Click-to-Call Software
        </Button>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-dark-500">
        <a href="/virtual-numbers" class="hover:text-lime-400 transition">Virtual Numbers</a>
        <span>·</span>
        <a href="/pricing" class="hover:text-lime-400 transition">Pricing</a>
        <span>·</span>
        <a href="/features" class="hover:text-lime-400 transition">All Features</a>
        <span>·</span>
        <a href="/integrations" class="hover:text-lime-400 transition">Integrations</a>
      </div>
    </div>
  </section>
</Base>
