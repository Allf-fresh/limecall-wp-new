---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Virtual Receptionist Service | AI-Powered | LimeCall',
  description: 'LimeCall\'s virtual receptionist service answers calls 24/7 with AI intelligence. From £57/mo flat — no per-call fees. Replace expensive phone answering services.',
  canonical: `${site.url}/virtual-receptionist/`,
};

const stats = [
  { value: '6,600+', label: 'Businesses searching monthly' },
  { value: '24/7/365', label: 'Always-on phone answering' },
  { value: '£57/mo', label: 'Flat rate vs £800/mo average' },
  { value: '28s', label: 'Avg transfer to your team' },
];

const features = [
  { icon: '📞', title: 'Instant Call Answering', desc: 'Every call answered in under 1 second — no hold music, no voicemail. Your callers speak to a professional virtual receptionist immediately.' },
  { icon: '🎯', title: 'Lead Qualification Built In', desc: 'Unlike basic phone answering services, LimeCall qualifies every caller on Budget, Authority, Need, and Timeline before routing or scheduling.' },
  { icon: '📅', title: 'Appointment Scheduling', desc: 'AI books appointments directly into your calendar system. Callers pick a time, get confirmation via SMS, and your team gets full context.' },
  { icon: '⚡', title: 'Instant Hot Transfer', desc: 'High-priority callers connect to your team in 28 seconds. The AI passes full qualification data so your rep is prepared before they say hello.' },
  { icon: '🔗', title: 'CRM & Tool Integration', desc: 'Every call auto-syncs to Salesforce, HubSpot, Pipedrive, and 1,000+ tools via Zapier. Zero manual data entry, zero missed records.' },
  { icon: '💬', title: 'SMS & Email Follow-Up', desc: 'Callers who can\'t be transferred get instant SMS with callback links or email confirmations. No lead slips through the cracks.' },
  { icon: '🌍', title: '12-Language Support', desc: 'Serve callers in English, Spanish, French, German, and 8 more languages. One virtual receptionist for your entire global operation.' },
  { icon: '📊', title: 'Real-Time Analytics', desc: 'Dashboard showing call volumes, peak times, qualification rates, and conversion metrics. Make data-driven staffing decisions.' },
];

const pricingRows = [
  ['LimeCall AI', '£57/mo', '£0', '£0', 'None', '✅ Yes'],
  ['Ruby Receptionist', '£349/mo', '£1.50+ overflow', '£95', '12 months', '💰 Extra'],
  ['Moneypenny', '£200/mo', '£1–3 per call', '£150', '6 months', '⚠️ Limited'],
  ['AnswerConnect', '£179/mo', '£0.99 per call', '£50', 'Monthly', '✅ Yes'],
  ['Davinci Virtual', '£129/mo', '£1.75 per min', '£0', 'Monthly', '❌ No'],
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is a virtual receptionist?',
      acceptedAnswer: { '@type': 'Answer', text: 'A virtual receptionist is a phone answering service that handles incoming business calls remotely — greeting callers, taking messages, qualifying leads, scheduling appointments, and routing calls to the right team member. Virtual receptionists can be human-operated, AI-powered, or a hybrid of both. LimeCall offers an AI-powered virtual receptionist that costs 90% less than human alternatives while providing 24/7 coverage.' }
    },
    {
      '@type': 'Question',
      name: 'How much does a virtual receptionist cost?',
      acceptedAnswer: { '@type': 'Answer', text: 'Virtual receptionist costs vary widely. Human-operated virtual receptionist services typically charge £200–800 per month with per-call or per-minute fees on top. AI-powered virtual receptionists like LimeCall start at £57/mo flat with no per-call fees. Traditional phone answering services charge £1–4 per call. When evaluating cost, factor in setup fees, contract length, after-hours surcharges, and per-call overflow charges — LimeCall has none of these.' }
    },
    {
      '@type': 'Question',
      name: 'What is the difference between a virtual receptionist and an answering service?',
      acceptedAnswer: { '@type': 'Answer', text: 'A traditional answering service primarily takes messages and forwards them to you. A virtual receptionist provides a more comprehensive service: greeting callers professionally, qualifying enquiries, scheduling appointments, transferring calls, and integrating with your business tools. LimeCall\'s AI-powered virtual receptionist goes further by qualifying leads using BANT methodology and scoring callers in real-time — something neither basic answering services nor most human virtual receptionists can do.' }
    },
    {
      '@type': 'Question',
      name: 'What is the best virtual receptionist for small business?',
      acceptedAnswer: { '@type': 'Answer', text: 'The best virtual receptionist for small business combines low cost, 24/7 availability, no per-call fees, and zero long-term contracts. LimeCall meets all four criteria at £57/mo flat. For small businesses, key requirements are: answering calls outside business hours (when 35% of purchase-intent calls happen), qualifying leads before they reach you (saving time), and CRM integration (eliminating manual data entry). AI-powered options like LimeCall are particularly well-suited because they scale instantly without hiring.' }
    },
    {
      '@type': 'Question',
      name: 'Can a virtual receptionist schedule appointments?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. LimeCall\'s AI virtual receptionist integrates with Google Calendar, Outlook, Calendly, and other scheduling tools. When a caller wants to book an appointment, the AI checks availability in real-time, offers available slots, confirms the booking, and sends SMS/email confirmation to both the caller and your team. The appointment appears in your calendar with full caller details and qualification notes attached.' }
    },
    {
      '@type': 'Question',
      name: 'Do I need to change my phone number to use a virtual receptionist?',
      acceptedAnswer: { '@type': 'Answer', text: 'No. LimeCall works with your existing phone number. You can set up call forwarding from your current number to LimeCall, or use our widget on your website. Setup takes under 5 minutes with no engineering work, no hardware changes, and no disruption to your current phone system. Your callers experience a seamless, professional interaction from the first call.' }
    },
    {
      '@type': 'Question',
      name: 'How does an AI virtual receptionist compare to a human one?',
      acceptedAnswer: { '@type': 'Answer', text: 'AI virtual receptionists answer instantly (under 1 second vs 15-90 seconds for humans), handle unlimited concurrent calls (vs one call per person), provide perfect consistency 24/7, and cost 90% less. Human virtual receptionists excel at complex emotional conversations, nuanced negotiations, and VIP relationship management. LimeCall\'s approach: AI handles 95% of calls with instant qualification and routing, then seamlessly escalates complex situations to your human team with full context.' }
    },
    {
      '@type': 'Question',
      name: 'Is a virtual receptionist GDPR compliant?',
      acceptedAnswer: { '@type': 'Answer', text: 'LimeCall\'s virtual receptionist is fully GDPR compliant. All call data is processed and stored within EU-compliant infrastructure. Caller data is encrypted in transit and at rest. You control data retention periods, and callers can request data deletion at any time. LimeCall also supports custom data processing agreements (DPAs) for enterprise customers. Call recordings and transcripts are accessible only to authorised team members within your account.' }
    },
  ],
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'LimeCall Virtual Receptionist',
  description: 'AI-powered virtual receptionist service and phone answering solution that handles calls 24/7, qualifies leads, and integrates with your CRM.',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '57',
    priceCurrency: 'GBP',
    priceValidUntil: '2026-12-31',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.5',
    reviewCount: '312',
  },
};

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: seo.title,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.speakable-answer'],
  },
  url: seo.canonical,
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={appSchema} />
  <JsonLd schema={speakableSchema} />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumbs items={[{ name: 'Virtual Receptionist', url: `${site.url}/virtual-receptionist/` }]} />
      <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400">
        📞 AI-Powered Phone Answering Service
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Virtual Receptionist Service<br class="hidden sm:block" />
        <span class="text-lime-400">— AI That Never Sleeps</span>
      </h1>
      <div class="speakable-answer mx-auto mt-6 max-w-2xl text-lg text-dark-300">
        <p>A virtual receptionist is a phone answering service that handles incoming business calls remotely — greeting callers, taking messages, qualifying leads, and routing calls to the right team member. LimeCall's AI-powered virtual receptionist answers in under 1 second, costs 90% less than human operators, and qualifies leads with BANT methodology before transferring.</p>
      </div>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center justify-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free — No Credit Card
        </a>
        <a href="/demo/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-dark-700 px-8 py-4 text-sm font-semibold text-white transition hover:border-lime-500/40 hover:text-lime-400">
          See It in Action →
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">★ 4.5 · 10,000+ businesses · From £57/mo flat</p>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-y border-dark-800 bg-dark-900/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <dt class="text-3xl font-extrabold text-lime-400">{s.value}</dt>
            <dd class="mt-1 text-sm text-dark-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- What is a Virtual Receptionist -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">What Is a Virtual Receptionist?</h2>
      </div>
      <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8 sm:p-10">
        <p class="text-dark-300 leading-relaxed text-lg">A <strong class="text-white">virtual receptionist</strong> is a remote phone answering service that handles your incoming business calls professionally — without requiring a physical receptionist at your office. Virtual receptionists greet callers, take messages, qualify enquiries, schedule appointments, transfer calls to the right person, and log everything in your CRM.</p>
        <p class="mt-4 text-dark-300 leading-relaxed">Traditional virtual receptionist services use human operators working from call centres. LimeCall takes a different approach: our AI-powered virtual receptionist uses natural language processing to handle calls with the quality of a trained human — at a fraction of the cost, with true 24/7/365 availability.</p>
        <p class="mt-4 text-dark-300 leading-relaxed">The result: every call answered instantly, every lead qualified systematically, and your team only speaks to prospects who are ready to buy.</p>
      </div>
    </div>
  </section>

  <!-- Types of Virtual Receptionist Services -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Types of Virtual Receptionist Services</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-dark-800 text-2xl mb-4">👤</div>
          <h3 class="text-xl font-bold text-white mb-3">Human-Operated</h3>
          <p class="text-sm text-dark-400 mb-4">Live operators answer calls from a remote call centre. Professional but expensive, limited by staffing hours, and constrained to 1 call per operator at a time.</p>
          <ul class="space-y-2 text-sm text-dark-400">
            <li>✓ Personal touch for sensitive calls</li>
            <li>✗ £300–800/mo for 100 calls</li>
            <li>✗ Limited after-hours availability</li>
            <li>✗ Cannot scale instantly</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-500/5 to-dark-900 p-8">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-lime-500/10 text-2xl mb-4">🤖</div>
          <h3 class="text-xl font-bold text-lime-400 mb-3">AI-Powered (LimeCall)</h3>
          <p class="text-sm text-dark-300 mb-4">Natural language AI answers calls instantly, qualifies leads, schedules appointments, and integrates with your CRM. True 24/7 coverage at a flat monthly rate.</p>
          <ul class="space-y-2 text-sm text-dark-300">
            <li class="text-lime-400">✓ £57/mo flat — unlimited calls</li>
            <li class="text-lime-400">✓ True 24/7/365 availability</li>
            <li class="text-lime-400">✓ 500 concurrent calls</li>
            <li class="text-lime-400">✓ Full BANT lead qualification</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-dark-800 text-2xl mb-4">🔄</div>
          <h3 class="text-xl font-bold text-white mb-3">Hybrid</h3>
          <p class="text-sm text-dark-400 mb-4">AI handles first-touch qualification and routine calls, then escalates complex situations to human operators. Best of both worlds — if you can afford both.</p>
          <ul class="space-y-2 text-sm text-dark-400">
            <li>✓ AI efficiency + human empathy</li>
            <li>✗ Higher cost than pure AI</li>
            <li>✓ Covers all call types</li>
            <li>✓ LimeCall supports this model</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Virtual Receptionist Pricing Comparison -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-6">Virtual Receptionist Pricing Comparison</h2>
      <p class="text-center text-dark-300 mb-12 max-w-2xl mx-auto">We compared the leading phone answering service providers so you don't have to. LimeCall's AI-powered virtual receptionist delivers more features at a fraction of the cost.</p>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              {['Provider', 'Monthly Cost', 'Per-Call Fee', 'Setup Fee', 'Contract', '24/7'].map(h => (
                <th class={`px-5 py-4 text-left font-semibold ${h === 'Provider' ? 'text-dark-300' : 'text-dark-300'}`}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {pricingRows.map((row, i) => (
              <tr class={`${i === 0 ? 'bg-lime-500/5' : ''} hover:bg-dark-800/30 transition`}>
                <td class={`px-5 py-4 font-medium ${i === 0 ? 'text-lime-400 font-bold' : 'text-dark-200'}`}>{row[0]}</td>
                <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{row[1]}</td>
                <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{row[2]}</td>
                <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{row[3]}</td>
                <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{row[4]}</td>
                <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{row[5]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-xs text-dark-500 text-center">Pricing as of March 2026. All prices approximate and may vary by plan tier. LimeCall pricing verified.</p>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Virtual Receptionist Features</h2>
        <p class="mt-4 text-lg text-dark-300 max-w-2xl mx-auto">Everything a phone answering service should include — and features that traditional virtual receptionist services can't match.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-dark-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Virtual Receptionist for Small Business -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-8">Virtual Receptionist for Small Business</h2>
      <p class="text-center text-dark-300 mb-12 max-w-2xl mx-auto">Small businesses lose an estimated 62% of incoming calls during business hours — and 78% of callers who reach voicemail never call back. An answering service for small business changes that equation entirely.</p>
      <div class="grid gap-8 sm:grid-cols-2">
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
          <h3 class="text-xl font-bold text-white mb-4">Why Small Businesses Need a Virtual Receptionist</h3>
          <ul class="space-y-3 text-sm text-dark-300">
            <li class="flex gap-3"><span class="text-lime-400 shrink-0 font-bold">01</span> You're too busy serving clients to answer every call</li>
            <li class="flex gap-3"><span class="text-lime-400 shrink-0 font-bold">02</span> After-hours calls go to voicemail — and 78% don't leave one</li>
            <li class="flex gap-3"><span class="text-lime-400 shrink-0 font-bold">03</span> Hiring a full-time receptionist costs £25,000+/yr</li>
            <li class="flex gap-3"><span class="text-lime-400 shrink-0 font-bold">04</span> Every missed call is revenue walking to a competitor</li>
            <li class="flex gap-3"><span class="text-lime-400 shrink-0 font-bold">05</span> You need professional call handling to build trust</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-500/5 to-dark-900 p-8">
          <h3 class="text-xl font-bold text-lime-400 mb-4">How LimeCall Solves It</h3>
          <ul class="space-y-3 text-sm text-dark-300">
            <li class="flex gap-3"><span class="text-lime-400 shrink-0">✓</span> AI answers every call instantly — you focus on your work</li>
            <li class="flex gap-3"><span class="text-lime-400 shrink-0">✓</span> 24/7/365 coverage captures every lead, day and night</li>
            <li class="flex gap-3"><span class="text-lime-400 shrink-0">✓</span> £57/mo flat — 97% cheaper than hiring a receptionist</li>
            <li class="flex gap-3"><span class="text-lime-400 shrink-0">✓</span> Qualified leads transferred to you in 28 seconds</li>
            <li class="flex gap-3"><span class="text-lime-400 shrink-0">✓</span> Professional, consistent greeting on every single call</li>
          </ul>
        </div>
      </div>
      <p class="mt-8 text-center text-dark-300">For small businesses, a virtual receptionist isn't a luxury — it's the difference between growing and losing leads to competitors who answer faster. At £57/mo, LimeCall pays for itself with one converted call per month for most businesses.</p>
    </div>
  </section>

  <!-- Industry Use Cases -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Virtual Receptionist by Industry</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { icon: '⚖️', title: 'Legal Firms', desc: 'Client intake qualification, case type routing, and after-hours coverage for urgent matters. Ensure no potential client goes unanswered.', href: '/legal/' },
          { icon: '🦷', title: 'Dental & Medical', desc: 'Patient appointment booking, insurance verification, and triage-level routing. Reduce no-shows with SMS confirmations.', href: '/healthcare/' },
          { icon: '🏠', title: 'Real Estate', desc: 'Property enquiry qualification — budget, timeline, location — before connecting to the listing agent. Capture leads from portal ads 24/7.', href: '/real-estate/' },
          { icon: '🔧', title: 'Trades & Contractors', desc: 'Emergency call routing, job booking, and quote request qualification. Never miss an emergency plumbing call at 2am again.', href: '/trades/' },
          { icon: '💰', title: 'Financial Services', desc: 'Compliant call handling, initial KYC collection, and qualified appointment scheduling with advisors.', href: '/financial-services/' },
          { icon: '💻', title: 'SaaS & Tech', desc: 'Demo request qualification, trial signup callbacks, and instant routing to sales when a prospect is ready to buy.', href: '/saas/' },
        ].map(item => (
          <a href={item.href} class="group rounded-2xl border border-dark-800 bg-dark-900/60 p-8 hover:border-lime-500/30 transition block">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="text-lg font-bold text-white mb-3 group-hover:text-lime-400 transition">{item.title}</h3>
            <p class="text-sm text-dark-400">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Case Study -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-500/5 to-dark-900 p-10">
        <div class="text-xs font-semibold text-lime-400 uppercase tracking-wider mb-4">Case Study</div>
        <h2 class="text-2xl font-extrabold text-white sm:text-3xl">Dental Practice Reduces Missed Patient Calls by 67%</h2>
        <p class="mt-4 text-dark-300 leading-relaxed">A busy dental practice with 3 dentists was losing patients because their reception team couldn't keep up with call volume during peak hours. Calls during lunch breaks and after 5pm went to voicemail — and most patients simply called the next practice on the list.</p>
        <p class="mt-4 text-dark-300 leading-relaxed">After deploying LimeCall's AI virtual receptionist, every call was answered instantly — including evenings and weekends. The AI books appointments directly into their practice management software, confirms via SMS, and flags emergency cases for immediate callback.</p>
        <div class="mt-8 grid grid-cols-3 gap-6">
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">67%</div>
            <div class="mt-1 text-sm text-dark-400">Fewer missed calls</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">23%</div>
            <div class="mt-1 text-sm text-dark-400">More appointments booked</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">£714</div>
            <div class="mt-1 text-sm text-dark-400">Monthly savings vs old service</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison: Virtual Receptionist vs Answering Service vs In-House -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Virtual Receptionist vs Answering Service vs In-House Receptionist</h2>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
