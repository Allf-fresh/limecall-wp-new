---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Call Scheduling Software — Reduce No-Shows by 80% | LimeCall`,
  description: `LimeCall's call scheduling software automates bookings, syncs with Google and Outlook calendars, sends reminders, and connects your team with leads in under 28 seconds. Free trial.`,
  canonical: `https://www.limecall.com/call-scheduling-2/`,
};

const stats = [
  { value: '80%', label: 'No-show reduction' },
  { value: '2x', label: 'More meetings booked' },
  { value: '28s', label: 'Avg connection time' },
  { value: '5 min', label: 'Setup time' },
];

const features = [
  {
    title: 'Smart Scheduling Widget',
    desc: 'Embed a scheduling widget on any page in minutes. Visitors pick from real-time availability slots, book instantly, and receive an automatic confirmation — no back-and-forth emails required.',
    icon: '📅',
  },
  {
    title: 'Calendar Sync (Google & Outlook)',
    desc: 'LimeCall syncs with Google Calendar and Microsoft Outlook in real time. Availability is always accurate, double-bookings are impossible, and new slots open automatically as calls complete.',
    icon: '🔄',
  },
  {
    title: 'Automated Reminders',
    desc: 'Reduce no-shows with automatic SMS and email reminders sent before each scheduled call. Set reminder timing at 24 hours, 1 hour, or 15 minutes — all configurable from your dashboard.',
    icon: '🔔',
  },
  {
    title: 'Timezone Detection',
    desc: "LimeCall detects each visitor's timezone automatically and displays available slots in their local time. No confusion, no missed calls due to timezone mistakes.",
    icon: '🌍',
  },
  {
    title: 'Callback Scheduling',
    desc: "When a lead isn't ready to talk now, let them schedule a callback for later. LimeCall dials your rep and the lead simultaneously at the scheduled time — no manual outreach needed.",
    icon: '📞',
  },
  {
    title: 'Team Calendar Management',
    desc: 'Manage availability across your entire team from one dashboard. Set business hours, block times, assign lead types to specific reps, and track upcoming scheduled calls in a unified view.',
    icon: '👥',
  },
];

const useCases = [
  {
    title: 'Sales Demo Scheduling',
    desc: 'Let high-intent prospects book a product demo directly from your pricing or features page. LimeCall routes bookings to the right pre-sales rep and sends both parties a calendar invite and reminder automatically.',
  },
  {
    title: 'Customer Support Callbacks',
    desc: 'Stop making customers wait on hold. Instead, let them schedule a callback at a convenient time. Your support team gets an organised queue, customers get a predictable experience.',
  },
  {
    title: 'Follow-Up Call Scheduling',
    desc: 'After a first conversation, send leads a scheduling link so they can book the next call themselves. Removes friction, speeds up the sales cycle, and reduces the risk of leads going cold between touchpoints.',
  },
  {
    title: 'Team Scheduling at Scale',
    desc: 'Growing teams need structure. LimeCall\'s team calendar view lets managers assign capacity, balance workloads, and ensure no rep is overbooked while others have empty slots.',
  },
];

const faqs = [
  {
    q: 'What is the difference between call scheduling and a callback widget?',
    a: 'A callback widget connects a visitor with a rep immediately — in under 28 seconds. Call scheduling lets a visitor pick a future time slot for a call. LimeCall supports both: immediate callback for hot leads and scheduling for those who aren\'t ready to talk right now. Many teams use both together.',
  },
  {
    q: 'Which calendar integrations does LimeCall support?',
    a: 'LimeCall integrates natively with Google Calendar and Microsoft Outlook / Office 365. Two-way sync ensures availability is always accurate. When a call is scheduled, it creates calendar events for both the rep and the lead. Additional calendar systems can be connected via Zapier.',
  },
  {
    q: 'How does LimeCall handle different time zones?',
    a: 'LimeCall automatically detects the visitor\'s browser timezone and displays all available slots in their local time. Your reps set their availability in their own timezone and the platform handles all conversions. There is no manual configuration required for international visitors.',
  },
  {
    q: 'Can reminders be customised?',
    a: 'Yes. You can configure reminder timing (e.g. 24h and 1h before), choose between SMS and email, and customise the message content. Reminders go to both the lead and the assigned rep. LimeCall\'s data shows that dual reminders cut no-show rates by up to 80%.',
  },
  {
    q: 'Does call scheduling work for teams with multiple reps?',
    a: 'Absolutely. You can set up round-robin scheduling, skill-based routing, or dedicated booking links for individual reps. The team calendar view gives managers visibility across all scheduled calls and rep availability in one place.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Call Scheduling', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Call Scheduling Software
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Automated call scheduling that<br class="hidden sm:block" />
        <span class="text-lime-400">eliminates no-shows</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Let leads book calls when it suits them. LimeCall syncs with your calendar, sends automatic reminders, and connects both parties at the scheduled time — without lifting a finger.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white sm:text-3xl">
        Everything you need to schedule calls at scale
      </h2>
      <p class="mb-12 text-center text-dark-400 max-w-xl mx-auto">
        From smart widgets to calendar sync, LimeCall handles the scheduling complexity so your team can focus on the conversation.
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-3 text-2xl">{f.icon}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white sm:text-3xl">Scheduling use cases</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(u => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <h3 class="mb-3 font-semibold text-lime-400">{u.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/50 p-5">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between gap-4">
              {f.q}
              <span class="shrink-0 text-lime-400 text-lg">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Start scheduling calls in 5 minutes</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · Calendar sync included</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Cross links -->
  <div class="py-8 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related features" links={[
        { href: '/conversation-scheduling/', title: 'Conversation Scheduling', desc: 'Schedule real-time conversations with leads, not just meetings.' },
        { href: '/callbackautomation/', title: 'Callback Automation', desc: 'Instant automated callbacks for inbound leads.' },
        { href: '/lead-routing-software/', title: 'Lead Routing', desc: 'Route every lead to the right rep automatically.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans for every team size.' },
      ]} />
    </div>
  </div>
</Base>
