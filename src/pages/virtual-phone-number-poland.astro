---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const country = "Poland";
const code = "+48";
const slug = "virtual-phone-number-poland";
const flag = "🇵🇱";

const seo = {
  title: `Poland Virtual Phone Number — Get a +48 Number | LimeCall`,
  description: `Get a Poland virtual phone number (+48) from $35/mo. Warsaw, Kraków, Wrocław numbers. Instant 5-min setup, no SIM required. Receive calls from anywhere.`,
  canonical: `https://www.limecall.com/${slug}/`,
};

const faqs = [
  {
    question: `Can I get a Poland virtual number without being in Poland?`,
    answer: `Yes. LimeCall provisions genuine Polish numbers (+48) that you can use from anywhere in the world. Polish callers dial a local number and your team answers via the LimeCall app, browser, or any forwarded device — no physical presence in Poland required.`,
  },
  {
    question: `What is the country code for Poland?`,
    answer: `Poland's international dialling code is +48. Polish numbers are 9 digits long after the country code. Warsaw numbers begin with 22, Kraków with 12, Wrocław with 71, Poznań with 61, and Gdańsk with 58. Mobile numbers begin with 5, 6, 7, or 8. When dialling from outside Poland, dial +48 followed by the 9-digit number (no leading 0).`,
  },
  {
    question: `How much does a Poland virtual phone number cost?`,
    answer: `LimeCall's Poland virtual numbers start from $35 per month. This includes the number rental plus per-minute rates for inbound calls. There are no setup fees and you can cancel at any time. See the pricing page for a full breakdown of rates.`,
  },
  {
    question: `Can I make outbound calls showing a Polish caller ID?`,
    answer: `Yes. LimeCall lets you place outbound calls displaying your Polish +48 number as the caller ID. Polish recipients see a familiar local number, which significantly improves answer rates for sales and support teams calling into Poland.`,
  },
  {
    question: `How quickly can I get a Poland virtual number?`,
    answer: `Your Poland virtual number is active within 5 minutes of signing up. No hardware, no SIM card, and no waiting for postal delivery. Choose your Polish city prefix, configure call routing, and start receiving calls immediately.`,
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Virtual Numbers', url: 'https://www.limecall.com/virtual-numbers/' },
        { name: 'Poland Virtual Number', url: seo.canonical }
      ]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a <span class="text-lime-400">Poland Virtual Phone Number</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Get a local Poland number ({code}) without being physically present in Poland. Instant 5-minute setup, no hardware, no SIM card required.
      </p>
      <!-- Trust signals -->
      <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm text-dark-400">
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Active in 5 minutes</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Cancel anytime</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> 30-day money-back guarantee</span>
      </div>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your Poland Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/80 py-6">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        <div>
          <div class="text-2xl font-bold text-lime-400">+48</div>
          <div class="mt-1 text-xs text-dark-400">Poland prefix</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">5 min</div>
          <div class="mt-1 text-xs text-dark-400">Setup time</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">$35/mo</div>
          <div class="mt-1 text-xs text-dark-400">Starting from</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">40+</div>
          <div class="mt-1 text-xs text-dark-400">Countries covered</div>
        </div>
      </div>
    </div>
  </section>

  <!-- What is a Poland virtual number -->
  <section class="py-16 sm:py-20 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-3xl font-bold text-white">What is a Poland virtual phone number?</h2>
      <p class="text-dark-300 leading-relaxed mb-4">
        A Poland virtual phone number is a real Polish telephone number — with a genuine +48 country code — that is hosted in the cloud rather than tied to a physical SIM card or landline in Poland. Calls to your Polish number are routed over the internet to any device you choose: your mobile phone, laptop, desk phone, or SIP endpoint anywhere in the world.
      </p>
      <p class="text-dark-300 leading-relaxed mb-4">
        Poland is one of Central Europe's fastest-growing economies and technology hubs. A Warsaw (22) or Kraków (12) prefix signals to Polish callers that you are a local, accessible business. For companies serving the Polish market — or the large Polish diaspora — a virtual number builds immediate trust.
      </p>
      <p class="text-dark-300 leading-relaxed">
        LimeCall virtual numbers include call routing, recording, CRM integration, and the same callback widget technology that connects website visitors to your team in under 28 seconds.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20 border-t border-dark-800 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">How to get your Poland number in 3 steps</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">1</div>
          <h3 class="mb-2 font-semibold text-white">Choose your number</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Pick a Polish city prefix — Warsaw (22), Kraków (12), Wrocław (71), Poznań (61), Gdańsk (58), Łódź (42) — or a national Polish mobile-style number.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">2</div>
          <h3 class="mb-2 font-semibold text-white">Configure routing</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Forward calls to any device, agent, or phone number globally. Set up IVR menus, voicemail, ring groups, or time-based routing rules.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">3</div>
          <h3 class="mb-2 font-semibold text-white">Receive calls anywhere</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Your Poland number goes live in minutes. Polish customers call a local number and your team answers from any country in the world.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Features included with your Poland number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Receive calls on any device</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Answer Polish calls on your mobile, laptop, browser, or SIP phone. Switch between devices without missing a call.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Call recording</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Record every incoming and outgoing Poland call automatically. Review calls for quality assurance and coaching from your dashboard.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">CRM sync</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Every Polish call is logged automatically in HubSpot, Salesforce, Pipedrive, and 50+ CRM integrations. No manual data entry.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Diaspora reach</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Poland has one of Europe's largest diasporas. A Polish +48 number helps you connect with Polish-speaking communities abroad who prefer calling Polish numbers.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">No physical SIM required</h3>
          <p class="text-sm text-dark-400 leading-relaxed">100% cloud-based. No SIM card, no hardware, no Polish address required. Fully compliant and operational from day one.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Callback widget</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Show your Poland +48 number on your website callback widget. Visitors click to call and connect to your team in under 28 seconds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20 bg-dark-900/40 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Who uses Poland virtual numbers?</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🏢</div>
          <h3 class="mb-2 font-semibold text-white">Market entry</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Establish a credible Polish presence without a physical office. A Warsaw or Kraków number builds instant trust with local prospects and partners.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">📞</div>
          <h3 class="mb-2 font-semibold text-white">Callback widget</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Display your Poland +48 number in the LimeCall callback widget. Convert Polish website visitors into calls within 28 seconds.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">💼</div>
          <h3 class="mb-2 font-semibold text-white">Sales teams</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Outbound sales teams calling Polish prospects see dramatically higher answer rates when calling from a recognised +48 local number.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🎧</div>
          <h3 class="mb-2 font-semibold text-white">Customer support</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Route Polish customer support calls to your global team. Polish callers pay local rates while your agents work remotely worldwide.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Did you know -->
  <section class="py-16 sm:py-20 border-t border-dark-800">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-8">
        <h2 class="mb-6 text-xl font-bold text-white">Poland phone system facts</h2>
        <ul class="space-y-3 text-sm text-dark-300 leading-relaxed">
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>Poland's international dialling code is <strong class="text-white">+48</strong>. All Polish numbers are 9 digits long after the country code — no leading zero is used.</span></li>
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>Major Polish city codes: <strong class="text-white">Warsaw 22</strong>, <strong class="text-white">Kraków 12</strong>, <strong class="text-white">Wrocław 71</strong>, <strong class="text-white">Poznań 61</strong>, <strong class="text-white">Gdańsk 58</strong>, <strong class="text-white">Łódź 42</strong>, <strong class="text-white">Katowice 32</strong>.</span></li>
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>Poland is one of the EU's largest economies by GDP and a major technology outsourcing hub, with a tech workforce exceeding 300,000 developers — making Polish virtual numbers valuable for tech companies.</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-20 bg-dark-900/40 border-t border-dark-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-bold text-white">Virtual number vs other Poland number options</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800">
              <th class="py-3 pr-6 text-left font-semibold text-dark-400">Feature</th>
              <th class="py-3 px-4 text-left font-semibold text-lime-400">LimeCall Virtual</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Local SIM</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Toll-free</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Existing mobile</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            <tr>
              <td class="py-3 pr-6 text-dark-300">Setup time</td>
              <td class="py-3 px-4 text-white">5 minutes</td>
              <td class="py-3 px-4 text-dark-400">Days to weeks</td>
              <td class="py-3 px-4 text-dark-400">1–3 days</td>
              <td class="py-3 px-4 text-dark-400">Immediate</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Physical presence needed</td>
              <td class="py-3 px-4 text-white">No</td>
              <td class="py-3 px-4 text-dark-400">Yes — must be in Poland</td>
              <td class="py-3 px-4 text-dark-400">Partial</td>
              <td class="py-3 px-4 text-dark-400">No</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Local Polish number</td>
              <td class="py-3 px-4 text-white">Yes (+48)</td>
              <td class="py-3 px-4 text-dark-400">Yes</td>
              <td class="py-3 px-4 text-dark-400">No (800 prefix)</td>
              <td class="py-3 px-4 text-dark-400">Foreign number</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Works from anywhere</td>
              <td class="py-3 px-4 text-white">Yes — globally</td>
              <td class="py-3 px-4 text-dark-400">Roaming charges apply</td>
              <td class="py-3 px-4 text-dark-400">Yes</td>
              <td class="py-3 px-4 text-dark-400">Yes</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Multiple numbers</td>
              <td class="py-3 px-4 text-white">Yes — unlimited</td>
              <td class="py-3 px-4 text-dark-400">One per SIM</td>
              <td class="py-3 px-4 text-dark-400">Limited</td>
              <td class="py-3 px-4 text-dark-400">One per device</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your Poland number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall to connect with Polish customers — from anywhere in the world.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/virtual-numbers/', title: 'All Virtual Numbers', desc: 'Browse all available countries.' },
        { href: '/virtual-business-numbers/', title: 'Virtual Business Numbers', desc: 'Business-grade virtual numbers.' },
        { href: '/virtual-phone-number-netherlands/', title: 'Netherlands Virtual Number', desc: 'Get a Netherlands +31 number.' },
        { href: '/virtual-phone-number-spain/', title: 'Spain Virtual Number', desc: 'Get a Spain +34 number.' },
        { href: '/pricing/', title: 'Pricing', desc: 'See all LimeCall plans.' },
      ]}
    />
  </div>
</Base>
