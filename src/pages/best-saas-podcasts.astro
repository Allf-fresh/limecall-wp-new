---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const seo = {
  title: `15 Best SaaS Podcasts to Follow in 2026 | LimeCall`,
  description: `The 15 best SaaS podcasts of 2026 — curated for founders, sales leaders, and marketers. From Lenny's Podcast to SaaStr, find the shows worth your commute.`,
  canonical: `https://www.limecall.com/best-saas-podcasts/`,
};

const podcasts = [
  {
    name: 'SaaS Interviews with Nathan Latka',
    host: 'Nathan Latka',
    covers: 'Daily short-form interviews with SaaS founders on real revenue numbers, churn rates, and growth strategies. Known for blunt financial questions.',
    frequency: 'Daily',
    category: 'Founder / Growth',
  },
  {
    name: 'The SaaS Podcast',
    host: 'Omer Khan',
    covers: 'Deep-dive interviews with SaaS founders and operators. Heavy focus on customer acquisition, product-market fit, and scaling from zero to revenue.',
    frequency: 'Weekly',
    category: 'Founder / Growth',
  },
  {
    name: 'Startups For the Rest of Us',
    host: 'Rob Walling',
    covers: 'Practical advice for bootstrapped and indie SaaS founders. Topics include pricing strategy, churn reduction, hiring, and self-funded scaling.',
    frequency: 'Weekly',
    category: 'Bootstrapped SaaS',
  },
  {
    name: 'MicroConf On Air',
    host: 'Rob Walling & Mike Taber',
    covers: 'The companion podcast to MicroConf events. Covers indie SaaS strategy, conference talks, founder stories, and community discussions.',
    frequency: 'Bi-weekly',
    category: 'Bootstrapped SaaS',
  },
  {
    name: 'The Growth Show',
    host: 'HubSpot',
    covers: 'Interviews with business leaders and growth practitioners on marketing, sales, and scaling. Broad appeal for B2B teams.',
    frequency: 'Bi-weekly',
    category: 'Marketing / Growth',
  },
  {
    name: 'SaaStr Podcast',
    host: 'Jason Lemkin',
    covers: 'The official podcast of the SaaStr community. Interviews with founders, VCs, and executives on scaling from $1M to $100M ARR.',
    frequency: 'Multiple per week',
    category: 'VC-backed SaaS',
  },
  {
    name: 'Indie Hackers Podcast',
    host: 'Courtland Allen',
    covers: 'Interviews with independent founders who have built profitable online businesses. Open about revenue numbers and struggles.',
    frequency: 'Weekly',
    category: 'Bootstrapped / Indie',
  },
  {
    name: 'Product Hunt Radio',
    host: 'Abadesi Osei',
    covers: 'Conversations with founders and makers launching new products. Covers product strategy, launch tactics, and early growth.',
    frequency: 'Weekly',
    category: 'Product / Launch',
  },
  {
    name: 'How I Built This',
    host: 'Guy Raz',
    covers: 'NPR\'s flagship entrepreneurship podcast. Long-form founder stories from the world\'s most iconic companies — including many SaaS businesses.',
    frequency: 'Weekly',
    category: 'Founder Stories',
  },
  {
    name: "Lenny's Podcast",
    host: 'Lenny Rachitsky',
    covers: 'Interviews with top product managers, founders, and growth leaders. Deep dives on growth loops, retention, hiring, and product strategy.',
    frequency: 'Weekly',
    category: 'Product / Growth',
  },
  {
    name: 'The Bootstrapped Founder',
    host: 'Arvid Kahl',
    covers: 'Built around the experience of building and selling FeedbackPanda. Covers audience building, writing, and building in public as a founder.',
    frequency: 'Weekly',
    category: 'Bootstrapped SaaS',
  },
  {
    name: 'Revenue Collective Podcast',
    host: 'Sam Jacobs',
    covers: 'Conversations with GTM leaders on building revenue teams, compensation design, sales process, and scaling go-to-market motions.',
    frequency: 'Weekly',
    category: 'Sales / GTM',
  },
  {
    name: 'The Official SaaStr Podcast',
    host: 'Harry Stebbings',
    covers: 'Originally launched as the 20VC for SaaS, this show features the world\'s top SaaS investors and founders on fundraising and growth.',
    frequency: 'Multiple per week',
    category: 'VC-backed SaaS',
  },
  {
    name: 'The Jason & Scot Show',
    host: 'Jason Goldberg & Scot Wingo',
    covers: 'Weekly discussion of e-commerce and retail technology news. Essential listening for SaaS companies serving retail, DTC, or marketplace sectors.',
    frequency: 'Weekly',
    category: 'E-commerce / Retail Tech',
  },
  {
    name: 'Acquired',
    host: 'Ben Gilbert & David Rosenthal',
    covers: 'Long-form deep dives on the history and strategy of iconic tech companies — from Stripe to Nvidia. Essential for understanding SaaS business models.',
    frequency: 'Monthly',
    category: 'Business Strategy',
  },
];

const categories = [...new Set(podcasts.map(p => p.category))];
---

<Base {...seo}>

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Best SaaS Podcasts 2026', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Updated for 2026
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        15 Best SaaS Podcasts<br class="hidden sm:block" />
        <span class="text-lime-400">to Follow in 2026</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Whether you are a SaaS founder, sales leader, or marketer, these are the podcasts worth your commute time. Curated for practical, actionable content — not hype.
      </p>
    </div>
  </section>

  <!-- Why SaaS podcasts matter -->
  <section class="border-b border-dark-800 bg-dark-900/30 py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="text-dark-300 leading-relaxed text-center">
        The SaaS industry moves faster than any blog can keep up with. The best founders and operators share their real-time thinking on podcasts — revenue numbers, GTM strategies, hiring mistakes, and growth frameworks that have not made it into a book yet. These 15 shows are the ones consistently cited by top SaaS leaders as their go-to listening.
      </p>
    </div>
  </section>

  <!-- Podcast grid -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-2xl font-bold text-white sm:text-3xl">The 15 podcasts</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {podcasts.map((p, i) => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6 flex flex-col">
            <div class="mb-3 flex items-center justify-between">
              <span class="text-xs font-bold text-lime-500/60">#{i + 1}</span>
              <span class="rounded-full border border-dark-700 px-2.5 py-0.5 text-xs text-dark-400">{p.frequency}</span>
            </div>
            <h3 class="mb-1 font-semibold text-white leading-snug">{p.name}</h3>
            <div class="mb-3 text-xs text-lime-400">Hosted by {p.host}</div>
            <p class="flex-1 text-sm text-dark-400 leading-relaxed">{p.covers}</p>
            <div class="mt-4 pt-4 border-t border-dark-800/50">
              <span class="rounded-full bg-dark-800 px-2.5 py-1 text-xs text-dark-400">{p.category}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Category summary -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-12 sm:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-xl font-bold text-white">Browse by category</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {categories.map(c => (
          <span class="rounded-full border border-dark-700 bg-dark-800 px-4 py-2 text-sm text-dark-300">{c}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">While you are listening...</h2>
      <p class="mt-4 text-dark-400 leading-relaxed max-w-lg mx-auto">
        Set up LimeCall so you never miss a lead while you are heads-down in your favourite podcast. Callback in 28 seconds, even when you are not watching your dashboard.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free Trial →
        </a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 font-bold text-white hover:border-lime-500/40 transition">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Cross links -->
  <div class="py-8 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="More resources" links={[
        { href: '/free-tools/', title: 'Free Sales Tools', desc: 'Phone validator, ROI calculator, and more — no signup needed.' },
        { href: '/saas-black-friday-deals/', title: 'SaaS Black Friday Deals', desc: 'Best SaaS discounts of 2026 — updated annually.' },
        { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'The research behind 28-second callbacks and higher conversion.' },
        { href: '/post/', title: 'LimeCall Blog', desc: 'Sales tips, guides, and product updates from the LimeCall team.' },
      ]} />
    </div>
  </div>
</Base>
