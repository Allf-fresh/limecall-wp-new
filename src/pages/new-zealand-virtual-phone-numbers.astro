---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const country = "New Zealand";
const code = "+64";
const flag = "🇳🇿";

const seo = {
  title: `New Zealand Virtual Phone Number — Get a NZ Number in 60 Seconds | LimeCall`,
  description: `Get a New Zealand virtual phone number (+64) from $4.99/mo. Auckland, Wellington & Christchurch numbers. Instant setup, no physical presence needed. Cancel anytime.`,
  canonical: `https://www.limecall.com/new-zealand-virtual-phone-numbers/`,
};

const faqs = [
  {
    question: `Can I get a New Zealand virtual number without being in New Zealand?`,
    answer: `Yes. You can get a New Zealand virtual phone number (+64) from anywhere in the world. LimeCall provisions a genuine NZ number that local customers can call at local rates, while your team answers from any country via app or browser.`,
  },
  {
    question: `What is the country code for New Zealand?`,
    answer: `New Zealand's country code is +64. Key city area codes include Auckland (09), Wellington (04), Christchurch (03), Hamilton (07), Dunedin (03), and Tauranga (07). Mobile numbers in New Zealand begin with 02.`,
  },
  {
    question: `How much does a New Zealand virtual phone number cost?`,
    answer: `LimeCall's New Zealand virtual numbers start from $4.99 per month. Incoming call rates and SMS charges are billed per use with no hidden setup fees. See the pricing page for full details.`,
  },
  {
    question: `Can I make outbound calls with my New Zealand virtual number?`,
    answer: `Yes. LimeCall lets you make outbound calls displaying your New Zealand (+64) number as the caller ID. NZ recipients see a local number, which improves answer rates significantly.`,
  },
  {
    question: `How quickly can I get a New Zealand virtual number?`,
    answer: `Your New Zealand virtual number is active within 60 seconds of signing up. No waiting for hardware, SIM cards, or approvals. Choose your city prefix, configure call routing, and you are ready to receive calls immediately.`,
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `${country} Virtual Number`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a <span class="text-lime-400">New Zealand Virtual Phone Number</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Get a local New Zealand number ({code}) without being physically present in NZ. Instant setup, no hardware, no SIM card required.
      </p>
      <!-- Trust signals -->
      <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm text-dark-400">
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Instant setup in 60 seconds</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Cancel anytime</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> 30-day money-back guarantee</span>
      </div>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your NZ Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">How to get your New Zealand number in 3 steps</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">1</div>
          <h3 class="mb-2 font-semibold text-white">Pick a number</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Choose your NZ city prefix — Auckland (09), Wellington (04), Christchurch (03), Hamilton (07), or Dunedin (03).</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">2</div>
          <h3 class="mb-2 font-semibold text-white">Configure routing</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Forward calls to any device, team member, or phone number globally. Set up IVR menus, voicemail, or ring groups.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">3</div>
          <h3 class="mb-2 font-semibold text-white">Start receiving calls</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Your NZ number goes live instantly. New Zealand customers call a local number and you answer from anywhere in the world.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Features included with your New Zealand number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Local presence in New Zealand</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Appear as a genuine local NZ business with a real +64 number. Build trust with New Zealanders who prefer calling local numbers.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">No physical address required</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Get a NZ virtual number without registering a company or renting office space in New Zealand. Fully remote, fully legal.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Forward to any device globally</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Route incoming NZ calls to mobile phones, laptops, desk phones, or SIP devices anywhere in the world.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Call recording & analytics</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Record every NZ call automatically. Review call quality, track response times, and analyse conversion rates from your dashboard.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Competitive per-minute rates</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Low per-minute rates for calls to and from New Zealand. Transparent pricing for all NZ traffic — no surprises.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">NZ city codes & formats supported</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Choose from Auckland +64-9, Wellington +64-4, Christchurch +64-3, Hamilton +64-7, Dunedin +64-3, and other NZ cities.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20 bg-dark-900/40 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Who uses New Zealand virtual numbers?</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🏢</div>
          <h3 class="mb-2 font-semibold text-white">Businesses expanding to NZ</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Establish a local New Zealand presence before committing to a physical office. Test the market with a real +64 number.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">💻</div>
          <h3 class="mb-2 font-semibold text-white">Remote teams with NZ clients</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Your distributed team answers NZ calls from anywhere. No need for anyone to be physically located in New Zealand.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🛒</div>
          <h3 class="mb-2 font-semibold text-white">E-commerce with NZ customers</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Display a local NZ support number to increase trust and conversions with New Zealand online shoppers.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🎧</div>
          <h3 class="mb-2 font-semibold text-white">Customer support with local number</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Route NZ customer support calls to your global team. Local callers pay local rates while your agents work remotely.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Did you know -->
  <section class="py-16 sm:py-20 border-t border-dark-800">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-8">
        <h2 class="mb-6 text-xl font-bold text-white">Did you know? New Zealand phone system facts</h2>
        <ul class="space-y-3 text-sm text-dark-300 leading-relaxed">
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>New Zealand's international dialling code is <strong class="text-white">+64</strong>. City codes include <strong class="text-white">Auckland +64-9</strong>, <strong class="text-white">Wellington +64-4</strong>, and <strong class="text-white">Christchurch +64-3</strong>.</span></li>
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>New Zealand mobile numbers begin with <strong class="text-white">02</strong> (e.g., 021, 022, 027). The country has two main mobile networks: Spark NZ (formerly Telecom NZ) and One NZ (formerly Vodafone NZ).</span></li>
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>The Commerce Commission and TCF (Telecommunications Carriers' Forum) regulate NZ telecoms. New Zealand has one of the highest internet and smartphone penetration rates in the Asia-Pacific region.</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-20 bg-dark-900/40 border-t border-dark-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-bold text-white">LimeCall virtual number vs physical NZ SIM</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800">
              <th class="py-3 pr-6 text-left font-semibold text-dark-400">Feature</th>
              <th class="py-3 px-4 text-left font-semibold text-lime-400">LimeCall Virtual</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Physical SIM</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            <tr>
              <td class="py-3 pr-6 text-dark-300">Setup time</td>
              <td class="py-3 px-4 text-white">Instant (60 seconds)</td>
              <td class="py-3 px-4 text-dark-400">Days to weeks</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Physical presence needed</td>
              <td class="py-3 px-4 text-white">No</td>
              <td class="py-3 px-4 text-dark-400">Yes — must be in NZ</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Works from</td>
              <td class="py-3 px-4 text-white">Anywhere in the world</td>
              <td class="py-3 px-4 text-dark-400">Must be in New Zealand</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Cancel anytime</td>
              <td class="py-3 px-4 text-white">Yes — no contracts</td>
              <td class="py-3 px-4 text-dark-400">Often locked to contract</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Multiple numbers</td>
              <td class="py-3 px-4 text-white">Yes — unlimited</td>
              <td class="py-3 px-4 text-dark-400">One per SIM card</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your New Zealand number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall to connect with New Zealand customers — without being in NZ.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/virtual-numbers/', title: 'All Virtual Numbers', desc: 'Browse all available countries.' },
        { href: '/australia-virtual-phone-numbers/', title: 'Australia Virtual Number', desc: 'Get an Australia +61 number.' },
        { href: '/singapore-virtual-phone-number/', title: 'Singapore Virtual Number', desc: 'Get a Singapore +65 number.' },
        { href: '/uk-virtual-phone-number/', title: 'UK Virtual Number', desc: 'Get a UK +44 number instantly.' },
      ]}
    />
  </div>
</Base>
