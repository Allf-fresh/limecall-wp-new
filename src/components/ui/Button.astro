---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';

const variants = {
  primary: 'bg-lime-500 text-dark-950 hover:bg-lime-400 font-semibold',
  secondary: 'bg-dark-800 text-white hover:bg-dark-700 font-medium',
  outline: 'border border-dark-600 text-dark-200 hover:border-lime-500 hover:text-lime-400 font-medium',
};

const sizes = {
  sm: 'px-3 py-1.5 text-sm rounded-md',
  md: 'px-5 py-2.5 text-sm rounded-lg',
  lg: 'px-6 py-3 text-base rounded-lg',
};
---

<Tag
  href={href}
  class:list={[
    'inline-flex items-center justify-center transition-colors',
    variants[variant],
    sizes[size],
    className,
  ]}
  {...rest}
>
  <slot />
</Tag>
