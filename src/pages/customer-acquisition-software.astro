---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Customer Acquisition Software — Convert More Leads | LimeCall',
  description: 'Acquire more customers with instant callback technology. 3x more leads converted, 28s callback time, 10-12x higher conversion than forms. Free trial.',
  canonical: `${site.url}/customer-acquisition-software/`,
};

const stats = [
  { value: '3x', label: 'More Customers Acquired', sub: 'vs. form-only lead capture strategies' },
  { value: '28s', label: 'Callback Time', sub: 'from lead request to live conversation' },
  { value: '10-12x', label: 'Higher Conversion', sub: 'vs. contact forms alone' },
  { value: '5 min', label: 'Setup Time', sub: 'paste one script tag and go live' },
];

const features = [
  {
    icon: '🚪',
    name: 'Exit-Intent Callback Widget',
    description: 'Trigger a callback offer the moment a visitor moves to leave your site. Recover abandoning visitors and convert them before they go to a competitor.',
  },
  {
    icon: '📋',
    name: 'Form-to-Call Automation',
    description: 'Connect your existing lead forms to LimeCall. Every submission triggers an automatic callback within 28 seconds — while the lead is still engaged.',
  },
  {
    icon: '🔀',
    name: 'Intelligent Lead Routing',
    description: 'Route each new lead to the best available rep based on territory, product expertise, or round-robin. The right rep gets the right lead instantly.',
  },
  {
    icon: '🔗',
    name: 'CRM Sync',
    description: 'Every lead, call, and outcome syncs automatically to HubSpot, Salesforce, Pipedrive, or Zoho. Zero manual data entry, full acquisition history.',
  },
  {
    icon: '📞',
    name: 'Call Tracking & Attribution',
    description: 'Know exactly which ad, keyword, or landing page drove each call. Optimise your ad spend based on real acquisition data, not guesswork.',
  },
  {
    icon: '🧪',
    name: 'A/B Testing',
    description: 'Test different widget designs, copy, and trigger timings to find the highest-converting combination for each audience segment.',
  },
];

const useCases = [
  {
    icon: '📣',
    title: 'PPC & Paid Ad Campaigns',
    description: 'Maximise ROI from Google Ads, Meta, and LinkedIn by converting clicks into conversations instantly — before intent cools.',
  },
  {
    icon: '🏠',
    title: 'Real Estate & High-Ticket Sales',
    description: 'Buyers of high-value products want to talk to a human. LimeCall connects them to your team in seconds, dramatically reducing drop-off.',
  },
  {
    icon: '🎓',
    title: 'Education & Course Enrolments',
    description: 'Prospective students who can ask questions immediately are far more likely to enrol. Cut your cost-per-enrolment with instant callbacks.',
  },
  {
    icon: '🏦',
    title: 'Finance & Insurance Leads',
    description: 'Financial products require trust. Immediate callback signals professionalism and urgency — the two drivers of financial lead conversion.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Install the Widget',
    description: 'Paste one snippet of code onto your website or landing page. The LimeCall callback widget is live in under 5 minutes — no developer needed.',
  },
  {
    number: '02',
    title: 'Lead Requests a Callback',
    description: 'A visitor clicks the widget or submits your form. LimeCall simultaneously dials your best available rep and the prospect within 28 seconds.',
  },
  {
    number: '03',
    title: 'Convert & Track',
    description: 'Your rep speaks to a warm, engaged prospect. The call is recorded, the lead syncs to your CRM, and attribution data captures the acquisition source.',
  },
];

const faqs = [
  {
    question: 'What is customer acquisition software?',
    answer: 'Customer acquisition software helps businesses attract, capture, and convert new customers through digital channels. LimeCall specialises in the conversion stage — turning website visitors and form leads into live phone conversations in under 28 seconds, which is proven to dramatically improve acquisition rates.',
  },
  {
    question: 'How does instant callback improve customer acquisition?',
    answer: 'Research shows leads are 9x more likely to convert if contacted within 5 minutes. LimeCall triggers automatic callbacks in under 28 seconds, catching prospects while intent is at its peak. This can increase your acquisition rate by 3x compared to form-only strategies.',
  },
  {
    question: 'What is a good customer acquisition cost (CAC)?',
    answer: 'CAC benchmarks vary widely by industry. SaaS companies typically target a CAC-to-LTV ratio of 1:3 or better. LimeCall reduces CAC by increasing your conversion rate from existing traffic — meaning you acquire more customers from the same ad spend without increasing budget.',
  },
  {
    question: 'How does LimeCall reduce customer acquisition cost?',
    answer: 'By converting 3x more of your existing website visitors into customers, LimeCall effectively reduces your CAC by up to 60%. If you are spending $10,000/month on ads and converting 1% of visitors, converting 3% of the same traffic means you are getting 3x the customers for the same spend.',
  },
  {
    question: 'Does LimeCall work with my existing ad campaigns?',
    answer: 'Yes. LimeCall integrates with Google Ads, Meta Ads, and all major ad platforms via UTM parameter tracking. Every call is attributed to the campaign, ad set, and keyword that drove it — so you can see your true cost-per-acquisition by channel.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqJsonLd} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Customer Acquisition Software', url: `${site.url}/customer-acquisition-software/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        Customer Acquisition
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Acquire More Customers with<br />
        <span class="text-lime-400">Instant Callback Technology</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Stop losing leads to slow follow-up. LimeCall connects your sales team with new prospects in under 28 seconds — converting up to 3x more visitors into customers without increasing your ad spend.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free — No Card Needed
        </a>
        <a
          href="/contact-us"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          Request a Demo
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Free plan available · 5-minute setup · No developer needed</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/60 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-center">
        {stats.map((s) => (
          <div class="p-4">
            <div class="text-4xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-2 text-sm font-bold text-white">{s.label}</div>
            <div class="mt-1 text-xs text-dark-500">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Built to Convert Visitors<br />
          <span class="text-lime-400">into Paying Customers</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Every LimeCall feature targets a specific moment in the customer acquisition journey — from first click to closed deal.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{f.name}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Who Uses LimeCall for<br />
          <span class="text-lime-400">Customer Acquisition?</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Any business that depends on inbound leads and needs to convert more of them into customers.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {useCases.map((uc) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-3">{uc.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          How LimeCall <span class="text-lime-400">Acquires More Customers</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          From visitor intent to live conversation in three automated steps — no manual effort required.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="relative flex flex-col rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="text-4xl font-extrabold text-lime-500/20 mb-4 leading-none">{step.number}</div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Stop Losing Leads.<br />
        <span class="text-lime-400">Start Acquiring More Customers.</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        Install LimeCall in 5 minutes and watch your customer acquisition rate climb — without spending more on ads.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free Trial
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          View Pricing
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">No credit card required · Free plan available · Cancel anytime</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="More Ways to Convert Leads into Customers"
        links={[
          { href: '/lead-capture-software', title: 'Lead Capture Software', desc: 'Capture more leads from every page of your website.' },
          { href: '/click-to-call-software', title: 'Click to Call Software', desc: 'One-click calling from your site to your sales team.' },
          { href: '/speed-to-lead', title: 'Speed to Lead', desc: 'Why the fastest responder wins — and how to be first.' },
          { href: '/pricing', title: 'Pricing', desc: 'Start free. Scale as you grow.' },
        ]}
      />
    </div>
  </section>
</Base>
