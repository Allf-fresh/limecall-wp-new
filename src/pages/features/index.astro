---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import { site, features } from '../../site.config';
---

<Base
  title="LimeCall Features — Click-to-Call, Callbacks, SMS & More"
  description="Explore all LimeCall features: instant click-to-call, automated callbacks, lead distribution, virtual numbers, SMS, call tracking, and CRM integrations. Start free."
  canonical="https://www.limecall.com/features/"
>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Features', url: `${site.url}/features/` }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        All Features
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Everything in <span class="text-lime-400">{site.name}</span>
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Powerful tools for converting website visitors into sales calls. Click-to-Call, Lead Distribution, Schedule Callbacks, Virtual Numbers, Web to Text — and more. All in one platform.
      </p>
      <!-- Stats -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm">
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">3x</span>
          more conversions
        </span>
        <span class="hidden h-5 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">28s</span>
          avg connect time
        </span>
        <span class="hidden h-5 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">50+</span>
          countries
        </span>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((feature) => (
          <FeatureCard
            icon={feature.icon}
            name={feature.name}
            description={feature.description}
            href={`/features/${feature.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Feature categories -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-2xl font-bold text-white sm:text-3xl">
        The complete lead conversion platform
      </h2>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">📞</div>
          <h3 class="font-bold text-white mb-2">Calling</h3>
          <ul class="space-y-2 text-sm text-dark-400">
            <li><a href="/click-to-call-software" class="hover:text-lime-400 transition">Click-to-Call Software</a></li>
            <li><a href="/customer-callback-software" class="hover:text-lime-400 transition">Customer Callback Software</a></li>
            <li><a href="/features/click-2-call" class="hover:text-lime-400 transition">Click2Call Widget</a></li>
          </ul>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">🔀</div>
          <h3 class="font-bold text-white mb-2">Lead Management</h3>
          <ul class="space-y-2 text-sm text-dark-400">
            <li><a href="/lead-distribution" class="hover:text-lime-400 transition">Lead Distribution</a></li>
            <li><a href="/speed-to-lead" class="hover:text-lime-400 transition">Speed to Lead</a></li>
            <li><a href="/conversation-scheduling" class="hover:text-lime-400 transition">Schedule Callbacks</a></li>
          </ul>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">💬</div>
          <h3 class="font-bold text-white mb-2">Messaging</h3>
          <ul class="space-y-2 text-sm text-dark-400">
            <li><a href="/business-texting" class="hover:text-lime-400 transition">Web to Text / SMS</a></li>
            <li><a href="/sms-for-slack" class="hover:text-lime-400 transition">SMS for Slack</a></li>
            <li><a href="/shared-inbox" class="hover:text-lime-400 transition">Shared Inbox</a></li>
          </ul>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">🌍</div>
          <h3 class="font-bold text-white mb-2">Phone Numbers</h3>
          <ul class="space-y-2 text-sm text-dark-400">
            <li><a href="/virtual-numbers" class="hover:text-lime-400 transition">Virtual Numbers</a></li>
            <li><a href="/incoming-numbers" class="hover:text-lime-400 transition">Incoming DID Numbers</a></li>
            <li><a href="/toll-free-numbers" class="hover:text-lime-400 transition">Toll-Free Numbers</a></li>
          </ul>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">📊</div>
          <h3 class="font-bold text-white mb-2">Analytics</h3>
          <ul class="space-y-2 text-sm text-dark-400">
            <li><a href="/calltracking-software" class="hover:text-lime-400 transition">Call Tracking</a></li>
            <li><a href="/features" class="hover:text-lime-400 transition">Performance Dashboards</a></li>
            <li><a href="/speed-to-lead" class="hover:text-lime-400 transition">Speed-to-Lead Reports</a></li>
          </ul>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="text-2xl mb-3">🔗</div>
          <h3 class="font-bold text-white mb-2">Integrations</h3>
          <ul class="space-y-2 text-sm text-dark-400">
            <li><a href="/integrations" class="hover:text-lime-400 transition">All Integrations</a></li>
            <li><a href="/sms-for-slack" class="hover:text-lime-400 transition">Slack</a></li>
            <li><a href="/integrations" class="hover:text-lime-400 transition">HubSpot, Salesforce &amp; more</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Compare plans CTA -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-500/10 to-dark-900 p-8 md:p-12 text-center">
        <h2 class="text-2xl font-bold text-white mb-3">Ready to get started?</h2>
        <p class="text-dark-300 mb-8 max-w-xl mx-auto">{site.cta.subtext}. Free plan available — no credit card required. Upgrade as you grow.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={site.cta.href} class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg bg-lime-500 hover:bg-lime-400 text-dark-950 font-bold transition">
            {site.cta.text}
          </a>
          <a href="/pricing" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg border border-dark-700 bg-dark-800 hover:border-lime-500/40 text-white font-bold transition">
            Compare Plans →
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
