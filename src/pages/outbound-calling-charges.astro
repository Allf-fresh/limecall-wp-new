---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const seo = {
  title: 'Outbound Call Rates — LimeCall Pricing Per Minute',
  description: 'LimeCall outbound call charges by country. Transparent per-minute rates for callback connections. See rates for US, UK, EU, and 40+ countries.',
  canonical: `${site.url}/outbound-calling-charges/`,
};

const callRates = [
  { country: 'United States', code: '+1', rate: '$0.015', per: 'min' },
  { country: 'United Kingdom', code: '+44', rate: '$0.018', per: 'min' },
  { country: 'Canada', code: '+1', rate: '$0.015', per: 'min' },
  { country: 'Australia', code: '+61', rate: '$0.025', per: 'min' },
  { country: 'Germany', code: '+49', rate: '$0.020', per: 'min' },
  { country: 'France', code: '+33', rate: '$0.020', per: 'min' },
  { country: 'India', code: '+91', rate: '$0.010', per: 'min' },
  { country: 'Singapore', code: '+65', rate: '$0.025', per: 'min' },
];
---

<Base {...seo}>

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Rates', url: `${site.url}/rates/` },
        { name: 'Outbound Call Rates', url: seo.canonical },
      ]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Outbound Call Rates
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Transparent <span class="text-lime-400">Outbound Call Rates</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        LimeCall's callback system places outbound calls to connect visitors with your team. Charges apply per minute based on the destination country. All rates include full call quality and recording.
      </p>
    </div>
  </section>

  <!-- Rates Table -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold text-white text-center">Call rates by country</h2>

      <div class="overflow-hidden rounded-2xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-6 py-4 text-left font-semibold text-white">Country</th>
              <th class="px-6 py-4 text-left font-semibold text-white">Dialling Code</th>
              <th class="px-6 py-4 text-right font-semibold text-lime-400">Rate per Minute</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800 bg-dark-900/40">
            {callRates.map((r, i) => (
              <tr class={i % 2 === 0 ? 'bg-dark-900/20' : ''}>
                <td class="px-6 py-4 text-white font-medium">{r.country}</td>
                <td class="px-6 py-4 text-dark-400">{r.code}</td>
                <td class="px-6 py-4 text-right font-bold text-lime-400">{r.rate}<span class="text-dark-500 font-normal">/{r.per}</span></td>
              </tr>
            ))}
            <tr class="border-t border-dark-700 bg-dark-800/40">
              <td class="px-6 py-4 text-white font-medium">All other countries</td>
              <td class="px-6 py-4 text-dark-400">Various</td>
              <td class="px-6 py-4 text-right font-bold text-lime-400">from $0.015<span class="text-dark-500 font-normal">/min</span></td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="mt-4 text-xs text-dark-500 text-center">
        Rates are charged in USD and billed to your account credit balance. Rates are subject to change with 30 days notice.
      </p>
    </div>
  </section>

  <!-- Note Box -->
  <section class="pb-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-6">
        <h3 class="mb-2 font-bold text-lime-400">About outbound call charges</h3>
        <p class="text-sm text-dark-300 leading-relaxed">
          Rates shown are for outbound legs — calls placed by LimeCall to connect your rep with a visitor. Your plan includes a monthly calling credit that covers most usage at normal volumes. Additional minutes beyond your credit are billed at the rates above. See the pricing page for full plan details and included call credits.
        </p>
        <div class="mt-4">
          <a href="/pricing/" class="inline-flex items-center gap-1 text-sm font-semibold text-lime-400 hover:text-lime-300 transition">
            View plan details and call credits →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How charges work -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How outbound call charges work</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          { n: '1', title: 'Visitor requests a call', desc: 'A website visitor clicks your LimeCall widget and requests an immediate or scheduled callback.' },
          { n: '2', title: 'LimeCall connects the call', desc: 'LimeCall places two outbound calls — one to your rep and one to the visitor — connecting them within 28 seconds.' },
          { n: '3', title: 'Per-minute charge applies', desc: 'Your account is charged at the destination rate for each minute of the completed call. Calls under 6 seconds are not billed.' },
        ].map((s) => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Start connecting with visitors today</h2>
      <p class="mt-4 text-dark-400">Free plan includes 30 calls per month with no outbound charge. Upgrade for higher volumes.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
          Start Free →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-10 py-4 text-base font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Related Pages"
      links={[
        { href: '/pricing/', title: 'Pricing Plans', desc: 'Full plan details with included call credits.' },
        { href: '/toll-free-numbers/', title: 'Toll-Free Numbers', desc: 'Get a toll-free number for inbound calls.' },
        { href: '/virtual-business-numbers/', title: 'Virtual Business Numbers', desc: 'Local numbers in 50+ countries.' },
        { href: '/outgoing-rates/', title: 'SMS Rates', desc: 'Per-message SMS pricing by country.' },
      ]}
    />
  </div>
</Base>
