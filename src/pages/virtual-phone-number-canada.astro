---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const country = "Canada";
const code = "+1";
const flag = "🇨🇦";

const seo = {
  title: `Get a Virtual Phone Number in Canada (+1) | LimeCall`,
  description: `Create a +1 virtual phone number in Canada in 1 minute. Unlimited calling from web and mobile. Get a local presence in Canada right away with LimeCall.`,
  canonical: `https://www.limecall.com/virtual-phone-number-canada/`,
};

const features = [
  { title: "Instant Setup", desc: "Get your Canadian virtual number in minutes. No hardware, no SIM card, no contracts." },
  { title: "Smart Call Routing", desc: "Route incoming calls to any device or team member — mobile, desktop, or desk phone." },
  { title: "Call Recording", desc: "Record and review every call for quality assurance and compliance." },
  { title: "Callback Automation", desc: "Let website visitors request instant callbacks from your Canadian or global team." },
  { title: "SMS & WhatsApp", desc: "Send and receive SMS messages on your Canadian virtual number." },
  { title: "Analytics Dashboard", desc: "Full call analytics, reporting, and conversion tracking in one dashboard." },
];

const stats = [
  { value: "Instant", label: "Activation" },
  { value: "416, 604, 647+", label: "Canadian Area Codes" },
  { value: "99.9%", label: "Uptime SLA" },
  { value: "No Contract", label: "Cancel Anytime" },
];

const countryFacts = [
  { title: "NANP — Sharing +1 with the US", desc: "Canada and the United States share country code +1 under the North American Numbering Plan (NANP). Canadian area codes are distinct — 416/647 for Toronto, 604/778 for Vancouver — making local codes critical for signalling Canadian presence." },
  { title: "4.5 Time Zones, One Number", desc: "Canada spans 4.5 time zones from the Pacific to Atlantic coast. A virtual Canadian number lets you manage incoming calls across all time zones from a single dashboard, routing to the right team at any hour." },
  { title: "English & French Markets", desc: "Canada has two official languages. Quebec businesses expect French communication. A local Montreal (514/438) number combined with French-language IVR menus can significantly improve engagement with French-speaking Canadian customers." },
];

const comparisonRows = [
  { aspect: "Setup Time", virtual: "Under 5 minutes", sim: "1–3 business days" },
  { aspect: "Monthly Cost", virtual: "From $4/mo", sim: "$30–80/mo plan required" },
  { aspect: "Works Internationally", virtual: "Yes — route from anywhere", sim: "Roaming charges apply" },
  { aspect: "Local Area Code", virtual: "416, 604, 647, 778, etc.", sim: "Depends on SIM region" },
  { aspect: "Toll-Free Option", virtual: "1-800/1-888 available", sim: "Not available on SIM" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I get a Canadian virtual phone number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sign up for LimeCall, select Canada, choose your preferred area code (Toronto 416/647, Vancouver 604/778, Montreal 514/438, Calgary 403, Ottawa 613), and your Canadian number activates in under 5 minutes.',
      },
    },
    {
      '@type': 'Question',
      name: 'What Canadian area codes are available through LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall offers a wide selection of Canadian area codes including 416 and 647 (Toronto), 604 and 778 (Vancouver), 514 and 438 (Montreal), 403 and 587 (Calgary), 613 (Ottawa), 902 (Nova Scotia), 204 (Manitoba), and more.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I send SMS with a Canadian virtual number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall Canadian virtual numbers support two-way SMS. You can send and receive text messages to Canadian numbers directly from the LimeCall dashboard or mobile app.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need to be in Canada to use a Canadian number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Your Canadian virtual number works from anywhere in the world. Calls are routed over the internet to your phone or computer — your Canadian customers see a local Canadian number regardless of where you are.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I get a toll-free Canadian number?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. In addition to local area code numbers, LimeCall offers Canadian toll-free numbers (1-800, 1-888). Toll-free numbers are free for callers across North America and present a national business image.',
      },
    },
  ],
};

const faqs = [
  {
    q: `What is a Canada virtual phone number?`,
    a: `A Canada virtual phone number uses the North American Numbering Plan (${code}) and isn't tied to a physical phone line or SIM card. It routes calls over the internet to any device — mobile, laptop, or desk phone — anywhere in the world. Canadian customers dial a local number, and the call reaches you wherever you are.`,
  },
  {
    q: `Do I need to be in Canada to get a Canadian virtual number?`,
    a: `No. Anyone can get a Canadian virtual phone number from anywhere in the world. LimeCall gives you a local ${code} number that Canadian customers can call at local rates, while your team answers from any country.`,
  },
  {
    q: `What types of Canadian virtual numbers are available?`,
    a: `LimeCall offers local Canadian numbers with city-specific area codes (Toronto 416/647, Vancouver 604/778, Montreal 514/438, Calgary 403, Ottawa 613, etc.) as well as national toll-free numbers. Choose the area code that best fits your business needs.`,
  },
  {
    q: "How long does setup take?",
    a: "Setup takes under 5 minutes. Sign up, choose your Canadian number, and you're ready to receive calls immediately — no waiting for hardware or SIM activation.",
  },
  {
    q: "Can I use a Canadian virtual number for callbacks?",
    a: "Yes — LimeCall's callback automation lets website visitors request a call and your team calls them back within 28 seconds using your Canadian virtual number. This dramatically improves lead conversion rates.",
  },
  {
    q: `Are Canadian virtual numbers compliant with CRTC regulations?`,
    a: `LimeCall's Canadian virtual numbers are provisioned through licensed telecom partners and comply with the Canadian Radio-television and Telecommunications Commission (CRTC) guidelines. All numbers are legitimate, registered numbers suitable for business use.`,
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `${country} Virtual Number`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a Virtual Phone Number in <span class="text-lime-400">{country}</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Local {country} number ({code}) that works anywhere. Instant setup, no hardware. Route calls, automate callbacks, and close more deals.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your {country} Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <p class="text-2xl font-extrabold text-lime-400">{s.value}</p>
            <p class="mt-1 text-xs text-dark-400 uppercase tracking-wide">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Everything included with your {country} number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Virtual vs SIM Comparison -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Virtual Canada Number vs Canadian SIM Card</h2>
      <p class="mb-10 text-center text-sm text-dark-400">Why a virtual number beats a physical SIM for most businesses</p>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-6 py-4 text-left font-semibold text-dark-300">Feature</th>
              <th class="px-6 py-4 text-left font-semibold text-lime-400">Virtual Number (LimeCall)</th>
              <th class="px-6 py-4 text-left font-semibold text-dark-400">Canadian SIM Card</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800 ${i % 2 === 0 ? 'bg-dark-900/20' : ''}`}>
                <td class="px-6 py-4 font-medium text-white">{row.aspect}</td>
                <td class="px-6 py-4 text-dark-300">{row.virtual}</td>
                <td class="px-6 py-4 text-dark-500">{row.sim}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Country Facts -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Canada Telecom & Business Facts</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {countryFacts.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="mb-2 text-sm font-bold text-lime-400 uppercase tracking-wide">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ with JSON-LD -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {item.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your {country} number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall virtual numbers to connect with customers globally.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/canada-virtual-phone-number/', title: 'Canada Virtual Numbers', desc: 'More Canadian number options.' },
        { href: '/incoming-numbers/', title: 'Incoming Numbers', desc: 'DID numbers for inbound calls.' },
        { href: '/toll-free-numbers/', title: 'Toll-Free Numbers', desc: 'Free for callers, professional for you.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
