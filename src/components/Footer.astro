---
import { site } from '../site.config';

const year = new Date().getFullYear();
const { footer, social, cta, name } = site;
---

<footer class="border-t border-dark-800 bg-dark-950">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">

    <!-- Top: logo + tagline + CTA -->
    <div class="mb-12 flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
      <div>
        <a href="/" class="flex items-center gap-2.5" aria-label={`${name} Home`}>
          <svg width="17" height="22" viewBox="0 0 22 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 9 L10 1 L10 21 L21 21 L21 27 L3 27 Z" fill="#a3e635"/>
          </svg>
          <span class="text-xl font-bold tracking-tight leading-none">
            <span class="text-lime-400">{name}</span>
          </span>
        </a>
        <p class="mt-2 text-sm text-dark-500">{footer.tagline}</p>
      </div>
      <a
        href={cta.href}
        class="inline-flex items-center gap-2 rounded-lg bg-lime-500 px-5 py-2.5 text-sm font-bold text-dark-950 transition-colors hover:bg-lime-400 flex-shrink-0"
      >
        {cta.text}
      </a>
    </div>

    <!-- Links grid -->
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      {footer.columns.map((section) => (
        <div>
          <h3 class="mb-4 text-xs font-bold uppercase tracking-wider text-dark-400">
            {section.title}
          </h3>
          <ul class="space-y-2.5">
            {section.links.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm text-dark-500 transition-colors hover:text-lime-400">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col gap-4 border-t border-dark-800 pt-8 sm:flex-row sm:items-center sm:justify-between">

      <!-- Copyright -->
      <p class="text-sm text-dark-600 order-last sm:order-first">
        &copy; {year} {footer.copyright}. All rights reserved.
      </p>

      <!-- Legal links -->
      <nav aria-label="Legal links" class="flex flex-wrap gap-x-4 gap-y-1.5">
        {footer.legal.map(({ href, label }) => (
          <a href={href} class="text-xs text-dark-600 transition-colors hover:text-dark-400">{label}</a>
        ))}
      </nav>

      <!-- Socials -->
      <div class="flex items-center gap-3">
        {social.twitter && (
          <a href={`https://twitter.com/${social.twitter}`} class="text-dark-600 hover:text-lime-400 transition" aria-label="X / Twitter">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        )}
        {social.github && (
          <a href={`https://github.com/${social.github}`} class="text-dark-600 hover:text-lime-400 transition" aria-label="GitHub">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>
</footer>
