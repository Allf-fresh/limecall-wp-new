---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const seo = {
  title: `Callback Software — Get More Calls From Your Website | LimeCall`,
  description: `Connect with potential customers instantly and improve your conversion rates by 3x with LimeCall's Callback Software. Callbacks in 28 seconds, 80% more call requests.`,
  canonical: `https://www.limecall.com/customer-callback-software/`,
};

const features = [
  {
    icon: '⚡',
    name: 'Callback in 28 Seconds',
    description: 'Your visitor requests a callback and LimeCall connects them with your sales rep in under 28 seconds — while they are still engaged and interested.',
  },
  {
    icon: '🎙️',
    name: 'Call Recording & Playback',
    description: 'Every callback is recorded and stored securely. Review conversations, train your team, and ensure quality — all from your LimeCall dashboard.',
  },
  {
    icon: '🏷️',
    name: 'Automatic Call Tagging',
    description: 'AI-powered tagging categorizes every call automatically. Add custom tags manually to segment leads and build smarter follow-up workflows.',
  },
  {
    icon: '📊',
    name: 'Performance Analytics',
    description: 'Detailed call logs, response-time reports, and custom dashboards show exactly how your team is performing and where you can improve.',
  },
  {
    icon: '🔀',
    name: 'Smart Lead Distribution',
    description: 'Route every callback to the right agent based on skills, availability, territory, or round-robin rules — no manual triage required. Pair this with <a href="/click-to-call-software/" class="text-lime-400 hover:underline">click-to-call software</a> for even faster first contact.',
  },
  {
    icon: '💬',
    name: 'Web to Text (SMS)',
    description: 'If a visitor prefers text over a call, let them start an SMS conversation right from your website widget — all managed in one inbox.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Visitor Requests a Callback',
    description: 'Your LimeCall widget appears on your site. A visitor enters their number and clicks "Call Me" — it takes under 10 seconds.',
  },
  {
    number: '02',
    title: 'LimeCall Connects Both Parties',
    description: 'LimeCall simultaneously dials your sales rep and the customer. Both pick up and are instantly connected — in under 28 seconds.',
  },
  {
    number: '03',
    title: 'Data Logged Automatically',
    description: 'The call is recorded, tagged, and synced to your CRM. Your rep has full context — no data entry, no missed follow-ups.',
  },
];

const faqs = [
  {
    question: 'What is customer callback software?',
    answer: 'Callback software places a widget on your website that lets visitors request an immediate phone call from your sales or support team. LimeCall dials your rep and the customer simultaneously, connecting them in under 28 seconds.',
  },
  {
    question: 'How does LimeCall reduce operating costs?',
    answer: 'By automating call routing, follow-ups, and lead distribution, LimeCall reduces the manual effort required to manage inbound calls. Customers report up to 20% reduction in operating costs after implementing LimeCall.',
  },
  {
    question: 'Can I set business hours for callbacks?',
    answer: 'Yes. You can configure your available hours, holiday schedules, and out-of-office behavior. When your team is unavailable, visitors are prompted to schedule a callback for a specific time slot.',
  },
  {
    question: 'Does LimeCall integrate with my CRM?',
    answer: 'LimeCall integrates with HubSpot, Salesforce, Pipedrive, Zoho, and many more via native integrations and Zapier. All call data, recordings, and lead info sync automatically.',
  },
  {
    question: 'What happens if no one is available to take a callback?',
    answer: 'LimeCall automatically schedules a follow-up, sends alerts to your team via SMS and email, and can present the visitor with a scheduling widget to pick their preferred callback time. For 24/7 coverage, consider adding an <a href="/ai-voice-agent/" class="text-lime-400 hover:underline">AI voice agent</a> to handle leads when your team is offline.',
  },
  {
    question: 'How is LimeCall different from a standard contact form?',
    answer: 'Contact forms create cold leads that go stale over hours or days. LimeCall initiates a live phone conversation within 28 seconds — when the prospect is most engaged. This dramatically increases conversion rates. Check our <a href="/pricing/" class="text-lime-400 hover:underline">pricing page</a> to see plans starting from free.',
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Customer Callback Software', url: `${site.url}/customer-callback-software/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        Callback Software
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Connect With Every Customer<br />
        <span class="text-lime-400">In Under 28 Seconds</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        LimeCall's callback widget sits on your website and connects visitors to your sales team in seconds — not hours. Increase call volume by 80% and cut response times to near zero. Pair it with a solid <a href="/website-conversion-rate-optimization/" class="text-lime-400 hover:text-lime-300 underline">website conversion rate optimization</a> strategy to get the most from every visitor.
      </p>

      <!-- Stats bar -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm">
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">28s</span>
          avg. callback time
        </span>
        <span class="hidden h-5 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">80%</span>
          more call requests
        </span>
        <span class="hidden h-5 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">20%</span>
          lower operating costs
        </span>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free — No Card Needed
        </a>
        <a
          href="/contact-us"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          Request a Demo
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">30-day money-back guarantee · Free plan available</p>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          How Callback Works in <span class="text-lime-400">3 Steps</span>
        </h2>
        <p class="mt-4 text-dark-400">From visitor intent to live conversation in under 30 seconds.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="relative flex flex-col rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="text-4xl font-extrabold text-lime-500/20 mb-4 leading-none">{step.number}</div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Built for <span class="text-lime-400">High-Converting Sales Teams</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Every feature in LimeCall is designed to reduce friction, increase answer rates, and help your team close more deals.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <FeatureCard icon={f.icon} name={f.name} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Callback Software vs. <span class="text-lime-400">Other Options</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          See how automated callback compares to phone systems and live chat for converting website visitors.
        </p>
      </div>
      <div class="overflow-x-auto rounded-2xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900/80">
              <th class="px-6 py-4 text-left font-semibold text-white">Feature</th>
              <th class="px-6 py-4 text-center font-semibold text-lime-400">Callback Software (LimeCall)</th>
              <th class="px-6 py-4 text-center font-semibold text-dark-400">Phone System / IVR</th>
              <th class="px-6 py-4 text-center font-semibold text-dark-400">Live Chat</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['Response time', '28 seconds', 'Customer waits on hold', '1–5 minutes'],
              ['Initiated by', 'Customer (no hold music)', 'Customer (hold queue)', 'Customer (text chat)'],
              ['Conversion quality', 'Live voice call', 'Live voice call', 'Text chat'],
              ['Missed call recovery', '✓ Auto follow-up + SMS', 'Voicemail only', 'Bot replies'],
              ['CRM integration', '✓ Automatic sync', 'Manual logging', 'Varies'],
              ['Call recording', '✓ Included', 'Add-on cost', '✗'],
              ['Lead analytics', '✓ Full tracking', 'Limited', 'Limited'],
              ['Setup time', '< 5 minutes', 'Hours / days', '30–60 minutes'],
            ].map(([feature, callback, phone, chat]) => (
              <tr class="bg-dark-950/40 hover:bg-dark-900/40 transition">
                <td class="px-6 py-4 font-medium text-white">{feature}</td>
                <td class="px-6 py-4 text-center text-lime-400 font-medium">{callback}</td>
                <td class="px-6 py-4 text-center text-dark-400">{phone}</td>
                <td class="px-6 py-4 text-center text-dark-400">{chat}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Social proof metrics -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-950/30 to-dark-900/80 p-8 sm:p-12">
        <h2 class="text-center text-2xl font-extrabold text-white mb-10">
          Results Our Customers Actually See
        </h2>
        <div class="grid gap-8 sm:grid-cols-4 text-center">
          <div>
            <div class="text-4xl font-extrabold text-lime-400">80%</div>
            <div class="mt-2 text-xs font-semibold text-white uppercase tracking-wide">More Call Requests</div>
          </div>
          <div>
            <div class="text-4xl font-extrabold text-lime-400">3x</div>
            <div class="mt-2 text-xs font-semibold text-white uppercase tracking-wide">Higher Conversions</div>
          </div>
          <div>
            <div class="text-4xl font-extrabold text-lime-400">20%</div>
            <div class="mt-2 text-xs font-semibold text-white uppercase tracking-wide">Lower Op. Costs</div>
          </div>
          <div>
            <div class="text-4xl font-extrabold text-lime-400">4.6/5</div>
            <div class="mt-2 text-xs font-semibold text-white uppercase tracking-wide">G2 &amp; Capterra</div>
          </div>
        </div>
        <blockquote class="mt-10 border-t border-dark-700 pt-8 text-center">
          <p class="text-lg text-dark-200 italic leading-relaxed">
            "Since adding LimeCall to our site, the number of inbound calls has increased by over 80%. Our sales team loves it — they're connecting with leads while they're still hot."
          </p>
          <footer class="mt-4 text-sm text-dark-500">— Head of Sales, LimeCall Customer</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Stop Losing Leads to <span class="text-lime-400">Slow Response Times</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        Every minute you wait to call a lead, your odds of connecting drop by 10x. LimeCall closes that gap automatically.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free Trial
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          View Pricing
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">30-day money-back guarantee · Cancel anytime</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="More from LimeCall"
        links={[
          { href: '/click-to-call-software', title: 'Click to Call Software', desc: 'Let website visitors call your team with a single click.' },
          { href: '/speed-to-lead', title: 'Speed to Lead', desc: 'Respond to every new lead in seconds, not hours.' },
          { href: '/lead-distribution', title: 'Lead Distribution', desc: 'Route every inbound lead to the right sales rep, automatically.' },
          { href: '/calltracking-software', title: 'Call Tracking', desc: 'Know which campaigns drive calls and conversions.' },
          { href: '/conversation-scheduling', title: 'Schedule Callbacks', desc: 'Let prospects book a callback at their preferred time.' },
          { href: '/pricing', title: 'Pricing', desc: 'Simple plans starting free. No hidden fees.' },
        ]}
      />
    </div>
  </section>
</Base>
