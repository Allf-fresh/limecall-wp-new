---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Programmable Callbacks — Custom Callback Automation | LimeCall',
  description: 'Trigger callbacks from any app or workflow via REST API. 99.9% uptime, <500ms trigger time, 50+ integrations. Build custom callback automation in minutes.',
  canonical: `${site.url}/programmable-callbacks/`,
};

const stats = [
  { value: '99.9%', label: 'API Uptime', sub: 'Enterprise SLA with redundant infrastructure' },
  { value: '<500ms', label: 'Trigger Time', sub: 'From API call to callback initiation' },
  { value: '50+', label: 'Integrations', sub: 'Connect any app via Zapier, webhooks, or REST' },
  { value: 'REST', label: 'API Standard', sub: 'JSON responses, webhook events, full docs' },
];

const features = [
  {
    icon: '⚙️',
    name: 'REST API',
    description: 'Trigger callbacks programmatically from any application or script. Full REST API with JSON responses, authentication tokens, and comprehensive documentation.',
  },
  {
    icon: '🔔',
    name: 'Webhooks',
    description: 'Receive real-time events for every callback state change — initiated, connected, completed, or missed. Build reactive workflows that act on call outcomes.',
  },
  {
    icon: '⚡',
    name: 'Zapier Integration',
    description: 'Connect LimeCall to 5,000+ apps without writing a line of code. Trigger callbacks from CRM updates, form submissions, e-commerce events, and more.',
  },
  {
    icon: '🎯',
    name: 'Custom Triggers',
    description: 'Define exactly when callbacks should fire based on any data signal — page visits, score thresholds, subscription events, or custom business logic.',
  },
  {
    icon: '🕐',
    name: 'Scheduling Rules',
    description: 'Specify callback windows, time zones, and retry schedules. Ensure callbacks only happen during business hours and retry automatically if the first attempt fails.',
  },
  {
    icon: '🔄',
    name: 'Retry Logic',
    description: 'Configure automatic retry sequences with customisable intervals. If a call is not answered, LimeCall retries up to 5 times across a timeframe you define.',
  },
];

const useCases = [
  {
    icon: '📋',
    title: 'Form Submission Trigger',
    description: 'When a visitor submits your lead form, the API fires a callback request to your team instantly — no manual handoff, no delay, no lost leads.',
  },
  {
    icon: '🏢',
    title: 'CRM Workflow Trigger',
    description: 'Trigger callbacks when a deal reaches a specific stage, a lead score crosses a threshold, or a contact has not been touched in 48 hours.',
  },
  {
    icon: '💬',
    title: 'Chat Escalation',
    description: 'When a live chat reaches a point where a human call would close faster, trigger an instant callback automatically — bridging chat and voice seamlessly.',
  },
  {
    icon: '🛒',
    title: 'E-commerce Cart Events',
    description: 'Trigger high-value callbacks when a cart exceeds a threshold, a customer abandons a high-value order, or a VIP customer needs concierge service.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Authenticate & Get Your API Key',
    description: 'Sign up for LimeCall and grab your API key from the developer dashboard. All API calls are authenticated with Bearer tokens over HTTPS.',
  },
  {
    number: '02',
    title: 'POST a Callback Request',
    description: 'Send a POST request with the customer\'s number, your team\'s number, and optional scheduling parameters. LimeCall initiates the callback within 500ms.',
  },
  {
    number: '03',
    title: 'Handle Webhook Events',
    description: 'Subscribe to webhook events to receive real-time updates on call outcomes. Update your CRM, trigger follow-ups, or log data — fully automated.',
  },
];

const faqs = [
  {
    question: 'What is a programmable callback?',
    answer: 'A programmable callback is a phone call triggered automatically by code or an automated workflow rather than a manual action. Using LimeCall\'s REST API, any application can initiate a callback — connecting a customer with a sales rep the moment a relevant trigger event occurs.',
  },
  {
    question: 'Do I need a developer to use programmable callbacks?',
    answer: 'Not necessarily. Non-technical teams can use LimeCall\'s Zapier integration to connect any of 5,000+ apps without writing code. Developers can use the REST API for maximum control and customisation. Both options are fully supported.',
  },
  {
    question: 'What programming languages does the LimeCall API support?',
    answer: 'LimeCall\'s REST API works with any language that can make HTTPS requests — Python, JavaScript/Node.js, PHP, Ruby, Java, Go, and more. We provide official client libraries for Python and JavaScript, plus code examples for all major languages in our documentation.',
  },
  {
    question: 'Can I schedule callbacks for a future time?',
    answer: 'Yes. The API supports a scheduled_at parameter that accepts an ISO 8601 timestamp. You can queue callbacks for specific times, and LimeCall will trigger them automatically. Callbacks outside business hours are held and triggered at the next available window.',
  },
  {
    question: 'How do webhooks work with programmable callbacks?',
    answer: 'When you register a webhook URL, LimeCall sends HTTP POST requests to that URL whenever a callback event occurs — such as call.initiated, call.connected, call.completed, or call.missed. Your server receives the payload and can trigger downstream actions like CRM updates or SMS follow-ups.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqJsonLd} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Programmable Callbacks', url: `${site.url}/programmable-callbacks/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        API & Developer Tools
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Trigger Callbacks from<br />
        <span class="text-lime-400">Any App or Workflow via API</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        LimeCall's programmable callback API lets developers and no-code teams fire instant phone callbacks from any trigger — form submissions, CRM events, chat escalations, or custom business logic.
      </p>

      <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-900 px-5 py-3 font-mono text-sm text-lime-400">
        POST https://api.limecall.com/v1/callbacks
      </div>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Get Your API Key Free
        </a>
        <a
          href="/integrations"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          View Integrations
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Full API docs included · Free tier available · No rate limits on paid plans</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/60 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-center">
        {stats.map((s) => (
          <div class="p-4">
            <div class="text-4xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-2 text-sm font-bold text-white">{s.label}</div>
            <div class="mt-1 text-xs text-dark-500">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Everything You Need to Build<br />
          <span class="text-lime-400">Custom Callback Automation</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          A complete developer toolkit for triggering, scheduling, and tracking programmatic callbacks at scale.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{f.name}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          What Teams Build with<br />
          <span class="text-lime-400">Programmable Callbacks</span>
        </h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {useCases.map((uc) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="text-3xl mb-3">{uc.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-2">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Integrate in <span class="text-lime-400">3 Steps</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          From API key to live callbacks in minutes. Our documentation covers every language and use case.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="relative flex flex-col rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="text-4xl font-extrabold text-lime-500/20 mb-4 leading-none">{step.number}</div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Build Smarter Callback Workflows.<br />
        <span class="text-lime-400">Start with a Free API Key.</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        Full REST API, webhook events, and Zapier integration included on every plan. Start building in minutes.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Get API Key Free
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          View Pricing
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">Free tier available · Full docs included · No lock-in</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="Explore Developer & Integration Resources"
        links={[
          { href: '/webhooks', title: 'Webhooks', desc: 'Real-time event notifications for every call state change.' },
          { href: '/integrations', title: 'Integrations', desc: 'Connect LimeCall to 50+ tools including HubSpot and Salesforce.' },
          { href: '/click-to-call-software', title: 'Click to Call Software', desc: 'No-code callback widget for your website.' },
          { href: '/pricing', title: 'Pricing', desc: 'API access included on Pro plan and above.' },
        ]}
      />
    </div>
  </section>
</Base>
