---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const industry = "Construction";
const icon = "🏗️";

const seo = {
  title: `Construction Lead Generation Software | LimeCall`,
  description: `Win more construction projects by responding first. LimeCall's instant callback software helps contractors and builders connect with project inquiries in under 28 seconds.`,
  canonical: `https://www.limecall.com/lead-generation-for-construction/`,
};

const useCases = [
  { title: "Instant Callback on Project Inquiries", desc: "Homeowners and project managers get multiple quotes. When someone submits a project inquiry on your site, LimeCall connects your estimator in under 28 seconds — putting you ahead of every competitor." },
  { title: "Contractor & Specialist Routing", desc: "Route project inquiries to the right contractor, foreman, or specialist based on project type, location, or scope. Get the right person on the call from the very first touch." },
  { title: "Quote Request Callbacks", desc: "Capture quote requests 24/7 and schedule callbacks during working hours. Your estimators wake up to a pipeline of warm leads who are ready to discuss project details." },
  { title: "Emergency & Urgent Work Capture", desc: "Storm damage, structural issues, and urgent repairs can't wait until Monday. Capture emergency callbacks with priority routing so your on-call crew responds before anyone else does." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More project quotes won" },
  { value: "80%", label: "Reduction in missed leads" },
  { value: "5 min", label: "Setup time" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Why is speed to lead so important for construction businesses?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '89% of construction leads go with the first contractor who responds. Homeowners and project managers typically request quotes from multiple contractors in one sitting. The contractor who calls back first sets the benchmark for price and service — and is usually the one who wins the job.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall handle urgent or emergency construction inquiry callbacks?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall supports priority routing for emergency inquiries. You can configure urgent request types — such as storm damage or structural issues — to route directly to your on-call crew at any hour, ensuring the highest-value emergency jobs are captured before a competitor is called.'
      }
    },
    {
      '@type': 'Question',
      name: 'How does LimeCall help estimators manage their quote pipeline?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall captures all after-hours quote requests and queues them for your estimating team. Each morning your team sees a prioritized list of warm callbacks to action. Every inquiry is logged with project details so estimators arrive at each call fully prepared.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall work for small contractors as well as large builders?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Absolutely. LimeCall is used by solo contractors, specialist tradespeople, and large construction firms alike. Setup takes 5 minutes and plans are available for any team size. Small contractors especially benefit because it levels the playing field against larger companies with dedicated call center teams.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I route construction callbacks to different specialists by trade?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall\'s routing rules let you direct roofing inquiries to your roofing team, groundwork queries to civil engineers, and interior fit-out requests to the appropriate project manager. This ensures every prospect speaks to a relevant expert from their very first call.'
      }
    },
  ]
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `Construction Lead Generation`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{icon}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        <span class="text-lime-400">{industry}</span> Lead Generation Software
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Win more construction projects by being the first contractor to call back. Connect with project inquiries in under 28 seconds.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Built for {industry} businesses</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How LimeCall works for Construction</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Client requests a quote", desc: "A homeowner or project manager visits your site and clicks the LimeCall widget to request a project callback." },
          { step: "2", title: "Estimator connected fast", desc: "LimeCall calls your estimator and the prospect simultaneously, connecting them in under 28 seconds." },
          { step: "3", title: "Opportunity logged", desc: "The conversation is recorded and logged. Auto-follow-up kicks in if no one answers the first time." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison section -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Why instant callbacks beat waiting for the client to call again</h2>
      <p class="mb-10 text-center text-dark-400 text-sm max-w-2xl mx-auto">3 in 4 homeowners call before hiring a contractor — but they call multiple contractors. The first one to respond wins 89% of the time.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 text-sm font-bold text-dark-400 uppercase tracking-wider">Waiting for the Client to Call Back</div>
          <ul class="space-y-3 text-sm text-dark-400">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Client fills in a form and moves on to the next contractor</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> You call back hours later — they've already accepted a competitor's quote</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Emergency jobs go to whoever answers first — not you</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> After-hours inquiries disappear before Monday morning</li>
          </ul>
        </div>
        <div class="rounded-xl border border-lime-500/30 bg-lime-950/10 p-6">
          <div class="mb-4 text-sm font-bold text-lime-400 uppercase tracking-wider">LimeCall Instant Callback</div>
          <ul class="space-y-3 text-sm text-dark-300">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Client is talking to your estimator in under 28 seconds</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> You're first to quote — and first to build trust</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Emergency routing ensures urgent jobs are captured any time</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> After-hours requests queued and ready for Monday morning</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="cursor-pointer list-none font-semibold text-white flex justify-between items-center gap-4">
              <span>{faq.name}</span>
              <span class="shrink-0 text-lime-400 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to win more construction projects?</h2>
      <p class="mt-4 text-dark-400">Set up in 5 minutes. No credit card required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4">
    <CrossLinks heading="More LimeCall Solutions" links={[
      { href: '/lead-generation-for-home-services/', title: 'Home Services Lead Gen', desc: 'Callbacks for plumbers, electricians & more.' },
      { href: '/click-to-call-software/', title: 'Click to Call', desc: 'Instant callbacks from your website.' },
      { href: '/conversation-scheduling/', title: 'Schedule Callbacks', desc: 'Let prospects pick a call time that suits them.' },
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
    ]} />
  </div>
</Base>
