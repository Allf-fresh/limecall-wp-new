---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';

const seo = {
  title: 'About Us | Callback Solutions Company | LimeCall',
  description: 'The idea and the people behind LimeCall. Our vision is to deliver a multichannel real-time platform enhanced by data integration that helps businesses convert website visitors into sales calls instantly.',
  canonical: 'https://www.limecall.com/about-us/',
};
---
<Base {...seo}>
  <!-- Hero -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 -translate-x-1/2 h-[500px] w-[700px] rounded-full bg-lime-500/8 blur-[120px]"></div>
    </div>
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block mb-4 rounded-full bg-lime-500/10 px-4 py-1.5 text-sm font-semibold text-lime-400">Our Story</span>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl leading-tight">
        Turning website visitors into
        <span class="text-lime-400"> real conversations</span>
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-dark-300 sm:text-xl max-w-2xl mx-auto">
        LimeCall was born from a simple insight: the gap between a website visitor and a sales conversation is costing businesses millions in lost revenue. We built the platform to close that gap — instantly.
      </p>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div>
          <h2 class="text-3xl font-bold text-white mb-6">Our Mission</h2>
          <p class="text-dark-300 text-lg leading-relaxed mb-4">
            We believe every sales conversation starts with a moment of intent. When a visitor lands on your website, they have a question, a need, a problem to solve. That moment is fleeting.
          </p>
          <p class="text-dark-300 text-lg leading-relaxed mb-4">
            LimeCall's mission is to make that connection instant — connecting the right visitor with the right sales rep in seconds, not minutes. Because speed-to-lead is everything.
          </p>
          <p class="text-dark-300 text-lg leading-relaxed">
            Our #1 callback automation platform increases website conversions by up to 300% by eliminating friction from the sales process.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-6">
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6 text-center">
            <div class="text-4xl font-extrabold text-lime-400 mb-2">300%</div>
            <div class="text-dark-400 text-sm">Increase in conversions</div>
          </div>
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6 text-center">
            <div class="text-4xl font-extrabold text-lime-400 mb-2">28s</div>
            <div class="text-dark-400 text-sm">Average callback time</div>
          </div>
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6 text-center">
            <div class="text-4xl font-extrabold text-lime-400 mb-2">50+</div>
            <div class="text-dark-400 text-sm">Countries supported</div>
          </div>
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6 text-center">
            <div class="text-4xl font-extrabold text-lime-400 mb-2">1000+</div>
            <div class="text-dark-400 text-sm">Businesses worldwide</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 border-t border-dark-800 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white">What drives us</h2>
        <p class="mt-4 text-dark-400 text-lg">The values behind every feature we build.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
          <div class="text-3xl mb-4">⚡</div>
          <h3 class="text-lg font-bold text-white mb-2">Speed First</h3>
          <p class="text-dark-400 text-sm leading-relaxed">Response time is the #1 factor in lead conversion. We obsess over every millisecond between intent and connection.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
          <div class="text-3xl mb-4">🎯</div>
          <h3 class="text-lg font-bold text-white mb-2">Right Person, Right Time</h3>
          <p class="text-dark-400 text-sm leading-relaxed">Smart lead distribution ensures every inbound call reaches the best available rep — not just whoever picks up first.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
          <div class="text-3xl mb-4">📊</div>
          <h3 class="text-lg font-bold text-white mb-2">Data-Driven</h3>
          <p class="text-dark-400 text-sm leading-relaxed">Every call, every conversion, every outcome is tracked. Use the insights to continuously improve your sales process.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-dark-800">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Ready to convert more visitors?
      </h2>
      <p class="mt-4 text-lg text-dark-400">
        Join thousands of businesses using LimeCall to turn website traffic into revenue.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/signup" size="lg">TRY FOR FREE</Button>
        <Button href="/contact-us" variant="outline" size="lg">Talk to sales</Button>
      </div>
    </div>
  </section>
</Base>
