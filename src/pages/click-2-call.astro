---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `Click 2 Call Software — Instant Calls From Your Website | LimeCall`,
  description: `Click 2 Call (also known as Click to Call) connects website visitors to your sales team instantly with one click. No hold times, no friction — just conversations that convert.`,
  canonical: `https://www.limecall.com/click-2-call/`,
};

const stats = [
  { value: "28s", label: "Avg. connection time" },
  { value: "10–12x", label: "Higher conversion vs forms" },
  { value: "300%", label: "More conversions" },
  { value: "5 min", label: "Setup time" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is click 2 call software?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Click 2 call software (also written click-to-call or click to call) lets website visitors initiate a phone call to your business with a single button click. Instead of finding and manually dialling a number, the visitor clicks a button and LimeCall connects them to your sales or support team within seconds — while their interest is at its peak.',
      },
    },
    {
      '@type': 'Question',
      name: 'How fast does click 2 call connect a call?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall connects click-to-call requests in under 28 seconds on average. When a visitor clicks the widget, LimeCall simultaneously dials your team and the visitor. Both parties pick up a live call — no hold music, no delays. This speed is the key to higher conversion: studies show leads contacted within the first minute are 391% more likely to convert.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does click 2 call work on mobile devices?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall\'s click-to-call widget is fully mobile-optimised. On mobile, the visitor can tap the button and enter their number, or LimeCall can use the number associated with their browser session. The callback then connects via a standard phone call — no app download required. Over 60% of LimeCall callbacks are initiated from mobile devices.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does click 2 call integrate with my CRM?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall integrates natively with HubSpot, Salesforce, Zoho CRM, Pipedrive, and Zendesk. Every click-to-call conversation is automatically logged with the caller\'s details, call duration, recording link, and outcome. Zapier support extends this to 5,000+ additional tools. No manual data entry required.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does click 2 call software cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall offers a free trial so you can test click-to-call on your website before committing to a paid plan. Paid plans include call routing, recording, analytics, and CRM integrations. Visit the LimeCall pricing page for current plan details and to compare features across tiers.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Click 2 Call", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Also known as "Click to Call"
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Click 2 Call — Connect Instantly
      </h1>
      <p class="mt-2 text-lg font-medium text-lime-400">Also referred to as Click to Call or Click-to-Call</p>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Let website visitors connect with your sales team with a single click. No hold times, no phone numbers to dial — just an instant, live conversation the moment interest peaks.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Try Click 2 Call Free →
        </a>
        <a href="/click-to-call-software/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          Learn More
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What is Click 2 Call -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8 sm:p-12">
        <h2 class="mb-6 text-2xl font-bold text-white">What is Click 2 Call?</h2>
        <div class="space-y-4 text-dark-300 leading-relaxed">
          <p>
            <strong class="text-white">Click 2 Call</strong> (or Click-to-Call, or Click to Call) is a technology that lets website visitors initiate a phone call to your business with a single button click. When a visitor clicks the button, LimeCall simultaneously calls your sales team and the visitor, connecting them in seconds.
          </p>
          <p>
            Unlike traditional callback forms that create delays, Click 2 Call connects callers instantly — while their interest is at its peak. Studies show that responding within the first minute of a web inquiry increases lead conversion by 391%.
          </p>
          <p>
            LimeCall's Click 2 Call solution includes smart routing, call recording, analytics, and CRM integration — everything you need to turn website traffic into live sales conversations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How Click 2 Call works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Visitor clicks the button", desc: "A high-intent visitor sees your Click 2 Call button on any page — product, pricing, landing page, or exit-intent overlay — and clicks it." },
          { step: "2", title: "LimeCall connects both parties", desc: "LimeCall simultaneously dials your team and the visitor. Both pick up a live call within 28 seconds — no hold music, no dialling, no delays." },
          { step: "3", title: "Conversation converts", desc: "Your rep talks to a warm, ready-to-buy prospect. Every call is recorded, logged, and attributed so you know exactly which pages and campaigns drive calls." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">What's included with Click 2 Call</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "One-Click Connection", desc: "Visitors click a button on your website. LimeCall calls your team and the visitor simultaneously — connected in under 28 seconds." },
          { title: "Smart Call Routing", desc: "Route calls to the right sales rep based on availability, skills, time zone, or round-robin distribution." },
          { title: "Call Recording", desc: "Record every call automatically for quality assurance, training, and compliance." },
          { title: "CRM Integration", desc: "Log every Click 2 Call conversation to your CRM automatically. Full context for every lead." },
          { title: "Analytics & Reporting", desc: "Track call volume, connection rates, duration, and conversions. Know what's working and optimize." },
          { title: "Customizable Widget", desc: "Match the Click 2 Call button to your brand. Choose colors, text, position, and display rules." },
        ].map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Click 2 Call vs a phone number on your website</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-lime-500/40 bg-lime-500/5 p-6">
          <h3 class="mb-4 text-lg font-bold text-lime-400">LimeCall Click 2 Call</h3>
          <ul class="space-y-3 text-sm text-dark-300">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span><span>Works on mobile without the visitor leaving the page</span></li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span><span>LimeCall connects the call — your rep just picks up</span></li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span><span>Every call tracked, recorded, and attributed to a source</span></li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span><span>Smart routing — right rep, right time, every time</span></li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span><span>After-hours: request queued and followed up next day</span></li>
          </ul>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-4 text-lg font-bold text-white">Static Phone Number</h3>
          <ul class="space-y-3 text-sm text-dark-400">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-dark-500">✗</span><span>Visitor must dial manually — friction kills conversions</span></li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-dark-500">✗</span><span>No call tracking — no idea which page or ad drove the call</span></li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-dark-500">✗</span><span>Calls ring on a single line — missed calls lost forever</span></li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-dark-500">✗</span><span>No routing — whoever answers gets the call</span></li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-dark-500">✗</span><span>After-hours calls go to voicemail — rarely returned</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="cursor-pointer list-none font-semibold text-white group-open:text-lime-400">{faq.name}</summary>
            <p class="mt-3 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to add Click 2 Call to your website?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall to connect with website visitors instantly and increase conversions.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="Explore More"
        links={[
          { href: '/click-to-call-software/', title: 'Click to Call Software', desc: 'Full click-to-call feature page with advanced routing.' },
          { href: '/lead-capture-software/', title: 'Lead Capture Software', desc: 'Capture every inbound lead automatically.' },
          { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'Why responding in seconds wins more deals.' },
          { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
        ]}
      />
    </div>
  </div>
</Base>
