---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { faqSchema, articleSchema } from '../lib/seo';
import { site } from '../site.config';

const seo = {
  title: 'B2B Lead Generation Software & Strategies (2025) | LimeCall',
  description:
    'The definitive B2B lead generation guide. How to generate, qualify, and convert B2B leads 5x faster with the right tech stack and callback strategy.',
  canonical: `${site.url}/b2b-lead-generation/`,
};

const faqs = [
  {
    question: 'What is the best B2B lead generation tool in 2025?',
    answer:
      'The best B2B lead generation tool depends on where you are in the funnel. For top-of-funnel, LinkedIn Sales Navigator and intent data platforms like Bombora drive pipeline. For conversion, callback software like LimeCall is the highest-ROI tool — because when a B2B buyer calls, they are 8x more likely to convert than a form fill. The winning stack combines CRM + marketing automation + callback software, with LimeCall as the instant-response layer. See our <a href="/lead-routing-software/" class="text-lime-400 hover:underline">lead routing software</a> for intelligent distribution.',
  },
  {
    question: 'How do you qualify B2B leads quickly?',
    answer:
      'The fastest way to qualify B2B leads is to call them immediately. Phone conversations reveal BANT (Budget, Authority, Need, Timeline) in 3–4 minutes — far faster than email chains that take days. LimeCall\'s callback software triggers an automatic call within 28 seconds of a lead showing intent, so your reps are qualifying live conversations rather than chasing cold form fills. Many teams also use LimeCall\'s AI voice agent for 24/7 automated first-touch qualification.',
  },
  {
    question: 'What is a good B2B lead conversion rate?',
    answer:
      'Average B2B lead-to-opportunity conversion is 13%, and opportunity-to-close is around 6% (Salesforce State of Sales). Top-performing teams achieve 25–40% lead-to-opportunity rates by combining intent-driven targeting with instant callback response. The single biggest lever is response time: responding within 5 minutes vs. 30 minutes can triple your qualification rate. LimeCall customers typically see 2–4x improvement in lead-to-meeting conversion within the first 90 days.',
  },
  {
    question: 'What is the dark funnel in B2B lead generation?',
    answer:
      'The dark funnel refers to all the B2B buyer research that happens before a prospect ever fills a form or contacts sales — review site visits, peer conversations, LinkedIn research, and competitor comparisons. Research from Forrester shows 67% of B2B buyers have already made a decision before contacting a vendor. This means the quality of your content, reviews, and word-of-mouth directly impacts inbound intent — and when a buyer finally does reach out, they are typically ready to move fast. This is exactly when instant callback matters most.',
  },
  {
    question: 'How does ABM (Account-Based Marketing) work with callback software?',
    answer:
      'ABM identifies high-value target accounts and orchestrates personalised outreach across channels. When ABM campaigns drive a target account to your website, callback software ensures the response is instant and routed to the correct account executive. LimeCall integrates with HubSpot, Salesforce, and Marketo — so when a target account contacts you, the right rep is dialled within seconds with full account context. This turns ABM\'s high-cost campaigns into high-conversion outcomes.',
  },
  {
    question: 'What is the phone call advantage in B2B sales?',
    answer:
      'When a B2B buyer calls or requests a callback, they are 8x more likely to convert than an equivalent form fill, according to Google and BIA/Kelsey research. Phone calls compress weeks of email back-and-forth into a single conversation. They allow instant qualification, objection handling, and relationship building. The challenge is answering fast enough — which is why callback automation is the most impactful investment for B2B sales teams. LimeCall\'s <a href="/ai-voice-agent/" class="text-lime-400 hover:underline">AI Voice Agent</a> can handle initial qualification 24/7.',
  },
];

const articleJsonLd = articleSchema({
  title: seo.title,
  description: seo.description,
  url: `${site.url}/b2b-lead-generation/`,
  publishDate: '2024-03-01',
  modifiedDate: '2025-02-01',
  author: site.name,
});

const channels = [
  {
    icon: '🎯',
    name: 'Account-Based Marketing (ABM)',
    desc: 'Target specific high-value accounts with personalised content and ads. Highest deal size, longest sales cycle.',
    roi: 'Highest deal value',
  },
  {
    icon: '💼',
    name: 'LinkedIn Outbound',
    desc: 'Direct reach to decision-makers. LinkedIn Sales Navigator enables precise targeting by title, industry, and company size.',
    roi: 'Best DM channel',
  },
  {
    icon: '🔍',
    name: 'SEO & Content',
    desc: 'Rank for buyer-intent keywords. Educational content builds trust across the long research phase of B2B buying.',
    roi: 'Lowest CPL at scale',
  },
  {
    icon: '💰',
    name: 'Paid Search (PPC)',
    desc: 'Immediate reach for high-intent keywords. Google and Bing capture buyers at decision stage.',
    roi: 'Fastest to launch',
  },
  {
    icon: '🎙',
    name: 'Webinars & Events',
    desc: 'Establish thought leadership and capture engaged audiences. High-quality leads who know your brand.',
    roi: 'Best for trust',
  },
  {
    icon: '🤝',
    name: 'Partnerships & Integrations',
    desc: 'Co-marketing with complementary tools creates warm introduction pipelines. Technology partnerships drive recurring qualified leads.',
    roi: 'Lowest CAC',
  },
  {
    icon: '🌟',
    name: 'Referrals',
    desc: 'Customer referrals close 4x faster than cold leads and require no marketing spend. Structured referral programmes scale this.',
    roi: 'Highest close rate',
  },
];

const qualFrameworks = [
  {
    name: 'BANT',
    stands: 'Budget · Authority · Need · Timeline',
    when: 'Best for transactional B2B sales with clear purchasing criteria',
    howCallback: 'Phone call covers all four BANT criteria in under 4 minutes',
  },
  {
    name: 'MEDDIC',
    stands: 'Metrics · Economic Buyer · Decision Criteria · Decision Process · Identify Pain · Champion',
    when: 'Enterprise deals with complex buying committees',
    howCallback: 'First callback surfaces champion and maps decision process before AE time is invested',
  },
  {
    name: 'CHAMP',
    stands: 'Challenges · Authority · Money · Prioritization',
    when: 'Modern challenger-sale approach — leads with pain, not budget',
    howCallback: 'Instant callback catches the moment of pain awareness — highest conversion window',
  },
];

const techStack = [
  { layer: 'CRM', tools: 'HubSpot, Salesforce, Pipedrive', purpose: 'Central record of all leads, accounts, and deals', critical: false },
  { layer: 'Marketing Automation', tools: 'Marketo, HubSpot, Pardot', purpose: 'Nurture sequences, lead scoring, campaign tracking', critical: false },
  { layer: 'Intent Data', tools: 'Bombora, 6sense, G2 Buyer Intent', purpose: 'Identify accounts showing buying signals before they contact you', critical: false },
  { layer: 'Callback Software', tools: 'LimeCall', purpose: 'Instant callbacks — convert inbound intent into live conversations in 28 seconds', critical: true },
  { layer: 'Sales Engagement', tools: 'Outreach, Salesloft, Apollo', purpose: 'Sequence-driven outbound follow-up and cadence management', critical: false },
  { layer: 'Analytics', tools: 'GA4, Segment, Tableau', purpose: 'Pipeline attribution, channel ROI, conversion funnel analysis', critical: false },
];

const buyerJourneyStages = [
  {
    stage: 'Awareness',
    description: 'The buyer realises they have a problem. They are researching broadly, often anonymously.',
    darkFunnel: 'Most of this happens invisibly — peer conversations, review sites, social scrolling.',
    tactic: 'Educational content, thought leadership, community presence.',
  },
  {
    stage: 'Consideration',
    description: 'The buyer is actively evaluating solutions and vendors. Intent signals spike here.',
    darkFunnel: 'G2/Capterra comparisons, LinkedIn research on your team, asking peers for recommendations.',
    tactic: 'Case studies, comparison pages, product demos, webinars.',
  },
  {
    stage: 'Decision',
    description: '67% of buyers have already decided when they contact you. This is the phone call moment.',
    darkFunnel: 'By the time they fill your form or click callback, the decision is nearly made. Response speed determines who wins.',
    tactic: 'Instant callback via LimeCall — connect within 28 seconds while intent is at peak.',
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />
  <JsonLd schema={articleJsonLd} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'B2B Lead Generation', url: `${site.url}/b2b-lead-generation/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        B2B Lead Generation Guide 2025
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        B2B Lead Generation:<br />
        <span class="text-lime-400">Generate More Pipeline, Convert Faster</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        B2B lead generation is the process of identifying and attracting potential business customers for your product or service. In 2025, the average B2B sales cycle is 6.2 months, but top performers shortcut this by responding to inbound leads within 5 minutes — 21x more likely to qualify than the industry average of 42 hours.
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-base text-dark-400 leading-relaxed">
        This guide shows you every channel, framework, and tool you need — including the phone call advantage that drives 8x higher conversions than form fills.
      </p>

      <!-- Stat trio -->
      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-5">
          <div class="text-3xl font-extrabold text-lime-400">6.2 mo</div>
          <div class="mt-1 text-sm font-semibold text-white">Average B2B deal cycle</div>
          <div class="mt-1 text-xs text-dark-500">Salesforce State of Sales 2024</div>
        </div>
        <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-5">
          <div class="text-3xl font-extrabold text-lime-400">8x</div>
          <div class="mt-1 text-sm font-semibold text-white">Higher conversion on phone vs. form</div>
          <div class="mt-1 text-xs text-dark-500">Google/BIA Kelsey research</div>
        </div>
        <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-5">
          <div class="text-3xl font-extrabold text-lime-400">67%</div>
          <div class="mt-1 text-sm font-semibold text-white">Decided before calling sales</div>
          <div class="mt-1 text-xs text-dark-500">Forrester B2B Buyer Study</div>
        </div>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free — Build Your B2B Pipeline
        </a>
        <a
          href="/contact-us"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          Request a Demo
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">30-day money-back guarantee · Free plan available</p>
    </div>
  </section>

  <!-- B2B vs B2C -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl mb-8">
        B2B vs B2C Lead Gen: <span class="text-lime-400">Key Differences</span>
      </h2>
      <div class="grid gap-5 sm:grid-cols-2">
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
          <div class="text-2xl mb-3">🏢</div>
          <h3 class="text-lg font-bold text-white mb-3">B2B Lead Generation</h3>
          <ul class="space-y-2 text-sm text-dark-400">
            <li class="flex gap-2"><span class="text-lime-400">→</span> Longer sales cycles (weeks to months)</li>
            <li class="flex gap-2"><span class="text-lime-400">→</span> Multiple stakeholders in the buying decision</li>
            <li class="flex gap-2"><span class="text-lime-400">→</span> Higher deal values ($5K–$500K+)</li>
            <li class="flex gap-2"><span class="text-lime-400">→</span> Rational, ROI-driven purchase decisions</li>
            <li class="flex gap-2"><span class="text-lime-400">→</span> Relationship and trust are primary conversion factors</li>
            <li class="flex gap-2"><span class="text-lime-400">→</span> Phone call is the #1 conversion channel</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
          <div class="text-2xl mb-3">🛒</div>
          <h3 class="text-lg font-bold text-white mb-3">B2C Lead Generation</h3>
          <ul class="space-y-2 text-sm text-dark-400">
            <li class="flex gap-2"><span class="text-dark-500">→</span> Shorter sales cycles (hours to days)</li>
            <li class="flex gap-2"><span class="text-dark-500">→</span> Single decision-maker, individual purchase</li>
            <li class="flex gap-2"><span class="text-dark-500">→</span> Lower average order values</li>
            <li class="flex gap-2"><span class="text-dark-500">→</span> Emotional and convenience-driven decisions</li>
            <li class="flex gap-2"><span class="text-dark-500">→</span> Social proof and UX drive conversion</li>
            <li class="flex gap-2"><span class="text-dark-500">→</span> Self-serve checkout is primary conversion channel</li>
          </ul>
        </div>
      </div>
      <p class="mt-6 text-dark-400 text-sm leading-relaxed">
        The critical B2B distinction: because deal values are high and buying cycles are long, the <strong class="text-white">moment a B2B buyer shows inbound intent is extraordinarily valuable</strong>. Responding instantly — via callback — is worth far more in B2B than any other context.
      </p>
    </div>
  </section>

  <!-- Buyer Journey -->
  <section class="border-t border-dark-800 bg-dark-900/50 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          The B2B Buyer Journey in 2025:<br />
          <span class="text-lime-400">The Dark Funnel Reality</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Most of the B2B buying journey is invisible to you. By the time a prospect makes contact, they have done 70% of their research — often choosing their preferred vendor before the first conversation.
        </p>
      </div>

      <div class="space-y-4">
        {buyerJourneyStages.map((stage, i) => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="grid gap-6 sm:grid-cols-3">
              <div>
                <div class="flex items-center gap-3 mb-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded-full bg-lime-500/15 text-xs font-extrabold text-lime-400">
                    {i + 1}
                  </div>
                  <h3 class="font-bold text-white text-lg">{stage.stage}</h3>
                </div>
                <p class="text-sm text-dark-400 leading-relaxed">{stage.description}</p>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-dark-500 mb-2">Dark Funnel Activity</div>
                <p class="text-sm text-dark-400 leading-relaxed italic">{stage.darkFunnel}</p>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-lime-400 mb-2">Your Tactic</div>
                <p class="text-sm text-dark-300 leading-relaxed">{stage.tactic}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Channels -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Top B2B Lead Generation <span class="text-lime-400">Channels in 2025</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Seven proven B2B demand generation channels — and how callback software converts each one into live pipeline.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {channels.map((ch) => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6 flex flex-col">
            <div class="text-3xl mb-3">{ch.icon}</div>
            <h3 class="font-bold text-white mb-2">{ch.name}</h3>
            <p class="text-xs text-dark-400 leading-relaxed flex-1 mb-4">{ch.desc}</p>
            <div class="rounded-lg bg-lime-500/5 border border-lime-500/20 px-3 py-2 text-xs text-lime-400 font-semibold">
              {ch.roi}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Phone Call Advantage -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-2 items-center">
        <div>
          <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
            The Phone Call Advantage:<br />
            <span class="text-lime-400">8x Higher Conversion Than Forms</span>
          </h2>
          <p class="mt-4 text-dark-400 leading-relaxed">
            When a B2B buyer picks up the phone or requests a callback, something profound has happened: they have moved from research mode to buying mode. This is the highest-intent signal in the entire customer acquisition funnel — and yet most companies respond with a form confirmation email that arrives hours later.
          </p>
          <p class="mt-4 text-dark-400 leading-relaxed">
            Google and BIA/Kelsey research consistently shows phone calls convert at 8x the rate of equivalent web form fills. In B2B contexts with complex products and high deal values, the multiplier is even larger. The reason is simple: a phone call compresses weeks of email back-and-forth into 15 minutes of direct qualification and relationship building.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              'Phone calls surface BANT criteria in 3–4 minutes vs. weeks of email',
              'Live conversation enables real-time objection handling',
              'Buyers who call have already vetted you — they want to be sold',
              'LimeCall answers every callback request in under 28 seconds',
              'AI Voice Agent handles 24/7 first-touch qualification automatically',
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-dark-300">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="space-y-4">
          <h3 class="text-lg font-bold text-white">Conversion Rate: Phone vs. Form</h3>
          {[
            { label: 'Inbound phone call / callback request', rate: '8x higher', pct: 88, highlight: true },
            { label: 'Live chat conversation', rate: '4x higher', pct: 55, highlight: false },
            { label: 'Form fill (demo request)', rate: 'Baseline (1x)', pct: 20, highlight: false },
            { label: 'Email enquiry', rate: '0.6x (slower)', pct: 12, highlight: false },
          ].map((r) => (
            <div class={`rounded-xl border p-5 ${r.highlight ? 'border-lime-500/30 bg-lime-950/20' : 'border-dark-800 bg-dark-900/60'}`}>
              <div class="flex justify-between items-center mb-2">
                <span class={`text-sm font-medium ${r.highlight ? 'text-white' : 'text-dark-300'}`}>{r.label}</span>
                <span class={`text-sm font-bold ${r.highlight ? 'text-lime-400' : 'text-dark-400'}`}>{r.rate}</span>
              </div>
              <div class="h-2 rounded-full bg-dark-800">
                <div class={`h-2 rounded-full ${r.highlight ? 'bg-lime-500' : 'bg-dark-600'}`} style={`width: ${r.pct}%`}></div>
              </div>
            </div>
          ))}
          <p class="text-xs text-dark-600">Relative conversion multiplier. Source: Google/BIA Kelsey, LimeCall customer data.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Qualification Frameworks -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Lead Qualification Frameworks —<br />
          <span class="text-lime-400">And How Callback Auto-Qualifies</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Every B2B team needs a qualification framework. The best ones are designed to be completed in a single phone call — not an email thread.
        </p>
      </div>
      <div class="space-y-4">
        {qualFrameworks.map((fw) => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="grid gap-6 sm:grid-cols-3">
              <div>
                <div class="text-2xl font-extrabold text-lime-400 mb-1">{fw.name}</div>
                <div class="text-xs text-dark-500">{fw.stands}</div>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider text-dark-500 mb-2">Best For</div>
                <p class="text-sm text-dark-400">{fw.when}</p>
              </div>
              <div class="rounded-lg border border-lime-500/20 bg-lime-500/5 px-4 py-3">
                <div class="text-xs font-semibold uppercase tracking-wider text-lime-400 mb-2">With Callback</div>
                <p class="text-sm text-dark-300">{fw.howCallback}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack Table -->
  <section class="border-t border-dark-800 bg-dark-900/50 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          The B2B Lead Gen <span class="text-lime-400">Tech Stack</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          Six layers that build a complete B2B pipeline engine — from intent identification to closed-won.
        </p>
      </div>
      <div class="overflow-x-auto rounded-2xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-6 py-4 text-left font-semibold text-dark-400 uppercase tracking-wider text-xs">Stack Layer</th>
              <th class="px-6 py-4 text-left font-semibold text-dark-400 uppercase tracking-wider text-xs">Tools</th>
              <th class="px-6 py-4 text-left font-semibold text-dark-400 uppercase tracking-wider text-xs">Purpose</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800/60">
            {techStack.map((row) => (
              <tr class={`transition-colors ${row.critical ? 'bg-lime-950/20 hover:bg-lime-950/30' : 'bg-dark-900/30 hover:bg-dark-800/40'}`}>
                <td class="px-6 py-4 font-semibold text-white">
                  {row.layer}
                  {row.critical && (
                    <span class="ml-2 rounded-full bg-lime-500/20 px-2 py-0.5 text-xs font-bold text-lime-400">Featured</span>
                  )}
                </td>
                <td class="px-6 py-4 text-dark-300">{row.tools}</td>
                <td class="px-6 py-4 text-dark-400">{row.purpose}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ROI Calculator Framework -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          B2B Lead Gen <span class="text-lime-400">ROI Calculator Framework</span>
        </h2>
