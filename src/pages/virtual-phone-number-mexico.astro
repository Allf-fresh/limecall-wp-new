---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const country = "Mexico";
const code = "+52";
const slug = "virtual-phone-number-mexico";
const flag = "🇲🇽";

const seo = {
  title: `Mexico Virtual Phone Number — Get a +52 Number | LimeCall`,
  description: `Get a Mexico virtual phone number (+52) from $35/mo. Mexico City, Monterrey, Guadalajara numbers. 5-minute setup, no SIM required. Receive calls from anywhere.`,
  canonical: `https://www.limecall.com/${slug}/`,
};

const faqs = [
  {
    question: `Can I get a Mexico virtual number without being in Mexico?`,
    answer: `Yes. LimeCall provisions genuine Mexican numbers (+52) that you can use from anywhere in the world. Mexican callers dial a local number and your team answers via the LimeCall app, browser, or any forwarded device — no physical presence in Mexico required.`,
  },
  {
    question: `What is the country code for Mexico?`,
    answer: `Mexico's international dialling code is +52. Key city codes include Mexico City (55), Monterrey (81), Guadalajara (33), Tijuana (664), Puebla (222), and Cancún (998). When dialling from outside Mexico, dial +52 followed by the 10-digit number.`,
  },
  {
    question: `How much does a Mexico virtual phone number cost?`,
    answer: `LimeCall's Mexico virtual numbers start from $35 per month. This includes the number rental with transparent per-minute rates for inbound calls. There are no setup fees and no long-term contracts — cancel at any time.`,
  },
  {
    question: `Can I make outbound calls showing a Mexican caller ID?`,
    answer: `Yes. LimeCall lets you place outbound calls displaying your Mexican +52 number as the caller ID. Mexican recipients see a familiar local number, which significantly improves answer rates for sales and support teams calling into Mexico.`,
  },
  {
    question: `Is a Mexico virtual number good for US businesses targeting Mexican customers?`,
    answer: `Absolutely. Many US businesses use LimeCall Mexico virtual numbers (+52) to establish a local presence for their Mexican customer base. Rather than displaying a US +1 number — which many Mexican consumers decline to answer — a local Mexican number dramatically increases call answer rates and builds customer trust.`,
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Virtual Numbers', url: 'https://www.limecall.com/virtual-numbers/' },
        { name: 'Mexico Virtual Number', url: seo.canonical }
      ]} />
      <div class="mt-4 text-5xl">{flag}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Get a <span class="text-lime-400">Mexico Virtual Phone Number</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Get a local Mexico number ({code}) without being physically present in Mexico. Instant 5-minute setup, no hardware, no SIM card required.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm text-dark-400">
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Active in 5 minutes</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Cancel anytime</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> 30-day money-back guarantee</span>
      </div>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Get Your Mexico Number →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/80 py-6">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        <div>
          <div class="text-2xl font-bold text-lime-400">+52</div>
          <div class="mt-1 text-xs text-dark-400">Mexico prefix</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">5 min</div>
          <div class="mt-1 text-xs text-dark-400">Setup time</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">$35/mo</div>
          <div class="mt-1 text-xs text-dark-400">Starting from</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-lime-400">40+</div>
          <div class="mt-1 text-xs text-dark-400">Countries covered</div>
        </div>
      </div>
    </div>
  </section>

  <!-- What is a Mexico virtual number -->
  <section class="py-16 sm:py-20 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-3xl font-bold text-white">What is a Mexico virtual phone number?</h2>
      <p class="text-dark-300 leading-relaxed mb-4">
        A Mexico virtual phone number is a genuine Mexican telephone number — with a real +52 country code — hosted in the cloud rather than tied to a physical SIM card or landline inside Mexico. Calls to your Mexican number are routed over the internet to any device you choose: mobile phone, laptop, desk phone, or SIP endpoint anywhere in the world.
      </p>
      <p class="text-dark-300 leading-relaxed mb-4">
        Mexico is the second-largest economy in Latin America with over 130 million people. A local Mexico City (55), Monterrey (81), or Guadalajara (33) number signals to Mexican callers that you are an accessible, local business — dramatically improving answer rates compared to foreign numbers.
      </p>
      <p class="text-dark-300 leading-relaxed">
        LimeCall virtual numbers include call routing, automatic recording, CRM sync, and the callback widget that connects website visitors to your team in under 28 seconds — perfect for the rapidly growing Mexican e-commerce and B2B market.
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20 border-t border-dark-800 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">How to get your Mexico number in 3 steps</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">1</div>
          <h3 class="mb-2 font-semibold text-white">Choose your number</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Pick a Mexican city prefix — Mexico City (55), Monterrey (81), Guadalajara (33), Tijuana (664), Puebla (222) — or a national Mexican mobile number.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">2</div>
          <h3 class="mb-2 font-semibold text-white">Configure routing</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Forward calls to any device, agent, or phone number globally. Set up IVR menus, voicemail, ring groups, or time-zone-based routing rules.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">3</div>
          <h3 class="mb-2 font-semibold text-white">Receive calls anywhere</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Your Mexico number goes live in minutes. Mexican customers call a local number and your team answers from any country worldwide.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Features included with your Mexico number</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Receive calls on any device</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Answer Mexican calls on your mobile, laptop, browser, or SIP phone from anywhere in the world without missing a single call.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Call recording</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Record every call automatically for quality assurance, team coaching, and compliance review. Access all recordings from your LimeCall dashboard.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">CRM sync</h3>
          <p class="text-sm text-dark-400 leading-relaxed">All Mexican calls are automatically logged in HubSpot, Salesforce, Pipedrive, and 50+ integrations. Every lead tracked without manual entry.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">WhatsApp available</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Mexico has some of the highest WhatsApp usage in Latin America. LimeCall supports WhatsApp messaging alongside your Mexican virtual voice number.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">No physical SIM required</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Fully cloud-based. No SIM card, no hardware, no Mexican address needed. Compliant with IFT (Instituto Federal de Telecomunicaciones) regulations.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <h3 class="mb-2 font-semibold text-white">Callback widget integration</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Show your Mexico +52 number in the LimeCall callback widget. Convert Mexican website visitors to calls in under 28 seconds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20 bg-dark-900/40 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Who uses Mexico virtual numbers?</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🏢</div>
          <h3 class="mb-2 font-semibold text-white">Local presence</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Build a credible Mexican presence without a physical office. A Mexico City (55) or Monterrey (81) number builds immediate trust with local prospects.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">📞</div>
          <h3 class="mb-2 font-semibold text-white">Callback widget</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Display your Mexico +52 number on your website callback widget. Convert Mexican visitors to calls in under 28 seconds with LimeCall.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">💼</div>
          <h3 class="mb-2 font-semibold text-white">Sales teams</h3>
          <p class="text-sm text-dark-400 leading-relaxed">US and global sales teams calling Mexican prospects see dramatically higher answer rates when dialling from a +52 local number.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🎧</div>
          <h3 class="mb-2 font-semibold text-white">Customer support</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Route Mexican customer support calls to your remote global team. Mexican callers pay local rates while your agents work from anywhere worldwide.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Did you know -->
  <section class="py-16 sm:py-20 border-t border-dark-800">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-8">
        <h2 class="mb-6 text-xl font-bold text-white">Mexico phone system facts</h2>
        <ul class="space-y-3 text-sm text-dark-300 leading-relaxed">
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>Mexico's international dialling code is <strong class="text-white">+52</strong>. All Mexican numbers are 10 digits after the country code.</span></li>
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>Key Mexican city codes: <strong class="text-white">Mexico City 55</strong>, <strong class="text-white">Monterrey 81</strong>, <strong class="text-white">Guadalajara 33</strong>, <strong class="text-white">Tijuana 664</strong>, <strong class="text-white">Puebla 222</strong>, <strong class="text-white">Cancún 998</strong>.</span></li>
          <li class="flex gap-3"><span class="text-lime-400 font-bold mt-0.5">•</span><span>Mexico is the 2nd largest economy in Latin America and a key nearshoring destination for US businesses. WhatsApp is used by over 90% of smartphone users, making voice + WhatsApp virtual numbers especially powerful in this market.</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-20 bg-dark-900/40 border-t border-dark-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-bold text-white">Virtual number vs other Mexico number options</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800">
              <th class="py-3 pr-6 text-left font-semibold text-dark-400">Feature</th>
              <th class="py-3 px-4 text-left font-semibold text-lime-400">LimeCall Virtual</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Local SIM</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Toll-free</th>
              <th class="py-3 px-4 text-left font-semibold text-dark-400">Existing mobile</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            <tr>
              <td class="py-3 pr-6 text-dark-300">Setup time</td>
              <td class="py-3 px-4 text-white">5 minutes</td>
              <td class="py-3 px-4 text-dark-400">Days to weeks</td>
              <td class="py-3 px-4 text-dark-400">1–3 days</td>
              <td class="py-3 px-4 text-dark-400">Immediate</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Physical presence needed</td>
              <td class="py-3 px-4 text-white">No</td>
              <td class="py-3 px-4 text-dark-400">Yes — must be in Mexico</td>
              <td class="py-3 px-4 text-dark-400">Partial</td>
              <td class="py-3 px-4 text-dark-400">No</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Local Mexican number</td>
              <td class="py-3 px-4 text-white">Yes (+52)</td>
              <td class="py-3 px-4 text-dark-400">Yes</td>
              <td class="py-3 px-4 text-dark-400">No (800 prefix)</td>
              <td class="py-3 px-4 text-dark-400">Foreign number</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Works from anywhere</td>
              <td class="py-3 px-4 text-white">Yes — globally</td>
              <td class="py-3 px-4 text-dark-400">Roaming charges</td>
              <td class="py-3 px-4 text-dark-400">Yes</td>
              <td class="py-3 px-4 text-dark-400">Yes</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-dark-300">Multiple numbers</td>
              <td class="py-3 px-4 text-white">Yes — unlimited</td>
              <td class="py-3 px-4 text-dark-400">One per SIM</td>
              <td class="py-3 px-4 text-dark-400">Limited</td>
              <td class="py-3 px-4 text-dark-400">One per device</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to get your Mexico number?</h2>
      <p class="mt-4 text-dark-400">Join thousands of businesses using LimeCall to connect with Mexican customers — from anywhere in the world.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore Virtual Numbers"
      links={[
        { href: '/virtual-numbers/', title: 'All Virtual Numbers', desc: 'Browse all available countries.' },
        { href: '/virtual-business-numbers/', title: 'Virtual Business Numbers', desc: 'Business-grade virtual numbers.' },
        { href: '/canada-virtual-phone-number/', title: 'Canada Virtual Number', desc: 'Get a Canada +1 number.' },
        { href: '/virtual-phone-number-spain/', title: 'Spain Virtual Number', desc: 'Get a Spain +34 number.' },
        { href: '/pricing/', title: 'Pricing', desc: 'See all LimeCall plans.' },
      ]}
    />
  </div>
</Base>
