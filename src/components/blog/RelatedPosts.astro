---
import type { ContentRow } from '../../lib/database.types';

interface Props {
  posts: ContentRow[];
}

const { posts } = Astro.props;

if (!posts || posts.length === 0) return;

const categoryStyles: Record<string, string> = {
  streaming:  'border-blue-500/20 bg-blue-500/10 text-blue-400',
  privacy:    'border-purple-500/20 bg-purple-500/10 text-purple-400',
  torrenting: 'border-orange-500/20 bg-orange-500/10 text-orange-400',
  unblocking: 'border-cyan-500/20 bg-cyan-500/10 text-cyan-400',
  security:   'border-red-500/20 bg-red-500/10 text-red-400',
  'how-to':   'border-lime-500/20 bg-lime-500/10 text-lime-400',
  news:       'border-blue-500/20 bg-blue-500/10 text-blue-400',
  guides:     'border-green-500/20 bg-green-500/10 text-green-400',
};

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString('en-US', {
      year: 'numeric', month: 'short', day: 'numeric',
    });
  } catch {
    return dateStr;
  }
}

function getPostUrl(post: ContentRow): string {
  const seg = post.category ? `/${post.category}` : '';
  return `/blog${seg}/${post.slug}`;
}
---

{posts.length > 0 && (
  <section class="mt-14 pt-10 border-t border-dark-800">
    <h2 class="text-xl font-bold text-white mb-6">Continue Reading</h2>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => {
        const postUrl = getPostUrl(post);
        const badgeStyle = post.category
          ? (categoryStyles[post.category] ?? 'border-dark-700 bg-dark-800 text-dark-400')
          : 'border-dark-700 bg-dark-800 text-dark-400';
        const badgeLabel = post.category
          ? (post.category.charAt(0).toUpperCase() + post.category.slice(1))
          : 'Blog';

        return (
          <a
            href={postUrl}
            class="group flex flex-col rounded-xl border border-dark-800 bg-dark-900 p-5 hover:border-dark-700 transition"
          >
            <div class="flex items-center gap-2 mb-3">
              <span class={`inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider ${badgeStyle}`}>
                {badgeLabel}
              </span>
              <time class="text-xs text-dark-600">{formatDate(post.publish_date)}</time>
            </div>
            <h3 class="text-sm font-semibold text-white leading-snug group-hover:text-lime-400 transition line-clamp-2 mb-2">
              {post.title}
            </h3>
            {post.meta_description && (
              <p class="text-xs text-dark-500 leading-relaxed line-clamp-2 flex-1">
                {post.meta_description}
              </p>
            )}
            <span class="mt-3 text-xs font-medium text-lime-500 group-hover:text-lime-400 transition flex items-center gap-1">
              Read more
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        );
      })}
    </div>
  </section>
)}
