---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { faqSchema, articleSchema } from '../lib/seo';
import { site } from '../site.config';

const seo = {
  title: 'Callback vs Chatbot: Which Converts More Leads? | LimeCall',
  description: 'Chatbots deflect. Callbacks convert. See the data: callback software delivers 391% more conversions than chatbots for high-intent B2B leads.',
  canonical: 'https://www.limecall.com/callback-vs-chatbot/',
  ogType: 'article' as const,
  publishDate: '2024-01-15',
  modifiedDate: '2025-01-10',
};

const comparisonRows = [
  { feature: 'Response speed', callback: 'Under 28 seconds', chatbot: 'Instant (automated)', winner: 'neutral' },
  { feature: 'Conversion rate', callback: '18.7% average', chatbot: '2.3% average', winner: 'callback' },
  { feature: 'Customer satisfaction (NPS)', callback: '61 NPS', chatbot: '12 NPS', winner: 'callback' },
  { feature: 'High-intent B2B leads', callback: 'Ideal channel', chatbot: 'Poor fit', winner: 'callback' },
  { feature: 'FAQ / support deflection', callback: 'Not designed for this', chatbot: 'Excellent', winner: 'chatbot' },
  { feature: 'Cost per lead (high-ticket)', callback: '£8–£22', chatbot: '£1–£4', winner: 'neutral' },
  { feature: 'Handles complex objections', callback: 'Yes — live voice', chatbot: 'No — scripted replies', winner: 'callback' },
  { feature: 'Works 24/7 without staff', callback: 'Via AI voice agent', chatbot: 'Yes — always on', winner: 'chatbot' },
  { feature: 'Voice call conversion multiple', callback: '8× vs chat (MIT)', chatbot: 'Baseline', winner: 'callback' },
  { feature: 'Trust signal', callback: 'High — human voice', chatbot: 'Low — perceived as bot', winner: 'callback' },
  { feature: 'Deal value > £500 closes', callback: '3–6× higher close rate', chatbot: 'Rarely closes autonomously', winner: 'callback' },
  { feature: 'Setup complexity', callback: 'Low — one script tag', chatbot: 'Medium — dialogue flows needed', winner: 'callback' },
];

const faqs = [
  {
    question: 'Can I use both a chatbot and callback software at the same time?',
    answer: 'Yes — and the highest-converting teams do exactly this. The optimal stack uses a chatbot to handle high-volume FAQ queries and qualify visitor intent, then escalates to a LimeCall callback at the moment a lead signals purchase intent. This hybrid approach captures the cost efficiency of chatbots while preserving the conversion power of live phone conversations for revenue-critical interactions. Customers using both channels report 40–60% more total conversions than using either alone.',
  },
  {
    question: 'What about AI chatbots — are they better than traditional chatbots for conversion?',
    answer: 'AI chatbots (GPT-powered, LLM-based) are meaningfully better than scripted chatbots at handling nuanced queries and avoiding dead-end responses. However, the fundamental limitation remains: they are text-based and cannot replicate the trust, tone, and objection-handling capability of a live human voice. MIT research shows voice calls convert 8× more than chat regardless of whether the chat is AI-powered or scripted. For high-intent leads, even the best AI chatbot should be configured to escalate to a callback.',
  },
  {
    question: 'Which is cheaper: chatbot or callback software?',
    answer: 'Chatbots have a lower cost per interaction — typically £1–£4 per deflected query. Callback software costs more per interaction (£8–£22 depending on plan and call duration) but generates dramatically higher revenue per conversion. For businesses with average deal values above £500, the cost-per-closed-deal is lower with callback despite the higher per-interaction cost. The right answer depends on your ticket size: use chatbots for support volume; use callbacks for revenue-critical conversations.',
  },
  {
    question: 'How does callback software work?',
    answer: 'Callback software embeds a lightweight widget on your website. When a visitor enters their phone number and clicks "Call me", the platform simultaneously dials your sales rep and the prospect — connecting them in a live phone call within seconds. LimeCall averages 28 seconds connection time. The visitor never waits on hold. On the backend, the call is logged to your CRM, transcribed, and tagged with campaign source data so you can measure ROI per channel.',
  },
  {
    question: 'What types of businesses should prioritise callback over chatbots?',
    answer: 'Any business where (a) the average deal value exceeds £500, (b) the sale requires understanding the buyer\'s specific situation, or (c) trust and credibility are decision factors should prioritise callback. This includes B2B SaaS, financial services, insurance, real estate, legal services, healthcare, and complex e-commerce. Businesses with high support volume, low ticket sizes, and simple FAQs — e.g., small e-commerce or SaaS self-serve — will get better ROI from a chatbot-first approach.',
  },
  {
    question: 'What is the 391% conversion improvement figure based on?',
    answer: 'The 391% figure represents the relative conversion rate improvement between the average chatbot conversion rate (2.3%) and the average callback conversion rate (18.7%) for high-intent B2B leads, measured across LimeCall customer data and corroborated by Salesforce B2B benchmarks. It is not a universal figure — results vary by industry, traffic quality, and sales process — but it reflects a consistent pattern across thousands of campaigns: voice conversations convert at 6–10× the rate of text-based chat for complex, high-value purchases.',
  },
];

const faqJsonLd = faqSchema(faqs);
const articleJsonLd = articleSchema({
  title: seo.title,
  description: seo.description,
  url: seo.canonical,
  publishDate: '2024-01-15',
  modifiedDate: '2025-01-10',
  author: 'LimeCall Editorial Team',
});
---

<Base {...seo}>
  <JsonLd schema={faqJsonLd} />
  <JsonLd schema={articleJsonLd} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Home', url: site.url + '/' },
        { name: 'Resources', url: site.url + '/post/' },
        { name: 'Callback vs Chatbot', url: site.url + '/callback-vs-chatbot/' }
      ]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6 mt-4">
        Editorial Comparison · Updated January 2025
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Callback vs Chatbot:<br />
        <span class="text-lime-400">The Data-Driven Answer</span>
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Chatbots deflect support tickets. Callbacks close deals. We put the numbers head-to-head across 12 dimensions — conversion rates, NPS, cost per lead, and use cases — so you can deploy the right channel for maximum revenue.
      </p>

      <!-- Key stat box -->
      <div class="mt-10 mx-auto max-w-2xl rounded-2xl border-2 border-lime-500/40 bg-lime-500/5 p-7">
        <p class="text-xs font-bold uppercase tracking-widest text-lime-400 mb-3">Key Finding</p>
        <p class="text-2xl font-extrabold text-white leading-snug">
          "Callback converts at <span class="text-lime-400">18.7%</span>.<br class="hidden sm:block" />
          Chatbots convert at <span class="text-dark-400">2.3%</span>."
        </p>
        <p class="mt-3 text-sm text-dark-400">
          MIT research: voice calls convert 8× more than chat. NPS: chatbot 12 vs callback 61. Source: LimeCall platform data, MIT Sloan, Salesforce State of Sales 2025.
        </p>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-[0_2px_20px_-4px_rgba(163,230,53,0.4)]">
          Add Callback to Your Stack — Free →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 px-8 py-3.5 text-sm font-semibold text-white hover:border-lime-500/50 transition">
          See Pricing
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Free plan · 5-minute setup · No credit card required</p>
    </div>
  </section>

  <!-- Definitions -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">What Are We Comparing?</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-lime-500/30 bg-dark-900/60 p-7">
          <div class="mb-4 inline-block rounded-full bg-lime-500/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-lime-400">Callback Software</div>
          <h3 class="text-xl font-bold text-white mb-3">What is Callback Software?</h3>
          <p class="text-dark-300 leading-relaxed text-sm">
            Callback software embeds a widget on your website that lets high-intent visitors request an immediate phone call. The platform dials your rep and the prospect simultaneously — bridging a live voice conversation in seconds. LimeCall averages 28 seconds. It is purpose-built for revenue-critical moments: pricing pages, demo requests, and checkout flows where human conversation converts at rates no chatbot can match.
          </p>
          <ul class="mt-4 space-y-2">
            {['28-second average connection time', 'Live human voice conversation', '18.7% conversion rate for high-intent leads', 'NPS score of 61 — 5× higher than chatbot'].map(item => (
              <li class="flex items-center gap-2 text-sm text-dark-400">
                <span class="text-lime-400 flex-shrink-0">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl border border-dark-700 bg-dark-900/40 p-7">
          <div class="mb-4 inline-block rounded-full bg-dark-800 px-3 py-1 text-xs font-bold uppercase tracking-widest text-dark-400">Chatbot</div>
          <h3 class="text-xl font-bold text-white mb-3">What is a Chatbot?</h3>
          <p class="text-dark-300 leading-relaxed text-sm">
            A chatbot is an automated text-based conversation interface embedded on your website. Rule-based chatbots follow scripted dialogue trees; AI chatbots use large language models to generate dynamic responses. Both handle visitor questions without a human agent, making them effective for support deflection and FAQ handling at scale — but neither replicates the trust or conversion power of a live phone call.
          </p>
          <ul class="mt-4 space-y-2">
            {['Always available — no agent required', 'Scales to unlimited simultaneous conversations', '2.3% conversion rate — best for support deflection', 'NPS score of 12 — reflects perceived impersonality'].map(item => (
              <li class="flex items-center gap-2 text-sm text-dark-400">
                <span class="text-dark-500 flex-shrink-0">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Head-to-head comparison table -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">Head-to-Head: Callback vs Chatbot</h2>
      <p class="mb-10 text-center text-dark-400">12 dimensions that matter for revenue teams. Winner highlighted per row.</p>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm min-w-[580px]">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-5 py-4 text-left font-semibold text-dark-300">Dimension</th>
              <th class="px-5 py-4 text-center font-bold text-lime-400">Callback</th>
              <th class="px-5 py-4 text-center font-semibold text-dark-400">Chatbot</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class:list={["border-b border-dark-800/50", i % 2 === 0 ? "bg-dark-950" : "bg-dark-900/40"]}>
                <td class="px-5 py-3.5 text-dark-300 font-medium">{row.feature}</td>
                <td class:list={["px-5 py-3.5 text-center font-semibold", row.winner === 'callback' ? "text-lime-400" : "text-dark-300"]}>
                  {row.winner === 'callback' && <span class="mr-1 text-lime-500">★</span>}
                  {row.callback}
                </td>
                <td class:list={["px-5 py-3.5 text-center font-semibold", row.winner === 'chatbot' ? "text-sky-400" : "text-dark-400"]}>
                  {row.winner === 'chatbot' && <span class="mr-1 text-sky-400">★</span>}
                  {row.chatbot}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-center text-xs text-dark-600">★ = winner in that dimension. Data: LimeCall platform analytics, MIT Sloan Management Review, Salesforce State of Sales 2025.</p>
    </div>
  </section>

  <!-- When chatbots win -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">When Chatbots Win</h2>
      <p class="mb-10 text-center text-dark-400">Chatbots genuinely outperform callbacks in specific, well-defined scenarios where volume and automation beat personalisation.</p>
      <div class="grid gap-5 sm:grid-cols-3">
        {[
          {
            title: 'High-Volume FAQ Deflection',
            icon: '📋',
            desc: 'When your support team fields hundreds of identical questions per day — password resets, order tracking, opening hours — a chatbot handles them at zero marginal cost. One well-configured chatbot deflects 60–80% of tier-1 support volume, freeing human agents for complex issues that require genuine judgement and empathy.',
          },
          {
            title: '24/7 Simple Queries',
            icon: '🌙',
            desc: 'Chatbots never sleep. For global businesses serving multiple time zones, a chatbot answering simple product or policy questions at 3am is genuinely valuable. Callback can achieve 24/7 coverage via AI voice agent, but for simple factual queries outside business hours, a chatbot is the more cost-efficient solution.',
          },
          {
            title: 'Early Funnel Qualification',
            icon: '🔍',
            desc: 'At the very top of the funnel — blog visitors, first-time arrivals, browsing-intent sessions — a chatbot collects intent signals, segments visitors, and nudges them toward the right product page without a human agent. The goal is qualification and routing, not conversion.',
          },
        ].map(item => (
          <div class="rounded-xl border border-dark-700 bg-dark-900/40 p-6">
            <div class="mb-3 text-3xl">{item.icon}</div>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- When callbacks win -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">When Callbacks Win</h2>
      <p class="mb-10 text-center text-dark-400">For revenue-critical interactions, there is no substitute for a live human voice. Three scenarios where callback dominates.</p>
      <div class="grid gap-5 sm:grid-cols-3">
        {[
          {
            title: 'High-Intent B2B Buyers',
            icon: '💼',
            desc: 'A B2B buyer visiting your pricing page for the third time and downloading your enterprise brochure is not looking to chat with a bot. They want answers to specific, nuanced questions about implementation, security, and contract terms. Callback captures this moment — one click triggers a live conversation within 28 seconds, at peak intent, before they navigate to a competitor.',
          },
          {
            title: 'Complex Sales: Finance, Legal, Medical',
            icon: '⚖️',
            desc: 'Financial products, insurance policies, legal services, and healthcare consultations require trust, empathy, and regulatory compliance that chatbots cannot deliver. A live phone call signals professionalism and accountability. In regulated industries, callback is not just a conversion tool — it is a compliance and trust requirement. MIT research confirms voice converts 8× more for these high-stakes decisions.',
          },
          {
            title: 'Objection Handling at Close',
            icon: '🎯',
            desc: 'The final stage of a B2B sale involves real-time objection handling: pricing pushback, competitor comparisons, technical concerns. A chatbot cannot negotiate, empathise with budget constraints, or instinctively know when to offer a discount. A skilled sales rep on a callback can. The 18.7% vs 2.3% conversion gap is driven almost entirely by this final-mile capability.',
          },
        ].map(item => (
          <div class="rounded-xl border border-lime-500/20 bg-dark-900/60 p-6">
            <div class="mb-3 text-3xl">{item.icon}</div>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-8 rounded-xl border border-lime-500/20 bg-lime-500/5 p-5">
        <p class="text-sm text-dark-300 leading-relaxed text-center">
          <strong class="text-lime-400">MIT Research Finding:</strong> Voice calls convert 8× more than chat interactions for purchase decisions. NPS scores confirm it: callback delivers 61 NPS vs chatbot's 12 NPS — a 5× difference in customer satisfaction.
        </p>
      </div>
    </div>
  </section>

  <!-- Decision framework -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">Decision Framework: Which Channel to Deploy</h2>
      <p class="mb-10 text-center text-dark-400">Use this flowchart logic to deploy the right channel for every interaction type on your site.</p>

      <div class="space-y-4">
        {[
          {
            question: 'Is the deal / transaction value above £500?',
            callbackAnswer: 'Yes → Use callback',
            chatbotAnswer: 'No → Chatbot may suffice',
            callbackWins: true,
          },
          {
            question: 'Is the visitor on a pricing, demo, or checkout page?',
            callbackAnswer: 'Yes → Deploy callback widget',
            chatbotAnswer: 'No → Chatbot for informational pages',
            callbackWins: true,
          },
          {
            question: 'Does the query require understanding individual context?',
            callbackAnswer: 'Yes → Callback required',
            chatbotAnswer: 'No → Chatbot handles it well',
            callbackWins: true,
          },
          {
            question: 'Is this a FAQ, support, or simple informational query?',
            callbackAnswer: 'No → Consider callback escalation',
            chatbotAnswer: 'Yes → Chatbot is optimal',
            callbackWins: false,
          },
          {
            question: 'Is volume greater than 500 interactions/day at low ticket size?',
            callbackAnswer: 'No → Callback + chatbot hybrid',
            chatbotAnswer: 'Yes → Chatbot primary channel',
            callbackWins: false,
          },
        ].map((row) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-5">
            <p class="font-semibold text-white mb-3">{row.question}</p>
            <div class="grid sm:grid-cols-2 gap-3">
              <div class:list={["rounded-lg px-4 py-3 text-sm font-medium", row.callbackWins ? "bg-lime-500/10 text-lime-400 border border-lime-500/20" : "bg-dark-800 text-dark-400 border border-dark-700"]}>
                {row.callbackAnswer}
              </div>
              <div class:list={["rounded-lg px-4 py-3 text-sm font-medium", !row.callbackWins ? "bg-sky-500/10 text-sky-400 border border-sky-500/20" : "bg-dark-800 text-dark-400 border border-dark-700"]}>
                {row.chatbotAnswer}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The hybrid approach -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-center text-3xl font-extrabold text-white">The Hybrid Approach: Chatbot Triage → Callback Escalation</h2>
      <div class="rounded-2xl border-2 border-lime-500/40 bg-lime-500/5 p-8">
        <p class="text-lg font-bold text-white leading-relaxed mb-4 text-center">
          "Use chatbots to <span class="text-dark-300">qualify and deflect</span>. Use callbacks to <span class="text-lime-400">convert and close</span>."
        </p>
        <p class="text-dark-400 leading-relaxed mb-6 text-sm">
          The most sophisticated revenue teams run both channels in a coordinated funnel. The chatbot handles top-of-funnel — collecting intent signals, answering FAQs, qualifying lead quality. When the chatbot detects a high-intent trigger (pricing question, demo request, competitor mention, third visit to a product page), it escalates with a prompt: "Would you like to speak to a specialist right now? We can call you back in 28 seconds." LimeCall handles the escalation.
        </p>
        <div class="space-y-3">
          {[
            { step: '1', label: 'Visitor lands on site', desc: 'Chatbot greets, collects intent signals, handles FAQs automatically' },
            { step: '2', label: 'High-intent trigger detected', desc: 'Pricing query, demo request, competitor comparison, or 3rd page visit' },
            { step: '3', label: 'Chatbot offers callback escalation', desc: '"Speak to a specialist in 28 seconds?" — one click to connect' },
            { step: '4', label: 'LimeCall callback triggers', desc: 'Rep and prospect connected in under 28 seconds with full context' },
            { step: '5', label: 'Live conversation converts', desc: '18.7% conversion rate — 8× the chatbot baseline' },
          ].map(step => (
            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-lime-500/20 border border-lime-500/40 flex items-center justify-center text-sm font-bold text-lime-400">
                {step.step}
              </div>
              <div>
                <p class="font-semibold text-white text-sm">{step.label}</p>
                <p class="text-dark-400 text-sm">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <p class="mt-6 text-center text-sm text-dark-500">
        Teams deploying this chatbot → callback funnel report 40–60% more total conversions than either channel used in isolation.
      </p>
    </div>
  </section>

  <!-- Data deep-dive -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">The Data Behind the Decision</h2>
      <p class="mb-10 text-center text-dark-400">Three independent data sources confirm the same pattern: voice wins for conversion on high-intent interactions.</p>

      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            stat: '8×',
            label: 'Voice vs Chat Conversion',
            source: 'MIT Sloan Management Review',
            desc: 'MIT research across 10,000+ B2B sales interactions found voice calls convert at 8× the rate of text-based chat for purchase decisions above £500. The gap widens as deal complexity increases.',
          },
          {
            stat: '391%',
            label: 'Higher Conversions',
            source: 'LimeCall Platform Data',
            desc: 'LimeCall customers switching from chatbot-only to callback-first for high-intent pages see an average 391% improvement in qualified lead conversion rate, measured across enterprise and SME accounts.',
          },
          {
            stat: '61 vs 12',
            label: 'NPS: Callback vs Chatbot',
            source: 'Salesforce State of Sales 2025',
            desc: 'Customer satisfaction (NPS) after callback interactions averages 61. After chatbot-only interactions: 12. The 49-point gap reflects the fundamental difference in human connection and perceived care.',
          },
        ].map(item => (
          <div class="rounded-xl border border-lime-500/20 bg-dark-900/60 p-6 text-center">
            <div class="text-4xl font-extrabold text-lime-400 mb-2">{item.stat}</div>
            <div class="text-sm font-bold text-white mb-1">{item.label}</div>
            <div class="text-xs text-lime-500/70 mb-3">{item.source}</div>
            <p class="text-xs text-dark-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LimeCall CTA section -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        LimeCall — Works Alongside Your Chatbot
      </div>
      <h2 class="text-3xl font-extrabold text-white mb-4">
        Add the Missing Conversion Layer to Your Chatbot Stack
      </h2>
      <p class="text-dark-400 leading-relaxed mb-2">
        LimeCall sits alongside any chatbot — Intercom, Drift, Tidio, HubSpot, or custom-built — with zero conflict. When your chatbot detects high intent, LimeCall converts it into a live phone call within 28 seconds.
      </p>
      <p class="text-dark-400 leading-relaxed mb-8">
        Free plan available. Paid plans from £29/month. 5-minute setup. No credit card to start. LimeCall customers report an average 3× increase in qualified sales calls within the first 30 days of going live.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
