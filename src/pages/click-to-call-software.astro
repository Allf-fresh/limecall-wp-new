---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const seo = {
  title: `Click to Call Software — Smart Callback Platform | LimeCall`,
  description: `Connect with potential customers instantly and improve your conversion rates by 3x with LimeCall's click to call solution. One-click web calls, instant callbacks in 28 seconds.`,
  canonical: `https://www.limecall.com/click-to-call-software/`,
};

const features = [
  {
    icon: '⚡',
    name: 'Instant Callbacks in 28 Seconds',
    description: 'When a visitor clicks your button, LimeCall connects your sales rep and the prospect in under 28 seconds — before they bounce to a competitor.',
  },
  {
    icon: '🎙️',
    name: 'Call Recording & Storage',
    description: 'Every call is automatically recorded and securely stored. Review calls for quality assurance, training, and compliance — anytime.',
  },
  {
    icon: '📱',
    name: 'Works on Every Device',
    description: 'Desktop, tablet, or mobile — your click-to-call button works flawlessly everywhere. Capture leads regardless of how visitors browse your site.',
  },
  {
    icon: '🔁',
    name: 'Automatic Follow-Up Calls',
    description: 'If a rep is unavailable, LimeCall automatically schedules a follow-up and sends SMS alerts so no lead ever falls through the cracks.',
  },
  {
    icon: '🎯',
    name: 'Lead Segmentation & CRM Sync',
    description: 'Understand where each lead came from, what pages they visited, and sync all data to your CRM automatically for seamless pipeline management.',
  },
  {
    icon: '🎨',
    name: 'Fully Customizable Widget',
    description: 'Match your brand perfectly. Customize button colors, position, text, and display rules — show the widget on specific pages or to specific visitor segments.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Add a Code Snippet',
    description: 'Paste one line of JavaScript into your website. Works with WordPress, Webflow, Shopify, and any HTML site. No developer needed.',
  },
  {
    number: '02',
    title: 'Customize Your Button',
    description: 'Choose colors, text, and display rules to match your brand. Set your business hours, available reps, and callback preferences.',
  },
  {
    number: '03',
    title: 'Start Converting Visitors',
    description: 'Go live and watch inbound calls increase. Every click is tracked, every call is recorded, and every lead is captured.',
  },
];

const faqs = [
  {
    question: 'What is click-to-call software?',
    answer: 'Click-to-call software places a button on your website that lets visitors initiate a phone call with one click — no dialing required. LimeCall connects the visitor and your sales rep automatically within seconds.',
  },
  {
    question: 'How quickly does LimeCall connect calls?',
    answer: 'LimeCall connects calls in an average of 28 seconds. When a visitor clicks the button, our system simultaneously dials your rep and the prospect, bridging them together almost instantly.',
  },
  {
    question: 'Does click-to-call work on mobile devices?',
    answer: 'Yes. LimeCall\'s click-to-call widget is fully responsive and works on desktops, tablets, and smartphones. Mobile visitors can initiate calls with a single tap.',
  },
  {
    question: 'Can I use click-to-call with my existing CRM?',
    answer: 'Absolutely. LimeCall integrates with popular CRMs including HubSpot, Salesforce, Pipedrive, and more. Call data, recordings, and lead info sync automatically.',
  },
  {
    question: 'What happens if my team misses a call?',
    answer: 'LimeCall automatically schedules a follow-up call and sends SMS and email alerts to your team. You can also configure offline hours so visitors are prompted to book a callback slot instead.',
  },
  {
    question: 'Is there a free plan?',
    answer: 'Yes. LimeCall offers a free Basic plan with 30 calls per month — no credit card required. Upgrade to a paid plan as your call volume grows.',
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Click to Call Software', url: `${site.url}/click-to-call-software/` }]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6">
        Click-to-Call Software
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Connect With Leads<br />
        <span class="text-lime-400">In 28 Seconds Flat</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300 leading-relaxed">
        Place a one-click call button on your website. When a visitor clicks it, LimeCall instantly connects them to your sales team — no hold music, no friction, no lost leads.
      </p>

      <!-- Stats bar -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm">
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">3x</span>
          more conversions
        </span>
        <span class="hidden h-5 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">28s</span>
          avg. connect time
        </span>
        <span class="hidden h-5 w-px bg-dark-700 sm:block"></span>
        <span class="flex items-center gap-2 text-dark-300">
          <span class="text-2xl font-extrabold text-lime-400">4.6/5</span>
          on G2 &amp; Capterra
        </span>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-7 py-3.5 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free — No Card Needed
        </a>
        <a
          href="/contact-us"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-7 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40"
        >
          Request a Demo
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">30-day money-back guarantee · Free plan available</p>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Everything You Need to <span class="text-lime-400">Never Miss a Lead</span>
        </h2>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto">
          LimeCall's click-to-call platform is built for sales teams who can't afford to let hot leads go cold.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <FeatureCard icon={f.icon} name={f.name} description={f.description} />
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
          Live in <span class="text-lime-400">3 Simple Steps</span>
        </h2>
        <p class="mt-4 text-dark-400">Get click-to-call running on your website in under 10 minutes.</p>
      </div>
      <div class="grid gap-8 sm:grid-cols-3">
        {steps.map((step) => (
          <div class="relative flex flex-col items-start rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="text-4xl font-extrabold text-lime-500/20 mb-4 leading-none">{step.number}</div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-gradient-to-br from-lime-950/30 to-dark-900/80 p-8 sm:p-12">
        <div class="grid gap-8 sm:grid-cols-3 text-center">
          <div>
            <div class="text-5xl font-extrabold text-lime-400">80%</div>
            <div class="mt-2 text-sm font-semibold text-white">More Call Requests</div>
            <div class="mt-1 text-xs text-dark-500">vs. standard contact forms</div>
          </div>
          <div class="sm:border-x sm:border-dark-700">
            <div class="text-5xl font-extrabold text-lime-400">3x</div>
            <div class="mt-2 text-sm font-semibold text-white">Higher Conversion Rate</div>
            <div class="mt-1 text-xs text-dark-500">compared to email follow-ups</div>
          </div>
          <div>
            <div class="text-5xl font-extrabold text-lime-400">28s</div>
            <div class="mt-2 text-sm font-semibold text-white">Average Connect Time</div>
            <div class="mt-1 text-xs text-dark-500">from click to live conversation</div>
          </div>
        </div>
        <blockquote class="mt-10 border-t border-dark-700 pt-8 text-center">
          <p class="text-lg text-dark-200 italic leading-relaxed">
            "LimeCall's click-to-call button increased our inbound sales calls by 80% in the first month. Setup took less than 15 minutes."
          </p>
          <footer class="mt-4 text-sm text-dark-500">— Sales Director, LimeCall Customer</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
        Ready to Turn Clicks Into <span class="text-lime-400">Conversations?</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        Join thousands of sales teams using LimeCall to connect with leads instantly. Start free — no credit card required.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/signup"
          class="inline-flex items-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-base font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400"
        >
          Start Free Trial
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 text-base font-bold text-white transition hover:border-lime-500/40"
        >
          View Pricing
        </a>
      </div>
      <p class="mt-3 text-sm text-dark-500">30-day money-back guarantee · Cancel anytime</p>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="border-t border-dark-800 bg-dark-900/40 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks
        heading="Explore More LimeCall Features"
        links={[
          { href: '/customer-callback-software', title: 'Callback Software', desc: 'Automated callbacks that connect customers to your team in 28 seconds.' },
          { href: '/speed-to-lead', title: 'Speed to Lead', desc: 'Respond to every lead in seconds and close deals before competitors.' },
          { href: '/calltracking-software', title: 'Call Tracking', desc: 'Know exactly which campaigns and channels drive phone calls.' },
          { href: '/virtual-numbers', title: 'Virtual Numbers', desc: 'Get local phone numbers in 40+ countries to build trust globally.' },
          { href: '/lead-distribution', title: 'Lead Distribution', desc: 'Route every inbound call to the right rep, automatically.' },
          { href: '/pricing', title: 'Pricing', desc: 'Simple plans starting free. Upgrade as you grow.' },
        ]}
      />
    </div>
  </section>
</Base>
