---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const industry = "Digital Marketing Agencies";
const icon = "📊";

const seo = {
  title: `Lead Generation for Digital Marketing Agencies | LimeCall`,
  description: `Help your clients convert more leads and prove campaign ROI. LimeCall's callback platform is built for agencies — white-label ready, reseller-friendly, and easy to deploy across client accounts.`,
  canonical: `https://www.limecall.com/lead-generation-for-digital-marketing-agencies/`,
};

const useCases = [
  { title: "Prove Campaign ROI with Call Attribution", desc: "Show clients exactly which campaigns, ads, and landing pages are driving phone conversations. Call attribution closes the loop between marketing spend and real revenue — making you indispensable." },
  { title: "Boost Client Lead Conversion Rates", desc: "Your campaigns drive traffic but leads still get lost. Add LimeCall to any client's site and watch conversion rates climb. Agencies using LimeCall report 3x more leads converted from existing traffic." },
  { title: "White-Label & Reseller Opportunity", desc: "Deploy LimeCall across all client accounts from a single agency dashboard. White-label the widget, add a margin, and turn lead gen into a recurring service revenue stream." },
  { title: "Instant Demo Callbacks for Your Own Agency", desc: "Use LimeCall on your own website to respond to new business inquiries in under 28 seconds. Be the fastest agency to follow up and win more pitches before competitors send their first email." },
];

const stats = [
  { value: "28s", label: "Average callback time" },
  { value: "3x", label: "More leads converted" },
  { value: "80%", label: "Reduction in missed leads" },
  { value: "5 min", label: "Client setup time" },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does LimeCall help digital marketing agencies prove PPC campaign ROI?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall captures UTM parameters, ad source, and keyword data with every callback request. This lets agencies show clients a direct line between their PPC spend and actual phone conversations. Callbacks deliver up to 400% more ROI on PPC campaigns compared to form-only conversion tracking.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can agencies manage LimeCall across multiple client accounts?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall offers an agency dashboard where you can manage all client accounts in one place. Each client gets their own sub-account with separate widgets, routing rules, and reporting. Onboarding a new client takes under 5 minutes.'
      }
    },
    {
      '@type': 'Question',
      name: 'Is LimeCall available as a white-label product for agencies?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall offers white-label and reseller options for agencies. You can brand the widget with your agency or client branding, set your own pricing, and offer callback automation as part of your service packages. Contact our partnerships team for reseller pricing.'
      }
    },
    {
      '@type': 'Question',
      name: 'Why do 30% of agency clients churn due to poor lead follow-up?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Agency clients judge performance on leads and revenue, not just traffic. When campaigns generate inquiries that go unanswered or receive slow follow-up, clients blame the agency — even if the campaign itself performed well. LimeCall ensures every lead is followed up in under 28 seconds, protecting campaign performance and client retention.'
      }
    },
    {
      '@type': 'Question',
      name: 'How quickly can an agency deploy LimeCall on a client website?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Setup takes under 5 minutes. Agencies add a single JavaScript snippet to the client\'s website or landing page. The LimeCall widget is immediately active. Routing rules, business hours, and team member assignments can all be configured from the agency dashboard.'
      }
    },
  ]
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: `Lead Generation for Digital Marketing Agencies`, url: seo.canonical }]} />
      <div class="mt-4 text-5xl">{icon}</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Lead Generation for <span class="text-lime-400">Digital Marketing Agencies</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Help your clients convert more leads and prove your campaign ROI. Add instant callbacks to any client site in 5 minutes.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Built for digital marketing agencies</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How LimeCall works for Digital Marketing Agencies</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: "1", title: "Visitor clicks the widget", desc: "A prospect lands on your client's site from a campaign ad and clicks the LimeCall callback widget." },
          { step: "2", title: "Instant connection", desc: "LimeCall connects the visitor with your client's sales team in under 28 seconds — while the campaign ad is still fresh in their mind." },
          { step: "3", title: "Conversion attributed", desc: "The call is logged with source attribution, giving you hard data to report in client dashboards." },
        ].map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/20 text-lg font-extrabold text-lime-400">{s.step}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison section -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">Why callbacks deliver 400% more PPC ROI than form fills</h2>
      <p class="mb-10 text-center text-dark-400 text-sm max-w-2xl mx-auto">30% of agency clients churn due to poor lead follow-up. Adding LimeCall to your campaigns protects client retention and proves your value beyond traffic metrics.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-4 text-sm font-bold text-dark-400 uppercase tracking-wider">PPC Campaign with Form Fill Only</div>
          <ul class="space-y-3 text-sm text-dark-400">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Lead submits form; enters a slow email nurture sequence</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> By the time sales calls back, intent has dropped significantly</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Attribution stops at form submission — no call data for reports</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-red-400">✕</span> Client can't see direct revenue impact of campaigns</li>
          </ul>
        </div>
        <div class="rounded-xl border border-lime-500/30 bg-lime-950/10 p-6">
          <div class="mb-4 text-sm font-bold text-lime-400 uppercase tracking-wider">PPC Campaign with LimeCall Callback</div>
          <ul class="space-y-3 text-sm text-dark-300">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Lead connected to sales within 28 seconds of clicking the ad</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Conversion happens while purchase intent is at its peak</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Full call attribution data for every campaign and keyword</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-lime-400">✓</span> Client reports show calls, conversions, and revenue — not just clicks</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5">
            <summary class="cursor-pointer list-none font-semibold text-white flex justify-between items-center gap-4">
              <span>{faq.name}</span>
              <span class="shrink-0 text-lime-400 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to add callback automation to your agency stack?</h2>
      <p class="mt-4 text-dark-400">Set up in 5 minutes. No credit card required.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4">
    <CrossLinks heading="More LimeCall Solutions" links={[
      { href: '/call-tracking/', title: 'Call Tracking', desc: 'Attribute every call to the right campaign.' },
      { href: '/partnership/', title: 'Agency Partnership', desc: 'Resell LimeCall as part of your service offering.' },
      { href: '/for-marketing-teams/', title: 'For Marketing Teams', desc: 'Marketing-specific features and integrations.' },
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
    ]} />
  </div>
</Base>
