---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `50+ Integrations — Connect LimeCall to Your Stack | LimeCall`,
  description: `LimeCall integrates with 50+ tools: HubSpot, Salesforce, Slack, Zapier, Google Analytics, Zendesk, and more. Connect your CRM, helpdesk, and marketing tools in minutes.`,
  canonical: `https://www.limecall.com/integrations/`,
};

const categories = [
  {
    name: "CRM",
    desc: "Sync every call with your CRM — log activities, update contacts, and trigger workflows automatically.",
    integrations: [
      { name: "HubSpot", desc: "Auto-log calls, sync leads, and trigger HubSpot workflows on every callback.", href: "/limecall-for-hubspot/", available: true },
      { name: "Salesforce", desc: "Sync callbacks with Salesforce contacts, leads, and opportunities automatically.", href: null, available: true },
      { name: "Pipedrive", desc: "Sync LimeCall leads into Pipedrive deals and activities automatically.", href: null, available: true },
      { name: "Zoho CRM", desc: "Log every LimeCall callback to Zoho CRM with full call details and recordings.", href: null, available: true },
      { name: "ActiveCampaign", desc: "Create contacts and start automations in ActiveCampaign from every callback.", href: "/activecampaign-integration/", available: true },
    ],
  },
  {
    name: "Productivity",
    desc: "Keep your team in sync — automate workflows and get instant lead notifications wherever your team works.",
    integrations: [
      { name: "Zapier", desc: "Connect LimeCall to 6,000+ apps via Zapier. No code. Trigger on callbacks, missed calls, or new leads.", href: "/zapier-integration/", available: true },
      { name: "Slack", desc: "Get instant call alerts in Slack. Your team sees every lead the moment they arrive.", href: "/sms-for-slack/", available: true },
      { name: "Webhooks / REST API", desc: "Full REST API and webhooks for custom integrations with any internal tool or system.", href: null, available: true },
      { name: "Make (Integromat)", desc: "Build advanced multi-step workflows with LimeCall as your trigger or action.", href: null, available: true },
    ],
  },
  {
    name: "Communication",
    desc: "Keep your team notified across SMS, WhatsApp, Slack, and Microsoft Teams the moment a lead arrives.",
    integrations: [
      { name: "Slack", desc: "Get instant call alerts in Slack. Your team sees every lead the moment they arrive.", href: "/sms-for-slack/", available: true },
      { name: "WhatsApp", desc: "Engage leads over WhatsApp click-to-chat directly from LimeCall — no extra app needed.", href: "/click-to-whatsapp/", available: true },
      { name: "Microsoft Teams", desc: "Receive LimeCall notifications and lead alerts directly in Teams channels.", href: null, available: true },
      { name: "SMS", desc: "Send automated follow-up SMS after every callback, missed call, or new lead.", href: null, available: true },
    ],
  },
  {
    name: "Marketing",
    desc: "Track which campaigns drive callbacks and attribute every conversion accurately.",
    integrations: [
      { name: "Google Ads", desc: "Track LimeCall callbacks as Google Ads conversions. Optimize campaigns on real phone leads.", href: null, available: true },
      { name: "Facebook Lead Ads", desc: "Fire Facebook/Meta conversion events when a visitor requests a callback. Improve ROAS.", href: null, available: true },
      { name: "Google Analytics", desc: "Track LimeCall callback events in GA4. See exactly which pages and sources convert best.", href: null, available: true },
      { name: "Mailchimp", desc: "Add every LimeCall lead to a Mailchimp audience and trigger nurture sequences automatically.", href: null, available: true },
    ],
  },
  {
    name: "eCommerce",
    desc: "Turn store visitors into conversations — rescue abandoned carts and close high-value orders.",
    integrations: [
      { name: "Shopify", desc: "Add LimeCall to your Shopify store to rescue abandoned carts and close big-ticket sales.", href: null, available: true },
      { name: "WooCommerce", desc: "Embed the LimeCall callback widget on WooCommerce product and checkout pages.", href: null, available: true },
      { name: "Klaviyo", desc: "Sync LimeCall callback data to Klaviyo for e-commerce post-call follow-up flows.", href: null, available: true },
    ],
  },
  {
    name: "Website Builders",
    desc: "Add the LimeCall widget to any website in minutes — no developer required.",
    integrations: [
      { name: "WordPress", desc: "Install LimeCall with our official WordPress plugin. Works with all themes and page builders.", href: "/limecall-for-wordpress/", available: true },
      { name: "Webflow", desc: "Add one script tag to your Webflow site. Go live in minutes — no custom code required.", href: "/limecall-for-webflow/", available: true },
      { name: "Wix", desc: "Embed LimeCall on any Wix site with a single code block.", href: null, available: true },
      { name: "Squarespace", desc: "Add LimeCall's callback widget to Squarespace via the custom code injection.", href: null, available: true },
    ],
  },
  {
    name: "Helpdesk",
    desc: "Turn every callback into a support ticket — automatically logged with full call context.",
    integrations: [
      { name: "Zendesk", desc: "Every callback creates a Zendesk ticket with full call context and recording.", href: "/integration-zendesk/", available: true },
      { name: "Intercom", desc: "Sync LimeCall conversations with Intercom contacts and conversations.", href: null, available: true },
      { name: "Freshdesk", desc: "Log LimeCall callbacks as Freshdesk tickets automatically.", href: null, available: true },
      { name: "HelpScout", desc: "Create HelpScout conversations from LimeCall callbacks and missed calls.", href: null, available: true },
    ],
  },
];

const spotlights = [
  {
    name: "HubSpot",
    category: "CRM",
    desc: "LimeCall's HubSpot integration is the deepest in its class. Every callback automatically creates or updates a HubSpot contact, logs the call activity with duration and recording, and can trigger any HubSpot workflow. Sales reps never have to manually update their CRM again.",
    href: "/limecall-for-hubspot/",
    highlight: "Auto-log calls · Sync contacts · Trigger workflows",
  },
  {
    name: "Salesforce",
    category: "CRM",
    desc: "Keep your Salesforce data always up to date. LimeCall pushes callback data to Salesforce leads, contacts, and opportunities in real time. Custom field mapping ensures data lands exactly where your team expects it.",
    href: null,
    highlight: "Real-time sync · Custom field mapping · Lead & opportunity updates",
  },
  {
    name: "Slack",
    category: "Communication",
    desc: "Never miss a hot lead. LimeCall sends instant Slack notifications with caller name, phone, page URL, and call recording link. Route alerts to the right channel by team, territory, or product line.",
    href: "/sms-for-slack/",
    highlight: "Instant alerts · Channel routing · Call recording links",
  },
  {
    name: "Zapier",
    category: "Automation",
    desc: "LimeCall's Zapier integration unlocks connections to 5,000+ apps without a single line of code. Trigger zaps from new callbacks, missed calls, or scheduled call requests. Popular workflows include Google Sheets logging, Trello card creation, and Airtable record updates.",
    href: null,
    highlight: "5,000+ apps · No code · Multi-step workflows",
  },
  {
    name: "Google Analytics",
    category: "Analytics",
    desc: "Track LimeCall callbacks as conversion events in GA4. See exactly which landing pages, traffic sources, and campaigns generate the most phone leads. Feed call conversion data back into Google Ads for smarter bidding.",
    href: null,
    highlight: "GA4 events · Source attribution · Ad conversion tracking",
  },
  {
    name: "Zendesk",
    category: "Helpdesk",
    desc: "Every LimeCall callback automatically creates a Zendesk ticket with the caller's details, the page they called from, and a link to the call recording. Support teams get full context before they even pick up the phone.",
    href: "/integration-zendesk/",
    highlight: "Auto-create tickets · Full call context · Recording links",
  },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'LimeCall Integrations Directory',
  description: 'All LimeCall integrations organized by category — CRM, communication, productivity, marketing, ecommerce, and website builders.',
  numberOfItems: 19,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'HubSpot Integration', url: 'https://www.limecall.com/limecall-for-hubspot/', description: 'Auto-log calls, sync leads, and trigger HubSpot workflows on every callback.' },
    { '@type': 'ListItem', position: 2, name: 'Salesforce Integration', url: 'https://www.limecall.com/integrations/', description: 'Sync callbacks with Salesforce contacts, leads, and opportunities automatically.' },
    { '@type': 'ListItem', position: 3, name: 'Pipedrive Integration', url: 'https://www.limecall.com/integrations/', description: 'Sync LimeCall leads into Pipedrive deals and activities automatically.' },
    { '@type': 'ListItem', position: 4, name: 'Zoho CRM Integration', url: 'https://www.limecall.com/integrations/', description: 'Log every LimeCall callback to Zoho CRM with full call details and recordings.' },
    { '@type': 'ListItem', position: 5, name: 'ActiveCampaign Integration', url: 'https://www.limecall.com/activecampaign-integration/', description: 'Create contacts and start automations in ActiveCampaign from every callback.' },
    { '@type': 'ListItem', position: 6, name: 'Zapier Integration', url: 'https://www.limecall.com/zapier-integration/', description: 'Connect LimeCall to 6,000+ apps via Zapier. No code required.' },
    { '@type': 'ListItem', position: 7, name: 'Slack Integration', url: 'https://www.limecall.com/sms-for-slack/', description: 'Get instant call alerts in Slack the moment a lead arrives.' },
    { '@type': 'ListItem', position: 8, name: 'WhatsApp Integration', url: 'https://www.limecall.com/click-to-whatsapp/', description: 'Click-to-WhatsApp buttons that connect website visitors to your team instantly.' },
    { '@type': 'ListItem', position: 9, name: 'Microsoft Teams Integration', url: 'https://www.limecall.com/integrations/', description: 'Receive LimeCall lead notifications directly in Microsoft Teams channels.' },
    { '@type': 'ListItem', position: 10, name: 'Google Analytics Integration', url: 'https://www.limecall.com/integrations/', description: 'Track LimeCall callback events in GA4. See which pages and sources convert best.' },
    { '@type': 'ListItem', position: 11, name: 'Google Ads Integration', url: 'https://www.limecall.com/integrations/', description: 'Track LimeCall callbacks as Google Ads conversions. Optimize campaigns on real leads.' },
    { '@type': 'ListItem', position: 12, name: 'Facebook Lead Ads Integration', url: 'https://www.limecall.com/integrations/', description: 'Fire Facebook/Meta conversion events when a visitor requests a callback.' },
    { '@type': 'ListItem', position: 13, name: 'Webhooks & REST API', url: 'https://www.limecall.com/integrations/', description: 'Full REST API and webhooks for custom integrations with any internal tool.' },
    { '@type': 'ListItem', position: 14, name: 'Shopify Integration', url: 'https://www.limecall.com/integrations/', description: 'Add LimeCall to your Shopify store to rescue abandoned carts and close sales.' },
    { '@type': 'ListItem', position: 15, name: 'WooCommerce Integration', url: 'https://www.limecall.com/integrations/', description: 'Add the LimeCall callback widget to WooCommerce stores.' },
    { '@type': 'ListItem', position: 16, name: 'WordPress Integration', url: 'https://www.limecall.com/limecall-for-wordpress/', description: 'Install LimeCall with the official WordPress plugin. Works with all themes.' },
    { '@type': 'ListItem', position: 17, name: 'Webflow Integration', url: 'https://www.limecall.com/limecall-for-webflow/', description: 'Add one script tag to your Webflow site. Go live in minutes.' },
    { '@type': 'ListItem', position: 18, name: 'Zendesk Integration', url: 'https://www.limecall.com/integration-zendesk/', description: 'Every callback creates a Zendesk ticket with full call context and recording.' },
    { '@type': 'ListItem', position: 19, name: 'Mailchimp Integration', url: 'https://www.limecall.com/integrations/', description: 'Add every LimeCall lead to a Mailchimp audience and trigger nurture sequences.' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Does LimeCall integrate with HubSpot?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall has a native HubSpot integration that automatically logs every callback as a call activity, creates or updates contacts, and can trigger any HubSpot workflow. No manual data entry required.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does the Zapier integration work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall connects to Zapier as a trigger app. You can trigger Zaps when a new callback is requested, when a call is completed, or when a call is missed. This lets you connect LimeCall to 5,000+ apps without any code.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I sync call data to Salesforce?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall syncs callback data to Salesforce in real time. Each callback can create or update a Lead, Contact, or Opportunity, and log a call activity with duration, recording, and custom fields.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall work with Google Ads?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall can fire Google Ads conversion events when a visitor requests a callback. This lets you attribute phone leads to the exact campaign, ad group, and keyword — and feed that data back to Google for smarter bidding.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is there a LimeCall API?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall offers a full REST API and webhook support on Pro plans and above. You can use the API to build custom integrations, retrieve call data, manage contacts, and trigger actions in your own systems.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall integrate with Microsoft Teams and WhatsApp?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall sends real-time lead notifications to Microsoft Teams channels so your team never misses a hot lead. For WhatsApp, LimeCall supports click-to-WhatsApp buttons that let website visitors start a WhatsApp conversation directly — ideal for teams that prefer messaging over phone calls.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={itemListSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Integrations', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        50+ integrations available
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall Works With<br class="hidden sm:block" />
        <span class="text-lime-400">Your Existing Stack</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Connect LimeCall with your CRM, helpdesk, marketing tools, and automation platforms. Every callback — automatically logged, synced, and attributed across 50+ integrations. <a href="/what-is-crm-integration/" class="text-lime-400 hover:text-lime-300 underline">Learn what CRM integration is</a> and why it matters for your sales stack.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">Connect Your Tools Free →</a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">See How It Works</a>
      </div>
      <!-- Integration logo strip -->
      <div class="mt-10 flex flex-wrap justify-center gap-3 text-xs text-dark-500">
        {["HubSpot", "Salesforce", "Slack", "Zapier", "Google Analytics", "Zendesk", "Mailchimp", "Pipedrive"].map(n => (
          <span class="rounded-lg border border-dark-800 bg-dark-900/80 px-3 py-1.5 text-dark-400">{n}</span>
        ))}
        <span class="rounded-lg border border-dark-800 bg-dark-900/80 px-3 py-1.5 text-lime-500/70 font-semibold">+42 more</span>
      </div>
    </div>
  </section>

  <!-- Popular integration spotlights -->
  <section class="py-16 sm:py-20 border-b border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 class="text-2xl font-bold text-white">Popular Integrations</h2>
        <p class="mt-2 text-dark-400">The tools teams connect with most — and what they unlock.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {spotlights.map(s => (
          <div class="flex flex-col rounded-xl border border-dark-800 bg-dark-900/60 p-6 hover:border-lime-500/30 transition">
            <div class="mb-3 flex items-center justify-between">
              <div>
                <span class="text-xs font-semibold uppercase tracking-wider text-lime-500/70">{s.category}</span>
                <h3 class="mt-0.5 text-lg font-bold text-white">{s.name}</h3>
              </div>
            </div>
            <p class="flex-1 text-sm text-dark-400 leading-relaxed">{s.desc}</p>
            <div class="mt-4 rounded-lg bg-dark-800/60 px-3 py-2 text-xs text-dark-500 leading-relaxed">{s.highlight}</div>
            {s.href ? (
              <a href={s.href} class="mt-4 text-xs font-semibold text-lime-500 hover:text-lime-400 transition">See {s.name} integration →</a>
            ) : (
              <a href={site.cta.href} class="mt-4 text-xs font-semibold text-lime-500/60 hover:text-lime-500 transition">Connect {s.name} →</a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Integration categories -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 class="text-2xl font-bold text-white">All Integrations by Category</h2>
        <p class="mt-2 text-dark-400">Browse all 50+ integrations organized by use case.</p>
      </div>
      <div class="space-y-16">
        {categories.map(cat => (
          <div>
            <div class="mb-6 flex items-start gap-3">
              <div>
                <h2 class="text-xl font-bold text-white">{cat.name}</h2>
                <p class="mt-1 text-sm text-dark-400">{cat.desc}</p>
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              {cat.integrations.map(int => (
                int.href ? (
                  <a href={int.href} class="group rounded-xl border border-dark-800 bg-dark-900/60 p-5 hover:border-lime-500/40 transition">
                    <h3 class="font-semibold text-white group-hover:text-lime-400 transition">{int.name}</h3>
                    <p class="mt-2 text-xs text-dark-400 leading-relaxed">{int.desc}</p>
                    <span class="mt-3 inline-block text-xs font-semibold text-lime-500">Learn more →</span>
                  </a>
                ) : (
                  <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-5">
                    <h3 class="font-semibold text-white">{int.name}</h3>
                    <p class="mt-2 text-xs text-dark-400 leading-relaxed">{int.desc}</p>
                    <span class="mt-3 inline-block text-xs font-semibold text-lime-500/60">Available</span>
                  </div>
                )
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Zapier callout -->
  <section class="border-t border-dark-800 py-10 bg-dark-900/50">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-8 text-center">
        <div class="mb-2 text-3xl">⚡</div>
        <h2 class="text-xl font-bold text-white mb-3">Don't see your tool?</h2>
        <p class="text-dark-300 leading-relaxed mb-6">
          Connect LimeCall to <strong class="text-white">6,000+ apps via Zapier</strong> — no code required. Trigger zaps from new callbacks, missed calls, or completed conversations and push data anywhere your team works.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={site.cta.href} class="rounded-xl bg-lime-500 px-7 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">Connect via Zapier →</a>
          <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-7 py-3 text-sm font-bold text-white hover:border-lime-500/40 transition">See How It Works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Zapier / API section -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 sm:grid-cols-2">
        <div>
          <h2 class="text-2xl font-bold text-white mb-4">Custom integrations via API</h2>
          <p class="text-dark-300 leading-relaxed mb-4">
            LimeCall's open REST API and webhook support let you connect with any tool your team uses. Build custom integrations or use our Zapier / Make connectors to reach 6,000+ apps — no code required.
          </p>
          <p class="text-dark-400 text-sm leading-relaxed mb-6">
            API access available on Pro plan. Our team can also assist with custom integration setup.
          </p>
          <a href={site.cta.href} class="inline-block rounded-xl bg-lime-500 px-6 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">Start Free Trial →</a>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-white mb-4">Example Zapier Workflows</h2>
          <p class="text-dark-300 leading-relaxed mb-4">
            Trigger automations from any LimeCall event — new callback, missed call, completed call, or scheduled request.
          </p>
          <div class="space-y-2">
            {[
              "New callback → Add to Google Sheets",
              "Missed call → Send Slack message",
              "New lead → Create Trello card",
              "Call completed → Update Airtable record",
              "Callback request → Add to Mailchimp audience",
              "Callback request → Add to ActiveCampaign list",
            ].map(zap => (
              <div class="flex items-center gap-2 text-sm text-dark-400">
                <svg class="h-4 w-4 flex-shrink-0 text-lime-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {zap}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Integration FAQs</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Connect LimeCall to your stack today</h2>
      <p class="mt-4 text-dark-400">Free trial · No credit card · 5-minute setup</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">Start Free →</a>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore LimeCall" links={[
