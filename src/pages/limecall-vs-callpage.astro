---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const competitor = "CallPage";
const competitorSlug = "callpage";

const seo = {
  title: `LimeCall vs ${competitor} — Which is Better in 2026? | LimeCall`,
  description: `LimeCall vs ${competitor}: honest side-by-side comparison. See features, pricing, and why teams switch to LimeCall for faster callbacks and better conversions.`,
  canonical: `https://www.limecall.com/limecall-vs-${competitorSlug}/`,
};

const features = [
  { feature: "Instant Callback (28 sec)", limecall: true, competitor: true },
  { feature: "Click-to-Call Widget", limecall: true, competitor: true },
  { feature: "Lead Distribution", limecall: true, competitor: false },
  { feature: "SMS & WhatsApp", limecall: true, competitor: false },
  { feature: "Virtual Phone Numbers (40+ countries)", limecall: true, competitor: false },
  { feature: "CRM Integrations", limecall: true, competitor: true },
  { feature: "Call Recording", limecall: true, competitor: true },
  { feature: "Free Plan (no credit card)", limecall: true, competitor: false },
  { feature: "Shared SMS Inbox", limecall: true, competitor: false },
  { feature: "Speed-to-Lead Automation", limecall: true, competitor: false },
  { feature: "G2 / Capterra Rating", limecall: "4.5 / 5", competitor: "4.2 / 5" },
];

const reasons = [
  { title: "Faster response time", desc: "LimeCall connects leads with your team in under 28 seconds. No delays, no lost opportunities." },
  { title: "More channels", desc: "Beyond callbacks — SMS, WhatsApp, and virtual numbers all in one platform." },
  { title: "Better value", desc: "More features at lower cost. No per-minute surprises. Start free with no credit card required." },
  { title: "Simple setup", desc: "Add the widget to your site in 5 minutes. No developer needed." },
  { title: "Omni-channel approach", desc: "LimeCall is a perfect fit for any SME looking for an omni-channel approach to sales." },
  { title: "Lead distribution built-in", desc: "Automatically route inbound leads to the right rep — a feature CallPage simply doesn't offer." },
];

const pricing = [
  {
    tool: "LimeCall",
    highlight: true,
    tiers: [
      { name: "Free", price: "$0/mo", note: "30 calls/month, no credit card" },
      { name: "Starter", price: "$29/mo", note: "100 calls, lead distribution, SMS" },
      { name: "Pro", price: "$99/mo", note: "500 calls, virtual numbers, API" },
    ],
  },
  {
    tool: "CallPage",
    highlight: false,
    tiers: [
      { name: "No free plan", price: "—", note: "Paid plan required to start" },
      { name: "Basic", price: "~$29/mo", note: "Limited callbacks, no SMS" },
      { name: "Pro", price: "~$79/mo", note: "More calls, no virtual numbers" },
    ],
  },
];

const testimonials = [
  {
    quote: "We switched from CallPage to LimeCall six months ago and our callback conversion rate went from 18% to 31%. The lead distribution feature alone paid for itself in the first week.",
    name: "Marcus T.",
    title: "Head of Sales, SaaS startup",
    metric: "+72% conversion rate",
  },
  {
    quote: "CallPage was fine for basic callbacks, but we needed SMS follow-ups and virtual numbers for our European clients. LimeCall had everything in one place and cost less per month.",
    name: "Priya S.",
    title: "Marketing Director, B2B services",
    metric: "3 channels, 1 platform",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is LimeCall a good CallPage alternative?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall offers all of CallPage\'s core callback features plus SMS, WhatsApp, virtual numbers, lead distribution, and more — at competitive pricing with a free plan that requires no credit card.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall require a credit card to start?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. LimeCall offers a free plan with 30 calls/month and no credit card required. CallPage does not offer a free plan.',
      },
    },
    {
      '@type': 'Question',
      name: 'How fast does LimeCall connect calls compared to CallPage?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall connects website visitors with your sales team in under 28 seconds. Both tools offer instant callback, but LimeCall\'s speed-to-lead automation and lead distribution mean the right rep is reached faster.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I migrate from CallPage to LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Migration takes about 3 steps: (1) Sign up for LimeCall free — no credit card needed. (2) Add the LimeCall widget script to your website — it takes under 5 minutes. (3) Connect your CRM and notification tools using LimeCall\'s native integrations. Your team can be fully live on LimeCall within a day.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall have better ratings than CallPage?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall holds a 4.5/5 rating on G2 and Capterra, compared to CallPage\'s 4.2/5. Reviewers consistently highlight LimeCall\'s broader feature set, responsive support, and better value for money.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Compare', url: 'https://www.limecall.com/compare/' }, { name: `LimeCall vs ${competitor}`, url: seo.canonical }]} />
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall vs <span class="text-lime-400">{competitor}</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300">
        An honest comparison. See why growing sales teams choose LimeCall over {competitor} for faster lead response and higher conversions.
      </p>
      <!-- Rating badges -->
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <div class="rounded-xl border border-lime-500/30 bg-lime-500/10 px-5 py-2.5 text-center">
          <div class="text-lg font-extrabold text-lime-400">4.5/5</div>
          <div class="text-xs text-dark-400">LimeCall on G2</div>
        </div>
        <div class="flex items-center px-2 text-dark-600 text-sm font-medium">vs</div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 px-5 py-2.5 text-center">
          <div class="text-lg font-extrabold text-dark-300">4.2/5</div>
          <div class="text-xs text-dark-500">{competitor} on G2</div>
        </div>
      </div>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">
          Try LimeCall Free →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 px-8 py-3.5 text-sm font-semibold text-white hover:border-lime-500/50 transition">
          See Pricing
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime</p>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Feature Comparison</h2>
      <div class="overflow-hidden rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-6 py-4 text-left font-semibold text-dark-300">Feature</th>
              <th class="px-6 py-4 text-center font-bold text-lime-400">LimeCall</th>
              <th class="px-6 py-4 text-center font-semibold text-dark-400">{competitor}</th>
            </tr>
          </thead>
          <tbody>
            {features.map((row, i) => (
              <tr class:list={["border-b border-dark-800/50", i % 2 === 0 ? "bg-dark-950" : "bg-dark-900/40"]}>
                <td class="px-6 py-3.5 text-dark-300">{row.feature}</td>
                <td class="px-6 py-3.5 text-center">
                  {typeof row.limecall === 'string'
                    ? <span class="text-lime-400 font-semibold">{row.limecall}</span>
                    : row.limecall
                      ? <span class="text-lime-400 text-base">✓</span>
                      : <span class="text-dark-600 text-base">✗</span>}
                </td>
                <td class="px-6 py-3.5 text-center">
                  {typeof row.competitor === 'string'
                    ? <span class="text-dark-400 font-semibold">{row.competitor}</span>
                    : row.competitor
                      ? <span class="text-dark-300 text-base">✓</span>
                      : <span class="text-dark-600 text-base">✗</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pricing comparison -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Pricing Comparison</h2>
      <p class="mb-10 text-center text-dark-400">LimeCall starts free. CallPage requires a paid plan from day one.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        {pricing.map(p => (
          <div class:list={["rounded-xl border p-6", p.highlight ? "border-lime-500/30 bg-dark-900/60" : "border-dark-800 bg-dark-900/40"]}>
            <h3 class:list={["mb-4 text-lg font-bold", p.highlight ? "text-lime-400" : "text-dark-300"]}>{p.tool}</h3>
            <div class="space-y-3">
              {p.tiers.map(t => (
                <div class="flex items-start justify-between gap-2">
                  <div>
                    <div class="text-sm font-semibold text-white">{t.name}</div>
                    <div class="text-xs text-dark-500">{t.note}</div>
                  </div>
                  <div class:list={["text-sm font-bold whitespace-nowrap", p.highlight ? "text-lime-400" : "text-dark-400"]}>{t.price}</div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-xs text-dark-600">Pricing approximate. Check each vendor's website for current rates.</p>
    </div>
  </section>

  <!-- Why switch -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Why teams switch from {competitor} to LimeCall</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {reasons.map(r => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{r.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Migration guide -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Switching from {competitor} to LimeCall in 3 Steps</h2>
      <p class="mb-10 text-center text-dark-400">Most teams are fully live within a single day.</p>
      <div class="space-y-4">
        {[
          { step: "1", title: "Sign up free — no credit card needed", desc: "Create your LimeCall account in 60 seconds. You get 30 calls/month free with immediate access to the widget builder and dashboard." },
          { step: "2", title: "Add the widget to your website", desc: "Copy one script tag and paste it before the </body> tag on your site. Works with WordPress, Webflow, Shopify, or any custom site. Takes under 5 minutes." },
          { step: "3", title: "Connect your CRM and notifications", desc: "Use LimeCall's native integrations to connect HubSpot, Salesforce, Slack, or any other tool you currently use with CallPage. Your team stays in the same workflow — just with more features." },
        ].map(s => (
          <div class="flex gap-4 rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-lime-500/10 text-sm font-bold text-lime-400">{s.step}</div>
            <div>
              <h3 class="font-semibold text-white mb-1">{s.title}</h3>
              <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">What Former {competitor} Users Say</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {testimonials.map(t => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-4 inline-block rounded-full bg-lime-500/10 px-3 py-1 text-xs font-bold text-lime-400">{t.metric}</div>
            <blockquote class="text-sm text-dark-300 leading-relaxed mb-4">"{t.quote}"</blockquote>
            <div>
              <div class="text-sm font-semibold text-white">{t.name}</div>
              <div class="text-xs text-dark-500">{t.title}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.name}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to make the switch?</h2>
      <p class="mt-4 text-dark-400">Join thousands who chose LimeCall over {competitor}. No credit card. Cancel anytime.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
        Start Free — No Credit Card →
      </a>
    </div>
  </section>

  <div class="py-8 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <CrossLinks heading="Explore LimeCall" links={[
      { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans.' },
      { href: '/click-2-call/', title: 'Click to Call', desc: 'Instant website callbacks.' },
      { href: '/features/', title: 'Features', desc: 'Everything LimeCall does.' },
      { href: '/alternative-to-callpage/', title: 'CallPage Alternative', desc: 'The best CallPage alternative for SMEs.' },
    ]} />
  </div>
</Base>
