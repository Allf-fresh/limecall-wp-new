---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const slug = "google-ads-integration";

const seo = {
  title: `LimeCall + Google Ads Call Tracking | Close the Loop on PPC Calls`,
  description: `Connect LimeCall to Google Ads to track which campaigns drive callbacks, import offline conversions, and optimise bidding on calls that actually convert.`,
  canonical: `${site.url}/google-ads-integration/`,
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'LimeCall Google Ads Integration',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Free trial available',
  },
  description: 'Connect LimeCall to Google Ads to track which campaigns drive callbacks, import offline conversions, and optimise Smart Bidding on calls that actually convert.',
  url: `${site.url}/google-ads-integration/`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Does the LimeCall Google Ads integration work with Performance Max campaigns?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall captures the GCLID (Google Click ID) from all campaign types, including Performance Max, Search, Display, and Shopping. Offline call conversions are imported back to Google Ads using the standard Offline Conversions API, which Performance Max campaigns read and optimise against in the same way as other campaign types.',
      },
    },
    {
      '@type': 'Question',
      name: 'How are offline call conversions imported into Google Ads?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'When a visitor clicks a Google Ad and then requests a callback, LimeCall captures and stores the GCLID from their session. When the call is completed and the outcome is logged, LimeCall automatically sends the conversion event — with the original GCLID, conversion time, and optional conversion value — to Google Ads via the Offline Conversions API. Google Ads attributes the conversion to the originating click, campaign, ad group, and keyword.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall replace Google call extensions or call ads?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. LimeCall complements Google call extensions and call ads rather than replacing them. Google call extensions and call ads measure clicks-to-call directly from the SERP. LimeCall tracks callback requests from your website — visitors who click through from an ad and then request a call via the LimeCall widget. Both measurement methods feed conversion data back to Google Ads for a complete picture of phone-driven revenue.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does dynamic number insertion work with Google Ads?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "LimeCall's dynamic number insertion (DNI) assigns a unique tracking number to each Google Ads campaign or ad group. When a visitor arrives from a specific campaign, LimeCall replaces any phone numbers on the page with the campaign-specific tracking number. Calls to that number are attributed to the correct campaign, ad group, and keyword automatically — even if the visitor later navigates to other pages on your site.",
      },
    },
    {
      '@type': 'Question',
      name: 'How long does it take for call conversions to appear in Google Ads?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall sends the conversion event to Google Ads within minutes of the call outcome being logged. Google typically processes and attributes the conversion within 3–6 hours, after which it appears in your Google Ads conversion reports and is factored into Smart Bidding decisions.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I set a conversion value for phone calls in Google Ads?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall lets you assign a monetary conversion value to different call outcomes — for example, a completed demo call might carry a £150 value based on your average close rate and deal size. You can also pass dynamic conversion values if you capture deal size or product selection through the LimeCall widget form. These values inform Target ROAS bidding in Google Ads.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall capture UTM parameters for non-Google Ads traffic too?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall captures all UTM parameters — utm_source, utm_medium, utm_campaign, utm_term, and utm_content — from every visitor session, regardless of the traffic source. This means you can attribute phone conversions to Google Ads, Microsoft Ads, Meta, email campaigns, and any other UTM-tagged traffic source within a single LimeCall reporting dashboard.',
      },
    },
  ],
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Connect LimeCall with Google Ads',
  description: 'Step-by-step guide to integrating LimeCall with Google Ads for GCLID tracking, offline conversion import, and Smart Bidding optimisation.',
  totalTime: 'PT10M',
  step: [
    {
      '@type': 'HowToStep',
      name: 'Add LimeCall tracking script',
      text: 'Paste the LimeCall tracking snippet into your site\'s <head> — or install via Google Tag Manager. LimeCall begins capturing GCLIDs and UTM parameters immediately.',
      position: 1,
    },
    {
      '@type': 'HowToStep',
      name: 'Set up conversion import',
      text: 'In LimeCall → Integrations → Google Ads, connect your Google Ads account and select or create a conversion action. Map call outcomes to conversion events and set optional conversion values.',
      position: 2,
    },
    {
      '@type': 'HowToStep',
      name: 'Enable Smart Bidding for calls',
      text: 'Switch your campaigns to Target CPA or Target ROAS and include your LimeCall call conversion action in the bidding signal. Smart Bidding starts learning from call data within days.',
      position: 3,
    },
  ],
};

const stats = [
  { value: "GCLID", label: "Captured on every PPC click" },
  { value: "Real-time", label: "Offline conversion import" },
  { value: "£42→£18", label: "Cost-per-call improvement (B2B SaaS)" },
  { value: "90 days", label: "To optimise Smart Bidding" },
];

const features = [
  {
    title: "Dynamic number insertion per campaign and ad group",
    desc: "LimeCall automatically displays a unique tracking phone number to visitors from each Google Ads campaign and ad group. Calls are attributed to the exact campaign, ad group, and keyword — giving you cost-per-call data at every level of your account.",
  },
  {
    title: "Import call conversions back to Google Ads",
    desc: "When a call converts, LimeCall sends the GCLID and outcome back to Google Ads via the Offline Conversions API. Google attributes the conversion to the originating click, enabling accurate conversion reporting without last-click guesswork.",
  },
  {
    title: "Smart Bidding optimised for phone leads",
    desc: "Once call conversions flow into Google Ads, Target CPA and Target ROAS Smart Bidding strategies can optimise specifically for calls that convert — not just form fills. Bids increase for queries that historically drive high-value phone leads.",
  },
  {
    title: "UTM parameter capture on every call",
    desc: "LimeCall captures utm_source, utm_medium, utm_campaign, utm_term, and utm_content from every visitor session. All UTM data is stored against the call record and available in LimeCall reports and any CRM or BI tool you connect.",
  },
  {
    title: "Cost-per-call reporting by keyword",
    desc: "Combine Google Ads spend data with LimeCall call volume by keyword to calculate true cost-per-call at keyword level. Identify which keywords drive the most callbacks and which drive the highest-quality conversations.",
  },
  {
    title: "GCLID sync for complete attribution",
    desc: "LimeCall stores the GCLID from every Google click. When the call outcome is logged — even hours or days later — the GCLID is included in the conversion import, ensuring Google Ads receives accurate attribution data with no drop-off.",
  },
];

const useCases = [
  {
    role: "PPC Managers",
    title: "Prove phone revenue from your Google Ads spend",
    desc: "Stop reporting on click-throughs and form fills. Feed call conversion data back into Google Ads and show the actual revenue generated by PPC campaigns that drive phone traffic — the hardest metric to prove without call tracking.",
  },
  {
    role: "Performance teams",
    title: "Let Smart Bidding optimise for real call conversions",
    desc: "Smart Bidding learns from conversion signals. By importing call outcomes — not just call connections — Google Ads bids more aggressively on search queries that drive demo bookings and qualified conversations, not just calls that last 10 seconds.",
  },
  {
    role: "Marketing directors",
    title: "Cost-per-acquisition by keyword, not just by campaign",
    desc: "LimeCall's keyword-level call attribution lets you calculate a true CPA for phone leads by keyword. Cut spend on keywords that generate high call volume but low conversion rates; scale keywords where calls convert.",
  },
  {
    role: "B2B SaaS companies",
    title: "Close the loop on high-value PPC phone leads",
    desc: "B2B buyers rarely convert on the first visit. LimeCall captures the GCLID at the first click, stores it across sessions, and sends it to Google Ads when the call happens weeks later — giving you attribution across a long B2B buying cycle.",
  },
];

const comparisonRows = [
  { feature: "GCLID capture on every click", limecall: true, googleOnly: "Partial", others: false },
  { feature: "Offline conversion import to Google Ads", limecall: true, googleOnly: "Manual", others: false },
  { feature: "Dynamic number insertion by campaign", limecall: true, googleOnly: false, others: "Partial" },
  { feature: "Smart Bidding optimisation for calls", limecall: true, googleOnly: "Limited", others: false },
  { feature: "Keyword-level cost-per-call reporting", limecall: true, googleOnly: false, others: false },
  { feature: "UTM capture for non-Google traffic", limecall: true, googleOnly: false, others: "Partial" },
  { feature: "Call outcome as conversion value", limecall: true, googleOnly: false, others: false },
  { feature: "CRM sync + Google Ads attribution", limecall: true, googleOnly: false, others: false },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={softwareSchema} />
  <JsonLd schema={howToSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Integrations', url: `${site.url}/integrations/` },
        { name: 'Google Ads Integration', url: seo.canonical },
      ]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Google Ads Integration · Offline Conversions · Smart Bidding
      </div>
      <h1 class="mt-5 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall + <span class="text-lime-400">Google Ads</span>:<br class="hidden sm:block" />
        Close the Loop on PPC Calls
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Connect LimeCall to Google Ads to track which campaigns drive callbacks, import offline conversions back to your account, and let Smart Bidding optimise for calls that actually convert.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/get-started/" class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Tracking PPC Calls Free →
        </a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          Watch Demo
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ROI callout -->
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-8 text-center">
        <div class="mb-2 text-xs font-bold uppercase tracking-widest text-lime-400">Customer result</div>
        <h2 class="text-2xl font-bold text-white mb-3">
          From £42 to £18 cost-per-call in 90 days
        </h2>
        <p class="text-dark-300 text-sm leading-relaxed max-w-xl mx-auto">
          A B2B SaaS company connected LimeCall to Google Ads and enabled offline call conversion import. After 90 days of Smart Bidding optimising against real call outcomes, cost-per-call dropped from £42 to £18 — a 57% reduction — while call quality improved as Smart Bidding shifted budget toward higher-converting keywords.
        </p>
      </div>
    </div>
  </section>

  <!-- Data flow diagram -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">How LimeCall closes the attribution loop with Google Ads</h2>
      <p class="mb-12 text-center text-dark-400 text-sm max-w-2xl mx-auto">
        From a paid search click to an imported conversion in Google Ads — fully automated, with GCLID-level accuracy.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-0">
        <div class="flex flex-col items-center text-center max-w-[170px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">1</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Click on Google Ad</h3>
          <p class="mt-1 text-xs text-dark-400">GCLID captured and stored by LimeCall</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[170px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">2</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Visitor requests callback</h3>
          <p class="mt-1 text-xs text-dark-400">LimeCall widget shown on campaign landing page</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[170px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">3</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Call completed</h3>
          <p class="mt-1 text-xs text-dark-400">Outcome and duration logged in LimeCall</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-12 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[170px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">4</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Conversion imported</h3>
          <p class="mt-1 text-xs text-dark-400">GCLID + outcome sent to Google Ads API</p>
        </div>
      </div>

      <!-- Setup steps -->
      <div class="mt-14 grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 1</div>
          <h3 class="mb-2 font-semibold text-white">Add LimeCall tracking script</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Paste the LimeCall tracking snippet into your site's &lt;head&gt; — or install via Google Tag Manager. LimeCall begins capturing GCLIDs and UTM parameters immediately.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 2</div>
          <h3 class="mb-2 font-semibold text-white">Set up conversion import</h3>
          <p class="text-sm text-dark-400 leading-relaxed">In LimeCall → Integrations → Google Ads, connect your Google Ads account and select or create a conversion action. Map call outcomes to conversion events and set optional conversion values.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 3</div>
          <h3 class="mb-2 font-semibold text-white">Enable Smart Bidding for calls</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Switch your campaigns to Target CPA or Target ROAS and include your LimeCall call conversion action in the bidding signal. Smart Bidding starts learning from call data within days.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Everything the LimeCall + Google Ads integration does</h2>
      <p class="mb-10 text-center text-dark-400 text-sm">Six capabilities that connect your PPC spend to phone revenue.</p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f, i) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 hover:border-lime-500/30 transition">
            <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-lg bg-lime-500/15 text-sm font-extrabold text-lime-400">{i + 1}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Who uses LimeCall + Google Ads and how</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-2 inline-block rounded-full bg-lime-500/15 px-3 py-1 text-xs font-bold text-lime-400">{uc.role}</div>
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">LimeCall + Google Ads vs other call tracking approaches</h2>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="py-4 px-5 text-left font-semibold text-dark-300">Feature</th>
              <th class="py-4 px-5 text-center font-semibold text-lime-400">LimeCall + Google Ads</th>
              <th class="py-4 px-5 text-center font-semibold text-dark-400">Google Ads only</th>
              <th class="py-4 px-5 text-center font-semibold text-dark-400">Other call trackers</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800/50 ${i % 2 === 0 ? 'bg-dark-950/40' : 'bg-dark-900/20'}`}>
                <td class="py-3 px-5 text-dark-300">{row.feature}</td>
                <td class="py-3 px-5 text-center">
                  {row.limecall === true
                    ? <span class="text-lime-400 font-bold">Yes</span>
                    : <span class="text-dark-500">{row.limecall}</span>}
                </td>
                <td class="py-3 px-5 text-center">
                  {row.googleOnly === false
                    ? <span class="text-dark-600">No</span>
                    : <span class="text-dark-400">{row.googleOnly}</span>}
                </td>
                <td class="py-3 px-5 text-center">
                  {row.others === false
                    ? <span class="text-dark-600">No</span>
                    : <span class="text-dark-400">{row.others}</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 group">
            <summary class="cursor-pointer font-semibold text-white list-none flex items-center justify-between">
              {item.name}
              <span class="ml-4 text-lime-400 text-xl leading-none group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to prove your Google Ads ROI from phone calls?</h2>
      <p class="mt-4 text-dark-400">GCLID tracking · Offline conversions · Smart Bidding optimisation</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/get-started/" class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free →
        </a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-10 py-4 font-bold text-white hover:border-lime-500/40 transition">
          Book a Demo
        </a>
      </div>
    </div>
  </section>

  <div class="py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="More from LimeCall" links={[
        { href: '/google-analytics-integration/', title: 'LimeCall + Google Analytics', desc: 'Track callback events in GA4 alongside your PPC data.' },
        { href: '/inbound-call-tracking/', title: 'Inbound Call Tracking', desc: 'Track every inbound call back to its source.' },
        { href: '/lead-routing-software/', title: 'Lead Routing Software', desc: 'Route PPC leads to the right rep in seconds.' },
        { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'Why 28-second callbacks convert more PPC traffic.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple plans with Google Ads integration included.' },
      ]} />
    </div>
  </div>
</Base>
