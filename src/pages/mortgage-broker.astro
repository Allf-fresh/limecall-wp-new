---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'Callback Software for Mortgage Brokers | LimeCall',
  description: "Convert mortgage enquiries 5x faster. LimeCall's 28-second callback connects brokers with applicants at peak intent — before competitors do.",
  canonical: 'https://www.limecall.com/mortgage-broker/',
};

const stats = [
  { value: '73%', label: 'Of mortgage leads go to the first broker to respond' },
  { value: '28s', label: 'LimeCall callback vs hours for most brokerages' },
  { value: '£340', label: 'Average broker fee per completed placement' },
  { value: '5×', label: 'Faster lead conversion vs email-only follow-up' },
];

const features = [
  { icon: '⚡', title: 'Mortgage Enquiry Instant Callback', desc: 'When an applicant submits a mortgage enquiry on your website, LimeCall connects them to the right adviser in 28 seconds — while their intent is at its peak and before they request a callback from another broker.' },
  { icon: '🔒', title: 'FCA-Compliant Call Recording', desc: 'All calls automatically recorded and stored to FCA standards. Configurable retention periods, encrypted storage, and full audit trail for regulatory compliance and consumer duty requirements.' },
  { icon: '🔗', title: 'CRM Sync — Salesforce, HubSpot & Broker Brain', desc: 'Every callback automatically logged in Salesforce, HubSpot, Broker Brain, or your CRM of choice — applicant name, number, mortgage type, loan amount, and call outcome without manual data entry.' },
  { icon: '🌙', title: 'After-Hours Lead Capture', desc: 'Mortgage applicants research at evenings and weekends. LimeCall queues after-hours enquiries and delivers a prioritised callback list first thing Monday morning — no lead falls through the gap.' },
  { icon: '💬', title: 'WhatsApp Document Sharing', desc: 'After the initial call, automatically trigger a WhatsApp message so applicants can securely share payslips, bank statements, IDs, and supporting documents without friction or email delays.' },
  { icon: '📋', title: 'Compliance Audit Trails', desc: 'Every interaction logged with timestamps, call recordings, and adviser notes. Full audit trail satisfies FCA Consumer Duty requirements and provides evidence of compliant advice delivery.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is LimeCall compliant with FCA regulations for mortgage brokers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall records and stores all calls in line with FCA requirements for regulated mortgage firms operating under MCOB (Mortgage Conduct of Business). Recordings are encrypted at rest and in transit, with configurable retention periods and a full audit trail. We sign Data Processing Agreements (DPAs) with all mortgage broker customers as standard, satisfying GDPR and FCA data handling obligations. The platform also supports Consumer Duty compliance by ensuring all advice interactions are recorded and retrievable.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which CRMs does LimeCall integrate with for mortgage brokers?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall integrates natively with Salesforce, HubSpot, and Broker Brain. It also connects to 1,000+ tools via Zapier, including Twenty7Tec, Air Sourcing, and most mortgage CRM platforms. Every callback is automatically logged with applicant details, mortgage type, loan amount range, call duration, and adviser notes — keeping your pipeline fully current without manual CRM entry.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does WhatsApp document sharing work for mortgage applications?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'After every callback, LimeCall can automatically send a WhatsApp message to the applicant, enabling them to share payslips, bank statements, proof of address, identification documents, and mortgage application forms directly via WhatsApp. This replaces slow email chains and reduces the average document collection time from several days to under 24 hours. All document sharing activity is logged for compliance purposes.',
      },
    },
    {
      '@type': 'Question',
      name: 'What happens to mortgage enquiries submitted outside office hours?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "After-hours mortgage enquiries are captured in LimeCall's callback queue and delivered to your advisers as a prioritised list at the start of the next business day. You can also configure emergency routing for time-sensitive applications — such as applicants with a purchase deadline or expiring mortgage offer. Saturday and Sunday enquiries can be routed to on-duty advisers or queued for Monday morning priority callbacks.",
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall route mortgage enquiries to the right specialist adviser?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. LimeCall supports intelligent routing based on the mortgage type enquired about — residential, buy-to-let, commercial, remortgage, or equity release. You can also route by applicant postcode, loan amount range, or the specific page visited on your website. This ensures first-time buyers reach your residential specialists, while portfolio landlords are connected to your buy-to-let advisers.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long are call recordings stored for mortgage compliance?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Call recording retention is fully configurable in LimeCall. For FCA-regulated mortgage brokers, the standard requirement under MCOB is a minimum of 5 years from the date of the call. Recordings can be exported, archived, or deleted on request with a full audit trail. All recordings are encrypted using AES-256 and can be made available for FCA review or internal compliance audits on demand.',
      },
    },
    {
      '@type': 'Question',
      name: 'How quickly can our mortgage brokerage go live with LimeCall?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most mortgage brokerages are live within 5 minutes. Add the LimeCall widget to your website or mortgage enquiry pages, configure routing to your advisers by mortgage type, and the system is active immediately. No developer or IT resource is required. Full onboarding support is included, and our team can assist with FCA compliance configuration, CRM integration setup, and adviser training.',
      },
    },
  ],
};

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'LimeCall for Mortgage Brokers',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web, iOS, Android',
  description: 'FCA-compliant callback software for mortgage brokers. Connects enquiries to advisers in 28 seconds. Salesforce, HubSpot, and Broker Brain CRM integration.',
  url: 'https://www.limecall.com/mortgage-broker/',
  offers: {
    '@type': 'Offer',
    price: '35',
    priceCurrency: 'USD',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: '35',
      priceCurrency: 'USD',
      unitText: 'MONTH',
    },
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '98',
    bestRating: '5',
  },
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={softwareAppSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumbs items={[{ name: 'Mortgage Brokers', url: `${site.url}/mortgage-broker/` }]} />
      <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400">
        🏠 For Mortgage Brokers & Advisers
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Callback Software for Mortgage Brokers<br class="hidden sm:block" />
        <span class="text-lime-400">— Connect Applicants in 28 Seconds</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300">
        73% of mortgage leads choose the first broker to respond. LimeCall's 28-second callback connects your advisers with applicants at peak intent — FCA-compliant, 24/7, before competitors even read the enquiry.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center justify-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free Trial — 14 Days
        </a>
        <a href="/demo/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-dark-700 px-8 py-4 text-sm font-semibold text-white transition hover:border-lime-500/40 hover:text-lime-400">
          Book a Demo →
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">★ FCA-Compliant Call Recording · Trusted by mortgage brokers in 40+ countries · No setup fee</p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y border-dark-800 bg-dark-900/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <dt class="text-3xl font-extrabold text-lime-400">{s.value}</dt>
            <dd class="mt-1 text-sm text-dark-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Problem callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-red-500/20 bg-red-500/5 p-8">
        <h2 class="text-xl font-bold text-white mb-3">⚠️ Mortgage Leads Go Cold in Minutes — Not Hours</h2>
        <p class="text-dark-300">
          A first-time buyer submitted a mortgage enquiry on your website at 7:32pm on a Thursday. By 7:35pm, they had submitted the same enquiry to two comparison sites. By Friday morning, two other brokers had already called and booked appointments. Your email response at 9:15am arrived third. Mortgage applicants don't wait — they are comparing simultaneously, and the first adviser to call earns the application. LimeCall eliminates that gap.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">How LimeCall Works for Mortgage Brokers</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: '01', title: 'Applicant Visits Your Mortgage Enquiry Page', desc: 'LimeCall widget appears on key pages — residential mortgages, remortgages, buy-to-let, equity release — capturing enquiries at peak intent from applicants actively researching.' },
          { step: '02', title: 'Applicant Requests Instant Callback', desc: 'Enters their number and mortgage type. LimeCall routes to the right specialist adviser — residential, BTL, or commercial — based on the enquiry type and adviser availability.' },
          { step: '03', title: 'Connected to Adviser in 28 Seconds', desc: 'Adviser speaks with the applicant while they are still on your website, active and engaged — books the appointment, collects initial details, and moves the application forward on the call.' },
        ].map(item => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-lg">{item.step}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-dark-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-14">Built for Mortgage Brokers & Advisers</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-dark-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Mortgage Broker Use Cases</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'First-Time Buyer Enquiries', desc: 'Website visitor on FTB page → right adviser in 28s → affordability discussion and DIP started on the call while applicant is still engaged.' },
          { title: 'Remortgage Renewals', desc: 'Existing client portal → callback trigger at renewal date → adviser retains client before they shop around on comparison sites.' },
          { title: 'Buy-to-Let Applications', desc: 'BTL enquiry page → portfolio specialist connected → rental yield calculation and product recommendation on the call.' },
          { title: 'Protection & Insurance Cross-Sell', desc: 'Post-mortgage completion → automated callback opportunity → life cover, critical illness, and income protection discussed and placed.' },
        ].map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="font-bold text-white mb-2">{u.title}</h3>
            <p class="text-sm text-dark-400">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case study / testimonial -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <blockquote class="rounded-2xl border border-lime-500/20 bg-lime-500/5 p-10 text-center">
        <p class="text-xl text-white italic leading-relaxed">
          "We went from booking 23% of website enquiries to 58% in three months. LimeCall connects our advisers to applicants before they've even closed our tab. The FCA-compliant recording meant our compliance officer approved the rollout immediately. We've generated an additional £1.2M in fee revenue this year."
        </p>
        <footer class="mt-6">
          <p class="font-bold text-lime-400">Director of Mortgage Advice</p>
          <p class="text-sm text-dark-500">Independent mortgage brokerage, London</p>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">LimeCall vs. Other Mortgage Enquiry Contact Methods</h2>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              {['Feature', 'LimeCall', 'Phone Only', 'Email Follow-Up', 'Live Chat'].map(h => (
                <th class={`px-5 py-4 text-left font-semibold ${h === 'LimeCall' ? 'text-lime-400' : 'text-dark-300'}`}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['Response time', '28 seconds', 'Adviser availability', '2–24 hours', 'Agent dependent'],
              ['FCA call recording', '✅ Automatic', '⚠️ Manual setup', '❌ Not applicable', '❌ No voice'],
              ['After-hours capture', '✅ Queue + AM callback', '❌ Missed', '✅ Email stored', '❌ No agent'],
              ['Mortgage-type routing', '✅ Automatic', '⚠️ Manual', '❌ None', '⚠️ Manual'],
              ['CRM auto-logging', '✅ Every call', '⚠️ Manual entry', '⚠️ Partial', '⚠️ Text only'],
              ['Document collection', '✅ WhatsApp trigger', '❌ Email only', '✅ Email attachment', '⚠️ File upload only'],
              ['Appointment conversion', '🟢 58%+ reported', '🟡 23% avg', '🔴 Low (slow)', '🟡 Medium'],
            ].map(([feature, ...vals]) => (
              <tr class="hover:bg-dark-800/30 transition">
                <td class="px-5 py-4 font-medium text-dark-200">{feature}</td>
                {vals.map((v, i) => (
                  <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Integration callout -->
  <section class="py-12 bg-dark-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-dark-700 bg-dark-900/60 p-8 sm:p-10 flex flex-col sm:flex-row items-center gap-8">
        <div class="shrink-0 text-5xl">🔗</div>
        <div>
          <h2 class="text-xl font-bold text-white mb-2">Integrates with Salesforce, HubSpot, Broker Brain & More</h2>
          <p class="text-dark-400 text-sm leading-relaxed">
            LimeCall connects directly to Salesforce, HubSpot, Broker Brain, and 1,000+ tools via Zapier — including Twenty7Tec and Air Sourcing. Every callback is automatically logged with applicant details, mortgage type, loan amount, call duration, and adviser notes. Setup takes under 5 minutes with no IT team required.
          </p>
          <a href="/integrations/" class="mt-4 inline-flex items-center text-sm font-semibold text-lime-400 hover:text-lime-300 transition">
            View all integrations →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FCA Compliance section -->
  <section class="py-16 sm:py-20 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-10">FCA-Ready for Mortgage Brokers</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          { icon: '🔒', title: 'MCOB-Compliant Recording', desc: 'All calls recorded and encrypted in transit and at rest using AES-256. Satisfies FCA MCOB requirements for mortgage advice call recording with configurable 5-year minimum retention.' },
          { icon: '📋', title: 'Consumer Duty Audit Trail', desc: 'Every interaction — call, WhatsApp, callback request — timestamped and logged. Provides evidence of compliant advice delivery and good consumer outcomes for FCA Consumer Duty.' },
          { icon: '📄', title: 'Data Processing Agreements', desc: 'We sign DPAs with all mortgage broker customers as standard. GDPR-compliant data handling with clearly defined controller/processor responsibilities for FCA-authorised firms.' },
        ].map(item => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 text-center">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-dark-400">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-dark-500">
        LimeCall is trusted by mortgage brokers and financial advisers across 40+ countries. <a href="/gdpr/" class="text-lime-400 hover:text-lime-300 transition">Read our compliance documentation →</a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(item => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <summary class="flex cursor-pointer items-center justify-between font-semibold text-white list-none">
              {item.name}
              <span class="ml-4 shrink-0 text-lime-400 group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <p class="mt-4 text-sm text-dark-400 leading-relaxed">{item.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-gradient-to-br from-lime-500/10 to-dark-900 border-t border-lime-500/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Stop Losing Mortgage Leads to Faster Brokers</h2>
      <p class="mt-4 text-lg text-dark-300">14-day free trial · FCA-compliant recording · No setup fee</p>
      <a href="/signup" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-lime-500 px-10 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
        Try Free — 14 Days →
      </a>
      <p class="mt-4 text-xs text-dark-500">No credit card required · Cancel anytime · Full onboarding support included</p>
    </div>
  </section>

  <!-- Cross-links -->
  <div class="py-12 bg-dark-950 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Explore More" links={[
        { href: '/financial-services/', title: 'Financial Services Callback', desc: 'Callback software for financial advisers.' },
        { href: '/salesforce-integration/', title: 'Salesforce Integration', desc: 'Auto-log every mortgage callback in Salesforce.' },
        { href: '/lead-routing-software/', title: 'Lead Routing Software', desc: 'Route enquiries to the right mortgage adviser.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Plans from $35/month.' },
      ]} />
    </div>
  </div>
</Base>
