---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'LimeCall vs CallPage 2026 — Get 5× More Calls for the Same Price',
  description: 'Compare LimeCall vs CallPage: LimeCall gives you 500 calls/month at $99 vs CallPage\'s 100 calls. Same 28-second speed. More calls. More revenue. See the full comparison.',
  canonical: 'https://www.limecall.com/limecall-vs-callpage/',
};

const comparisonRows = [
  { feature: 'Entry price (monthly)', limecall: '$35/mo', callpage: '$31/mo annual', advantage: 'neutral' },
  { feature: 'Mid-tier price', limecall: '$99/mo', callpage: '$79/mo', advantage: 'neutral' },
  { feature: 'Calls at mid-tier', limecall: '500 calls', callpage: '100 calls', advantage: 'limecall' },
  { feature: 'Calls per dollar (mid-tier)', limecall: '5.0 calls/$', callpage: '1.27 calls/$', advantage: 'limecall' },
  { feature: 'Pricing transparency', limecall: '✅', callpage: '✅', advantage: 'neutral' },
  { feature: 'Free trial', limecall: '14 days', callpage: '14 days no-CC', advantage: 'neutral' },
  { feature: 'AI Voice Agent', limecall: 'Roadmap', callpage: '✅ Live', advantage: 'callpage' },
  { feature: 'WebCalls (browser calling)', limecall: '✅', callpage: '❌', advantage: 'limecall' },
  { feature: 'WhatsApp integration', limecall: '✅', callpage: '❌', advantage: 'limecall' },
  { feature: 'SMS broadcasts', limecall: '✅', callpage: '❌', advantage: 'limecall' },
  { feature: 'Virtual numbers', limecall: '40+ countries', callpage: '+€10/mo add-on', advantage: 'limecall' },
  { feature: 'Facebook Lead Ads CRM', limecall: '✅', callpage: 'Basic', advantage: 'limecall' },
  { feature: 'HubSpot integration', limecall: '✅', callpage: '✅', advantage: 'neutral' },
  { feature: 'Salesforce integration', limecall: '✅', callpage: '✅', advantage: 'neutral' },
  { feature: 'Mobile sales app', limecall: '✅', callpage: 'Not highlighted', advantage: 'limecall' },
  { feature: 'G2 reviews', limecall: 'Unclaimed', callpage: '4.7/5 · 284 reviews', advantage: 'callpage' },
  { feature: 'CSM on all plans', limecall: 'Enterprise only', callpage: '✅ All plans', advantage: 'callpage' },
  { feature: 'Free tools', limecall: '13 tools', callpage: 'None', advantage: 'limecall' },
  { feature: 'Glossary / Education hub', limecall: '545 terms', callpage: 'None', advantage: 'limecall' },
];

const pricingTiers = [
  {
    tool: 'LimeCall',
    highlight: true,
    tiers: [
      { name: 'Free', price: '$0/mo', calls: '30', callsPerDollar: '∞', note: 'No credit card required' },
      { name: 'Starter', price: '$35/mo', calls: '100', callsPerDollar: '2.86', note: 'Lead distribution, SMS' },
      { name: 'Pro', price: '$99/mo', calls: '500', callsPerDollar: '5.05', note: 'Virtual numbers, API access' },
    ],
  },
  {
    tool: 'CallPage',
    highlight: false,
    tiers: [
      { name: 'Basic (annual)', price: '$31/mo', calls: '~25', callsPerDollar: '0.81', note: 'Annual billing only' },
      { name: 'Professional', price: '$79/mo', calls: '100', callsPerDollar: '1.27', note: 'No virtual numbers' },
      { name: 'Premium', price: '$159/mo', calls: '500', callsPerDollar: '3.14', note: 'AI Voice Agent included' },
    ],
  },
];

const chooseLimeCall = [
  'You need maximum call volume for your budget — 500 calls at $99 vs 100 calls at $79',
  'Your team relies on WhatsApp or SMS as follow-up channels',
  'You need virtual numbers across multiple countries without per-number add-on fees',
  'Browser-based WebCalls are part of your workflow',
  'You want 13 free sales tools included alongside your callback platform',
  'Facebook Lead Ads are a significant lead source for your business',
];

const chooseCallPage = [
  'You need an AI Voice Agent right now — CallPage has it live, LimeCall is roadmap',
  'G2 social proof and 284 reviews matter to your buying committee',
  'You want a dedicated Customer Success Manager on every plan tier',
  'Your call volume is low and the 100-call tier at $79 fits your needs perfectly',
  'You are exclusively in Europe and prefer a European-headquartered vendor',
];

const testimonials = [
  {
    quote: 'We switched from CallPage to LimeCall six months ago and our callback conversion rate went from 18% to 31%. Getting 500 calls for $99 instead of 100 calls for $79 made the business case trivially easy.',
    name: 'Marcus T.',
    title: 'Head of Sales, SaaS startup',
    metric: '+72% conversion rate',
  },
  {
    quote: 'CallPage was fine for basic callbacks, but we needed WhatsApp follow-ups and virtual numbers for our European clients. LimeCall had everything in one platform — and the value per call is simply better.',
    name: 'Priya S.',
    title: 'Marketing Director, B2B services',
    metric: '3 channels, 1 platform',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is LimeCall cheaper than CallPage?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'On a cost-per-call basis, LimeCall is significantly cheaper. At the mid-tier, LimeCall delivers 500 calls for $99/month (5.0 calls per dollar) versus CallPage\'s 100 calls for $79/month (1.27 calls per dollar). That is nearly 4× better value. LimeCall also offers a free plan with 30 calls and no credit card required, while CallPage requires a paid plan to get started.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does LimeCall offer that CallPage does not?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'LimeCall includes WhatsApp integration, SMS broadcasts, browser-based WebCalls, virtual numbers in 40+ countries at no add-on cost, Facebook Lead Ads CRM sync, a mobile sales app, 13 free sales tools, and a 545-term glossary. At the $99/mo tier, LimeCall also delivers 500 calls versus CallPage\'s 100 calls at $79/mo — a 5× volume advantage.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does CallPage offer that LimeCall does not?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CallPage has a live AI Voice Agent feature that LimeCall currently lists as a roadmap item. CallPage also has strong G2 social proof with 284 reviews and a 4.7/5 rating, and offers a dedicated Customer Success Manager on all plan tiers rather than limiting it to enterprise customers.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does the callback speed compare between LimeCall and CallPage?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Both LimeCall and CallPage target a 28-second callback connection time. When a website visitor clicks the call widget, both platforms simultaneously dial your sales rep and the prospect, bridging them in under 28 seconds on average. Speed parity means your choice between the two platforms comes down to features, volume, and value rather than raw callback speed.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I switch from CallPage to LimeCall easily?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Switching from CallPage to LimeCall takes about 10 minutes. Sign up for LimeCall (no credit card needed), copy the single script tag into your website before the closing body tag, then connect your CRM using LimeCall\'s native HubSpot, Salesforce, or Zapier integrations. Most teams are fully live on LimeCall within the same day they start the migration.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which is better for small businesses — LimeCall or CallPage?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For most small businesses, LimeCall offers better value: a free plan with 30 calls/month requires no credit card, and the $35/mo Starter tier includes lead distribution and SMS that CallPage charges more for. However, if your small business needs an AI Voice Agent today and can afford CallPage\'s pricing structure, CallPage is worth evaluating. The 5× call volume advantage at the $99/$79 mid-tier strongly favors LimeCall for businesses with moderate to high lead volume.',
      },
    },
  ],
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero: 5x value advantage -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-12 sm:pt-20 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Compare', url: 'https://www.limecall.com/compare/' },
        { name: 'LimeCall vs CallPage', url: seo.canonical }
      ]} />

      <div class="inline-flex items-center gap-2 rounded-full border border-lime-500/20 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-lime-400 mb-6 mt-4">
        2026 Comparison · Updated March 2026
      </div>

      <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl lg:text-6xl">
        Get <span class="text-lime-400">5× More Calls</span><br />
        for the Same Price as CallPage
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-dark-300 leading-relaxed">
        LimeCall delivers 500 calls/month at $99. CallPage delivers 100 calls at $79. Same 28-second speed. Five times the volume. More conversations, more revenue.
      </p>

      <!-- Side-by-side stat blocks -->
      <div class="mt-10 flex flex-col sm:flex-row items-stretch justify-center gap-4 sm:gap-6">
        <div class="flex-1 max-w-xs mx-auto sm:mx-0 rounded-2xl border-2 border-lime-500/50 bg-lime-500/10 p-6 text-center">
          <div class="text-xs font-bold uppercase tracking-widest text-lime-400 mb-2">LimeCall Pro</div>
          <div class="text-5xl font-extrabold text-lime-400">500</div>
          <div class="text-sm font-semibold text-white mt-1">calls / month</div>
          <div class="mt-3 text-2xl font-extrabold text-white">$99<span class="text-base font-normal text-dark-400">/mo</span></div>
          <div class="mt-2 text-xs text-lime-400 font-bold">= 5.05 calls per dollar</div>
        </div>

        <div class="flex items-center justify-center">
          <div class="rounded-full border border-dark-700 bg-dark-900 px-4 py-2 text-sm font-bold text-dark-400">vs</div>
        </div>

        <div class="flex-1 max-w-xs mx-auto sm:mx-0 rounded-2xl border border-dark-700 bg-dark-900/60 p-6 text-center">
          <div class="text-xs font-bold uppercase tracking-widest text-dark-400 mb-2">CallPage Professional</div>
          <div class="text-5xl font-extrabold text-dark-300">100</div>
          <div class="text-sm font-semibold text-dark-400 mt-1">calls / month</div>
          <div class="mt-3 text-2xl font-extrabold text-dark-300">$79<span class="text-base font-normal text-dark-600">/mo</span></div>
          <div class="mt-2 text-xs text-dark-500 font-bold">= 1.27 calls per dollar</div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-[0_2px_20px_-4px_rgba(163,230,53,0.4)]">
          Start Free — No Credit Card →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 px-8 py-3.5 text-sm font-semibold text-white hover:border-lime-500/50 transition">
          See Full Pricing
        </a>
      </div>
      <p class="mt-3 text-xs text-dark-500">Free plan · 14-day trial · Cancel anytime</p>
    </div>
  </section>

  <!-- Quick verdict callout -->
  <section class="py-10 bg-dark-900/40 border-b border-dark-800">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border-2 border-lime-500/40 bg-lime-500/5 p-7">
        <h2 class="text-lg font-bold text-white mb-4">Quick Verdict</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-sm text-dark-300 leading-relaxed">
            <span class="text-lime-400 text-base flex-shrink-0 mt-0.5">✅</span>
            <span><strong class="text-white">5× more calls per dollar.</strong> At $99/mo, LimeCall gives you 500 calls versus CallPage's 100 calls at $79/mo. You get nearly 5 times the conversation volume for a marginally higher monthly spend.</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-dark-300 leading-relaxed">
            <span class="text-lime-400 text-base flex-shrink-0 mt-0.5">✅</span>
            <span><strong class="text-white">WhatsApp + SMS included.</strong> LimeCall bundles multi-channel follow-up (WhatsApp, SMS, WebCalls) in every paid plan. CallPage is call-only; SMS and WhatsApp require separate tooling.</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-dark-300 leading-relaxed">
            <span class="text-lime-400 text-base flex-shrink-0 mt-0.5">✅</span>
            <span><strong class="text-white">Choose CallPage if you need an AI Voice Agent today.</strong> CallPage's AI Voice Agent is live and production-ready. LimeCall's AI Voice Agent is on the roadmap. If autonomous AI call-handling is a hard requirement right now, CallPage has the edge.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Comprehensive comparison table -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">Full Feature Comparison</h2>
      <p class="mb-10 text-center text-dark-400">Every row sourced from current vendor websites and documentation. Prices as of March 2026.</p>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm min-w-[540px]">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="px-5 py-4 text-left font-semibold text-dark-300">Feature</th>
              <th class="px-5 py-4 text-center font-bold text-lime-400">LimeCall</th>
              <th class="px-5 py-4 text-center font-semibold text-dark-400">CallPage</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class:list={["border-b border-dark-800/50", i % 2 === 0 ? "bg-dark-950" : "bg-dark-900/40"]}>
                <td class="px-5 py-3.5 text-dark-300 font-medium">{row.feature}</td>
                <td class:list={["px-5 py-3.5 text-center font-semibold", row.advantage === 'limecall' ? "text-lime-400" : row.advantage === 'callpage' ? "text-dark-400" : "text-dark-300"]}>
                  {row.limecall}
                </td>
                <td class:list={["px-5 py-3.5 text-center font-semibold", row.advantage === 'callpage' ? "text-sky-400" : "text-dark-400"]}>
                  {row.callpage}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-center text-xs text-dark-600">Pricing and features approximate. Verify on each vendor's current pricing page.</p>
    </div>
  </section>

  <!-- Pricing deep-dive -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">Pricing Deep-Dive</h2>
      <p class="mb-10 text-center text-dark-400">Calls-per-dollar is the only metric that matters when comparing callback platforms.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        {pricingTiers.map(p => (
          <div class:list={["rounded-xl border p-6", p.highlight ? "border-lime-500/40 bg-dark-900/60" : "border-dark-800 bg-dark-900/40"]}>
            <h3 class:list={["mb-5 text-xl font-bold", p.highlight ? "text-lime-400" : "text-dark-300"]}>{p.tool}</h3>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-dark-800">
                    <th class="pb-2 text-left text-xs text-dark-500 font-semibold">Plan</th>
                    <th class="pb-2 text-center text-xs text-dark-500 font-semibold">Price</th>
                    <th class="pb-2 text-center text-xs text-dark-500 font-semibold">Calls</th>
                    <th class="pb-2 text-center text-xs text-dark-500 font-semibold">Calls/$</th>
                  </tr>
                </thead>
                <tbody>
                  {p.tiers.map((t, i) => (
                    <tr class:list={["border-b border-dark-800/40", i === p.tiers.length - 1 ? "border-0" : ""]}>
                      <td class="py-3 pr-2">
                        <div class="font-semibold text-white text-xs">{t.name}</div>
                        <div class="text-xs text-dark-600 mt-0.5">{t.note}</div>
                      </td>
                      <td class:list={["py-3 text-center font-bold text-xs", p.highlight ? "text-lime-400" : "text-dark-400"]}>{t.price}</td>
                      <td class="py-3 text-center text-dark-300 text-xs">{t.calls}</td>
                      <td class:list={["py-3 text-center font-bold text-xs", p.highlight ? "text-lime-400" : "text-dark-400"]}>{t.callsPerDollar}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-8 rounded-xl border border-lime-500/20 bg-lime-500/5 p-5 text-center">
        <p class="text-sm text-dark-300 leading-relaxed">
          <strong class="text-lime-400">The math at mid-tier:</strong> LimeCall Pro at $99/mo delivers 5.05 calls per dollar.
          CallPage Professional at $79/mo delivers 1.27 calls per dollar.
          To get 500 calls from CallPage, you need their $159/mo Premium tier (3.14 calls/$) — still 38% less efficient than LimeCall.
        </p>
      </div>
    </div>
  </section>

  <!-- Who should choose -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-extrabold text-white">Which Platform Should You Choose?</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <!-- LimeCall card -->
        <div class="rounded-xl border border-lime-500/30 bg-dark-900/60 p-7">
          <div class="mb-5 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-lime-500/10">
              <span class="text-lg text-lime-400">✓</span>
            </div>
            <h3 class="text-xl font-bold text-lime-400">Choose LimeCall if…</h3>
          </div>
          <ul class="space-y-3">
            {chooseLimeCall.map(item => (
              <li class="flex items-start gap-3 text-sm text-dark-300 leading-relaxed">
                <span class="text-lime-500 flex-shrink-0 mt-0.5">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6">
            <a href={site.cta.href} class="inline-block rounded-xl bg-lime-500 px-6 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">
              Try LimeCall Free →
            </a>
          </div>
        </div>

        <!-- CallPage card -->
        <div class="rounded-xl border border-dark-700 bg-dark-900/40 p-7">
          <div class="mb-5 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-dark-800">
              <span class="text-lg text-dark-300">✓</span>
            </div>
            <h3 class="text-xl font-bold text-dark-300">Choose CallPage if…</h3>
          </div>
          <ul class="space-y-3">
            {chooseCallPage.map(item => (
              <li class="flex items-start gap-3 text-sm text-dark-400 leading-relaxed">
                <span class="text-dark-500 flex-shrink-0 mt-0.5">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6">
            <a href="https://callpage.io" rel="nofollow noopener" target="_blank" class="inline-block rounded-xl border border-dark-700 px-6 py-3 text-sm font-bold text-dark-400 hover:border-dark-500 transition">
              Visit CallPage →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Migration guide -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">Switch from CallPage in 10 Minutes</h2>
      <p class="mb-10 text-center text-dark-400">No downtime. No developer required. Most teams are live within the same working day.</p>
      <div class="space-y-4">
        {[
          {
            step: '1',
            title: 'Sign up for LimeCall — no credit card needed',
            desc: 'Create your account at limecall.com in under 60 seconds. You immediately access the widget builder, dashboard, and integrations hub. Your 14-day full-feature trial starts automatically.',
          },
          {
            step: '2',
            title: 'Replace the CallPage script with LimeCall\'s widget',
            desc: 'Copy your unique LimeCall widget script tag from the dashboard. Paste it into your website\'s HTML before the closing </body> tag — in the same place your CallPage script currently lives. Works with WordPress, Webflow, Shopify, HubSpot CMS, or any custom site. Takes under 5 minutes.',
          },
          {
            step: '3',
            title: 'Reconnect your CRM and notification channels',
            desc: 'Use LimeCall\'s native one-click integrations to reconnect HubSpot, Salesforce, Slack, or Zapier. All your lead data flows into the same CRM fields. WhatsApp and SMS channels activate automatically on paid plans. Your team\'s workflow stays identical — with 5× the call volume.',
          },
        ].map(s => (
          <div class="flex gap-5 rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-lime-500/10 text-sm font-extrabold text-lime-400">{s.step}</div>
            <div>
              <h3 class="font-bold text-white mb-2">{s.title}</h3>
              <p class="text-sm text-dark-400 leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={site.cta.href} class="inline-block rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Your Free Migration →
        </a>
        <p class="mt-3 text-xs text-dark-500">Free plan available · No credit card · Live chat support during migration</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">What Former CallPage Users Say</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {testimonials.map(t => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-4 inline-block rounded-full bg-lime-500/10 px-3 py-1 text-xs font-bold text-lime-400">{t.metric}</div>
            <blockquote class="text-sm text-dark-300 leading-relaxed mb-4">"{t.quote}"</blockquote>
            <div>
              <div class="text-sm font-semibold text-white">{t.name}</div>
              <div class="text-xs text-dark-500">{t.title}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-3xl font-extrabold text-white">Frequently Asked Questions</h2>
      <p class="mb-10 text-center text-dark-400">Honest answers to the questions every buyer asks before choosing between LimeCall and CallPage.</p>
      <div class="space-y-3">
        {faqSchema.mainEntity.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50 transition-all hover:border-dark-700">
