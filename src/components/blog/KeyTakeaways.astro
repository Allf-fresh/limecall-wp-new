---
interface Props {
  takeaways: string[];
}
const { takeaways } = Astro.props;
---

{takeaways.length > 0 && (
  <aside
    role="note"
    aria-label="Key Takeaways"
    class="mb-8 rounded-xl border border-lime-500/25 bg-lime-500/5 p-5 not-prose"
  >
    <p class="flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-lime-400 mb-3">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      Key Takeaways
    </p>
    <ul class="space-y-2.5 m-0 p-0 list-none">
      {takeaways.map((point) => (
        <li class="flex gap-2.5 text-sm text-dark-300 leading-relaxed">
          <svg class="w-4 h-4 text-lime-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
          <span>{point}</span>
        </li>
      ))}
    </ul>
  </aside>
)}
