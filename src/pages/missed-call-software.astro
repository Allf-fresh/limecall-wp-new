---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { faqSchema } from '../lib/seo';
import { site } from '../site.config';

const slug = "missed-call-software";

const seo = {
  title: `Missed Call Software — Auto-Callback in 28 Seconds | LimeCall`,
  description: `Never lose a missed call lead again. LimeCall automatically detects missed calls and calls the lead back in 28 seconds. SMS alerts, CRM logging, auto-queue included.`,
  canonical: `https://www.limecall.com/${slug}/`,
};

const faqs = [
  {
    question: `What is missed call software?`,
    answer: `Missed call software automatically detects when an inbound call goes unanswered and triggers an immediate follow-up action — typically an automated callback attempt to the missed caller within seconds, plus an SMS notification, CRM log entry, and an alert to the responsible sales agent. LimeCall's missed call software initiates the callback process within 28 seconds of a missed call, dramatically reducing the time between a missed lead and a live conversation.`,
  },
  {
    question: `Why does speed of follow-up matter for missed calls?`,
    answer: `Research consistently shows that the probability of qualifying an inbound lead drops by over 400% if the response time exceeds 5 minutes. When a prospect calls your business and nobody answers, they are almost certainly calling your competitor next. LimeCall's 28-second auto-callback system ensures your team reaches that caller before they find an alternative — turning a potential lost sale into a live conversation.`,
  },
  {
    question: `Does the missed call auto-callback work outside business hours?`,
    answer: `Yes. You can configure LimeCall to handle after-hours missed calls in multiple ways: auto-send an SMS to the caller acknowledging the missed call and promising a callback when the team is available, add the missed caller to a priority callback queue for when business hours resume, or use an automated voice response to collect the caller's details. This ensures no lead is permanently lost regardless of when they called.`,
  },
  {
    question: `Does LimeCall log missed calls in my CRM?`,
    answer: `Yes. Every missed call is automatically logged in your CRM — including the caller's number, the time of the missed call, the source (if call tracking is active), and the outcome of any subsequent auto-callback attempt. HubSpot, Salesforce, Pipedrive, and 50+ CRM integrations are supported. Your team has a complete record of every missed lead without any manual data entry.`,
  },
  {
    question: `Can I get SMS notifications for missed calls?`,
    answer: `Yes. LimeCall can send instant SMS notifications to one or multiple team members when a call is missed. The SMS includes the caller's number, the time of the call, and a direct link to call them back. This ensures the right person is immediately alerted — even if they were away from their desk when the call came in.`,
  },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema(faqs)} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Missed Call Software', url: seo.canonical }
      ]} />
      <div class="mt-4 text-5xl">📵</div>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Missed Call Software —<br /><span class="text-lime-400">Auto-Call Back Every Missed Lead in 28 Seconds</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Every missed call is a missed sale. LimeCall automatically detects unanswered calls and calls the lead back within 28 seconds — before they call your competitor.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm text-dark-400">
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Auto-callback in 28 seconds</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> SMS alerts to your team</span>
        <span class="flex items-center gap-1.5"><span class="text-lime-400">✓</span> Logged automatically in CRM</span>
      </div>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Stop Losing Missed Call Leads →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Problem section -->
  <section class="py-16 sm:py-20 bg-dark-950">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-3xl font-bold text-white">Missed calls = missed revenue</h2>
      <p class="text-dark-300 leading-relaxed mb-4">
        The average business misses between 22% and 40% of all inbound phone calls. These are not just missed conversations — they are missed leads, missed sales opportunities, and missed revenue actively leaving your business and going to a competitor who did pick up the phone.
      </p>
      <p class="text-dark-300 leading-relaxed mb-4">
        The research on speed-to-lead is unambiguous: responding to an inbound lead within 5 minutes makes you <strong class="text-white">100x more likely to connect</strong> than if you respond within 30 minutes. After an hour, the probability of ever reaching that lead drops to near zero. For missed calls specifically, the lead is already walking away — every second counts.
      </p>
      <p class="text-dark-300 leading-relaxed">
        LimeCall's missed call software solves this with automated detection and immediate callback. The moment a call goes unanswered, LimeCall triggers the callback queue, sends an SMS alert to your team, and logs the missed call in your CRM — all within 28 seconds of the missed call.
      </p>

      <!-- Stats -->
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 text-center">
          <div class="text-3xl font-bold text-lime-400">22–40%</div>
          <div class="mt-2 text-sm text-dark-400">of inbound calls go unanswered on average</div>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 text-center">
          <div class="text-3xl font-bold text-lime-400">100x</div>
          <div class="mt-2 text-sm text-dark-400">more likely to connect if you respond within 5 minutes</div>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 text-center">
          <div class="text-3xl font-bold text-lime-400">28 sec</div>
          <div class="mt-2 text-sm text-dark-400">LimeCall's average callback initiation time</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20 border-t border-dark-800 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">How LimeCall missed call software works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">1</div>
          <h3 class="mb-2 font-semibold text-white">Missed call detected</h3>
          <p class="text-sm text-dark-400 leading-relaxed">LimeCall monitors all inbound calls in real time. The instant a call goes unanswered — whether due to no agents available, after-hours, or a dropped ring — it is flagged automatically.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">2</div>
          <h3 class="mb-2 font-semibold text-white">Auto-callback triggered</h3>
          <p class="text-sm text-dark-400 leading-relaxed">LimeCall immediately adds the missed caller to the auto-callback queue. Within 28 seconds, LimeCall dials the caller and the next available agent simultaneously, connecting them the moment both pick up.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 border border-lime-500/20 text-lime-400 font-bold text-lg">3</div>
          <h3 class="mb-2 font-semibold text-white">Logged and alerted</h3>
          <p class="text-sm text-dark-400 leading-relaxed">The missed call, callback attempt, and outcome are all logged in your CRM. SMS alerts are sent to responsible team members. Nothing falls through the cracks.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">LimeCall missed call features</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-2xl">🔍</div>
          <h3 class="mb-2 font-semibold text-white">Missed call detection</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Real-time detection of every unanswered call across all your LimeCall numbers and routing rules. No missed calls slip through undetected.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-2xl">⚡</div>
          <h3 class="mb-2 font-semibold text-white">Auto-callback queue</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Missed callers are added to a priority callback queue instantly. LimeCall connects the lead and an available agent within 28 seconds — the fastest response in the industry.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-2xl">💬</div>
          <h3 class="mb-2 font-semibold text-white">SMS notification</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Instant SMS alerts are sent to your team when a call is missed. Each alert includes the caller's number, call time, and a one-tap link to call them back immediately.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-2xl">📋</div>
          <h3 class="mb-2 font-semibold text-white">CRM logging</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Every missed call, callback attempt, and outcome is automatically logged in HubSpot, Salesforce, Pipedrive, and 50+ CRM integrations. Zero manual entry required.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-2xl">🌙</div>
          <h3 class="mb-2 font-semibold text-white">After-hours handling</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Configure after-hours rules: auto-SMS the caller, schedule a next-day callback, collect their details via voicemail, or route to an emergency on-call agent.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-2xl">📊</div>
          <h3 class="mb-2 font-semibold text-white">Missed call reporting</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Dashboard reports on missed call volume, callback success rates, and average response times. Identify peak missed-call periods and optimise staffing accordingly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 sm:py-20 bg-dark-900/40 border-t border-dark-800">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Who needs missed call software?</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🏡</div>
          <h3 class="mb-2 font-semibold text-white">Real estate</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Property enquiries have an extremely short decision window. A missed call from a motivated buyer that goes unanswered for 10 minutes is often a permanently lost deal.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">🏥</div>
          <h3 class="mb-2 font-semibold text-white">Healthcare</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Patients who cannot reach a clinic call the next one on Google. Auto-callback keeps your practice competitive and reduces new patient acquisition costs.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">⚖️</div>
          <h3 class="mb-2 font-semibold text-white">Legal services</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Legal leads are high-value and time-sensitive. A law firm that calls back within 28 seconds closes dramatically more new client consultations than one that returns calls hours later.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-950 p-6">
          <div class="mb-3 text-2xl">💼</div>
          <h3 class="mb-2 font-semibold text-white">B2B sales teams</h3>
          <p class="text-sm text-dark-400 leading-relaxed">B2B buyers who call in are often in active evaluation mode. Auto-callback ensures your sales team talks to every inbound prospect before they move on in their buying process.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group rounded-xl border border-dark-800 bg-dark-900/50">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium text-white select-none">
              {faq.question}
              <svg class="h-4 w-4 flex-shrink-0 ml-4 text-dark-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed text-dark-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Stop losing missed call leads today</h2>
      <p class="mt-4 text-dark-400">LimeCall detects every missed call and calls the lead back in 28 seconds. Set up takes less than 10 minutes and works with your existing phone numbers.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Related features"
      links={[
        { href: '/click-2-call/', title: 'Click-to-Call', desc: 'Connect visitors in 28 seconds.' },
        { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'Respond to leads instantly.' },
        { href: '/inbound-call-tracking/', title: 'Inbound Call Tracking', desc: 'Know which campaigns drive calls.' },
        { href: '/virtual-pbx/', title: 'Virtual PBX', desc: 'Cloud PBX for modern teams.' },
        { href: '/pricing/', title: 'Pricing', desc: 'See all LimeCall plans.' },
      ]}
    />
  </div>
</Base>
