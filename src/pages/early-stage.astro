---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: `LimeCall for Early-Stage Startups — Grow Faster From Day One`,
  description: `LimeCall helps early-stage startups convert website visitors into sales calls instantly. Free plan available, 5-minute setup, no CRM required.`,
  canonical: `https://www.limecall.com/early-stage/`,
};

const stats = [
  { value: 'Free', label: 'Plan available' },
  { value: '5 min', label: 'Setup time' },
  { value: '28s', label: 'Callback speed' },
  { value: '10k+', label: 'Companies started here' },
];

const freeFeatures = [
  '1 callback widget on your website',
  '30 calls per month included',
  'Click-to-call button for instant connections',
  'Scheduled callback booking',
  'Email support and documentation',
  'No credit card required to start',
];

const upgradeFeatures = [
  'Unlimited widgets across all pages',
  'Lead distribution to multiple team members',
  'CRM integrations (HubSpot, Salesforce, Zoho)',
  'SMS notifications and follow-ups',
  'Call recording and transcription',
  'Virtual phone numbers in 50+ countries',
];

const whyItMatters = [
  {
    title: 'Speed-to-lead at seed stage',
    desc: 'At seed stage, every demo counts. When a potential customer raises their hand on your site, you have minutes — not hours — to respond. LimeCall connects your team with that lead in under 28 seconds, before they click on a competitor.',
    icon: '⚡',
  },
  {
    title: 'Investor-ready metrics',
    desc: 'Raise your next round with data, not anecdotes. LimeCall gives you clean call analytics, response time metrics, and conversion data that impresses investors and validates your go-to-market motion.',
    icon: '📈',
  },
  {
    title: 'No CRM? No problem',
    desc: 'Most early-stage startups do not have a CRM in place yet — and that is fine. LimeCall\'s CRM-free mode logs every call in a simple dashboard so you never lose a lead, with CRM integrations ready when you need them.',
    icon: '🗂️',
  },
  {
    title: 'Built for lean teams',
    desc: 'Whether it is just the founders on calls or a 3-person BDR team, LimeCall routes leads intelligently and never lets one fall through the cracks. Grow your team without changing your setup.',
    icon: '👥',
  },
];

const features = [
  {
    title: 'Simple 5-Minute Setup',
    desc: 'Paste one line of JavaScript on your site and your callback widget is live. No developer, no lengthy onboarding, no professional services required. Most startups are taking calls within the hour.',
    icon: '🚀',
  },
  {
    title: 'CRM-Free Mode',
    desc: 'Track every lead and call directly inside LimeCall without connecting an external CRM. When you are ready to scale, plug in HubSpot, Salesforce, Zoho, or Pipedrive with a few clicks.',
    icon: '📋',
  },
  {
    title: 'Widget + Phone Number',
    desc: 'Get a local virtual phone number alongside your website widget. Your startup looks established and professional from day one — without the cost and complexity of a legacy phone system.',
    icon: '📞',
  },
];

const testimonials = [
  {
    quote: 'We launched our MVP and put LimeCall on the site the same day. Within a week we had our first 10 paying customers, all from inbound calls. The 28-second callback was the difference.',
    name: 'Priya S.',
    role: 'Co-Founder, B2B SaaS startup (Seed stage)',
  },
  {
    quote: 'I was handling every sales call myself as the founder. LimeCall made it so I never missed a lead, even at 11pm. The call recordings helped me perfect my pitch in the first 30 days.',
    name: 'James T.',
    role: 'Founder, E-commerce startup (Pre-seed)',
  },
];

const faqs = [
  {
    q: 'Is LimeCall really free for early-stage startups?',
    a: 'Yes. LimeCall\'s Basic plan is permanently free — not a trial. It includes 1 widget and 30 calls per month with no credit card required. This is designed specifically for early-stage teams that need to validate their sales motion before committing to paid tooling.',
  },
  {
    q: 'What are the limits of the free plan?',
    a: 'The free Basic plan includes 1 website widget and 30 calls per month. It includes Click-to-Call and scheduled callbacks. Lead distribution, virtual numbers, SMS, and CRM integrations are available on paid plans starting at $29/month.',
  },
  {
    q: 'Can I scale up as my startup grows?',
    a: 'Absolutely. LimeCall plans scale from free to Starter ($29/month) to Pro ($99/month) as your call volume and team size grow. There is no migration or data loss when you upgrade — everything carries over seamlessly.',
  },
  {
    q: 'Do I need a CRM to use LimeCall?',
    a: 'No. LimeCall\'s built-in dashboard tracks all your leads and calls without any external CRM. When you are ready to integrate with HubSpot, Salesforce, Zoho, or Pipedrive, it takes less than 5 minutes to connect.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: 'Early-Stage Startups', url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        For Startups
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Grow faster from<br class="hidden sm:block" />
        <span class="text-lime-400">day one</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        The free callback widget that connects your startup with every inbound lead in under 28 seconds. Start free — no credit card, no developer, no CRM required.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Start Free — No Card Needed →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          See All Plans
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What you get -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white sm:text-3xl">What you get — free, forever</h2>
      <p class="mb-12 text-center text-dark-400 max-w-xl mx-auto">Start with zero cost and scale when your startup does.</p>
      <div class="grid gap-8 sm:grid-cols-2">
        <div class="rounded-2xl border border-lime-500/30 bg-dark-900/60 p-7">
          <h3 class="mb-5 text-lg font-semibold text-lime-400">Free plan includes</h3>
          <ul class="space-y-3">
            {freeFeatures.map(f => (
              <li class="flex items-start gap-3 text-sm text-dark-300">
                <span class="mt-0.5 text-lime-400 font-bold shrink-0">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <div class="mt-6">
            <a href={site.cta.href} class="inline-block rounded-xl bg-lime-500 px-6 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">
              Start Free →
            </a>
          </div>
        </div>
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
          <h3 class="mb-5 text-lg font-semibold text-white">Upgrade path when you scale</h3>
          <ul class="space-y-3">
            {upgradeFeatures.map(f => (
              <li class="flex items-start gap-3 text-sm text-dark-300">
                <span class="mt-0.5 text-dark-500 font-bold shrink-0">+</span>
                {f}
              </li>
            ))}
          </ul>
          <div class="mt-6">
            <a href="/pricing/" class="inline-block rounded-xl border border-dark-700 bg-dark-800 px-6 py-3 text-sm font-bold text-white hover:border-lime-500/40 transition">
              View Pricing →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why it matters -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white sm:text-3xl">Why speed-to-lead matters at seed stage</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {whyItMatters.map(w => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7">
            <div class="mb-3 text-2xl">{w.icon}</div>
            <h3 class="mb-2 font-semibold text-white">{w.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white sm:text-3xl">Built for early-stage teams</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-3 text-2xl">{f.icon}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="border-t border-dark-800 bg-dark-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Founders who started with LimeCall</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {testimonials.map(t => (
          <figure class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 flex flex-col">
            <blockquote class="flex-1 text-sm text-dark-300 leading-relaxed">
              <span class="text-2xl text-lime-500 font-bold leading-none">"</span>
              {t.quote}
            </blockquote>
            <figcaption class="mt-5 border-t border-dark-800 pt-4">
              <div class="font-semibold text-white text-sm">{t.name}</div>
              <div class="text-xs text-dark-500 mt-0.5">{t.role}</div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="font-semibold text-white mb-2">{f.q}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="text-3xl font-bold text-white">Start converting leads from day one</h2>
      <p class="mt-4 text-dark-400">Free plan available · No credit card · 5-minute setup</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-10 py-4 font-bold text-dark-950 hover:bg-lime-400 transition">
          Start Free Trial →
        </a>
        <a href="/how-it-works/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-4 font-bold text-white hover:border-lime-500/40 transition">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Cross links -->
  <div class="py-8 border-t border-dark-800">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <CrossLinks heading="Related resources" links={[
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent plans — including a free tier for startups.' },
        { href: '/for-sales-teams/', title: 'For Sales Teams', desc: 'Tools to help your sales team close more deals, faster.' },
        { href: '/speed-to-lead/', title: 'Speed to Lead', desc: 'Why responding in under 28 seconds makes all the difference.' },
        { href: '/integrations/', title: 'Integrations', desc: 'Connect LimeCall to your CRM, Slack, Zapier and more.' },
      ]} />
    </div>
  </div>
</Base>
