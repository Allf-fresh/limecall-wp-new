---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../site.config';

const seo = {
  title: `Lead Routing Software — Route Every Lead Instantly | LimeCall`,
  description: `LimeCall's lead routing software connects website visitors to the right sales rep in seconds. Smart routing rules, instant callback, and real-time distribution.`,
  canonical: `https://www.limecall.com/lead-routing-software/`,
};

const features = [
  { title: "Rules-Based Routing", desc: "Route leads based on location, lead source, form data, or any custom criteria. The right rep gets every lead." },
  { title: "Round-Robin Distribution", desc: "Distribute leads evenly across your sales team. Fair allocation with automatic failover if a rep is unavailable." },
  { title: "Skills-Based Routing", desc: "Match leads to reps based on expertise, language, product knowledge, or territory for better conversion rates." },
  { title: "Availability Routing", desc: "Route only to available reps. If a rep is busy or offline, the lead goes to the next available team member." },
  { title: "Instant Callback Trigger", desc: "When a lead is captured, LimeCall triggers an instant callback — connecting the lead to the right rep in under 28 seconds." },
  { title: "Routing Analytics", desc: "Track how leads are routed, which reps get the most leads, and how routing rules affect conversion rates." },
];

const steps = [
  { n: "1", title: "Set your routing rules", desc: "Define who gets which leads based on territory, product, source, or any custom field." },
  { n: "2", title: "Lead arrives", desc: "A visitor submits a form, clicks to call, or requests a callback on your website." },
  { n: "3", title: "Routed and connected", desc: "LimeCall applies your routing rules and connects the lead to the right rep in seconds." },
];
---

<Base {...seo}>
  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ name: "Lead Routing Software", url: seo.canonical }]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-sm font-medium text-lime-400">
        Lead Routing Software
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Route Every Lead to the <span class="text-lime-400">Right Rep, Instantly</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Stop losing leads to slow routing. LimeCall's lead routing software connects website visitors to the right sales rep in seconds, automatically — based on your custom rules.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 transition hover:bg-lime-400 shadow-lg">
          Start Free Trial →
        </a>
        <a href="/pricing/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white transition hover:border-lime-500/40">
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Smart lead routing, every time</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">How lead routing works</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {steps.map(s => (
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-lime-500/10 text-lime-400 font-bold text-lg border border-lime-500/20">{s.n}</div>
            <h3 class="mb-2 font-semibold text-white">{s.title}</h3>
            <p class="text-sm text-dark-400">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-dark-800 py-16 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Never route a lead to the wrong rep again</h2>
      <p class="mt-4 text-dark-400">Set up LimeCall's lead routing in minutes. Start connecting leads to the right reps instantly.</p>
      <a href={site.cta.href} class="mt-8 inline-block rounded-xl bg-lime-500 px-10 py-4 text-base font-bold text-dark-950 transition hover:bg-lime-400">
        Start Free Trial →
      </a>
    </div>
  </section>

  <div class="py-8">
    <CrossLinks
      heading="Explore More"
      links={[
        { href: '/instant-lead-routing/', title: 'Instant Lead Routing', desc: 'Route leads in real time.' },
        { href: '/automatic-lead-distribution/', title: 'Auto Lead Distribution', desc: 'Automatically distribute leads.' },
        { href: '/lead-distribution/', title: 'Lead Distribution', desc: 'Full lead distribution feature.' },
        { href: '/pricing/', title: 'Pricing', desc: 'Simple, transparent pricing.' },
      ]}
    />
  </div>
</Base>
