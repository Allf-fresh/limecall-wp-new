---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const seo = {
  title: 'AI Voice Agent: Smart Call Center & Answering Service | LimeCall',
  description: 'LimeCall\'s AI voice agent replaces your traditional ai call center and ai answering service — qualifying leads, booking meetings, and connecting prospects 24/7. Start free.',
  canonical: 'https://www.limecall.com/ai-voice-agent/',
};

const stats = [
  { value: '24/7', label: 'Always-on lead qualification' },
  { value: '28s', label: 'Avg time to connect qualified lead' },
  { value: '3×', label: 'More leads converted vs voicemail' },
  { value: '90%', label: 'Leads qualified without rep' },
];

const features = [
  { icon: '🤖', title: 'Natural Voice Conversations', desc: 'AI handles objections, answers FAQs, and qualifies leads in real voice — indistinguishable from a human opener.' },
  { icon: '⚡', title: 'Instant Hot-Lead Transfer', desc: 'When AI scores a lead as sales-ready, your rep is connected in 28 seconds flat.' },
  { icon: '📅', title: 'Automatic Meeting Booking', desc: 'AI schedules calls directly into rep calendars. No back-and-forth, no no-shows.' },
  { icon: '🎯', title: 'Custom Qualification Scripts', desc: 'Define your BANT or MEDDIC criteria; the AI follows your playbook exactly.' },
  { icon: '📊', title: 'Full Call Transcripts', desc: 'Every AI conversation logged, scored, and synced to your CRM automatically.' },
  { icon: '🕐', title: 'After-Hours Coverage', desc: 'Capture and qualify leads at 2am; follow up with context first thing in the morning.' },
];

const useCases = [
  { title: 'Inbound Demo Requests', desc: 'AI qualifies intent and budget before routing to AE — only warm leads reach your team.' },
  { title: 'Website Chat-to-Call', desc: 'Visitor asks a question; AI transitions to voice and qualifies before connecting to a rep.' },
  { title: 'After-Hours Lead Capture', desc: 'No lead falls through because a rep was offline. AI handles nights and weekends.' },
  { title: 'High-Volume Ad Campaigns', desc: 'Run paid ads 24/7; AI handles the surge without adding headcount.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is an AI voice agent for sales?',
      acceptedAnswer: { '@type': 'Answer', text: 'An AI voice agent is software that uses natural language processing to engage inbound leads in real voice conversations — qualifying them, answering questions, and booking meetings or transferring hot prospects to human reps, without requiring a live salesperson to be available.' }
    },
    {
      '@type': 'Question',
      name: 'How is LimeCall\'s AI agent different from a chatbot?',
      acceptedAnswer: { '@type': 'Answer', text: 'LimeCall\'s AI agent operates via voice (phone call), not text chat. It can engage in natural spoken conversations, qualify leads verbally, and instantly bridge a hot lead to a live rep in 28 seconds — something a chatbot cannot do.' }
    },
    {
      '@type': 'Question',
      name: 'Can the AI voice agent replace my sales reps?',
      acceptedAnswer: { '@type': 'Answer', text: 'No — the AI agent is a qualification and routing layer, not a closer. It handles the first-touch qualification (budget, timeline, need) and instantly transfers sales-ready leads to your human reps so they can close. Your reps spend 100% of their time on qualified conversations.' }
    },
    {
      '@type': 'Question',
      name: 'How does the AI qualify leads before transferring to a rep?',
      acceptedAnswer: { '@type': 'Answer', text: 'You define your qualification criteria (BANT, MEDDIC, or custom questions) in the LimeCall dashboard. The AI asks these questions in natural conversation, scores the lead in real-time, and only bridges to a rep when the threshold is met. Unqualified leads get a scheduled callback or nurture sequence.' }
    },
    {
      '@type': 'Question',
      name: 'Does the AI voice agent work with my CRM?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. LimeCall integrates with HubSpot, Salesforce, Pipedrive, and 1,000+ tools via Zapier. Every AI conversation — transcript, qualification score, contact details — is synced automatically to your CRM.' }
    },
    {
      '@type': 'Question',
      name: 'How quickly can I set up an AI voice agent?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most teams are live within 5 minutes. Add the LimeCall widget to your website, define your qualification script in the dashboard, and the AI agent is active. No engineering, no long implementation projects.' }
    },
    {
      '@type': 'Question',
      name: 'What is an AI call center?',
      acceptedAnswer: { '@type': 'Answer', text: 'An AI call center uses artificial intelligence — including voice agents, natural language processing, and real-time lead scoring — to handle inbound and outbound calls without requiring a large team of human agents. LimeCall\'s AI call center solution manages qualification, routing, and meeting booking at a fraction of the cost of traditional call center infrastructure.' }
    },
    {
      '@type': 'Question',
      name: 'How does an AI answering service work?',
      acceptedAnswer: { '@type': 'Answer', text: 'An AI answering service uses natural language understanding to greet callers, understand their intent, answer common questions, and route them to the right department or person — all without a human operator. Unlike legacy IVR systems, an AI answering service holds natural conversations, operates 24/7 without shift scheduling, and supports multiple languages out of the box.' }
    },
    {
      '@type': 'Question',
      name: 'AI voice agent vs IVR — what\'s the difference?',
      acceptedAnswer: { '@type': 'Answer', text: 'Traditional IVR (Interactive Voice Response) forces callers through rigid menu trees using keypad presses ("press 1 for sales"). An AI voice agent understands natural speech, holds dynamic conversations, and adapts to caller intent in real time. The result is faster resolution, higher caller satisfaction, and significantly more qualified leads reaching your sales team.' }
    },
  ],
};

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: seo.title,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.hero-speakable', '.features-speakable'],
  },
  url: seo.canonical,
};
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={speakableSchema} />

  <!-- Hero -->
  <section class="hero-speakable relative overflow-hidden bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumbs items={[{ name: 'AI Voice Agent', url: `${site.url}/ai-voice-agent/` }]} />
      <div class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-500/10 border border-lime-500/20 px-4 py-1.5 text-xs font-semibold text-lime-400">
        🤖 AI-Powered Lead Qualification
      </div>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        AI Voice Agent for Sales<br class="hidden sm:block" />
        <span class="text-lime-400">That Never Sleeps</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-dark-300">
        Qualify leads, book meetings, and connect hot prospects to your team in 28 seconds — 24/7, even when your reps are off the clock.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/signup" class="inline-flex items-center justify-center gap-2 rounded-xl bg-lime-500 px-8 py-4 text-sm font-bold text-dark-950 shadow-[0_2px_20px_-4px_rgba(163,230,53,0.5)] transition hover:bg-lime-400">
          Start Free — No Credit Card
        </a>
        <a href="/demo/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-dark-700 px-8 py-4 text-sm font-semibold text-white transition hover:border-lime-500/40 hover:text-lime-400">
          See It in Action →
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">★ 4.5 · 10,000+ sales teams · Responds in 28 seconds</p>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-y border-dark-800 bg-dark-900/60">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map(s => (
          <div class="text-center">
            <dt class="text-3xl font-extrabold text-lime-400">{s.value}</dt>
            <dd class="mt-1 text-sm text-dark-400">{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- How the AI Agent Works -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">How LimeCall's AI Voice Agent Works</h2>
        <p class="mt-4 text-lg text-dark-300 max-w-2xl mx-auto">Three steps from visitor to qualified conversation — all automatic, all instant.</p>
      </div>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { step: '01', title: 'Visitor Arrives on Your Site', desc: 'AI widget engages — asking qualifying questions via natural voice or text. No forms. No friction.' },
          { step: '02', title: 'AI Qualifies in Real-Time', desc: 'Scores intent, collects name/company/need, filters out tire-kickers based on your custom criteria.' },
          { step: '03', title: 'Hot Lead Connected in 28s', desc: 'Qualified prospect instantly bridged to available rep. Unqualified leads get a scheduled callback.' },
        ].map(item => (
          <div class="relative rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-lime-500/10 text-lime-400 font-extrabold text-lg">{item.step}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-dark-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="features-speakable py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Everything Your AI Agent Does for You</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map(f => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-dark-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">Where Teams Deploy AI Voice Agents</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {useCases.map(u => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="font-bold text-white mb-2">{u.title}</h3>
            <p class="text-sm text-dark-400">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI vs Traditional Comparison -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">AI Voice Agent vs. Traditional Options</h2>
      <div class="overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              {['Feature', 'LimeCall AI Agent', 'Voicemail', 'Live Chat', 'Contact Form'].map(h => (
                <th class={`px-5 py-4 text-left font-semibold ${h === 'LimeCall AI Agent' ? 'text-lime-400' : 'text-dark-300'}`}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            {[
              ['Response time', '28 seconds', 'Whenever rep checks', 'Depends on agent', '1–48 hours'],
              ['Qualification depth', '✅ Full BANT/MEDDIC', '❌ None', '⚠️ Text only', '❌ None'],
              ['After-hours coverage', '✅ 24/7', '✅ Records message', '❌ No agent', '✅ Accepts form'],
              ['CRM sync', '✅ Automatic', '❌ Manual entry', '⚠️ Limited', '⚠️ Limited'],
              ['Lead scoring', '✅ Real-time', '❌ None', '❌ None', '❌ None'],
              ['Cost per qualified lead', '💚 Low', '⚠️ High (rep time)', '⚠️ Medium', '🔴 Very high (drop-off)'],
            ].map(([feature, ...vals]) => (
              <tr class="hover:bg-dark-800/30 transition">
                <td class="px-5 py-4 font-medium text-dark-200">{feature}</td>
                {vals.map((v, i) => (
                  <td class={`px-5 py-4 ${i === 0 ? 'text-white font-semibold' : 'text-dark-400'}`}>{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Industry Applications -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">AI Voice Agents Across Every Industry</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          { industry: 'Real Estate', icon: '🏠', desc: 'AI qualifies buyer intent, budget range, and timeline before connecting to an agent — so every call is a serious buyer.' },
          { industry: 'Healthcare', icon: '🏥', desc: 'AI screens appointment requests, insurance details, and urgency level before routing to the correct department.' },
          { industry: 'E-Commerce', icon: '🛒', desc: 'AI handles product questions, qualifies purchase intent, and bridges high-value buyers to a sales rep before they abandon cart.' },
        ].map(item => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="text-lg font-bold text-white mb-3">{item.industry}</h3>
            <p class="text-sm text-dark-400">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl text-center mb-12">What Sales Leaders Say</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {[
          { quote: 'Our reps used to spend 60% of their time chasing unqualified leads. Since deploying LimeCall\'s AI agent, they only touch pre-qualified prospects. Pipeline quality went up 3×.', name: 'Marcus T.', role: 'VP of Sales, SaaS Platform, 120 reps' },
          { quote: 'The after-hours coverage alone paid for itself in the first week. We were losing European leads at 5pm EST. Now the AI qualifies them overnight and our team has warm leads waiting every morning.', name: 'Sarah L.', role: 'Sales Director, B2B Services' },
        ].map(t => (
          <blockquote class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
            <p class="text-dark-200 italic leading-relaxed">"{t.quote}"</p>
            <footer class="mt-6">
              <p class="font-bold text-white">{t.name}</p>
              <p class="text-sm text-dark-500">{t.role}</p>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- AI Voice Agent as Your Call Center -->
  <section class="py-16 sm:py-24 bg-dark-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">AI Voice Agent as Your Call Center</h2>
        <p class="mt-4 text-lg text-dark-300 max-w-2xl mx-auto">Replace expensive call center infrastructure with an AI call center that scales instantly and costs a fraction of the price.</p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2">
        <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
          <h3 class="text-lg font-bold text-white mb-4">Traditional Call Center Costs</h3>
          <ul class="space-y-3 text-sm text-dark-400">
            <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">&#10007;</span> Hiring, training, and managing live agents</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">&#10007;</span> Office space, telephony infrastructure, software licences</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">&#10007;</span> Shift scheduling, overtime, and attrition</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">&#10007;</span> Inconsistent quality across agents and shifts</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-lime-500/30 bg-dark-900/60 p-8">
          <h3 class="text-lg font-bold text-lime-400 mb-4">LimeCall AI Call Center</h3>
          <ul class="space-y-3 text-sm text-dark-400">
            <li class="flex items-start gap-2"><span class="text-lime-400 mt-0.5">&#10003;</span> Flat-rate pricing from $57/mo — no per-agent fees</li>
            <li class="flex items-start gap-2"><span class="text-lime-400 mt-0.5">&#10003;</span> Handle 500+ concurrent calls without adding headcount</li>
            <li class="flex items-start gap-2"><span class="text-lime-400 mt-0.5">&#10003;</span> Consistent qualification — AI follows your script perfectly every time</li>
            <li class="flex items-start gap-2"><span class="text-lime-400 mt-0.5">&#10003;</span> Zero ramp-up: deploy in minutes, not months</li>
          </ul>
        </div>
      </div>
      <div class="mt-10 overflow-x-auto rounded-2xl border border-dark-700">
        <table class="w-full text-sm">
          <thead class="bg-dark-800/80">
            <tr>
              <th class="px-5 py-4 text-left font-semibold text-dark-300">Metric</th>
              <th class="px-5 py-4 text-center font-semibold text-dark-300">Traditional Call Center</th>
              <th class="px-5 py-4 text-center font-semibold text-lime-400">LimeCall AI Call Center</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800">
            <tr class="hover:bg-dark-800/30 transition">
              <td class="px-5 py-4 font-medium text-dark-200">Cost per agent hour</td>
              <td class="px-5 py-4 text-center text-dark-400">$15 – $25</td>
              <td class="px-5 py-4 text-center text-white font-semibold">$57/mo flat</td>
            </tr>
            <tr class="hover:bg-dark-800/30 transition">
              <td class="px-5 py-4 font-medium text-dark-200">Concurrent call capacity</td>
              <td class="px-5 py-4 text-center text-dark-400">Limited by headcount</td>
              <td class="px-5 py-4 text-center text-white font-semibold">500+ simultaneous</td>
            </tr>
            <tr class="hover:bg-dark-800/30 transition">
              <td class="px-5 py-4 font-medium text-dark-200">Availability</td>
              <td class="px-5 py-4 text-center text-dark-400">Shift-dependent</td>
              <td class="px-5 py-4 text-center text-white font-semibold">24/7/365</td>
            </tr>
            <tr class="hover:bg-dark-800/30 transition">
              <td class="px-5 py-4 font-medium text-dark-200">Script compliance</td>
              <td class="px-5 py-4 text-center text-dark-400">Variable (human error)</td>
              <td class="px-5 py-4 text-center text-white font-semibold">100% every call</td>
            </tr>
            <tr class="hover:bg-dark-800/30 transition">
              <td class="px-5 py-4 font-medium text-dark-200">Time to scale</td>
              <td class="px-5 py-4 text-center text-dark-400">Weeks to months</td>
              <td class="px-5 py-4 text-center text-white font-semibold">Instant</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-6 text-sm text-dark-400 text-center max-w-2xl mx-auto">
        An AI call center does not mean eliminating your human team. It means freeing them from repetitive qualification calls so they can focus on closing deals and building relationships with high-value accounts.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        {[
          { title: 'No Bad Days', desc: 'Your AI call center agent delivers the same quality on call 1 and call 500. No fatigue, no mood swings, no Monday-morning slump.' },
          { title: 'Instant Surge Capacity', desc: 'Launch a new ad campaign at midnight? The AI handles the spike without you hiring a single extra agent or paying overtime.' },
          { title: 'Complete Call Records', desc: 'Every AI call center interaction is transcribed, scored, and logged automatically — giving managers full visibility without listening to recordings.' },
        ].map(item => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/50 p-6">
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-dark-400">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI Answering Service Features -->
  <section class="py-16 sm:py-24 bg-dark-900/40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">AI Answering Service Features</h2>
        <p class="mt-4 text-lg text-dark-300 max-w-2xl mx-auto">A modern AI answering service goes far beyond "press 1 for sales." LimeCall delivers intelligent, natural conversations that route callers to the right outcome every time.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { icon: '🌙', title: '24/7 Availability', desc: 'Your AI answering service never clocks out. Every call is handled immediately — nights, weekends, and holidays included — without shift scheduling or overtime.' },
          { icon: '🧠', title: 'Natural Language Understanding', desc: 'Callers speak naturally. The AI understands intent, context, and nuance — no frustrating menu trees or "I didn\'t catch that" loops.' },
          { icon: '🔀', title: 'Intelligent Routing by Intent', desc: 'The AI identifies whether a caller wants sales, support, billing, or something else, then routes them to the correct team or rep instantly.' },
          { icon: '🌐', title: 'Multi-Language Support', desc: 'Serve global audiences in their preferred language. LimeCall\'s AI answering service supports multiple languages with native-level fluency.' },
        ].map(item => (
          <div class="rounded-2xl border border-dark-800 bg-dark-900/60 p-7 hover:border-lime-500/30 transition">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="text-base font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-dark-400">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
        <h3 class="text-lg font-bold text-white mb-3">How AI Answering Service Differs from Legacy IVR</h3>
        <p class="text-sm text-dark-400 mb-4">Traditional IVR menus frustrate callers with rigid "press 1" trees. An AI answering service understands natural speech, adapts to caller intent, and resolves requests without forcing people through predetermined paths. The result: shorter call times, higher satisfaction, and more qualified transfers to your team.</p>
        <div class="grid gap-3 sm:grid-cols-2 mt-4">
          <div class="text-sm text-dark-400"><span class="text-red-400 font-semibold">IVR:</span> "Press 1 for sales, press 2 for support, press 3 for billing..."</div>
          <div class="text-sm text-dark-400"><span class="text-lime-400 font-semibold">AI:</span> "Hi, how can I help you today?" — then routes based on what the caller actually says.</div>
        </div>
      </div>
      <div class="mt-6 rounded-2xl border border-dark-800 bg-dark-900/60 p-8">
        <h3 class="text-lg font-bold text-white mb-4">Why Businesses Switch from Traditional Answering Services to AI</h3>
        <div class="grid gap-6 sm:grid-cols-3">
          <div>
            <p class="text-2xl font-extrabold text-lime-400">90%</p>
