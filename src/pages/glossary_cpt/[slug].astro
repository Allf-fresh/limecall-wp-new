---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import CrossLinks from '../../components/CrossLinks.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { site } from '../../site.config';
import glossary from '../../data/glossary.json';

export async function getStaticPaths() {
  return glossary.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

// Related terms: 6 random other entries
const related = glossary
  .filter(e => e.slug !== entry.slug)
  .sort(() => 0.5 - Math.random())
  .slice(0, 6);

// JSON-LD: DefinedTerm + BreadcrumbList
const termSchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: entry.title,
  description: entry.seo_description || '',
  url: entry.canonical || `${site.url}/glossary_cpt/${entry.slug}/`,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'LimeCall Sales & Call Centre Glossary',
    url: `${site.url}/glossary/`,
  },
};
---

<Base
  title={entry.seo_title || `${entry.title} — LimeCall Glossary`}
  description={entry.seo_description || `Definition of ${entry.title} — learn what it means in sales, call tracking, and contact centres.`}
  canonical={entry.canonical || `${site.url}/glossary_cpt/${entry.slug}/`}
>
  <JsonLd schema={termSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Glossary', url: `${site.url}/glossary/` },
        { name: entry.title, url: entry.canonical || `${site.url}/glossary_cpt/${entry.slug}/` }
      ]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        📖 Glossary Term
      </div>
      <h1 class="mt-3 text-3xl font-extrabold leading-tight text-white sm:text-4xl">{entry.title}</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="wp-content prose-dark" set:html={entry.content} />

      <!-- LimeCall CTA inline -->
      <div class="mt-10 rounded-2xl border border-lime-500/20 bg-lime-500/5 p-8 text-center">
        <p class="text-white font-semibold mb-2">See {entry.title} in action</p>
        <p class="text-dark-300 text-sm mb-5">LimeCall connects your sales team with leads in 28 seconds — turning theory into revenue.</p>
        <a href="/signup" class="inline-block rounded-xl bg-lime-500 px-7 py-3 text-sm font-bold text-dark-950 hover:bg-lime-400 transition">
          Try Free — No Credit Card
        </a>
      </div>
    </div>
  </section>

  <!-- Related Terms -->
  {related.length > 0 && (
    <section class="border-t border-dark-800 py-12">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-6 text-lg font-bold text-white">Related Terms</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {related.map(r => (
            <a href={`/glossary_cpt/${r.slug}/`} class="rounded-xl border border-dark-800 bg-dark-900/60 p-5 hover:border-lime-500/30 transition group">
              <h3 class="font-semibold text-white group-hover:text-lime-400 transition text-sm">{r.title}</h3>
              {r.seo_description && (
                <p class="mt-1 text-xs text-dark-400 line-clamp-2">{r.seo_description}</p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CrossLinks
    heading="Explore LimeCall"
    links={[
      { href: '/glossary/', title: 'Full Glossary', desc: '409 terms defined.' },
      { href: '/call-centre-glossary/', title: 'Call Centre Glossary', desc: '50+ contact centre terms.' },
      { href: '/sales-terminology-glossary/', title: 'Sales Glossary', desc: '60+ sales terms.' },
      { href: '/click-to-call-software/', title: 'Click-to-Call Software', desc: 'Connect leads in 28s.' },
    ]}
  />
</Base>
