---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import CrossLinks from '../components/CrossLinks.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { site } from '../site.config';

const integration = "Salesloft (Drift)";
const slug = "drift-integration";

const seo = {
  title: 'LimeCall + Salesloft (Drift) | Chat to Call',
  description: 'Connect LimeCall with Salesloft (formerly Drift) to offer instant callbacks from conversational marketing flows, capture buyer intent signals, and close deals faster.',
  canonical: 'https://www.limecall.com/drift-integration/',
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'LimeCall Salesloft Drift Integration',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: 'Native integration between LimeCall callback software and Salesloft (formerly Drift). Trigger callbacks from Drift playbooks, sync conversation data to call records, and log call outcomes back to Drift automatically.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Included on LimeCall Pro plan and above',
  },
  provider: {
    '@type': 'Organization',
    name: 'LimeCall',
    url: 'https://www.limecall.com',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Does the LimeCall integration work with both Drift and Salesloft?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Drift was acquired by Salesloft in 2023 and is now part of the Salesloft platform. The LimeCall integration works with both the standalone Drift product and the Salesloft-integrated version. If you are using Drift independently, the webhook-based trigger integration works as before. If you have migrated to or are using Salesloft with Drift capabilities, LimeCall connects to both the Drift conversation layer and the Salesloft CRM layer — so call outcomes are logged to both the Drift conversation timeline and the Salesloft contact record.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does the conversational ABM use case work with LimeCall and Drift?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The conversational ABM flow works as follows: a target account visitor lands on your pricing or demo page. Drift identifies them as a target account via Clearbit or your ABM list and routes them to a personalised playbook. The playbook qualifies their intent through a short conversation. At the right moment — when the visitor shows high intent — the Drift playbook triggers a LimeCall callback offer. The visitor enters their number and a rep calls them within 28 seconds. The entire flow from identification to live call can happen in under 3 minutes. All conversation data from Drift is passed to the LimeCall call record and synced to the Salesloft contact.',
      },
    },
    {
      '@type': 'Question',
      name: 'What data is passed from Drift to Salesloft CRM after a LimeCall callback?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'After a LimeCall callback triggered from a Drift playbook, the following data is synced to the Salesloft CRM: the Drift conversation ID and transcript summary, the LimeCall call duration, call outcome as marked by the rep, the page URL the visitor was on, UTM source and campaign, and the timestamp of the callback. LimeCall creates or updates the Salesloft contact with the phone number used for the callback, and logs a call activity note on the contact timeline with all of the above fields. This gives your sales team a complete picture of the buyer journey — from chat to call — inside Salesloft.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I configure which Drift playbooks offer a LimeCall callback?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'In LimeCall → Integrations → Salesloft / Drift → Playbook Triggers, you configure which Drift playbooks fire the LimeCall callback offer. For each playbook, you specify the trigger condition — for example, "when the bot reaches the intent-confirmed step" or "when the visitor is on the pricing page and has been in conversation for 60 seconds". LimeCall provides a Drift App Block that you add to the playbook at the step where you want the callback offer to appear. No custom code is required — the App Block is drag-and-drop within the Drift playbook builder.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can LimeCall route calls to specific sales reps based on Drift qualification?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Drift passes qualification data — company name, company size, industry, and custom attributes from the conversation — to LimeCall via the webhook trigger. LimeCall uses this data to apply routing rules. For example, enterprise-qualified visitors (company size > 500) route to the enterprise AE team; SMB-qualified visitors route to the SMB team. You configure routing rules in LimeCall → Routing → Drift Rules, mapping Drift attributes to agent groups or individual agents. This ensures every LimeCall callback triggered from Drift connects the buyer to the most appropriate rep.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does LimeCall log call outcomes back to the Drift conversation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. After a LimeCall callback completes, LimeCall posts a call summary note back to the originating Drift conversation. The note includes call duration, outcome (as marked by the rep), and agent name. This means anyone reviewing the Drift conversation history later sees the full arc — the chat conversation, the callback escalation, and the call outcome — all in one place. If the visitor was identified as a Salesloft contact, the note is also posted to the Salesloft activity timeline.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I target high-intent visitors on my pricing page with a LimeCall callback prompt via Drift?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. This is one of the most common use cases for the LimeCall + Drift integration. You create a Drift playbook targeting your pricing page URL. The playbook greets visitors, asks a qualifying question, and after confirming intent, offers a LimeCall callback — "Want us to call you right now?" The LimeCall App Block inside the playbook captures the visitor\'s number and connects them to a rep within 28 seconds. Companies using this flow report significantly higher pricing-page-to-demo conversion rates compared to a form-only approach, because the callback eliminates the friction of scheduling and waiting.',
      },
    },
  ],
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Connect LimeCall with Salesloft (Drift)',
  description: 'Step-by-step guide to integrating LimeCall with Salesloft (formerly Drift) for chat-to-call conversion, playbook triggers, and Salesloft CRM sync.',
  totalTime: 'PT10M',
  step: [
    {
      '@type': 'HowToStep',
      name: 'Drift webhook → LimeCall trigger',
      text: 'Go to LimeCall → Integrations → Salesloft / Drift. Authorise via OAuth or configure the Drift webhook endpoint. LimeCall provides the webhook URL and the Drift App Block to add to your playbooks. Connection takes under 2 minutes.',
      position: 1,
    },
    {
      '@type': 'HowToStep',
      name: 'Configure which playbooks offer callback',
      text: 'Add the LimeCall App Block to the playbook steps where you want the callback offer to appear — post-qualification, on pricing pages, or for enterprise visitors. Configure routing rules to match Drift qualification attributes to LimeCall agent groups.',
      position: 2,
    },
    {
      '@type': 'HowToStep',
      name: 'Test and go live',
      text: 'Trigger a test playbook from the LimeCall integration settings. Verify the callback offer appears in the Drift chat, the call connects to the correct agent, and the outcome is logged to both the Drift conversation and the Salesloft contact record.',
      position: 3,
    },
  ],
};

const stats = [
  { value: "28s", label: "Call connect after Drift qualification" },
  { value: "2 clicks", label: "OAuth connect — no developers" },
  { value: "3 min", label: "ABM visitor to live call" },
  { value: "2x", label: "Higher demo rate vs form-only" },
];

const features = [
  {
    title: "Drift playbook trigger → LimeCall callback offer",
    desc: "Add the LimeCall App Block to any Drift playbook step. When a visitor reaches that step — after qualification, intent confirmation, or any other condition — the callback offer appears inside the Drift chat. One click, number entry, and a rep calls within 28 seconds.",
  },
  {
    title: "Sync Drift conversation data to call record",
    desc: "Every LimeCall callback triggered from Drift automatically receives the full Drift conversation context — visitor identity, company, qualification answers, and page URL. Reps see this data before the call connects, so every call starts with full buyer context.",
  },
  {
    title: "Auto-create Salesloft contacts on call",
    desc: "When a callback completes, LimeCall creates or updates the Salesloft contact record with the caller's phone number, email (if provided in chat), company, and call data. Duplicate check runs on every sync — no contact bloat in Salesloft.",
  },
  {
    title: "Log call outcomes to Drift conversation",
    desc: "After every call, LimeCall posts a summary note to the originating Drift conversation: call duration, outcome, agent name. Anyone reviewing the conversation history later sees the full chat-to-call arc in one place.",
  },
  {
    title: "Target high-intent visitors with callback prompt",
    desc: "Configure playbooks to surface the LimeCall callback offer on high-intent pages — pricing, demo request, product comparison. Drift identifies the intent signal; LimeCall converts it to a live call within seconds, before the visitor bounces.",
  },
  {
    title: "Route to specific reps based on Drift qualification",
    desc: "Drift qualification data — company size, industry, role, deal stage — passes to LimeCall routing rules. Enterprise visitors route to the enterprise team; SMB to SMB. Every buyer reaches the right rep on the first try.",
  },
];

const automations = [
  {
    trigger: "ABM target visits pricing page",
    action: "Drift qualifies → LimeCall callback in 28s",
    desc: "A target account visitor lands on pricing. Drift identifies them via your ABM list and fires a personalised playbook. After 2 qualifying questions, the callback offer appears. The visitor enters their number. A rep calls in 28 seconds — the entire cycle happens in under 3 minutes.",
  },
  {
    trigger: "Enterprise visitor in Drift conversation",
    action: "Route to AE via LimeCall",
    desc: "Drift identifies an enterprise visitor (500+ employees) and routes to the enterprise playbook. The playbook offers a LimeCall callback. LimeCall routing rules send the call to the enterprise AE team — not the general queue. The right rep picks up every enterprise call.",
  },
  {
    trigger: "Call completed with outcome 'Demo scheduled'",
    action: "Log to Drift + create Salesloft task",
    desc: "When a rep marks a LimeCall callback as 'demo scheduled', the outcome is posted to the Drift conversation and a Salesloft task is created for the AE to prep the demo. The full buyer journey — chat to call to task — is captured automatically.",
  },
  {
    trigger: "Missed callback from Drift trigger",
    action: "Re-engage via Drift message",
    desc: "If a callback triggered from Drift goes unanswered, LimeCall fires a webhook back to Drift. A follow-up playbook sends a message: 'Sorry we missed you — here is a link to book a time.' The re-engagement happens within minutes, not hours.",
  },
];

const useCases = [
  {
    role: "Sales Development",
    title: "ABM target visits pricing — rep calls in 28 seconds",
    desc: "SDRs no longer wait for a form fill from their target accounts. When an ABM target lands on pricing, Drift qualifies them and LimeCall connects the call while the buyer is still on the page. The window between intent and conversation shrinks from days to seconds.",
  },
  {
    role: "Account Executives",
    title: "Full chat context before every Drift-triggered call",
    desc: "Before an AE picks up a LimeCall callback from Drift, they see the buyer's Drift conversation, qualification answers, company size, and the page they were on. AEs start every call knowing exactly what the buyer needs — no cold-start small talk.",
  },
  {
    role: "Marketing Teams",
    title: "Measure chat-to-call conversion by playbook",
    desc: "LimeCall tracks which Drift playbooks generate callbacks and which generate missed calls. Marketing can A/B test playbook messaging to optimise chat-to-call conversion rates — knowing which playbook variant actually books more demos.",
  },
  {
    role: "Revenue Operations",
    title: "Single source of truth across Drift and Salesloft",
    desc: "RevOps teams use the integration to ensure every Drift-qualified buyer has a complete Salesloft contact with call history. No more manual data entry from chat transcripts into CRM. The LimeCall + Drift + Salesloft pipeline is fully automated.",
  },
];

const comparisonRows = [
  { feature: "Drift playbook trigger → callback offer", limecall: true, manual: false, others: false },
  { feature: "Drift conversation data in call record", limecall: true, manual: false, others: false },
  { feature: "Auto-create Salesloft contacts on call", limecall: true, manual: false, others: "Partial" },
  { feature: "Log call outcome to Drift conversation", limecall: true, manual: false, others: false },
  { feature: "Route by Drift qualification attributes", limecall: true, manual: false, others: false },
  { feature: "Re-engage missed calls via Drift playbook", limecall: true, manual: false, others: false },
  { feature: "Works with both Drift and Salesloft", limecall: true, manual: "N/A", others: false },
];
---

<Base {...seo}>
  <JsonLd schema={faqSchema} />
  <JsonLd schema={appSchema} />
  <JsonLd schema={howToSchema} />

  <!-- Hero -->
  <section class="border-b border-dark-800 bg-gradient-to-b from-dark-900 to-dark-950 pt-14 pb-10 sm:pt-20 sm:pb-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { name: 'Integrations', url: 'https://www.limecall.com/integrations/' },
        { name: 'Salesloft Integration', url: seo.canonical },
      ]} />
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-lime-500/30 bg-lime-500/10 px-4 py-1.5 text-xs font-semibold text-lime-400">
        Native Integration · Formerly Drift · Conversational ABM
      </div>
      <h1 class="mt-5 text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        LimeCall + <span class="text-lime-400">Salesloft (Drift)</span>:<br class="hidden sm:block" />
        Chat-to-Call Conversion
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-dark-300 leading-relaxed">
        Connect LimeCall with Salesloft (formerly Drift) to offer instant callbacks from conversational marketing flows, capture buyer intent signals, and close deals faster. Drift qualifies the buyer — LimeCall connects the call in 28 seconds.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={site.cta.href} class="rounded-xl bg-lime-500 px-8 py-3.5 text-sm font-bold text-dark-950 hover:bg-lime-400 transition shadow-lg">
          Connect Salesloft Free →
        </a>
        <a href="/demo/" class="rounded-xl border border-dark-700 bg-dark-800 px-8 py-3.5 text-sm font-bold text-white hover:border-lime-500/40 transition">
          Watch Demo
        </a>
      </div>
      <p class="mt-4 text-xs text-dark-500">
        Formerly known as Drift · Now part of the Salesloft platform · Integration works with both
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-dark-800 bg-dark-900/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 text-center">
        {stats.map(s => (
          <div>
            <div class="text-3xl font-extrabold text-lime-400">{s.value}</div>
            <div class="mt-1 text-sm text-dark-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it flows -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-center text-2xl font-bold text-white">How a Drift conversation becomes a live call</h2>
      <p class="mb-12 text-center text-dark-400 text-sm max-w-2xl mx-auto">
        From ABM target landing on your pricing page to a rep on the phone — the entire cycle takes under 3 minutes.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-0">
        <div class="flex flex-col items-center text-center max-w-[160px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">1</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Target account visits</h3>
          <p class="mt-1 text-xs text-dark-400">ABM target lands on pricing or demo page</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-10 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[160px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">2</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Drift qualifies intent</h3>
          <p class="mt-1 text-xs text-dark-400">Personalised playbook runs qualification</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-10 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[160px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">3</div>
          <h3 class="mt-3 text-sm font-semibold text-white">LimeCall callback offered</h3>
          <p class="mt-1 text-xs text-dark-400">Callback button appears inside Drift chat</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-10 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[160px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">4</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Rep calls in 28s</h3>
          <p class="mt-1 text-xs text-dark-400">Right rep connects with full chat context</p>
        </div>
        <div class="h-8 w-px sm:h-px sm:w-10 bg-lime-500/30 mx-2 my-0"></div>
        <div class="flex flex-col items-center text-center max-w-[160px]">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-lime-500/20 border border-lime-500/30 text-2xl font-extrabold text-lime-400">5</div>
          <h3 class="mt-3 text-sm font-semibold text-white">Salesloft updated</h3>
          <p class="mt-1 text-xs text-dark-400">Contact created, call logged, task created</p>
        </div>
      </div>

      <!-- Setup steps -->
      <div class="mt-14 grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 1</div>
          <h3 class="mb-2 font-semibold text-white">Drift webhook → LimeCall trigger</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Go to LimeCall → Integrations → Salesloft / Drift. Authorise via OAuth or configure the Drift webhook endpoint. LimeCall provides the webhook URL and the Drift App Block to add to your playbooks. Connection takes under 2 minutes.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 2</div>
          <h3 class="mb-2 font-semibold text-white">Configure which playbooks offer callback</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Add the LimeCall App Block to the playbook steps where you want the callback offer to appear — post-qualification, on pricing pages, or for enterprise visitors. Configure routing rules to match Drift qualification attributes to LimeCall agent groups.</p>
        </div>
        <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
          <div class="mb-3 text-xs font-bold uppercase tracking-widest text-lime-400">Step 3</div>
          <h3 class="mb-2 font-semibold text-white">Test and go live</h3>
          <p class="text-sm text-dark-400 leading-relaxed">Trigger a test playbook from the LimeCall integration settings. Verify the callback offer appears in the Drift chat, the call connects to the correct agent, and the outcome is logged to both the Drift conversation and the Salesloft contact record.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Everything the LimeCall + Salesloft (Drift) integration does</h2>
      <p class="mb-10 text-center text-dark-400 text-sm">Six capabilities that connect your Drift conversational marketing to LimeCall voice — and back to Salesloft CRM.</p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f, i) => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6 hover:border-lime-500/30 transition">
            <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-lg bg-lime-500/15 text-sm font-extrabold text-lime-400">{i + 1}</div>
            <h3 class="mb-2 font-semibold text-white">{f.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular automations -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center text-2xl font-bold text-white">Popular LimeCall + Salesloft (Drift) automations</h2>
      <p class="mb-10 text-center text-dark-400 text-sm">The most-used conversational ABM to call automation recipes our customers set up on day one.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        {automations.map(a => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-3 flex flex-wrap items-center gap-3">
              <span class="rounded-full bg-lime-500/15 px-3 py-1 text-xs font-bold text-lime-400">When: {a.trigger}</span>
              <span class="text-dark-600 text-xs">→</span>
              <span class="rounded-full bg-dark-800 px-3 py-1 text-xs font-semibold text-dark-300">Then: {a.action}</span>
            </div>
            <p class="text-sm text-dark-400 leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">Who uses LimeCall + Salesloft (Drift) and how</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {useCases.map(uc => (
          <div class="rounded-xl border border-dark-800 bg-dark-900/60 p-6">
            <div class="mb-2 inline-block rounded-full bg-lime-500/15 px-3 py-1 text-xs font-bold text-lime-400">{uc.role}</div>
            <h3 class="mb-2 font-semibold text-white">{uc.title}</h3>
            <p class="text-sm text-dark-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="border-t border-dark-800 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-2xl font-bold text-white">LimeCall + Salesloft (Drift) vs the alternatives</h2>
      <div class="overflow-x-auto rounded-xl border border-dark-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-800 bg-dark-900">
              <th class="py-4 px-5 text-left font-semibold text-dark-300">Feature</th>
              <th class="py-4 px-5 text-center font-semibold text-lime-400">LimeCall + Salesloft</th>
              <th class="py-4 px-5 text-center font-semibold text-dark-400">Manual handoff</th>
              <th class="py-4 px-5 text-center font-semibold text-dark-400">Other callback tools</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={`border-b border-dark-800/50 ${i % 2 === 0 ? 'bg-dark-950/40' : 'bg-dark-900/20'}`}>
                <td class="py-3 px-5 text-dark-300">{row.feature}</td>
                <td class="py-3 px-5 text-center">
                  {row.limecall === true
                    ? <span class="text-lime-400 font-bold">Yes</span>
                    : <span class="text-dark-500">{row.limecall}</span>}
                </td>
                <td class="py-3 px-5 text-center">
                  {row.manual === false
                    ? <span class="text-dark-600">No</span>
                    : <span class="text-dark-400">{row.manual}</span>}
                </td>
                <td class="py-3 px-5 text-center">
                  {row.others === false
                    ? <span class="text-dark-600">No</span>
                    : <span class="text-dark-400">{row.others}</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-dark-800 py-16 sm:py-20 bg-dark-900/30">
